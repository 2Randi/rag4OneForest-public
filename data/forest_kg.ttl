    rdfs:domain skos:Concept ;
    rdfs:range xsd:decimal .

ex:minAreaHa a rdf:Property ;
    rdfs:label "Minimum area (ha)"@en ;
    rdfs:domain skos:Concept ;
    rdfs:range xsd:decimal .

ex:minCrownCoverPct a rdf:Property ;
    rdfs:label "Minimum crown cover (%)"@en ;
    rdfs:domain skos:Concept ;
    rdfs:range xsd:decimal .

ex:minStripWidthM a rdf:Property ;
    rdfs:label "Minimum strip width (m)"@en ;
    rdfs:domain skos:Concept ;
    rdfs:range xsd:decimal .

ex:minTreeHeightM a rdf:Property ;
    rdfs:label "Minimum tree height (m)"@en ;
    rdfs:domain skos:Concept ;
    rdfs:range xsd:decimal .

