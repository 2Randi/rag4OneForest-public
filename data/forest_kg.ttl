ex:Forest_1346 a skos:Concept ;
    dct:creator "USA-STATE-Connecticut" ;
    dct:date "2004"^^xsd:gYear ;
    dct:source "http://farm.fic.niu.edu/fic/laws/state/ct12107.html"^^xsd:anyURI,
        "http://www.caao.com/M39FORESTLAND.pdf"^^xsd:anyURI,
        "http://www.coventryct.org/index.aspx?NID=146"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "The term \"forest land\" means any tract or tracts of land aggregating twenty-five acres or more in area bearing tree growth in such quantity and so spaced as to constitute in the opinion of the State Forester a forest area and maintained in the opinion of the State Forester in a state of proper forest condition and such land consists of (1) one tract of land of twenty-five or more contiguous acres, which acres may be in contiguous municipalities, (2) two or more tracts of land aggregating twenty-five acres or more in which no single component tract shall consist of less than ten acres or (3) any tract of land which is contiguous to a tract owned by the same owner which has been designated as forest land by the State Forester, provided land designated by the State Forester as forest land in accordance with section 12-107d prior to July 1, 1976, shall not be subject to the provisions of subdivisions (1) to (3), inclusive, of this subsection; Source: and and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Connecticut 2004" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_1347 a skos:Concept ;
    dct:creator "USA-STATE-Connecticut" ;
    dct:date "2011"^^xsd:gYear ;
    dct:source "http://search.cga.state.ct.us/dtsearch_lpa.asp?cmd=getdoc&DocId=20782&Index=I%3A%5Czindex%5C1991&HitCount=8&hits=2ab+382+38b+47c+4e2+878+987+e6e+&hc=79519&req=his&Item=2138"^^xsd:anyURI,
        "http://www.cga.ct.gov/2011/pub/chap451a.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"Forest land\" means that portion of a parcel of land which constitutes a total of at least one contiguous acre on which there is no structure, maintained landscape area, accessway or other improvement and which is (A) occupied in random distribution by trees having a minimum diameter of three inches as measured from a point on the trunk which is four and one-half feet above the ground such trees comprising at least seven and one-half square feet of basal area and the crowns of such trees occupying no less than fifteen per cent of the total area; or (B) which is planted with at least five hundred trees per acre and is not maintained for Christmas tree or nursery stock production; and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Connecticut 2011" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_1348 a skos:Concept ;
    dct:creator "USA-STATE-Delaware" ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"Forest\" means a biological community dominated by trees covering a contiguous area of land and includes any definition thereof developed by the Department of Agriculture Forest Service. A \"forest\" may be identified by the diversity of the tree species composing it or by its type. A \"forest type\" is a forest composed of associations of tree species that have similar ecological requirements"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Delaware" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_1349 a skos:Concept ;
    dct:creator "USA-STATE-Delaware-Wilmington" ;
    dct:source "http://www.wilmingtonnc.gov/Portals/0/documents/Development%20Services/Plans%20and%20Documents/LDC/Art%2015%20-%20Definitions.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forested area(s): A forest is defined as any area on a site with greater than or equal to one hundred (100) trees per acre"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Delaware-Wilmington" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_135 a skos:Concept ;
    dct:creator "19th century" ;
    dct:source "http://dspace.wbpublibnet.gov.in/dspace/bitstream/10689/10100/4/Chapter%201_1%20-%20125p.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "An area which contain wild growing trees"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "19th century" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_1350 a skos:Concept ;
    dct:creator "USA-STATE-Florida" ;
    dct:date "1999"^^xsd:gYear ;
    dct:source "http://www.dot.state.fl.us/surveyingandmapping/Manuals/fluccmanual.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Upland Forest -This category of land cover is reserved for those upland areas which support a tree canopy closure of ten (10) percent or more"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Florida 1999" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_1351 a skos:Concept ;
    dct:creator "USA-STATE-Florida" ;
    dct:date "2009"^^xsd:gYear ;
    dct:source "http://edis.ifas.ufl.edu/fr063"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A biological community of plants and animals that is dominated by trees and other woody plants. Florida 2009"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Florida 2009" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_1352 a skos:Concept ;
    dct:creator "USA-STATE-Hawaii" ;
    dct:date "1993"^^xsd:gYear ;
    dct:source "http://www.state.hi.us/dlnr/dofaw/rules/Chap106.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "“Forest” means forest land occupied by forest trees and associated wildlife species, and timber thereon"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Hawaii 1993" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_1353 a skos:Concept ;
    dct:creator "USA-STATE-Hawaii" ;
    dct:source "http://www.fs.fed.us/psw/publications/documents/psw_gtr076/psw_gtr076.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Closed forest--Generally, a unit of vegetation with overstory trees whose crowns are mostly touching. Plant communities with trees having a crown cover of 60 percent or more are considered closed forests"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Hawaii" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_1354 a skos:Concept ;
    dct:creator "USA-STATE-Hawaii-Kauai County" ;
    dct:source "http://www.kauaigov.org/finance/RPA/tfde.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"Forest\" means forestland occupied by forest trees and associated wildlife species, and timber thereon"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Hawaii-Kauai County" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_1355 a skos:Concept ;
    dct:creator "USA-STATE-Idaho" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest land means any land which has enough forest growth, standing or down, to constitute, in the judgement of the Department, an insect or disease infestation breeding ground of a nature to constitute a menace, injurious and dangerous to the forest resources in the district or zone of infestation. www.fs.fed.us/im/directives/field/r1/fsm/3400/3400_zero_code.rtf"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Idaho" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_1356 a skos:Concept ;
    dct:creator "USA-STATE-Illinois" ;
    dct:source "http://www.agr.state.il.us/gis/stats/landcover/mainpages/glossary.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Includes areas that are predominantly covered with trees and woody vegetation"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Illinois" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_1357 a skos:Concept ;
    dct:creator "USA-STATE-Illinois" ;
    dct:source "http://www.gurnee.il.us/municipal_code/pdf_chapters/chapter45.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest means a dense growth of trees and underbrush covering a large tract of land, or a significant portion of a large tract of land"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Illinois" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_1358 a skos:Concept ;
    dct:creator "USA-STATE-Illinois" ;
    dct:source "http://dnr.state.il.us/orep/inrin/ctap/sumrepo/glossary.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Generally, land with trees on it. Foresters define as forestland any land stocked with trees of any size that cover 16.7% of the land area. The Changing Illinois Environment: Critical Trends"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Illinois" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_1359 a skos:Concept ;
    dct:creator "USA-STATE-Iowa" ;
    dct:date "1999"^^xsd:gYear ;
    dct:source "http://www.legis.state.ia.us/IACODE/1999SUPPLEMENT/161A/42.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"Forest\" means stands of native or introduced trees containing at least two hundred trees per acre and located on privately owned land. However, a stand of fruit trees is not a forest"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Iowa 1999" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_136 a skos:Concept ;
    dct:creator "Moon and Courtlandt" ;
    dct:date "1914"^^xsd:gYear ;
    skos:broadMatch ex:Forest ;
    skos:definition "An area whose principle crop is trees. A forest includes both the forest cover and the soil beneath it"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Moon and Courtlandt 1914" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_1360 a skos:Concept ;
    dct:creator "USA-STATE-Iowa" ;
    dct:date "2003"^^xsd:gYear ;
    dct:source "http://www.legis.state.ia.us/Rules/2003/iac/027iac/2710/2710.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "“Forest land” means land with stands of native or introduced trees containing at least 200 trees per acre. Stands of fruit trees shall not be considered as forest land"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Iowa 2003" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_1361 a skos:Concept ;
    dct:creator "USA-STATE-Iowa" ;
    dct:source "http://www.legis.state.ia.us/GA/77GA/Legislation/HF/02300/HF02351/Current.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"Forestland\" means stands of native or introduced forest plantation of at least three acres, including trees located on privately owned land. However, a stand of fruit trees or Christmas trees is not forestland"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Iowa" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_1362 a skos:Concept ;
    dct:creator "USA-STATE-Kansas" ;
    dct:date "1971"^^xsd:gYear ;
    skos:broadMatch ex:Forest ;
    skos:definition "Generally an ecosystem characterized by a more or less dense and extensive tree cover. More particularly, a plant community predominantly of trees and other woody vegetation, growing more or less closely together. \"Terminology of Forest Science, Technology, Practice & Products\" SAF, 1971. Robert L. Atchison ratchiso@oznet.ksu.edu"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Kansas 1971" ;
    skos:prefLabel "Forest"@no ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_1363 a skos:Concept ;
    dct:creator "USA-STATE-Kentucky" ;
    dct:source "http://www.surfacemining.ky.gov/Publications/NonCoalRegs/405KAR5_001_Definitions_091203.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"Forest land\" means lands dominated by canopy forming trees, or from a postmining land use standpoint, areas planted throughout with trees"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Kentucky" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_1364 a skos:Concept ;
    dct:creator "USA-STATE-Kentucky" ;
    dct:source "http://www.lrc.state.ky.us/kar/302/028/010.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"Forest\" means a concentration of trees and related vegetation in nonurban areas characterized by natural terrain and drainage patterns"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Kentucky" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_1365 a skos:Concept ;
    dct:creator "USA-STATE-Kentucky" ;
    skos:broadMatch ex:Forest ;
    skos:definition "an ecosystem characterized by a more or less dense and extensive tree cover, often consisting of composition, structure, age class, and associated processes, and commonly including meadows, streams, fish, and wildlife. The State of Kentucky does not have the terms Forest, Forestland, or Tree officially defined in State Statute or Regulation. The Division of Forestry utilizes the Society of American Forester's definitions for these terms as listed in John A. Helms' The Dictionary of Forestry. Steve.Kull@mail.state.ky.us"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Kentucky" ;
    skos:prefLabel "Forest"@no ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_1366 a skos:Concept ;
    dct:creator "USA-STATE-Louisiana" ;
    dct:source "http://text.lsuagcenter.com/en/environment/forestry/commercial_forestry/Glossary+of+Forestry+Terms.htm#F"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A large area of land primarily covered with trees as well as the other organisms, soil, water and air associated with them"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Louisiana" ;
    skos:prefLabel "Forest"@no ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_1367 a skos:Concept ;
    dct:creator "USA-STATE-Maine" ;
    dct:source "http://www.memun.org/resources/public/html/TAXDATA/PropertyTaxBull/bulletin4.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land 5 acres or greater dominated by the growth of forest trees and other woody vegetation"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Maine" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_1368 a skos:Concept ;
    dct:creator "USA-STATE-Maine" ;
    dct:source "http://www.maine.gov/doc/mfs/woodswise/glossary.html#F"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A biological community dominated by trees and other woody plants"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Maine" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_1369 a skos:Concept ;
    dct:creator "USA-STATE-Maryland" ;
    dct:source "http://www.dnr.state.md.us/download/reforest.pdf"^^xsd:anyURI,
        "http://www.sha.state.md.us/businesswithsha/bizStdsSpecs/oed/reforestationLawSum/reforestlaw.asp"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "“Forest” means:(i) a biological community dominated by trees or other woody plants covering a land area of 1 acre or more, or (ii) an area that has been cut but not cleared of trees or other woody plants. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Maryland" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_137 a skos:Concept ;
    dct:source "http://en.wikipedia.org/wiki/Forest"^^xsd:anyURI,
        "http://explanation-guide.info/meaning/Forest.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "An area with a high density of trees and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_1370 a skos:Concept ;
    dct:creator "USA-STATE-Maryland" ;
    dct:source "http://pilot.wash.lib.md.us/washco/forestcn.html"^^xsd:anyURI,
        "http://www.dnr.state.md.us/forests/landplanning/fca.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A biological community dominated by trees and other woody plants covering a land area of at least 10,000 square feet as long as there are at least 100 live trees per acre with at least 50 percent of those trees having a 2-inch or greater diameter at 4.5 feet above the ground. Areas that have been cut but not cleared of stumps or the root mat may also be included. \"Forest\" does not include orchards. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Maryland" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_1371 a skos:Concept ;
    dct:creator "USA-STATE-Maryland" ;
    dct:source "http://www.dnr.state.md.us/Forests/Education/gloss.html"^^xsd:anyURI,
        "http://www.dnr.state.md.us/forests/gloss.html#f"^^xsd:anyURI,
        "http://www.pfmt.org/glossary/f.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A biological community dominated by trees and other woody plants. , or"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Maryland" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_1372 a skos:Concept ;
    dct:creator "USA-STATE-Maryland-Rockville" ;
    dct:source "http://www.rockvillemd.gov/zoning/glossary.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A dense growth of trees, together with other plants, covering a large area. According to the Forest and Tree Preservation Ordinance of the City of Rockville, a forest must cover a land area of 10,000 square feet or greater"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Maryland-Rockville" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_1373 a skos:Concept ;
    dct:creator "USA-STATE-Michigan" ;
    skos:broadMatch ex:Forest ;
    skos:definition "“Forest” means a tract of land that is thick with trees and underbrush. www.deq.state.mi.us/documents/deq-swq-biosolids-Part%2024.doc"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Michigan" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_1374 a skos:Concept ;
    dct:creator "USA-STATE-Michigan-Alpena County" ;
    dct:source "http://www.alpenalib.org/Alpena%20Library/Chapter6_Land-Use.PDF"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forestland use areas are generally at least ten percent stocked by trees of any size"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Michigan-Alpena County" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_1375 a skos:Concept ;
    dct:creator "USA-STATE-Minnesota" ;
    dct:date "2009"^^xsd:gYear ;
    dct:source "http://www.revisor.leg.state.mn.us/stats/88/01.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"Forest\" means a plant association predominantly of trees and other woody vegetation occupying an extensive area of land"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Minnesota 2009" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_1376 a skos:Concept ;
    dct:creator "USA-STATE-Minnesota" ;
    dct:source "http://deli.dnr.state.mn.us/metadata/tables/lusatra3_tab.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest Includes areas with at least two-thirds or more of the total canopy cover composed of predominantly woody deciduous or coniferous species"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Minnesota" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_1377 a skos:Concept ;
    dct:creator "USA-STATE-Minnesota" ;
    dct:source "http://www.lmic.state.mn.us/projects/aboutlanduse.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forested: Areas where two-thirds or more of the total canopy cover is composed of predominantly woody deciduous and coniferous species and areas of regenerated or young forest where commercial timber has been completely or partially removed by logging, other management activities or natural events; includes woodlots, shelterbelts and plantation"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Minnesota" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_1378 a skos:Concept ;
    dct:creator "USA-STATE-MississippI" ;
    dct:date "2008"^^xsd:gYear ;
    dct:source "http://msucares.com/pubs/publications/p1250.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A plant community dominated by trees and woody plants"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-MississippI 2008" ;
    skos:prefLabel "Forest"@no ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_1379 a skos:Concept ;
    dct:creator "USA-STATE-Missouri" ;
    dct:date "1998"^^xsd:gYear ;
    skos:broadMatch ex:Forest ;
    skos:definition "Although we do not have \"official\" definitions, we commonly use the accepted SAF definitions for these terms. See Dictionary of Forestry; John A. Helms, editor; published 1998 by the Sociecy of American Foresters. \"Mike Hoffmann\" hoffmm@mail.conservation.state.mo.us"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Missouri 1998" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_138 a skos:Concept ;
    dct:source "http://www.mepred.eu/_docs/Triangel1.4.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "An area with a high density of trees"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_1380 a skos:Concept ;
    dct:creator "USA-STATE-Missouri" ;
    dct:date "2003"^^xsd:gYear ;
    dct:source "http://mdc4.mdc.mo.gov/Documents/13183.doc"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "An area dominated by trees forming a closed canopy and interspersed with multilayer shade tolerant sub-canopy trees, shrubs, vines, ferns and herbs. Trees attain a height of 60 to over 100 feet. The ground-flora is rich in spring ephemerals"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Missouri 2003" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_1381 a skos:Concept ;
    dct:creator "USA-STATE-MissourI" ;
    dct:date "2003"^^xsd:gYear ;
    dct:source "http://mdc4.mdc.mo.gov/Documents/13183.doc"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "An ecosystem characterized by a more or less dense and extensive tree cover, often consisting of stands varying in characteristics such as species or composition, structure, age class, and associated processes, and commonly including meadows, streams, fish, and wildlife – note: forests include special kinds such as industrial forests, non-industrial private forests, plantations, public forests, protection forests, and urban forests, as well as parks and wilderness"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-MissourI 2003" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_1382 a skos:Concept ;
    dct:creator "USA-STATE-Montana" ;
    dct:source "http://www.deq.state.mt.us/dir/Legal/Chapters/CH50-08.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"Forest\" means a tract of land with trees and underbrush"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Montana" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_1383 a skos:Concept ;
    dct:creator "USA-STATE-Montana" ;
    dct:source "http://data.opi.state.mt.us/bills/mca/15/44/15-44-102.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"Forest\" means forest land and the timber on the land"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Montana" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_1384 a skos:Concept ;
    dct:creator "USA-STATE-New" ;
    dct:date "2002"^^xsd:gYear ;
    dct:source "http://www.state.nj.us/dep/gis/digidownload/metadata/lulc02/anderson2002.html"^^xsd:anyURI ;
    dct:spatial "Jersey" ;
    skos:broadMatch ex:Forest ;
    skos:definition "This Level I category contains any lands covered by woody vegetation other than wetlands. These areas are capable of producing timber and other wood products, and of supporting many kinds of outdoor recreation. Forestland is an important category environmentally, because it affects air quality, water quality, wildlife habitat, climate, and many other aspects of the ecology of an area. The Level II categories under Forestland are Deciduous; Coniferous; Mixed Deciduous-Coniferous; and Brushland"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-New Jersey 2002" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_1385 a skos:Concept ;
    dct:creator "USA-STATE-New" ;
    dct:source "http://www.state.nj.us/dep/parksandforests/fire/docs/conservation_and_development.pdf"^^xsd:anyURI ;
    dct:spatial "Jersey" ;
    skos:broadMatch ex:Forest ;
    skos:definition "“Forest” means and includes any forest, bushland, grassland, salt marsh, and any combination thereof"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-New Jersey" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_1386 a skos:Concept ;
    dct:creator "USA-STATE-New" ;
    dct:date "2007"^^xsd:gYear ;
    dct:source "http://www.conwaygreene.com/lpbin21/lpext.dll/Test/NMACRaw/1/51fd0/571dd/572c0/572d3?fn=document-frame.htm&f=templates"^^xsd:anyURI,
        "http://www.emnrd.state.nm.us/FD/documents/19204_Amended_6-14-07.pdf"^^xsd:anyURI ;
    dct:spatial "Mexico" ;
    skos:broadMatch ex:Forest ;
    skos:definition "“Forest” means an area of at least one acre with at least 10 percent tree crown cover. New Mexico. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-New Mexico 2007" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_1387 a skos:Concept ;
    dct:creator "USA-STATE-North Carolina" ;
    dct:date "1971"^^xsd:gYear ;
    skos:broadMatch ex:Forest ;
    skos:definition "A plant community predominantly of trees and other woody vegetation, growing more or less closely together. Source: Terminology of Forest Science, Technology Practice and Products. Edited by F.C. Ford-Robertson. Society of American Foresters, Washington, D.C., 1971. David R. Brown David.R.Brown@ncmail.net"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-North Carolina 1971" ;
    skos:prefLabel "Forest"@no ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_1388 a skos:Concept ;
    dct:creator "USA-STATE-North Carolina" ;
    dct:date "1994"^^xsd:gYear ;
    dct:source "http://cgia.cgia.state.nc.us/gicc/standards/nclulc.html#P3"^^xsd:anyURI,
        "http://www.ncgicc.com/Portals/3/documents/nclulc.html#P2"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest lands are covered with deciduous or coniferous woody vegetation about 3 meters or more in height. Forest lands exhibit a tree-crown area density of at least 10 percent. Lands from which trees have been removed to less than 10 percent crown density should be included in Category 3 (Herbaceous Cover and Shrubland) or another land cover category if appropriate. This category includes upland forests and forest land on seasonally or permanently wet or inundated areas often called \"forested wetlands\" in other classification schemes. For lands on which there is forest rotation involving clear-cutting and block planting, the clear-cut or plantation areas are not included in this subcategory until planted trees reach a growth stage to meet the criteria for 10 percent crown density coverage. Otherwise, these areas are classified under Category 3. This category includes managed areas of tree growth such as orchards or Christmas tree farms that meet the basic criteria for forest areas. Where applicable, subcategory definitions include a reference to physiographic classes accepted by the Forest Resources Division of the North Carolina Department of Environment, Health and Natural Resources on which the forest stands most commonly occur. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-North Carolina 1994" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_1389 a skos:Concept ;
    dct:creator "USA-STATE-North Dakota" ;
    dct:source "http://www.state.nd.us/lr//cencode/T57C57.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"Forest\" means an area of land normally supporting a growth of planted tree cover, woodlands, or windbreaks"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-North Dakota" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_139 a skos:Concept ;
    dct:source "http://www.sandiegozoo.org/wildideas/glossary_e-f.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "An area with many trees"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_1390 a skos:Concept ;
    dct:creator "USA-STATE-Ohio" ;
    dct:source "http://www.dnr.state.oh.us/odnr/relm/remsen/landuse/class4.html#no4"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest Lands have a tree-crown areal density (crown closure percentage) of 10 percent or more, are stocked with trees capable of producing timber or other wood products, and exert an influence on the climate or water regime"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Ohio" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_1391 a skos:Concept ;
    dct:creator "USA-STATE-Oregon" ;
    dct:source "http://www.leg.state.or.us/ors/477.html"^^xsd:anyURI,
        "http://www.paperadvantage.org/ORS/526.html#forestland"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"Forestland\" means any woodland, brushland, timberland, grazing land or clearing that, during any time of the year, contains enough forest growth, slashing or vegetation to constitute, in the judgment of the forester, a fire hazard, regardless of how the land is zoned or taxed. As used in this subsection, \"clearing\" means any grassland, improved area, lake, meadow, mechanically or manually cleared area, road, rocky area, stream or other similar forestland opening that is surrounded by or contiguous to forestland and that has been included in areas classified as forestland under ORS 526.305 to 526.370 and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Oregon" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_1392 a skos:Concept ;
    dct:creator "USA-STATE-Oregon-Portland" ;
    dct:source "http://www.portlandonline.com/shared/cfm/image.cfm?id=106047"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Trees with their crowns overlapping (generally forming 60-100% of cover. Natural Resource Inventory vegetation mapping project City of Portland Bureau of Planning. 18 p"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Oregon-Portland" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_1393 a skos:Concept ;
    dct:creator "USA-STATE-Pennsylvania" ;
    dct:date "1974"^^xsd:gYear ;
    dct:source "http://farm.fic.niu.edu/fic/laws/state/pa72.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"Forest reserve.\" Land, ten acres or more, stocked by forest trees of any size and capable of producing timber or other wood products. Source: \"PA FARMLAND & FOREST LAND ASSESSMENT ACT\" (CLEAN AND GREEN) Act of 1974, P.L. 973, No. 319"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Pennsylvania 1974" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_1394 a skos:Concept ;
    dct:creator "USA-STATE-Pennsylvania-Centre County" ;
    dct:source "http://county.centreconnect.org/planning/compplan/draft/forest.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forests are a biological community dominated by trees and other woody plants covering a land area of one acre or more. This also includes forests that have been cut but not cleared. In other areas, Forests are a biological community dominated by trees and other woody plants covering a land area of 10,000 square feet or greater"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Pennsylvania-Centre County" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_1395 a skos:Concept ;
    dct:creator "USA-STATE-Rhode Island" ;
    dct:source "http://www.dem.ri.gov/pubs/regs/regs/agric/ffosimp.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Any tract or contiguous tracts of land, ten (10) acres or larger, exclusive of house site, bearing a dense growth of trees, including underbrush and young regenerating forest and ancillary habitat areas having either the quality of self perpetuation, or being dependent upon its development by the planting and replanting of trees in stands of closely growing timber, actively managed under a stewardship plan approved by the director"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Rhode Island" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_1396 a skos:Concept ;
    dct:creator "USA-STATE-South Dakota" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest: An ecosystem characterized by a more or less dense and extensive tree cover, often consisting of stands varying in characteristics such as species composition, structure, age class, and associated processes, and commonly including meadows, streams, fish, and wildlife. Forests include special kinds such as industrial forests, nonindustrial private forests, plantations, public forests, protection forests, and urban forests, as well as parks and wilderness. Source - The Dictionary of Forestry, 1998, published by the Society of American Foresters, John A. Helms, editor. Greg.Josten@state.sd.us"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-South Dakota" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_1397 a skos:Concept ;
    dct:creator "USA-STATE-Texas" ;
    dct:date "1977"^^xsd:gYear ;
    dct:source "http://capitol.tlc.state.tx.us/cgi-bin/cqcgi?CQ_SESSION_KEY=XMYTLGTJBKOU&CQ_QUERY_HANDLE=123988&CQ_CUR_DOCUMENT=14&CQ_TLO_DOC_TEXT=YES"^^xsd:anyURI,
        "http://www.capitol.state.tx.us/statutes/nr/nr0015200.html"^^xsd:anyURI,
        "http://www.statutes.legis.state.tx.us/Docs/NR/htm/NR.152.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"Forest\" means the standing trees on forest land. Source: CHAPTER 152. FOREST PEST CONTROL SUBCHAPTER A. GENERAL PROVISIONS , and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Texas 1977" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_1398 a skos:Concept ;
    dct:creator "USA-STATE-Texas" ;
    dct:date "1999"^^xsd:gYear ;
    dct:source "http://www.dir.state.tx.us/tgic/pubs/lulc-report.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forested – trees with crowns overlapping (generally 60-100% cover) 1999"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Texas 1999" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_1399 a skos:Concept ;
    dct:creator "USA-STATE-Texas" ;
    dct:source "http://www.capitol.state.tx.us/tlo/74R/billtext/SB00977H.HTM"^^xsd:anyURI,
        "http://www.statutes.legis.state.tx.us/Docs/NR/htm/NR.152.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"Forest\" means a tract of land thick with trees and underbrush. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Texas" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_14 a skos:Concept ;
    dct:creator "Blackstone" ;
    dct:source "http://www.foresthistory.org/ASPNET/Publications/CCCforestry/contents.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A waste grounds belonging to the king"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Blackstone" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "General"@en .

ex:Forest_140 a skos:Concept ;
    dct:creator "as in large plantations with no undergrowth" ;
    dct:source "http://www.foresthistory.org/ASPNET/Publications/CCCforestry/contents.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "An association of trees , or shrubs (as in the watersheds of the Southwest), or both (as in the hardwood and mixed forests), growing on a considerable area, upon which it is possible to practice forestry"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "as in large plantations with no undergrowth" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_1400 a skos:Concept ;
    dct:creator "USA-STATE-Texas" ;
    dct:source "http://capitol.tlc.state.tx.us/cgi-bin/cqcgi?CQ_SESSION_KEY=XMYTLGTJBKOU&CQ_QUERY_HANDLE=123988&CQ_CUR_DOCUMENT=14&CQ_TLO_DOC_TEXT=YES"^^xsd:anyURI,
        "http://www.statutes.legis.state.tx.us/Docs/NR/htm/NR.152.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "3) \"Forest land\" means land on which the trees are potentially valuable for timber products, protection of watersheds, wildlife habitat, recreational uses, or for other purposes, but does not include land within the incorporated limits of a village, town, or city. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Texas" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_1401 a skos:Concept ;
    dct:creator "USA-STATE-Texas" ;
    dct:source "http://www.tpwd.state.tx.us/conserve/whap/appendices.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Deciduous or evergreen trees dominant; mostly greater than 30 feet tall with closed crowns or nearly so (71 to 100 percent canopy cover); midstory generally apparent except in managed monoculture"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Texas" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_1402 a skos:Concept ;
    dct:creator "USA-STATE-Texas" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Trees with crowns overlapping (generally 60-100% cover) (woody veg > 4 m in height) www.tgic.state.tx.us/tgic/documents/plans/lulc-report.pdf"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Texas" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_1403 a skos:Concept ;
    dct:creator "USA-STATE-Utah-Tremonton" ;
    dct:source "http://www.ulct.org/resources/ordinance_codes/tremonton/tremzong.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Areas, groves, or stands of mature or largely mature (i.e., greater than six inches caliper) trees covering an area greater than one-quarter acre; or groves of mature trees (greater than 12 inches caliper) consisting of more than 10 individual trees"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Utah-Tremonton" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_1404 a skos:Concept ;
    dct:creator "USA-STATE-Virgin Islands" ;
    dct:source "http://rps.uvi.edu/CES/vivegzon.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Closed tree canopy (Trees >5 m, canopy cover > 50%"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Virgin Islands" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_1405 a skos:Concept ;
    dct:creator "USA-STATE-Virginia ?" ;
    dct:date "2002"^^xsd:gYear ;
    dct:source "http://www.state.va.us/dcr/dnh/ncglossary.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest – vegetation dominated by trees (= 6m [20 ft] tall) producing a more or less closed canopy, typically with 60-100% cover; some forests may temporarily have < 60% canopy cover following disturbances such as windthrow, disease, etc"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Virginia 2002?" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_1406 a skos:Concept ;
    dct:creator "USA-STATE-Virginia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"Forest land\" means land on which forest trees are found. Under Authority of Department of Forestry. § 10.1-1178. Definitions. \"Starr, James\" starrj@dof.state.va.us"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Virginia" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_1407 a skos:Concept ;
    dct:creator "USA-STATE-West Virginia" ;
    dct:source "http://www.legis.state.wv.us/scripts/as_web.exe?Command=search&file=total2&request=forest+definition&MaxHits=10&NumLines=1"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "a) \"Timberland\" means any surface real property except farm woodlots of not less than ten contiguous acres which is primarily in forest and which, in consideration of their size, has sufficient numbers of commercially valuable species of trees to constitute at least forty percent normal stocking of forest trees which are well distributed over the growing site"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-West Virginia" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_1408 a skos:Concept ;
    dct:creator "USA-STATE-Wisconsin ?" ;
    dct:date "2017"^^xsd:gYear ;
    dct:source "http://docs.legis.wisconsin.gov/statutes/statutes/77/VI/81"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "“Forestry\" means managing forest lands and their related resources, including trees and other plants, animals, soil, water and air"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Wisconsin 2017?" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_1409 a skos:Concept ;
    dct:creator "USA-STATE-Wyoming" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest -We informally use the FS definition of >10% crown cover to define forest vs nonforest. To the best of my knowledge there is no definition either in statute or in any written documents. \"Howard Pickerd\" HPICKE@state.wy.us"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Wyoming" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_141 a skos:Concept ;
    dct:creator "e.g., tropical, boreal - another word for northern -or coastal" ;
    dct:source "http://www.evergreentheatre.com/forests.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "An ecosystem characterised by more or less continuous tree cover. However, a forest is more than trees - a forest also includes shrubs, vines, herbs, mosses, microorganisms, insects and other animals, which interact among themselves and with their environment. The type of forest is defined by either geography or climate or for the predominant tree found in that forest (coniferous, deciduous or mixed"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "e.g., tropical, boreal - another word for northern -or coastal" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_1410 a skos:Concept ;
    dct:creator "Tasmania" ;
    dct:source "http://www.forestrytas.com.au/forestrytas/pdf_files/sustainable_forest_management/sfm_2003/glossary.pdf"^^xsd:anyURI ;
    dct:spatial "Australia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "An area incorporating all living and non-living components, dominated by trees having usually a single stem and a mature (or potentially mature) stand height exceeding 5m, with existing or potential projective foliage cover of overstorey strata, about equal to or greater than 30%. This definition includes native forests and plantations regardless of age, and areas of trees sometimes described as woodlands"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Australia-Tasmania" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1411 a skos:Concept ;
    dct:creator "Victoria" ;
    dct:source "http://www.dse.vic.gov.au/dse/nrenfor.nsf/FID/-9A9762E4B40E608F4A256AB1000306D0?OpenDocument"^^xsd:anyURI ;
    dct:spatial "Australia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "An area, incorporating all living and non-living components, that is dominated by trees with an existing or potential stand height exceeding 5 metres, and with existing or potential projective foliage cover of overstorey strata at least 30 per cent. This definition includes Australia's diverse native forests and plantations, regardless of age. It is also sufficiently broad to encompass areas of trees that are sometimes described as woodlands"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Australia-Victoria" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1412 a skos:Concept ;
    dct:creator "Victoria" ;
    dct:source "http://www.dse.vic.gov.au/dse/nrenfor.nsf/FID/-9A9762E4B40E608F4A256AB1000306D0?OpenDocument"^^xsd:anyURI ;
    dct:spatial "Australia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Woody vegetation with a potential top height greater than five metres and with a crown cover projection greater than 10 percent"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Australia-Victoria" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1413 a skos:Concept ;
    dct:creator "Flemmish Region" ;
    dct:date "1997"^^xsd:gYear ;
    dct:spatial "Belgium" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Wooded areas = 50 acres, width = 25 m, cover = 20 % (excepted for clear cutting or forest damages). (European Communities 1997a - p 112"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Belgium-Flemmish Region 1997" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1414 a skos:Concept ;
    dct:creator "BC" ;
    dct:source "http://www.swp.bc.ca/myw/html/21_Glossary.htm"^^xsd:anyURI ;
    dct:spatial "Canada" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land having as its highest and best use the growing and harvesting of trees. BC Assessment Authority"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Canada-BC" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1415 a skos:Concept ;
    dct:creator "BC" ;
    dct:source "http://www.for.gov.bc.ca/tasb/legsregs/forest/foract/part2.htm#4"^^xsd:anyURI ;
    dct:spatial "Canada" ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"Forest land\" means land classified as forest land under section 4; = Forest land. The chief forester must classify land as forest land if he or she considers that it will provide the greatest contribution to the social and economic welfare of British Columbia if predominantly maintained in successive crops of trees or forage, or both, or maintained as wilderness"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Canada-BC" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1416 a skos:Concept ;
    dct:creator "BC" ;
    dct:source "http://www.assessmentappeal.bc.ca/informationsheets/AACT1098board.asp#defn"^^xsd:anyURI ;
    dct:spatial "Canada" ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"Forest land\" means land, other than a farm, that (a) is forest reserve land, other than forest reserve land that is not used for the production and harvesting of timber, or (b) although not forest reserve land, has as its highest and best use the production and harvesting of timber"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Canada-BC" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1417 a skos:Concept ;
    dct:creator "BC" ;
    dct:source "http://www.for.gov.bc.ca/pab/publctns/glossary/glossary.htm"^^xsd:anyURI ;
    dct:spatial "Canada" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Crown land or private land that is predominantly maintained in one or more successive stands of trees, successive crops of forage, or wilderness. [Source: Glossary of Forestry Terms, Province of British Columbia, Ministry of Forests, via Igor A. Yakovlev]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Canada-BC" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1418 a skos:Concept ;
    dct:creator "Manitoba" ;
    dct:source "http://web2.gov.mb.ca/laws/statutes/ccsm/f150e.php"^^xsd:anyURI ;
    dct:spatial "Canada" ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"Forest land\" means any uncultivated land in the province on which trees or shrubs are growing or standing; any barren, dry marsh, or bog, whether the land is owned by the Crown or by private persons, or held under lease from the Crown; (« forêt »"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Canada-Manitoba" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1419 a skos:Concept ;
    dct:creator "New Brunswick" ;
    dct:source "http://www.gnb.ca/public/fire-feu/prevent-e.asp"^^xsd:anyURI ;
    dct:spatial "Canada" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest land means any land outside the boundaries of a city or town and not cultivated for agricultural purposes on which trees, shrubs, plants or grass are growing"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Canada-New Brunswick" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_142 a skos:Concept ;
    dct:creator "Helms" ;
    dct:date "2002"^^xsd:gYear ;
    skos:broadMatch ex:Forest ;
    skos:definition "An ecosystem characterised by more or less dense and extensive tree cover. From: Alexander.Korotkov@unece.org. Date: Thu, 15 Oct 1998 17:09:40 +0200 and SAF 1971"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Helms 2002" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_1420 a skos:Concept ;
    dct:creator "Nova Scotia" ;
    dct:date "2009"^^xsd:gYear ;
    dct:source "http://www.gov.ns.ca/just/regulations/regs/fofire.htm"^^xsd:anyURI,
        "http://www.gov.ns.ca/just/regulations/regs/for8297.htm"^^xsd:anyURI,
        "https://nslegislature.ca/sites/default/files/legc/statutes/forests.htm"^^xsd:anyURI ;
    dct:spatial "Canada" ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"Forest land\" means land bearing forest growth or land from which the forest has been removed but which shows surface evidence of past forest occupancy and is not now in other use; ,. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Canada-Nova Scotia 2009" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1421 a skos:Concept ;
    dct:creator "Ontario" ;
    dct:date "2003"^^xsd:gYear ;
    dct:source "http://www.mnr.gov.on.ca/stdprodconsume/groups/lr/@mnr/@forests/documents/document/mnr_e000254.pdf"^^xsd:anyURI ;
    dct:spatial "Canada" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Silvicultural Management) An area managed for the production of timber and other forest products, or maintained under woody vegetation for such indirect benefits as protection of site or for recreation"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Canada-Ontario 2003" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1422 a skos:Concept ;
    dct:creator "Prince Edward Island" ;
    dct:source "http://www.gov.pe.ca/law/statutes/pdf/f-14.pdf"^^xsd:anyURI ;
    dct:spatial "Canada" ;
    skos:broadMatch ex:Forest ;
    skos:definition "“Forest land” means (i) any land, excluding the cleared land immediately adjacent to an occupied building, on which living or dead trees are the tallest type of vegetation, (ii) any land on which tree seedlings exist or have been planted and are retained for the purposes of producing forest products, or (iii) any land which is being manipulated by tree harvesting, site preparation, tree planting, and or other techniques that promote the establishment of tree seedlings"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Canada-Prince Edward Island" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1423 a skos:Concept ;
    dct:creator "Yukon" ;
    dct:date "2017"^^xsd:gYear ;
    dct:source "http://www.emr.gov.yk.ca/forestry/pdf/yukon-forestry-handbook-2017.pdf"^^xsd:anyURI ;
    dct:spatial "Canada" ;
    skos:broadMatch ex:Forest ;
    skos:definition "An ecosystem characterized by a more or less dense and continuous tree cover, often consisting of stands varying in composition, structure, age class and associated processes, and commonly including meadows, streams, fish and wildlife"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Canada-Yukon 2017" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1424 a skos:Concept ;
    dct:creator "INDIA-Kerala" ;
    dct:date "2003"^^xsd:gYear ;
    dct:source "http://www.kerenvis.nic.in/legislation/Microsoft%20Word%20-%20Act2003.pdf"^^xsd:anyURI ;
    dct:spatial "India" ;
    skos:broadMatch ex:Forest ;
    skos:definition "“forest” means any land principally covered with naturally grown trees and under growth and includes any forest statutorily recognized and declared as reserved forest, protected forest or otherwise, but does not include any land which is used principally for the cultivation of crops of long duration such as tea, coffee, rubber, pepper, cardamom, coconut, arecanut or cashew or any other sites of residential buildings and surroundings essential for the convenient use of such buildings"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "INDIA-Kerala 2003" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_143 a skos:Concept ;
    dct:source "http://nfdp.ccfm.org/silviterm/silvi_e/silvitermetohe.htm#F"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "An ecosystem characterized by a more or less dense and extensive tree cover. More particularly, a plant community predominantly of trees and other woody vegetation, growing more or less closely together"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_1432 a skos:Concept ;
    dct:creator "USA-STATE-Alabama" ;
    dct:source "http://farm.fic.niu.edu/fic/laws/state/al40.html#stat"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "forest (meaning real property used for the growing and sale of timber and forest products) Source"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Alabama" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1433 a skos:Concept ;
    dct:creator "USA-STATE-Alaska" ;
    dct:source "http://touchngo.com/lglcntr/akstats/Statutes/Title41/Chapter17/Section950.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"Forest land\" means land stocked or having been stocked with forest trees of any size and not currently developed for nonforest use, regardless of whether presently available or accessible for commercial purposes, and includes any such land under state, municipal, or private ownership"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Alaska" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1434 a skos:Concept ;
    dct:creator "USA-STATE-Arkansas" ;
    dct:source "http://www.forestry.state.ar.us/bmp/glossary.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land bearing forest growth, or land from which the forest has been removed, and is in any stage of forest growth, or production, or maintains the potential for forest growth"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Arkansas" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1435 a skos:Concept ;
    dct:creator "USA-STATE-California" ;
    dct:source "http://ceres.ca.gov/foreststeward/pdf/CFIPguide.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"Forestland\" means the land: (1) can support 10 percent or more tree cover with trees native to California, including native oaks, (generally but not always this is Site V (Dunning) and better timberland); and (2) is zoned to allow forest resource management"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-California" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1436 a skos:Concept ;
    dct:creator "USA-STATE-California" ;
    dct:source "http://www.arb.ca.gov/bluebook/bb03/HS/42801.htm"^^xsd:anyURI,
        "http://www.energy.ca.gov/global_climate_change/documents/SB_812_20020909_chapter.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "‘‘Forest’’ means lands that support, or can support,’’ at least 10 percent tree canopy cover and that allow for management of one or more forest resources including timber, fish and wildlife, biodiversity, water quality, recreation, aesthetics and other public benefits. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-California" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1437 a skos:Concept ;
    dct:creator "USA-STATE-California-Mendocino County" ;
    dct:source "http://mendolafco.org/lafcopp/lafcopandp2002.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "“Forest Land” means lands, which are suited for and are appropriately retained for the growing, harvesting and production of timber and forest and timber-related products. The classification includes lands eligible to be zoned Timberland Production (TPZ), including lands which have the present or future potential for timber production, intermixed smaller parcels and other contiguous lands, the inclusion of which is necessary for the protection and efficient management of forest resource lands"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-California-Mendocino County" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1438 a skos:Concept ;
    dct:creator "USA-STATE-Colorado" ;
    dct:source "http://www.palmerfoundation.org/Legal_CO.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"Forest land\" means land of which at least ten percent is stocked by forest trees of any size and includes land that formerly had such tree cover and that will be naturally or artificially regenerated. \"Forest land\" includes roadside, streamside, and shelterbelt strips of timber which have a crown width of at least one hundred twenty feet. \"Forest land\" includes unimproved roads and trails, streams, and clearings which are less than one hundred twenty feet wide"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Colorado" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1439 a skos:Concept ;
    dct:creator "USA-STATE-Florida" ;
    dct:source "http://election.dos.state.fl.us/laws/98laws/ch_98-294.pdf"^^xsd:anyURI,
        "http://www.myflorida.com/dor/tips/tip98a115.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "``Forest\" means land stocked by trees of any size used in the production of forest products, or forest land that has been harvested and is not currently developed for nonforest use. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Florida" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_144 a skos:Concept ;
    dct:creator "Helms" ;
    dct:date "2002"^^xsd:gYear ;
    skos:broadMatch ex:Forest ;
    skos:definition "An ecosystem characterized by more or less dense and extensive tree cover usually consisting of stands varying in characteristics such as species, structure, composition, age class, and commonly including streams, fish, and wildlife… SAF 1998"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Helms 2002" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_1440 a skos:Concept ;
    dct:creator "USA-STATE-Hawaii-Kauai Co" ;
    dct:date "1988"^^xsd:gYear ;
    dct:source "http://www.fs.fed.us/pnw/pubs/rb156.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land at least 10 percent stocked with trees and not now developed for nonforest use; also includes land 50 percent or more covered by shrubs. The minimum area recognized as forest land is 1 acre. This land includes both timberland and other forest land (Buck et al. 1988"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Hawaii-Kauai Co. 1988" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1441 a skos:Concept ;
    dct:creator "USA-STATE-Idaho" ;
    dct:source "http://www2.state.id.us/tax/propertytax/PTpdfs/revisedforestlanddesign.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forestland means privately owned land being held and used primarily for the continuous purpose of growing and harvesting trees of a marketable species"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Idaho" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1442 a skos:Concept ;
    dct:creator "USA-STATE-Idaho" ;
    dct:date "1974"^^xsd:gYear ;
    dct:source "https://adminrules.idaho.gov/rules/current/20/0201.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest Land. Federal, state and private land growing forest tree species which are, or could be at maturity, capable of furnishing raw material used in the manufacture of lumber or other forest products. The term includes federal, state and private land from which forest tree species have been removed but have not yet been restocked. It does not include land affirmatively converted to uses other than the growing of forest tree species"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Idaho-1974" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1443 a skos:Concept ;
    dct:creator "USA-STATE-Idaho" ;
    dct:date "2005"^^xsd:gYear ;
    dct:source "http://www3.state.id.us/cgi-bin/newidst?sctid=630170001.K"^^xsd:anyURI,
        "http://www3.state.id.us/oasis/2005/H0126.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"Forest\" means forest land and the timber thereon. \"Forest land\" means privately owned land being held and used primarily for the continuous purpose of growing and harvesting trees of a marketable species. Having met the above criteria, forest land may be further identified by the consideration of any of the following criteria: (a) Forest land is land evidenced by present use and silvicultural treatment. (b) Forest land is land which has a dedicated use that is further evidenced by a forest land management plan that includes eventual harvest of the forest crop. (c) Forest land is land bearing forest growth or land which has not been converted to another use. (d) Forest land is land which has had the trees removed by man through harvest, including clear-cuts or by natural disaster, such as but not limited to fire, and which within five (5) years after harvest or initial assessment will be reforested as specified in the forest practices act (chapter 13, title 38, Idaho Code). and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Idaho-2005" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1444 a skos:Concept ;
    dct:creator "USA-STATE-Illinois" ;
    dct:date "1996"^^xsd:gYear ;
    dct:source "http://www.legis.state.il.us/ilcs/ch525/ch525act40.htm#Top"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "State forests shall include only such lands as are decided by the Department of Natural Resources to be more valuable for the growing of forests than for other purposes, and shall have for their purpose the production of forest products, the protection of watersheds that are subject to serious erosion, the maintenance of purity of springs and streams and to afford recreation places for the people of the State. (Source: P.A. 89-445, eff. 2-7-96.) Source"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Illinois 1996" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1445 a skos:Concept ;
    dct:creator "USA-STATE-Illinois" ;
    dct:source "http://dnr.state.il.us/legal/1537.pdf"^^xsd:anyURI,
        "http://www.legis.state.il.us/commission/jcar/admincode/017/017015370000010R.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"Forest\" means an area whose principal crop is trees. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Illinois" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1446 a skos:Concept ;
    dct:creator "USA-STATE-Illinois" ;
    dct:source "http://dnr.state.il.us/legal/62-1701.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"Forestry\" means land used or managed for the long-term production of wood, wood fiber, or wood-derived products. Allowable support facilities include water impoundments, access and fire control lanes, erosion control structures such as grassed waterways, downdrains, terraces and sediment ponds, and other incidental facilities related to sound multiple use management of the forest resource"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Illinois" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1447 a skos:Concept ;
    dct:creator "USA-STATE-Illinois" ;
    dct:source "http://dnr.state.il.us/mines/lrd/guides/citrec7.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land used or managed for the long-term production of wood, wood fiber or wood derived products. Land used for facilities in support of forest harvest and management operations that is adjacent to or an integral part of these operations is also included"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Illinois" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1448 a skos:Concept ;
    dct:creator "USA-STATE-Iowa" ;
    dct:date "1999"^^xsd:gYear ;
    dct:source "http://www.legis.state.ia.us/IACODE/1999SUPPLEMENT/161A/42.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"Forest\" means stands of native or introduced trees containing at least two hundred trees per acre and located on privately owned land. However, a stand of fruit trees is not a forest. 1999"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Iowa 1999" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1449 a skos:Concept ;
    dct:creator "USA-STATE-Kansas" ;
    dct:date "1971"^^xsd:gYear ;
    skos:broadMatch ex:Forest ;
    skos:definition "An area managed for the production of timber and other forest produce, or maintained under woody vegetation for such indirect benefits as protection of catchment areas or recreation. \"Terminology of Forest Science, Technology, Practice & Products\" SAF, 1971. Robert L. Atchison ratchiso@oznet.ksu.edu"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Kansas 1971" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_145 a skos:Concept ;
    dct:creator "from the Latin word meaning outside the door" ;
    dct:source "http://figueresonline.com/csdafinal/English/publications/cdm/glossary.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "An ecosystem characterized by trees or a plant community in which trees predominate"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "from the Latin word meaning outside the door" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_1450 a skos:Concept ;
    dct:creator "USA-STATE-Kentucky" ;
    dct:source "http://www.lrc.state.ky.us/kar/405/030/010.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest land\" means land used or managed for the long-term production of wood, wood fiber, or wood derived products. Land used for facilities in support of forest harvest and management operations which is adjacent to or an integral part of these operations is also included"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Kentucky" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1451 a skos:Concept ;
    dct:creator "USA-STATE-Maine" ;
    dct:source "http://janus.state.me.us/legis/statutes/17/title17sec3853-D.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"Forest land\" means land used for the production of forest products"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Maine" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1452 a skos:Concept ;
    dct:creator "USA-STATE-Maine" ;
    dct:source "http://janus.state.me.us/legis/statutes/36/title36sec573.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest land. \"Forest land\" means land used primarily for growth of trees to be harvested for commercial use, but does not include ledge, marsh, open swamp, bog, water and similar areas, which are unsuitable for growing a forest product or for harvesting for commercial use even though these areas may exist within forest lands. Source"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Maine" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1453 a skos:Concept ;
    dct:creator "USA-STATE-Maine" ;
    dct:source "http://www.state.me.us/revenue/propertytax/Bulletins/Tax%20Bulletin%2019.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forestland--means land used primarily for growth of trees to be harvested for commercial use; may be either seedling, pole timber, or saw log stands. Forestland does not include ledge, marsh, open swamp, bog, water and similar areas that are unsuitable for growing a forest product or for harvesting for commercial use even though these areas may exist within forestlands"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Maine" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1454 a skos:Concept ;
    dct:creator "USA-STATE-Maine" ;
    dct:source "http://www.google.com/search?q=cache:www.memun.org/municipal_resources/Public_files/TAXDATA/HTML/PropertyTaxBull/html/bulletin19.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land used primarily for growth of trees to be harvested for commercial use; may be either seedling, poletimber, or sawlog stands. Land which would otherwise be included in this definition shall not be excluded because of: (1) Multiple use for public recreation; (2) Statutory or governmental restrictions which prevent commercial harvesting of trees or require a primary use of the land other than commercial harvesting; (3) Deed restrictions, restrictive covenants or organizational charters that prevent commercial harvesting of trees or require a primary use of land other than commercial harvesting and that were effective prior to January 1, 1982; or (4) Past or present multiple use for mineral exploration"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Maine" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1455 a skos:Concept ;
    dct:creator "USA-STATE-Maine-Acton" ;
    dct:date "2003"^^xsd:gYear ;
    dct:source "http://www.actonmaine.com/warrant/2003/warrant.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest Land means land used primarily to grow trees to be harvested for commercial use, but does not include marsh, open swamp, bog, water and similar areas, which are unsuitable for growing a forest product or for harvesting for commercial use even though these areas may exist within forest lands"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Maine-Acton 2003" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1456 a skos:Concept ;
    dct:creator "USA-STATE-Maryland" ;
    dct:date "1974"^^xsd:gYear ;
    dct:source "http://ia700309.us.archive.org/35/items/landuseclassific209mary/landuseclassific209mary.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "These lands are at least 10% stocked with trees capable of producing timber or other wood products, and lands dedicated to forest production but temporarily cleared (i.e. logged). This lands include abandoned fields with woody brush that prevents classification as Agricultural land"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Maryland 1974" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1457 a skos:Concept ;
    dct:creator "USA—STATE-Maryland" ;
    dct:date "2007"^^xsd:gYear ;
    dct:source "http://www.dnr.state.md.us/download/reforest.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "i) \"Forest\" means a biological community dominated by trees or other woody plants covering a land area of 1 acre or more.(ii) \"Forest\" includes an area that has been cut but not cleared of trees or other woody plants. Maryland 2007"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA—STATE-Maryland 2007" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1458 a skos:Concept ;
    dct:creator "USA-STATE-Maryland" ;
    dct:source "http://www.mde.state.md.us/assets/document/sedimentStormwater/MDEFHOESManualDraft063005_glossary.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land bearing forest growth or land from which the forest has been removed but which shows evidence of past forest occupancy and which is not now in other use"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Maryland" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1459 a skos:Concept ;
    dct:creator "USA-STATE-Maryland" ;
    dct:date "1974"^^xsd:gYear ;
    dct:source "http://ia700309.us.archive.org/35/items/landuseclassific209mary/landuseclassific209mary.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest land are lands that are at least 10 percent stocked with trees capable of producing timber or other wood products that exert an influence on climate or water regime. Lands from which trees have been removed to less than 10 percent stocking but which have not been developed for other use are also included"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Maryland-1974" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_146 a skos:Concept ;
    dct:source "http://forestinfo.org/sust.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "An ecosystem dominated by trees, with a unique combination of plants, animals, microbes, soil, and climate"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_1460 a skos:Concept ;
    dct:creator "USA-STATE-Maryland-Easton" ;
    dct:source "http://www.town-eastonmd.com/Planning/fco/fco_a002.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"Forest\" means a biological community dominated by trees and other woody plants covering a land area of 10,000 square feet or greater. B. \"Forest\" includes: (1) Areas that have at least 100 live trees per acre with at least 50 percent of those trees having a 2-inch or greater diameter at 4.5 feet above the ground and larger; and (2) Areas that have been cut but not cleared. C. \"Forest\" does not include orchards"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Maryland-Easton" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1461 a skos:Concept ;
    dct:creator "USA-STATE-Maryland-Rockville" ;
    dct:date "2009"^^xsd:gYear ;
    dct:source "http://www.rockvillemd.gov/e-gov/rec-parks/ForestConservationManual.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "“forest\" means (1) a contiguous biological community dominated by trees and other woody plants covering a land area of five thousand (5,000) square feet or greater. (2) \"Forest\" includes:a. Areas that have at least one hundred (100) live trees per acre with at least fifty (50) percent of those trees having a two-inch or greater diameter at four and one-half (4.5) feet above the ground and larger; and b. Areas that have been cut but not cleared. (3) \"Forest\" does not include orchards. “Rockville, Maryland. 2009"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Maryland-Rockville 2009" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1462 a skos:Concept ;
    dct:creator "USA-STATE-Maryland-Rockville" ;
    dct:source "http://www.ci.rockville.md.us/cityprojects/envguide/eggloss.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A biological community dominated by trees and other woody plants covering a land area of 10,000 square feet or greater. Forest includes: (1) Areas that have at least 100 trees per acre with at least 50 percent of those trees having a 2-inch or greater dbh. (2) Forest areas that have been cut, but not cleared. Forest does not include orchards"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Maryland-Rockville" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1463 a skos:Concept ;
    dct:creator "USA-STATE-Massachusetts" ;
    dct:source "http://www.state.ma.us/dem/regs/304011c.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest Land means land with at least 15% of the area occupied by the crowns of forest trees of any size that contains at least 7.5 square feet of basal area per acre; or that is a plantation containing at least 500 trees per acre; or land recently harvested that is in the process of regeneration"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Massachusetts" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1464 a skos:Concept ;
    dct:creator "USA-STATE-Massachusetts" ;
    dct:source "http://www.daviesand.com/Laws/Chapter_61/Ch61_Regs/"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest Lands: (1) To be eligible for classification, land must meet the following criteria: (a) be a parcel of land containing ten or more adjacent or contiguous acres; (b) be at least 16 and 7/8% stocked with forest products and contain at least 7 and 5/10 square feet of basal area per acre by forest trees of any size; or formerly had such tree cover and is not currently developed for nonforest use, or is a plantation containing at least 500 trees per acre; and (c) has no subdivision plan on file. (2) The following areas may be included in the calculation of acreage: (a) certain permanent or temporary wetlands, water courses and submerged areas and other minor unproductive areas deemed by the State Forester to be comparable with forest production; (b) cleared rightsofway not exceeding 20 feet in width, including road bed, brushed out road edges, and other reasonable improvements to reduce erosion of the rightofway and to protect forest land, wetlands and stream crossings, or when the primary purpose of the improvement is for forest protection and access for forest management. The maximum width may be exceeded for turnouts, turn arounds or for temporary storage areas for forest products. Source: 304 CMR 8.00: CHAPTER 61, FOREST CLASSIFICATION"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Massachusetts" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1465 a skos:Concept ;
    dct:creator "USA-STATE-Massachusetts" ;
    dct:source "http://www.forestmeister.com/laws/ch61.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land that is at least sixteen and seven-tenths per cent stocked, that contains at least seven and five-tenths square feet of basal area per acre by forest trees of any size; or that formerly had such tree cover and is not currently developed for non-forest use; or that is a plantation containing at least five hundred trees per acre. [Source Chapter 61 Massachusetts Taxation Law - ]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Massachusetts" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1466 a skos:Concept ;
    dct:creator "USA-STATE-Michigan" ;
    dct:source "http://www.dnr.state.mi.us/www/law/law_book/statutes/code/part501.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"Forest land\" means a tract of land or the timber rights in that land owned or occupied by a member, which land is at least 10% occupied by forest tree species with a growth potential of 50 cubic feet per acre per year and consists of 40 acres or more. Forest land includes land from which forest tree species have been removed and have not been restocked, but does not include land converted to uses other than the growing of forest tree species or land currently zoned for uses incompatible with forest practices"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Michigan" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1467 a skos:Concept ;
    dct:creator "USA-STATE-Michigan" ;
    dct:source "http://www.michigan.gov/dnr/0,1607,7-153-10367_11851-24039--,00.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"Forest land\" means timbered land, potential timber-producing land, cutover or burned timber land or grass lands not including lands devoted to agriculture"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Michigan" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1468 a skos:Concept ;
    dct:creator "USA-STATE-Michigan" ;
    dct:source "http://www.michiganlegislature.org/law/getObject.asp?objName=324-51101&objType=section&highlight=forest"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "d) \" Forest land\" means a tract of land that may include nonproductive land that is intermixed with productive land that is an integral part of a managed forest and that meets all the following: (i) Does not have material natural resources other than those resources suitable for forest growth or the potential for forest growth. (ii) Is not used for agricultural, mineral extraction except as provided in section 51113, grazing, industrial, developed recreational, residential, resort, commercial, or developmental purposes. (iii) The owner agrees to develop, maintain, and actively manage the land as a commercial forest through planting, natural reproduction, or other silvicultural practices. Source"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Michigan" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1469 a skos:Concept ;
    dct:creator "USA-STATE-Michigan" ;
    dct:date "2002"^^xsd:gYear ;
    dct:source "https://www.legislature.mi.gov/(S(tirvdsukrupau3mkfduqnn55))/documents/mcl/pdf/mcl-chap320.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "“Forest” means a tract of land that is at least 10% stocked by trees of any size, whether of commercial or noncommercial species, or formerly having tree cover and not currently developed for nonforest use, including woodlands, woodlots, windbreaks, and shelter belts"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Michigan 2002" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_147 a skos:Concept ;
    dct:source "http://www.museum.state.il.us/muslink/forest/htmls/intro_def.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "An ecosystem or assemblage of ecosystems dominated by trees and other woody vegetation"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_1470 a skos:Concept ;
    dct:creator "USA-State-Minnesota" ;
    dct:date "2009"^^xsd:gYear ;
    dct:source "https://www.revisor.mn.gov/statutes/?id=88.01"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"Forest land\" means land which is at least ten percent stocked by trees of any size and capable of producing timber, or of exerting an influence on the climate or on the water regime; land from which the trees described above have been removed to less than ten percent stocking and which has not been developed for other use; and afforested areas"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-State-Minnesota 2009" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1471 a skos:Concept ;
    dct:creator "USA-STATE-Minnesota" ;
    dct:source "http://www.revisor.leg.state.mn.us/stats/89/51.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest land or forest. Forest land or forest, means land on which occurs a stand or potential stand of trees valuable for timber products, watershed or wildlife protection, recreational uses or other purposes, and shall include lands owned or controlled by the state of Minnesota"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Minnesota" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1472 a skos:Concept ;
    dct:creator "USA-STATE-Montana" ;
    dct:date "1996"^^xsd:gYear ;
    dct:source "http://data.opi.mt.gov/bills/1997/Bills/Senate/SB0100_ENR.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"Forest\" means forest land and the timber on the land. (5) \"Forest land\" means contiguous land of 15 acres or more in one ownership that is capable of producing timber that can be harvested in commercial quantity and is producing timber unless the trees have been removed by man through harvest, including clearcuts, or by natural disaster, including but not limited to fire. Forest land includes land: (a) that has not been converted to another use"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Montana 1996" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1473 a skos:Concept ;
    dct:creator "USA-STATE-Montana" ;
    dct:source "http://data.opi.state.mt.us/bills/mca/15/44/15-44-102.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"Forest land\" means contiguous land of 15 acres or more in one ownership that is capable of producing timber that can be harvested in commercial quantity and is producing timber unless the trees have been removed by man through harvest, including clearcuts, or by natural disaster, including but not limited to fire. Forest land includes land: a) that has not been converted to another use; and b) on which the annual net wood production equals or exceeds 25 cubic feet an acre at the culmination of mean annual increment"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Montana" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1474 a skos:Concept ;
    dct:creator "USA-STATE-Nevada" ;
    dct:source "http://www.leg.state.nv.us/NRS/NRS-527.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "“Forest” or “forest land” means land on which occurs a stand or potential stand of trees valuable for timber products, watershed or wildlife protection, recreational uses or for other purposes"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Nevada" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1475 a skos:Concept ;
    dct:creator "USA-STATE-Nevada" ;
    dct:source "http://www.dcnr.nv.gov/nrp/y-tr1nrp.pdf"^^xsd:anyURI,
        "http://www.nalms.org/glossary/lkword_f.htm"^^xsd:anyURI,
        "http://www.safc.org/resources/glossary.htm#definitions"^^xsd:anyURI,
        "http://www.state.nv.us/cnr/ndwp/dict-1/WORD_F.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land which is at least 10 percent occupied by forest trees of any size or formerly having had such tree cover and not currently developed for non-forest use. Lands developed for non-forest use include areas for crops, improved pasture, residential, or administrative areas, improved roads of any width, and adjoining road clearing and power line clearing of any width. Water Words Dictionary, Lake and Water Words Glossary, and (36 CFR 219.3"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Nevada" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1476 a skos:Concept ;
    dct:creator "USA-STATE-New York" ;
    dct:source "http://www.dec.state.ny.us/website/regs/199.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest land means land primarily devoted to and suitable for forest crop production under accepted evenaged or unevenaged forest management systems through natural regeneration or through forestation and sufficiently stocked with forest trees to produce a merchantable forest crop within 30 years of time of original certification. Forest land shall consist of a stand or stands of commercial species of forest trees which contain at least either 500 stems per acre or 60 square feet of basal area per acre which shall be evenly distributed over the area of the stand. The department may approve a smaller number of planted trees per acre if the resulting spacing between trees is appropriate for satisfactory growth for the species being planted. For natural seedlings to be part of a stand, they must be at least one foot in height, and planted trees must be at least in their third growing season on the site"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-New York" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1477 a skos:Concept ;
    dct:creator "USA-STATE-North Carolina" ;
    dct:source "http://www.cals.ncsu.edu/wq/LandPreservationNotebook/statutes/nc/presentusevalue.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Individually owned forestland consisting of one or more tracts, one of which consists of at least 20 acres that are in actual production and are not included in a farm unit"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-North Carolina" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1478 a skos:Concept ;
    dct:creator "USA-STATE-North Carolina" ;
    dct:source "http://www.cals.ncsu.edu/wq/LandPreservationNotebook/statutes/nc/presentusevalue.htm"^^xsd:anyURI,
        "http://www.co.forsyth.nc.us/tax/defermnt.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land that is a part of a forest unit that is actively engaged in the commercial growing of trees under a sound management program. Forestland includes wasteland that is a part of the forest unit, but the wasteland included in the unit shall be appraised under the use-value schedules as wasteland. A forest unit may consist of more than one tract of forestland, but at least one of the tracts must meet the requirements in G.S. 105-277.3(a)(3), and each tract must be under a sound management program. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-North Carolina" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1479 a skos:Concept ;
    dct:creator "USA-STATE-North Carolina-Counties" ;
    dct:source "http://www.co.anson.nc.us/assessor/defermnt.htm"^^xsd:anyURI,
        "http://www.co.chatham.nc.us/dept/tax/web/Listing.htm"^^xsd:anyURI,
        "http://www.lincolncounty.org/County/Departments/Tax/LandUseValueQualifications.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forestland means land that is a part of a forest unit that is actively engaged in the commercial growing of trees under a sound management program. Forestland includes wasteland that is a part of the forest unit, but the wasteland included in the unit shall be appraised under the use value schedules as wasteland. The requirements for a forestland deferment are as follows: May consist of more than one tract of forestland, but at least one of the tracts must meet the qualification requirements and each tract must be under a sound management program. One tract must consist of at least 20 acres that are in actual production and are not included in a farm unit. If individually owned, the property must be the owner's residence or have been owned by the current owner or a relative of the current owner for four years preceding January 1 of the year in which the benefit is claimed. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-North Carolina-Counties" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_148 a skos:Concept ;
    dct:source "http://www.fscus.org/html/about_fsc/who_we_are/glossary_of_terms.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "An ecosystem that, when intact, is characterized by tree cover usually consisting of stands varying in characteristics such as species, structure, composition, age-class, and commonly including streams, and wildlife. While forest ecosystems are not bound by property lines, for the purpose of this document, \"forest\" may be delimited by ownership or other qualifying characteristics"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_1480 a skos:Concept ;
    dct:creator "USA-STATE-Ohio" ;
    dct:date "2001"^^xsd:gYear ;
    dct:source "http://auditor.cuyahoga.oh.us/auditor/appraisal/forestland.htm"^^xsd:anyURI,
        "http://www.ohiodnr.com/forestry/rules/pdf/3-10-01.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"Forest land\" means land for which the primary purpose is the growing, managing and harvesting of a merchantable forest product of commercial species under accepted silvicultural systems through natural or artificial reforestation methods and for which there is an approved forest management plan. The forest land shall consist of a stand or stands of commercial species of forest trees which contain at least fifty square feet of basal area or at least three hundred stems per acre which shall be evenly distributed throughout the stand. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Ohio 2001" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1481 a skos:Concept ;
    dct:creator "USA-STATE-Oklahoma" ;
    dct:date "2003"^^xsd:gYear ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest means a tract of land that is at least ten percent (10%) stocked by trees of any size, whether of commercial or noncommercial species, or formerly having tree cover and not currently developed for nonforest use, including woodlands, woodlots, windbreaks, and shelterbelts; www.lsb.state.ok.us/2003-04SB/sb606_cs.rtf"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Oklahoma 2003" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1482 a skos:Concept ;
    dct:creator "USA-STATE-Oklahoma" ;
    dct:source "http://oklegal.onenet.net/oklegal-cgi/isearch"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"Forests\" means forest land that is at least ten percent (10%) stocked by forest trees of any size, whether of commercial or noncommercial species, or formerly having such tree cover and not currently developed for nonforest use, including woodlands, woodlots, windbreaks and shelterbelts; Source: &sect;2-1301-102"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Oklahoma" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1483 a skos:Concept ;
    dct:creator "USA-STATE-Oregon" ;
    dct:source "http://arcweb.sos.state.or.us/rules/OARS_600/OAR_629/629_022.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"Forestland\" means land zoned in a county comprehensive plan for forest or farm use that is capable of producing commercial hardwood or softwood timber, regardless of the vegetation currently on the land"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Oregon" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1484 a skos:Concept ;
    dct:creator "USA-STATE-Oregon" ;
    dct:source "http://www.savinggraves-us.org/or/laws/308a.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "“Forestland\" means forestland that is a parcel of land of more than 10 acres that has been zoned in the comprehensive plan for exclusive farm use, forest use or farm and forest use and that is, as of the assessment date for which value for the forest homesite is being determined: (a) Land that has as its highest and best use the growing and harvesting of trees of a marketable species; (b) Land that has been designated as forestland under ORS 321.257 to 321.390 or 321.805 to 321.825; or (c) Land that has been classified under ORS 321.705 to 321.765"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Oregon" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1485 a skos:Concept ;
    dct:creator "USA-STATE-Oregon" ;
    dct:source "http://www.leg.state.or.us/99reg/measures/sb1100.dir/sb1151.en.html"^^xsd:anyURI,
        "http://www.leg.state.or.us/ors/321.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Any land producing forest products. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Oregon" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1486 a skos:Concept ;
    dct:creator "USA-STATE-Oregon" ;
    dct:source "http://rredc.nrel.gov/biomass/states/bio_glossary/glossary.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Any land that is capable of producing or has produced forest growth or, if lacking forest growth, has evidence of a former forest and is not now in other use"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Oregon" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1487 a skos:Concept ;
    dct:creator "USA-STATE-Oregon" ;
    dct:source "http://159.121.125.11/forasst/Library/Pub/UrbanFP.pdf"^^xsd:anyURI,
        "http://arcweb.sos.state.or.us/rules/OARS_600/OAR_629/629_600.html"^^xsd:anyURI,
        "http://www.cof.orst.edu/cof/teach/for442/odfdefin.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forestland” means land used for the growing and harvesting of forest tree species, regardless of how the land is zoned, taxed or how any state statutes or local ordinances, rules or regulations are applied. , and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Oregon" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1488 a skos:Concept ;
    dct:creator "USA-STATE-Oregon" ;
    dct:source "http://159.121.125.11/rp/Far/crt5ind26.asp#SelectRef"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land at least 10% stocked by forest trees of any size, including land that formerly had such tree cover and that will be regenerated. Strips of forest must have a crown width of 36.58 meters to qualify as forestland"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Oregon" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1489 a skos:Concept ;
    dct:creator "USA-STATE-Oregon" ;
    dct:source "http://www.law.utexas.edu/dawson/nuisance/or_nuis.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land that is used for the growing and harvesting of forest tree species"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Oregon" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_149 a skos:Concept ;
    dct:creator "Gardner-Outlaw and Engelman" ;
    dct:date "1998"^^xsd:gYear ;
    skos:broadMatch ex:Forest ;
    skos:definition "An ecosystem with a minimum level of tree cover that is generally associated with wild flora, fauna and natural soil conditions, and not subject to agricultural practices"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Gardner-Outlaw and Engelman 1998" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_1490 a skos:Concept ;
    dct:creator "USA-STATE-Oregon-Klamath County" ;
    dct:source "http://www.co.klamath.or.us/ComDevelopment/Planning/GOAL4.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest lands are (1) lands composed of existing and potential forest lands suitable for commercial forest uses; (2) other forested lands needed for watershed protection, wildlife and fish habitat, and recreation; (3) lands where extreme conditions of climate, soil and topography require the maintenance of vegetative cover irrespective of use; and (4) other forested lands in urban and agricultural areas that provide urban buffers, wind breaks, wildlife and fish habitat, livestock, scenic corridors and recreation use"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Oregon-Klamath County" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1491 a skos:Concept ;
    dct:creator "USA-STATE-Oregon-Multnomah Co" ;
    dct:source "http://www2.co.multnomah.or.us/Community_Services/LUT-Planning/urban/CRGNSAPlan/PartII/NSAMP_PII_C2Forest.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Those lands used or suitable for the production of forest products"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Oregon-Multnomah Co." ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1492 a skos:Concept ;
    dct:creator "USA-STATE-Pennsylvania" ;
    dct:source "http://www.pacode.com/secure/data/025/0088.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land used for the long-term production of wood, wood fiber or wood-derived products; watershed protection or site stabilization and for the production, protection and management of species of fish and wildlife. Land used for facilities in support of forestry and watershed management operations which is adjacent to or an integral part of these operations is also included"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Pennsylvania" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1493 a skos:Concept ;
    dct:creator "USA-STATE-Rhode Island" ;
    dct:source "http://www.state.ri.us/dem/pubs/regs/regs/forest/altgrant.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "“Forestland” means any tract or contiguous tracts of land, five (5) acres or more bearing a dense growth of trees, young regenerating forest, and having either the quality of selfperpetuation, or being dependent upon its development by the planting and replanting"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Rhode Island" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1494 a skos:Concept ;
    dct:creator "USA-STATE-Rhode Island" ;
    dct:source "http://farm.fic.niu.edu/fic/laws/state/ri44271.html"^^xsd:anyURI,
        "http://www.state.ri.us/dem/pubs/regs/regs/agric/ffosimp.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "The term \"forest land\" means any tract or contiguous tracts of land, ten (10) acres or larger bearing a dense growth of trees, including any underbrush thereon, and having either the quality of self perpetuation, or being dependent upon its development by the planting and replanting of trees in stands of closely growing timber, actively managed under a forest management plan approved by the director of environmental management. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Rhode Island" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1495 a skos:Concept ;
    dct:creator "USA-STATE-South Carolina" ;
    dct:date "2009"^^xsd:gYear ;
    dct:source "http://www.lpitr.state.sc.us/code/t48c029.htm"^^xsd:anyURI,
        "http://www.scstatehouse.gov/code/t48c029.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest land\" or \"forest\" means land supporting a stand or potential stand of trees valuable for timber products, watershed or wildlife protection, recreational uses, or for other purposes. South Carolina South Carolina Code of Laws (Unannotated) Current through the end of the 2009 Session and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-South Carolina 2009" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1496 a skos:Concept ;
    dct:creator "USA-STATE-South Dakota" ;
    dct:date "1998"^^xsd:gYear ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest land: Land at least 10 percent stocked by forest trees of any size, including land that formerly had such tree cover and that will be naturally or artificially regenerated. Forest land includes (a) transition zones, such as areas between forested and nonforested lands that are at least 10 percent stocked with forest trees, and forest areas adjacent to urban and built-up lands, (b) pinion-juniper and chaparral areas. The minimum area for classification of forest land is 1 acre (0.4 ha); roadside, streamside, and shelterbelt strips of trees must have a crown width of at least 120 ft (36.6 m); unimproved roads and trails, streams, and clearings in forest areas are classified as forest if less than 120 ft (36.6 m) wide. Source - The Dictionary of Forestry, 1998, published by the Society of American Foresters, John A. Helms, editor. Greg.Josten@state.sd.us"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-South Dakota 1998" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1497 a skos:Concept ;
    dct:creator "USA-STATE-Tennessee" ;
    dct:source "http://farm.fic.niu.edu/fic/laws/state/tn675100.html"^^xsd:anyURI,
        "http://www.padctn.com/greenbelt_law.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"Forest land\" means land constituting a forest unit engaged in the growing of trees under a sound program of sustained yield management or any tract of fifteen (15) or more acres having tree growth in such quantity and quality and so managed as to constitute a forest; Source: and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Tennessee" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1498 a skos:Concept ;
    dct:creator "USA-STATE-Texas" ;
    dct:source "http://www.capitol.state.tx.us/statutes/nr/nr0015200.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"Forest land\" means land on which the trees are potentially valuable for timber products, protection of watersheds, wildlife habitat, recreational uses, or for other purposes, but does not include land within the incorporated limits of a village, town, or city"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Texas" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1499 a skos:Concept ;
    dct:creator "USA-STATE-Texas" ;
    dct:source "http://www.tpwd.state.tx.us/texaswater/rivers/riddellcriminaltrespass.phtml"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest land” means land on which the trees are potentially valuable for timber products"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Texas" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_15 a skos:Concept ;
    skos:broadMatch ex:Forest ;
    skos:definition "An area of land proclaimed to be forest under a Forest Act or Ordinance. Ford-Robertson 1971: 107, 298"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "General"@en .

ex:Forest_150 a skos:Concept ;
    dct:source "http://www.taxbar.com/tr/jaggers.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "An extensive area of land covered with trees and undergrowth. Shorter Oxford English Dictionary"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_1500 a skos:Concept ;
    dct:creator "USA-STATE-Vermont" ;
    dct:source "http://farm.fic.niu.edu/fic/laws/state/vt323751.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "9) \"Managed forest land\" means any land, exclusive of any housesite, which is at least 25 acres in size and which is under active forest management for the purpose of growing and harvesting repeated forest crops in accordance with accepted forest management practices. There shall be a presumption that land is under active forest management if at least 50 percent of the land: (A) is certified to be a \"tree farm\" under the American Tree Farm System; (B) has qualified for a federal cost-sharing forest improvement program, and that program has actually been carried out within the past five years; (C) is certified by the county forester as conforming with accepted forest management practices; or (D) conforms with such criteria for managed forest land as are accepted by the board; Source: Vt. Stat. Ann. tit. 32, &sect;&sect; 3751 to 3775"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Vermont" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1501 a skos:Concept ;
    dct:creator "USA-STATE-Vermont" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest land means any land, exclusive of any housesite, which is under active forest management for the purpose of growing and harvesting repeated forest crops. www.leg.state.vt.us/statutes/fullchapter.cfm?Title=24&Chapter=075"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Vermont" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1502 a skos:Concept ;
    dct:creator "USA-STATE-Virginia" ;
    dct:date "2000"^^xsd:gYear ;
    dct:source "http://www.dof.virginia.gov/gis/dwnld-vaforest2000-faq.shtml"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forestland is defined as lands with at least a stocking of 10% cover of live forest trees of any size, or formerly having such tree cover, and not currently developed for non-forest use. The minimum area for classification of forestland is usually 1 acre with a minimum width of 120 feet stem-to-stem. Forested strips must be at least 120 feet wide for a continuous length of at least 363 feet in order to meet the acre threshold. Unimproved roads and trails, and clearings in forest areas are classified as forest if less than 120 feet wide or smaller than 1 acre"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Virginia 2000" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1503 a skos:Concept ;
    dct:creator "USA-STATE-Virginia-Ablemarle County" ;
    dct:date "2010"^^xsd:gYear ;
    dct:source "http://www.albemarle.org/department.asp?department=finance&relpage=3309"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land used for forestal use must be a minimum of twenty acres and must include standing timber and trees devoted to tree growth in such quantity and so spaced and maintained as to constitute a forest area. Requires a minimum of 20 or more contiguous unimproved acres exclusively devoted to forestal use with no livestock access. Forestal acreage with livestock access must be qualified under the agricultural use category. Forestal participants are required to have a forest management plan prepared by a forestry professional or a letter of intent stating that the land will be forested"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Virginia-Ablemarle County 2010" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1504 a skos:Concept ;
    dct:creator "USA-STATE-Virginia-Loudoun Coounty" ;
    dct:source "http://www.co.loudoun.va.us/finserv/landuse2.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "To qualify for this category, the property must be a minimum of twenty acres and must meet the standards for productive forestland or nonproductive forestland"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Virginia-Loudoun Coounty" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1505 a skos:Concept ;
    dct:creator "USA-STATE-Washington" ;
    dct:date "1996"^^xsd:gYear ;
    dct:source "http://www.gmaboards.wa.gov/eastern/ew_decisions/ew1996/96-1-0017,ellensburg,orderoncomplianceandinvalidity.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land primarily devoted to growing trees for long-term commercial timber production on land that can be economically and practically managed for such production, including Christmas trees subject to the excise tax imposed under RCW 84.33.100 through 84.33.140, and that has long-term commercial significance. In determining whether forest land is primarily devoted to growing trees for long-term commercial timber production on land that can be economically and practically managed for such production, the following factors shall be considered: (a) The proximity of the land to urban, suburban, and rural settlements; (b) surrounding parcel size and the compatibility and intensity of adjacent and nearby land uses; (c) long-term local economic conditions that affect the ability to manage for timber production; and (d) the availability of public facilities and services conductive to conversion of forest land to other uses. 1994 State Legislature"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Washington 1996" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1506 a skos:Concept ;
    dct:creator "USA-STATE-Washington" ;
    dct:date "1996"^^xsd:gYear ;
    dct:source "http://www.gmaboards.wa.gov/eastern/ew_decisions/ew1996/96-1-0017,ellensburg,orderoncomplianceandinvalidity.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land primarily useful for growing trees, including Christmas trees subject to the excise tax imposed under RCW 84.33.100 through 84.33.140, for commercial purposes, and that has long-term commercial significance for growing trees commercially. The Growth Management Act RCW 36.70A.30(8"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Washington 1996" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1507 a skos:Concept ;
    dct:creator "USA-STATE-Washington" ;
    dct:date "2001"^^xsd:gYear ;
    dct:source "http://www.leg.wa.gov/sl/2001-02/5497-s_sl.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "“Forest land\" means all land which is capable of supporting a merchantable stand of timber and is not being actively used for a use which is incompatible with timber growing. Forest land does not include agricultural land that is or was enrolled in the conservation reserve enhancement program by contract if such agricultural land was historically used for agricultural purposes and the landowner intends to continue to use the land for agricultural purposes in the future"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Washington 2001" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1508 a skos:Concept ;
    dct:creator "USA-STATE-Washington" ;
    dct:date "2010"^^xsd:gYear ;
    dct:source "http://app.leg.wa.gov/rcw/default.aspx?cite=76.09.020"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"Forestland\" means all land which is capable of supporting a merchantable stand of timber and is not being actively used for a use which is incompatible with timber growing. Forestland does not include agricultural land that is or was enrolled in the conservation reserve enhancement program by contract if such agricultural land was historically used for agricultural purposes and the landowner intends to continue to use the land for agricultural purposes in the future. As it applies to the operation of the road maintenance and abandonment plan element of the forest practices rules on small forest landowners, the term \"forestland\" excludes: (a) Residential home sites, which may include up to five acres; and (b) Cropfields, orchards, vineyards, pastures, feedlots, fish pens, and the land on which appurtenances necessary to the production, preparation, or sale of crops, fruit, dairy products, fish, and livestock exist"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Washington 2010" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1509 a skos:Concept ;
    dct:creator "USA-STATE-Washington" ;
    dct:source "http://farm.fic.niu.edu/fic/laws/state/wa8434.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "3) \"Timber land\" means any parcel of land that is five or more acres or multiple parcels of land that are contiguous and total five or more acres which is or are devoted primarily to the growth and harvest of forest crops for commercial purposes. Wash. Rev. Code secs. 84.34.010 to - .922"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Washington" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_151 a skos:Concept ;
    dct:source "http://www.britell.com/lex.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "An extensive plant community in all stages of growth with a closed canopy, having the quality of self perpetuation and of potential development into an ecological climax"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_1510 a skos:Concept ;
    dct:creator "USA-STATE-Washington" ;
    dct:source "http://www.sanjuancounty.org/assessor/dfl.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "State Tax Assessment- Any parcel of land twenty or more acres in size or multiple parcels of land that are contiguous and total twenty acres or more in size that is primarily used for the growth and harvesting of timber"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Washington" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1511 a skos:Concept ;
    dct:creator "USA-STATE-Washington-Bainbridge Island" ;
    dct:date "2004"^^xsd:gYear ;
    dct:source "http://www.ci.bainbridge-isl.wa.us/documents/CompPlan2004_Glossary.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land used for growing trees, not including Christmas trees, for commercial purposes (as shown by record of income) that has long-term commercial significance; or unharvested forest land preserved in open space for the environmental benefits and maintenance of rural character"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Washington-Bainbridge Island 2004" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1512 a skos:Concept ;
    dct:creator "USA-STATE-Washington-San Juan County" ;
    dct:source "http://www.co.san-juan.wa.us/assessor/current.aspx"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Timber Land means any parcel of land that is five or more acres or multiple parcels of land that are contiguous and total five or more acres which is or are devoted primarily to the growth and harvest of forest crops for commercial purposes"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Washington-San Juan County" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1513 a skos:Concept ;
    dct:creator "USA-STATE-Washington-San Juan County" ;
    dct:source "http://www.co.san-juan.wa.us/assessor/default.asp?page=dfl"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land designated as ‘forest land’ means any parcel of land twenty or more acres in size or multiple parcels of land that are contiguous and total twenty acres or more in size that is primarily used for the growth and harvesting of timber. Forest land refers only to the land"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Washington-San Juan County" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1514 a skos:Concept ;
    dct:creator "USA-STATE-Washington-Stevens County" ;
    dct:source "http://www.co.stevens.wa.us/assessor/Current%20Land%20Use/PDF%20docs/continuance.PDF"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forestland means all land in contiguous ownership of 20 or more acres; which is primarily devoted to and used for growing and harvesting timber"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Washington-Stevens County" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1515 a skos:Concept ;
    dct:creator "USA-STATE-Wisconsin" ;
    dct:date "2003"^^xsd:gYear ;
    dct:source "http://www.wra.org/pdf/government/landuse/Proposal_Shoreland_Changes2003.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"Forest Land\" means any area on which trees exist, standing or fallen, alive or dead, that are primarily grown because they are valuable for forest products, watershed or wildlife protection or non-residential recreational uses in contrast to areas where shade or ornamental trees are grown primarily because they are valuable for landscape, aesthetic, agricultural or similar purposes"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Wisconsin 2003" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1516 a skos:Concept ;
    dct:creator "USA-STATE-Wyoming" ;
    dct:date "2002"^^xsd:gYear ;
    dct:source "http://www.osmre.gov/stateregs/wyregschap1.txt"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forestry means land used or managed for the long-term production of wood, wood fiber, or wood-derived products. (2002"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Wyoming 2002" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1517 a skos:Concept ;
    dct:creator "INDONESIA-Papua" ;
    dct:date "2002"^^xsd:gYear ;
    dct:source "http://74.125.93.132/search?q=cache:bwzUkrDvEFsJ:www.papuaweb.org/dlib/lap/sullivan/perdasi-perdasus/forestry.rtf+%22forest+means%22&cd=215&hl=en&ct=clnk&gl=us&client=safari"^^xsd:anyURI ;
    dct:spatial "Indonesia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest means a unit of ecosystem in the form of lands comprising biological resources, dominated by trees in their natural forms and environment, which can not be separated each other"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "INDONESIA-Papua-2002" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "State"@en .

ex:Forest_1518 a skos:Concept ;
    dct:creator "Russia Khabarovsk Krai" ;
    dct:date "1999"^^xsd:gYear ;
    dct:source "http://wenku.baidu.com/view/d74f09d349649b6648d747c8.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest is defined as the totality of forest vegetation, land, wildlife, and other components’ of the environment having important ecological, economic and social significance"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Russia Khabarovsk Krai 1999" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "State"@en .

ex:Forest_1519 a skos:Concept ;
    dct:creator "USA-STATE-California" ;
    dct:date "2002"^^xsd:gYear ;
    dct:source "http://www.climatechange.ca.gov/publications/legislation/SB_812.PDF"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "‘‘Forest’’ means lands that support, or can support,’’ at least 10 percent tree canopy cover and that allow for management of one or more forest resources including timber, fish and wildlife, biodiversity, water quality, recreation, aesthetics and other public benefits"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-California 2002" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "State"@en .

ex:Forest_152 a skos:Concept ;
    dct:source "http://www.for.nau.edu/courses/for250/Definitions/Definitions.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "An extensive wood or tract of wooded country"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_1520 a skos:Concept ;
    dct:creator "USA-STATE-California" ;
    dct:source "http://caselaw.lp.findlaw.com/cacodes/prc/4789-4789.7.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"Forest land\" means timberland defined pursuant to subdivision (g), and other lands that have been withdrawn from timber production, such as units of the state park system, national parks, and wilderness areas"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-California" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "State"@en .

ex:Forest_1521 a skos:Concept ;
    dct:creator "USA-STATE" ;
    dct:date "2003"^^xsd:gYear ;
    dct:source "http://www.legis.state.ga.us/legis/2003_04/fulltext/sb356.htm"^^xsd:anyURI ;
    dct:spatial "Georgia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "'Forest' means lands that support, or can support, at least 10 percent tree canopy cover and that allow for management of one or more forest resources including but not limited to timber, fish and wildlife, biodiversity, water quality, air quality, soil conservation, recreation, aesthetics, or other benefits"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Georgia 2003" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "State"@en .

ex:Forest_1522 a skos:Concept ;
    dct:creator "USA-STATE-Idaho" ;
    dct:date "1974"^^xsd:gYear ;
    dct:source "https://adminrules.idaho.gov/rules/current/20/0201.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Noncommercial Forest Land. Habitat types not capable of producing twenty (20) cubic feet per acre per year"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Idaho 1974" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "State"@en .

ex:Forest_1523 a skos:Concept ;
    dct:creator "USA-STATE-na" ;
    dct:date "1999"^^xsd:gYear ;
    dct:source "http://www.state.in.us/legislative/ic/1999/title6/ar1.1/ch6.html"^^xsd:anyURI ;
    dct:spatial "India" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Sec. 1. For the purpose of property taxation, forest land may be classified and assessed under this chapter if the land satisfies the conditions prescribed in this chapter for classification as native forest land or a forest plantation. (Formerly: Acts 1975, P.L.47, SEC.1.) IC 6-1.1-6-2 Sec. 2. Land may be classified as a forest plantation if it is cleared land which has growing on it a good stand of timber producing trees as that concept is understood by competent foresters. (Formerly: Acts 1975, P.L.47, SEC.1.) IC 6-1.1-6-3 Sec. 3. Land may be classified as native forest land if it has never been plowed or cultivated and contains at least forty (40) square feet of basal area per acre or at least one thousand (1,000) timber producing trees, of any size, per acre. (Formerly: Acts 1975, P.L.47, SEC.1.) IC 6-1.1-6-4 Sec. 4. For purposes of this chapter, the following types of trees are not considered timber producing trees: dogwoods (Cornus); water-beech (Carpinus); ironwood (Ostrya); red bud (Cercis); sassafras; persimmon; pawpaw; black haw; willows (Salix); pomaceous trees; and Christmas trees which are grown for commercial purposes. (Formerly: Acts 1975, P.L.47, SEC.1.). Source: Chapter 6. Assessment of Certain Forest Lands IC 6-1.1-6-1"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Indiana 1999" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "State"@en .

ex:Forest_1524 a skos:Concept ;
    dct:creator "USA-STATE-Minnesota" ;
    dct:source "http://www.revisor.leg.state.mn.us:81/SEARCH/BASIS/mnstat/public/www/DDW?W%3DTEXT+PH+IS+%27forest+means%27+ORDER+BY+SORT_KEY/Ascend%26M%3D1%26K%3D88.01%26R%3DY%26U%3D20%26PCU%3D1"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"Forest land\" means land which is at least ten percent stocked by trees of any size and capable of producing timber, or of exerting an influence on the climate or on the water regime; land from which the trees described above have been removed to less than ten percent stocking and which has not been developed for other use; and afforested areas. Source: Section: 88.01 continued"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Minnesota" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "State"@en .

ex:Forest_1525 a skos:Concept ;
    dct:creator "USA-STATE-Montana" ;
    dct:source "http://www.discoveringmontana.com/racicot/eo/21-22-23Background.htm"^^xsd:anyURI,
        "http://www.dnrc.state.mt.us/forestry/classifi.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"Forest land\" means land that has enough timber, standing or down, slash, or brush to constitute in the judgment of the department a fire menace to life or property. Grassland and agricultural areas are included when those areas are intermingled with or contiguous to and no further than one-half mile from areas of forest land. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Montana" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "State"@en .

ex:Forest_1526 a skos:Concept ;
    dct:creator "USA-STATE-Nebraska" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Nebraska accepts the definitions of forestland, forest, etc. as defined in the U.S. Forest Service's Forest Inventory and Analysis program. ghergenr@unlnotes.unl.edu"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Nebraska" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "State"@en .

ex:Forest_1527 a skos:Concept ;
    dct:creator "USA-STATE-New Hampshire" ;
    dct:source "http://www.gencourt.state.nh.us/rsa/html/XIX-A/227-G/227-G-2.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"Forestland'' means all lands in this state, except those owned and managed by the United States of America, which by reason of their location and character of soil have the capacity to grow trees and the continuance of which under forest cover is of substantial importance to the public interest"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-New Hampshire" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "State"@en .

ex:Forest_1528 a skos:Concept ;
    dct:creator "USA-STATE-New" ;
    dct:source "http://www.judiciary.state.nj.us/criminal/charges/arson2.htm"^^xsd:anyURI ;
    dct:spatial "Jersey" ;
    skos:broadMatch ex:Forest ;
    skos:definition "A \"forest\" means and includes any forest, brush land, grass land, salt marsh, wooded area and any combination thereof, including but not limited to, an open space area, public lands, wetlands, park lands, natural habitats, a State conservation area, a wildlife refuge area or any other designated undeveloped open space whether or not it is subject to specific protection under law"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-New Jersey" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "State"@en .

ex:Forest_1529 a skos:Concept ;
    dct:creator "USA-STATE-New York" ;
    dct:source "http://assembly.state.ny.us/cgi-bin/claws?law=37&art=12"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"Forest land\" includes not only lands which may be covered with tree growth but also lands which are best adapted to forests"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-New York" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "State"@en .

ex:Forest_153 a skos:Concept ;
    dct:source "http://www.christiantech.com/cgi-bin/webster.exe?search_for_cgi-bin_texts_web1828=forest"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "An extensive wood, or a large tract of land covered with trees. In America, the word is usually applied to a wood of native growth, or a tract of woodland which has never been cultivated. It differs from wood or woods chiefly in extent"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_1530 a skos:Concept ;
    dct:creator "USA-STATE-North Dakota" ;
    dct:source "http://www.legis.nd.gov/cencode/t57c57.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"Forest\" means an area of land normally supporting a growth of planted tree cover, woodlands, or windbreaks"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-North Dakota" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "State"@en .

ex:Forest_1531 a skos:Concept ;
    dct:creator "USA-STATE-Oregon" ;
    dct:source "http://www.leg.state.or.us/ors/526.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"Forestland\" means any woodland, brushland, timberland, grazing land or clearing, which, during any time of the year, contains enough forest growth, slashing or vegetation to constitute, in the opinion of the forester, a fire hazard, regardless of how the land is zoned or taxed. Source: 526.005 Definitions"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Oregon" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "State"@en .

ex:Forest_1532 a skos:Concept ;
    dct:creator "USA-STATE-Oregon-Yamhill County" ;
    dct:source "http://www.co.yamhill.or.us/assessor/bin/forest.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest land is land which either is being held or used predominantly to grow and harvest trees of a; marketable species and has been designated as forest land or is land the highest and best use of which is to grow and harvest such trees. A. Land may qualify if the designated area is at least two contiguous acres of bare land or two contiguous acres plus one homesite of improved land in one ownership. B. The land must meet one of the following stocking requirements: 1.Trees of a marketable species must be growing on the land, and there must be at least a minimum number of these trees per acre according to the rules established by the state forester. Call the state forester, extension service or your county assessor for more information. 2.If the land does not meet the requirements in (1) above, the owner must give the assessor a written management plan for establishing trees to meet the minimum stocking requirements. At least one-fifth (20 percent), but not less than two acres, of the area in the plan shall be planted by December 31 of the first assessment year that the land is designated as forest land. Each additional year thereafter, a minimum of 1/5 (20 percent) of the area shall be planted, in addition to the previous year's requirements. At the end of the fifth year after designation is approved by the assessor, 100 percent of the area in the plan must be planted. Extensions to planting requirements may be granted by the assessor if a loss of planted stock occurs due to conditions beyond the control of the land owner"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Oregon-Yamhill County" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "State"@en .

ex:Forest_1533 a skos:Concept ;
    dct:creator "USA-STATE-Pennsylvania" ;
    dct:source "http://www.dcnr.state.pa.us/forestry/sfrmp/overview.htm#sustainability"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forests are defined as ecosystems dominated by trees, but with other components such as shrubs, herbs, mammals, birds, insects, microscopic creatures, soil, air, water, and the interactive processes that bind them together"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Pennsylvania" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "State"@en .

ex:Forest_154 a skos:Concept ;
    dct:source "http://machaut.uchicago.edu/cgi-bin/WEBSTER.sh?WORD=forest"^^xsd:anyURI,
        "http://www.graylab.ac.uk/cgi-bin/omd?forest"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "An extensive wood; a large tract of land covered with trees; in the United States, a wood of native growth, or a tract of woodland which has never been cultivated. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_155 a skos:Concept ;
    dct:source "http://www.forestcouncil.org/fv/fv103/article6.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "An interconnected web that focuses on sustaining the whole, not on producing any one part or commodity. Trees are critical structural members of the forest web, and also—from the human viewpoint—the most obvious component of a forest. However, trees are only a small portion of the whole that creates a fully functioning forest. A forest also consists of animals, plants, and microorganisms, arranged in infinite diversity across scales that range from soil bacteria to the continents of Earth. We need trees to have a forest, but we also need a forest to have trees"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_156 a skos:Concept ;
    dct:source "http://www.cbnrm.net/pdf/mutanga_e_001_forestmgmt.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "An open system with naturally occurring flora and fauna species which are interrelated and depends on one another for their survival"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_157 a skos:Concept ;
    dct:source "http://www.panda.org/forests4life/whatisforest.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Any area with over 40 per cent crown cover. This works well with broadleaf or mixed coniferous and broadleaf forests but less well with purely coniferous forests, where canopy cover is often less than 40 per cent"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_158 a skos:Concept ;
