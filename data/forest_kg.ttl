    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_206 a skos:Concept ;
    dct:creator "2" ;
    dct:source "http://www.cnr.vt.edu/for3364/ecolterms.htm#F"^^xsd:anyURI,
        "http://www.fw.vt.edu/zedaker/3364/ecolterms.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Generally, an ecosystem characterized by a more or less dense and extensive tree cover. More particularly, a plant community predominately of trees and other woody vegetation, growing more or less closely together. , and Ford-Robertson 1971: 107, 298 and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "2" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_207 a skos:Concept ;
    dct:source "http://figueresonline.com/csdafinal/English/publications/cdm/glossary.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Generally, that portion of the ecosystem characterized by tree cover; more particularly, a plant community predominantly of trees and other woody vegetation growing close together"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_208 a skos:Concept ;
    dct:source "http://www.scopenvironment.org/downloadpubs/scope56/Chapter04.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
