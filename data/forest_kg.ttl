    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Virgin Island" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_75 a skos:Concept ;
    dct:creator "USA-STATE-Virginia" ;
