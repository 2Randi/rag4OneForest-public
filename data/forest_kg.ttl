ex:Concept_85 a skos:Concept ;
    dct:creator "UNFCCC" ;
    dct:date "2001"^^xsd:gYear ;
    dct:source "http://www.unfccc.int/resource/docs/cop6secpart/l11r01.pdf"^^xsd:anyURI ;
    skos:definition "\"Revegetation” is a direct human-induced activity to increase carbon stocks on sites through the establishment of vegetation that covers a minimum area of 0.05 hectares and does not meet the definitions of afforestation and reforestation contained here"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UNFCCC 2001" .

