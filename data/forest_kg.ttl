    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_21 a skos:Concept ;
    dct:source "http://ext.msstate.edu/pubs/pub1250.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "From a management standpoint, a forest is a collection of stands administered as a unit"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "General"@en .

ex:Forest_210 a skos:Concept ;
    dct:source "http://ccel.wheaton.edu/pager.cgi?file=e/easton/ebd/ebd/T0001300.html&from=T0001374&up=e/easton/ebd/ebd.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Heb. ya'ar, meaning a dense wood, from its luxuriance"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_211 a skos:Concept ;
    dct:source "http://www.botany.uwc.ac.za/envfacts/facts/deforestation.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "In a forest the crowns of individual trees touch to form a single canopy. In a woodland, trees grow far apart, so that the canopy is open"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_212 a skos:Concept ;
    dct:source "http://www.globaled.org/issues/152/a.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "In a forest, the treetops touch each other to form a canopy, Woodlands, trees are spaced further apart"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_213 a skos:Concept ;
    dct:source "http://www.wildlifetrust.org.uk/suffolk/redgrave/glossary.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "In England this means a wood with no coppiced trees, often conifer Plantations. Traditionally meant a hunting ground or 'chase' Nature Conservation Glossary"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_214 a skos:Concept ;
    dct:creator "usually, at least 10 percent of the area is covered by trees" ;
    dct:source "http://www.aces.edu/waterquality/glossary/glossary_results.php3?rowid=2008"^^xsd:anyURI,
        "http://www.rmrs.nau.edu/publications/rm_gtr_295/glossary.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "In general, an area or biotic community dominated by trees of any size . If distinction is made to woodlands, forests are composed of taller, more closely-spaced trees. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "usually, at least 10 percent of the area is covered by trees" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_215 a skos:Concept ;
    dct:source "http://www.arcticatlas.org/glossary/index"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "In the Preliminary Classification for Alaskan Vegetation, vegetation with at least a 10% crown cover by trees; i.e., single stemmed woody plants at least 5 m in height at maturity"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_216 a skos:Concept ;
    dct:source "http://www.biology-online.org/dictionary/Forest"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "In the United States, a wood of native growth, or a tract of woodland which has never been cultivated"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_217 a skos:Concept ;
    dct:creator "which, along with rainforest, form 'closed forest'" ;
    dct:source "http://www.wilderness.org.au/projects/Forests/forbkgnd.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Includes mangroves , and forest-forming mallees (which, along with schlerophyll forest, form 'open forest'"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "which, along with rainforest, form 'closed forest'" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_218 a skos:Concept ;
    dct:creator "'hard-leaved' trees, mainly forests dominated by eucalypts, but also species like acacias and melaleucas" ;
    dct:source "http://www.wilderness.org.au/projects/Forests/forbkgnd.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Includes sclerophyll forest which has a canopy cover greater than 50%, and all rainforest"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "'hard-leaved' trees, mainly forests dominated by eucalypts, but also species like acacias and melaleucas" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_22 a skos:Concept ;
    dct:source "http://www.tnw.org.uk/Note17.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Historically, a prescribed but unenclosed area of land on which the sovereign had the exclusive right to hunt and make Forest Laws. More commonly, a large wooded area"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "General"@en .

ex:Forest_220 a skos:Concept ;
    dct:source "http://library.advanced.org/17456/main1.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Interconnected communities of diverse organisms -- bacteria and fungi, gigantic trees, birds, shrubs, ants and beetles, fish, and mammals"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_221 a skos:Concept ;
    dct:creator "ou mieux la projection de leurs cimes sur le sol" ;
    skos:broadMatch ex:Forest ;
    skos:definition "La forêt est un formation végétale dans laquelle les arbres prédominent au point de modifier les conditions écologiques régnant au sol. Elle est dite dense ou fermée si les arbres sont jointifs ou occupent plus des 2/3 de la surface, claire et ouverte si les arbres couvrent de 2/3 à 1/4 de la surface. Les autres formations sont par définition exclues des forêts. l'Encyclopédia Universalis. Sandrine PETIT"@fr ;
    skos:inScheme ex:ForestScheme ;
    skos:note "ou mieux la projection de leurs cimes sur le sol" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_222 a skos:Concept ;
    dct:source "http://www.pbs.org/earthonedge/ecosystems/forests1.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land areas \"dominated by trees where the tree canopy covers at least 10% of the ground area"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_223 a skos:Concept ;
    dct:source "http://www.wvgazette.com/static/series/mining/reports/EIS/VIII.Glossary.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land bearing a stand of trees of any stature, including seedlings, and of species attaining a minimum of 6 feet average height at maturity or land from which such a stand has been removed but on which no other use has been substituted. The term is commonly limited to land not in farms; forests on farms are commonly called woodland or farm forest"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_224 a skos:Concept ;
    dct:source "http://www.uncg.edu/bio/ConBio105/info/glossary2.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land bearing forest growth"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_225 a skos:Concept ;
    dct:creator "2 500 - 3 500 m" ;
    dct:source "http://www.usangu.org/reports/landres.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land covered by a closed stand of trees of one or more storeys, with an interlaced upper canopy, rising to 7 - 40 m or more in height. The ground cover is dominated by herbs and shrubs, and lianes and epiphytes are characteristic. Dwarf forests are as defined but rise to less than 7 m in height. Sub-types are sub-alpine dwarf forest ; lowland forest (<1 000 m); and groundwater forest"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "2 500 - 3 500 m" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_226 a skos:Concept ;
    dct:source "http://ag.arizona.edu/AREC/pubs/rmg/2._Rangeland_Management_/4Terms.pdf"^^xsd:anyURI,
        "http://ag.arizona.edu/arec/pubs/rmg/2._Rangeland_Management_/4Terms.pdf"^^xsd:anyURI,
        "http://www.agroselviter.unito.it/range/docs/4Terms.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land on which the vegetation is dominated by trees. Lands shall be classified forestland if the trees now present will provide 25% or greater canopy cover at maturity. RANGELAND TERMINOLOGY and and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_227 a skos:Concept ;
    dct:source "http://dictionary.kids.net.au/word/forest"^^xsd:anyURI,
        "http://www.scrabblefinder.com/word/forest/"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land that is covered with trees and shrubs and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_228 a skos:Concept ;
    dct:source "http://src.doc.ic.ac.uk/packages/Project-Gutenberg/etext99/world97.txt"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land under dense stands of trees. Paraphrased from"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_229 a skos:Concept ;
    dct:source "http://rmmcweb.cr.usgs.gov/public/mrgb/mrgblulcdefs.html#vg4.11"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land where trees form at least 25% of the canopy cover"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_23 a skos:Concept ;
    dct:source "http://en.wikipedia.org/wiki/Forest"^^xsd:anyURI,
        "http://explanation-guide.info/meaning/Forest.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Historically, an area set aside for hunting. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "General"@en .

ex:Forest_230 a skos:Concept ;
    dct:creator "or equivalent stocking level" ;
    dct:source "http://www.cei-bois.org/files/FINAL_-_BoA_-_EN_-_2011_text_and_cover.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land with tree crown cover of more than 10% and area of more than 0.5 ha. The trees should be able to reach a minimum height of at least 5m at maturity in situ"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "or equivalent stocking level" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_231 a skos:Concept ;
    dct:creator "stand density" ;
    dct:source "http://books.google.com/books?id=zeTU8QauENcC&pg=PA192&lpg=PA192&dq=Germany+Forest+definition+define+%22forest+is%22+law+act+code&source=bl&ots=1jUsKaLHy4&sig=uRBHD83hyloLheFqPmfiDgK687o&hl=en&sa=X&ei=OcY-T7PEOcX10gHzx8jzBw&ved=0CDgQ6AEwAw#v=onepage&q=Germany%20Forest%20definition%20define%20%22forest%20is%22%20law%20act%20code&f=false"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land with tree crown cover of more than about 20% of the area. Continuous forest with trees usually growing to more than 7 m in height and able to produce wood. This includes both closed forest formations where trees of various layers and undergrowth cover a high proportion of the ground and open forest formation with a continuous grass layer in which tree synusia cover at least 10 % of the ground.(1993"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "stand density" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
