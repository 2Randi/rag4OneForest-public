ex:Forest_100 a skos:Concept ;
    dct:source "http://www.mpl.ird.fr/crea/taller-colombia/FAO/AGLL/pdfdocs/landglos.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
