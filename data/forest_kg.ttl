    skos:broadMatch ex:Deforestation ;
    skos:definition "The process of clearing forests"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_142 a skos:Concept ;
    dct:source "http://www.europe.apnet.com/inscight/12031996/defores1.htm"^^xsd:anyURI,
        "http://www.harcourt.com/dictionary/def/2/8/3/7/2837200.html"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The process of clearing land of trees or forest. or"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_143 a skos:Concept ;
    dct:source "http://www.worldbank.org/html/schools/glossary.htm#d"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The process of clearing of forests"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_144 a skos:Concept ;
    dct:creator "s" ;
    dct:source "http://www.sandiegozoo.org/wildideas/glossary_c-d.html"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The process of destroying forest habitat"@en ;
