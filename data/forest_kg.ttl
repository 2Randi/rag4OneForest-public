    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_1000 a skos:Concept ;
    dct:date "2006"^^xsd:gYear ;
    dct:source "http://www.communities.gov.uk/documents/planningandbuilding/pdf/144275.pdf"^^xsd:anyURI ;
    dct:spatial "United Kingdom" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Woodland is defined as an area of trees, where a tree is a woody species capable of achieving >5m in height and 25% canopy cover under favourable growing conditions"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "United Kingdom 2006" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_1002 a skos:Concept ;
    dct:date "2009"^^xsd:gYear ;
    dct:source "http://www.efi.int/files/attachments/publications/annex_1_to_efi_technical_report_88__2013.pdf"^^xsd:anyURI ;
    dct:spatial "United Kingdom" ;
    skos:broadMatch ex:Forest ;
    skos:definition "For the National Forest Inventory (2009-2014), the definition of forest or woodland as an area of tree covered land greater than 0.5ha (about 1.25 acres) and at least 20 m wide whose “canopy cover” or “canopy closure” extends to 20% or more of the land area (or the potential to achieve this).In other words, if the site were viewed from the air, 20% or more of the ground would be obscured by the trees' foliage when the trees are mature. This definition of woodland is in keeping with other internationally accepted definitions of woodland. The current National Inventory is being carried out between 2009 and 2014. FC, 2010"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "United Kingdom 2009" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_1003 a skos:Concept ;
    dct:date "2010"^^xsd:gYear ;
    dct:source "http://www.efi.int/files/attachments/publications/annex_1_to_efi_technical_report_88__2013.pdf"^^xsd:anyURI ;
    dct:spatial "United Kingdom" ;
    skos:broadMatch ex:Forest ;
    skos:definition "For the National Inventory of Woodland, forest is defined as areas with a canopy cover of 20% or more (or the potential to achieve this) and over 50 m in width. The NIWT woodland map aimed to include all areas satisfying this definition and with a minimum area of 2.0 ha or over. Woodland area from 0.1 ha to 2.0 ha was derived from the Survey of Small Woods and Trees"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "United Kingdom 2010" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_1004 a skos:Concept ;
    dct:source "http://jncc.defra.gov.uk/page-2433#1858"^^xsd:anyURI ;
    dct:spatial "United Kingdom" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Woodland) vegetation dominated by trees that are more than 5 m high when mature, which form a distinct, although sometimes open canopy which has a cover of greater than 20%"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "United Kingdom" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_1005 a skos:Concept ;
    dct:source "http://www.forestresearch.gov.uk/fr/INFD-5V8E8R"^^xsd:anyURI ;
    dct:spatial "United Kingdom" ;
    skos:broadMatch ex:Forest ;
    skos:definition "A large area dominated by trees, both conifers and broad-leaved, either planted or natural. Usually taken to include a complex landscape comprising of woodland, open space, water and settlements"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "United Kingdom" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_1006 a skos:Concept ;
    dct:date "1988"^^xsd:gYear ;
    dct:spatial "Uruguay" ;
    skos:broadMatch ex:Forest ;
    skos:definition "A los efectos de la aplicación de esa Ley, se consideran bosques las asociaciones vegetales que tengan ciertas características y que ocupen una superficie mínima de 2 500 m&sup2;. Además, se designan como terrenos forestales ciertas zonas o grupos de suelos (costas arenosas, orillas de ríos, etc.) y se habilita al departamento competente para designar otras por razones de conveniencia pública y teniendo en cuenta la aptitud forestal de los suelos. Por otra parte, el presente Decreto establece los requisitos y los criterios según los cuales los \"bosques particulares\" pueden calificarse como protectores o productores. Cuando sus características no permitan incluirlos en la calificación indicada se considerarán \"bosques generales\". Asimismo se declara obligatoria la plantación de ciertos terrenos forestales que ocupen una superficie mínima de 10 hectáreas. Por último se dictan varias disposiciones cuyo objeto es la conservación de los recursos forestales y, en particular, la prohibición de las cortas que sean perjudiciales para los bosques protectores. LEX-FAOC003578. URUGUAY: Decreto 452/988 por el que se dictan normas reglamentarias para considerar bosques aquellas asociaciones vegetales de determinadas características. Date of text: 06 July 1988"@es ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Uruguay 1988" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_1007 a skos:Concept ;
    dct:date "2003"^^xsd:gYear ;
    dct:source "http://www.fs.fed.us/research/sustain/2003SustainabilityReport/documents/SustainableForests.pdf"^^xsd:anyURI ;
    dct:spatial "Uruguay" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Minimum area = 0.25 ha"@pt ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Uruguay 2003" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_1008 a skos:Concept ;
    dct:creator "USA" ;
    dct:date "2003"^^xsd:gYear ;
    dct:source "http://www.fs.fed.us/research/sustain/2003SustainabilityReport/documents/SustainableForests.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
