@prefix agv: <http://aims.fao.org/aos/agrovoc/> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix ex: <http://example.org/forest-def/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:ASubcategoryOfForestLand_1 a skos:Concept ;
    dct:date "1997"^^xsd:gYear ;
    dct:spatial "France" ;
    skos:broadMatch ex:Woodland ;
    skos:definition "where the main function is not production. They consist of unmanaged forests: in accessible forest or forest land located on too steep slopes, protective forests (where cuttings are forbidden) and recreation forests, green spaces, no-admittance areas (military grounds for example). (European Communities 1997a - p. 255"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "France 1997" ;
    skos:prefLabel "A subcategory of forest land"@en .

ex:AfforestationForestationArabic_1 a skos:Concept ;
    dct:spatial "Morocco" ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "Afforestation / Forestation (Arabic : Tashjeer, French : Boisement/Reboisement) - Artificial creation (by man) of a forest on an land which has never been forested before, as far as man’s memory can remember, using seedlings, vegetative materials or seeds(sowing) Mohammed Ellatifi, m.ellatifi@ellatifi.8m.com"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Morocco" ;
    skos:prefLabel "Afforestation Forestation Arabic"@en .

ex:AfforestationReboisementOuRepeuplement_1 a skos:Concept ;
    dct:spatial "France" ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "afforestation = reboisement ou repeuplement : plantation de jeunes arbres ou semis de graines d'arbres \"Michel Godron\" <michel.godron@libertysurf.fr"@fr ;
    skos:inScheme ex:ForestScheme ;
    skos:note "France" ;
    skos:prefLabel "afforestation reboisement ou repeuplement"@fr .

ex:Afforestation_1 a skos:Concept ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "Afforestation - may be a legal term or a process of stocking land. In the case of the latter, we group the definitions into those that imply a change in land cover only and those that imply a change in land cover and use. Four definitions specify \"crops\" implying that the trees will be later removed for commercial purposes. The time period for lands \"never having been forested\" vary from never to 30 to 100 years"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_10 a skos:Concept ;
    dct:creator "BC" ;
    dct:source "http://www.for.gov.bc.ca/pab/publctns/westland/gloss.htm"^^xsd:anyURI ;
    dct:spatial "Canada" ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "The process of converting open land into forest"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Canada - BC" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_101 a skos:Concept ;
    dct:creator "e.g. agricultural or other land" ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "Artificial establishment by planting or seeding of forest on a non-forest area . [Source: UN/ECE 1990, via Brita Pajari]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "e.g. agricultural or other land" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_102 a skos:Concept ;
    dct:source "http://dnr.state.il.us/legal/1537.htm"^^xsd:anyURI,
        "http://epdweb.engr.wisc.edu/dmc/courses/hazards/BB02-apx1.html"^^xsd:anyURI ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "Establishment of a tree crop in an area where trees have always or long been absent. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_103 a skos:Concept ;
    dct:source "http://solstice.crest.org/social/SJ-glossary/A.html#"^^xsd:anyURI ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "Forest crops established by purposeful planting on land previously not used for tree crops"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_104 a skos:Concept ;
    dct:source "http://www.state.nv.us/cnr/ndwp/dict-1/WORD_A.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "The artificial establishment of forest crops by planting or sowing on land that has not previously, or recently, grown trees"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_105 a skos:Concept ;
    dct:creator "Helms" ;
    dct:date "1998"^^xsd:gYear ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "The establishment of a forest or stand in an area where the preceding vegetation or land use was not forest"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Helms 1998" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_106 a skos:Concept ;
    dct:creator "e.g., the moorlands of Great Britain" ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "The establishment of a forest or stand of trees by sowing, planting, or natural regeneration on an area not previously forested, or in areas where forests were cleared long ago and other land-use patterns have dominated the landscape for many generations (Dunster and Dunster 1996"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "e.g., the moorlands of Great Britain" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_107 a skos:Concept ;
    dct:source "http://www.shsu.edu/~chemistry/Glossary/a.html#A"^^xsd:anyURI ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "The process or act of changing land into forest by planting trees, seeding, etc. on land formerly used for something other than forestry. This can obviously be contrasted with deforestation. [American Forestry; v100; 23-25; 1994.] [New Scientist; v143; 30-35; 1994.]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_108 a skos:Concept ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "To produce a forest product \"crop\" on lands that previously have not supported forests for more than 50 years. IPPC Guidelines"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_11 a skos:Concept ;
    dct:source "http://carbon.cfs.nrcan.gc.ca/definitions_e.html"^^xsd:anyURI ;
    dct:spatial "Canada" ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "The conversion of land that has not been forested for at least 50 years to forested land through human activities such as planting and seeding"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Canada" ;
    skos:prefLabel "Afforestation"@en .

ex:Afforestation_12 a skos:Concept ;
    dct:spatial "Colombia" ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "Areas de Aptitud Forestal: \"se definen como aquellas que originalmente tuvieron bosques o deberían tenerlo de acuerdo a criterios eco-biológicos y socio-económicos\" ( Ministerio del medio Ambiente. Doc. Compes 2834. Politica de Bosques\"). \"Gerardo Lozano\" <glozano@impsat.net.co"@es ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Colombia" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_13 a skos:Concept ;
    dct:creator "Cote d’Ivoire" ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "Sont considérés comme reboisement, les terrains plantés de main d'homme en espèces ne donnant pas de produits agricoles, ainsi que les forêts naturelles enrichies artificiellement en essence de bois d'oeuvre par des travaux de plantation ou be silviculture. TITRE I DEFINITIONS, Article 1. - LOI NO 65/425 DU 20 DEC 1965. portant Code Forestier"@fr ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Cote d’Ivoire" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_14 a skos:Concept ;
    dct:spatial "Cuba" ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "Forestación: la acción de poblar con especies arbóreas terrenos donde nunca hubo bosques, naturales o artificiales, o donde hace mucho desaparecieron. Christoph Kleinn <ckleinn@catie.ac.cr"@es ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Cuba" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_15 a skos:Concept ;
    dct:spatial "Cyprus" ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "Afforestation: the establishment of a forest or stand in an area where the preceding vegetation or land use was not forest. A.K. Christou \"Forestry Department - Research and Publicity Sector\" publicity@cytanet.com.cy"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Cyprus" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_16 a skos:Concept ;
    dct:creator "Czech Republic" ;
    dct:date "1995"^^xsd:gYear ;
    dct:source "http://www.uhul.cz/images/ke_stazeni/legislativa_jazyky/Lesni_zakon_en.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "Afforestation shall mean the establishment of forest stand"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Czech Republic1995" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_17 a skos:Concept ;
    dct:creator "EC" ;
    dct:source "http://ec.europa.eu/agriculture/publi/enlarge/gloss_en.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "Measures to encourage new woodland development, including financial incentives for farmers who convert agricultural land to woodland and forest"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "EC" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_19 a skos:Concept ;
    dct:spatial "Fiji" ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "Newly planted trees where no trees existed before. Malakai Sevudredre, Conservator of Forests, F.9641/2. 01/06/2000"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Fiji" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_2 a skos:Concept ;
    dct:source "http://orb.rhodes.edu/Medieval_Terms.html"^^xsd:anyURI ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "AFFOREST: To make into a forest by application of forest law"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_20 a skos:Concept ;
    dct:spatial "Ghana" ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "An act to plant areas of land with trees to attain forest status. Example is woodlot establishment. (Osei Kofi, Forestry Dept.- Letter 7 May 99"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Ghana" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_21 a skos:Concept ;
    dct:creator "GM/UNCCD" ;
    dct:date "2008"^^xsd:gYear ;
    dct:source "http://www.global-mechanism.org/dynamic/documents/document_file/final2-viet-nam-climate-change-report---1july08.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "The process of establishing and growing forests on bare or cultivated land, which has not been forested in recent history"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "GM/UNCCD 2008" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_22 a skos:Concept ;
    dct:spatial "Hungary" ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "The activity aimed at reproducing the felled or dead growing stock of the forest. The afforestation may be performed: a) by natural means aa) from the seed of the wood being felled dropping onto the soil (natural afforestation from seed origin), and ab) from the shoots sprouting from the root or stump of the felled wood (natural afforestation from shoot origin), ac) by select-cutting ensuring the creation and continuous maintenance of a mixed-age growing stock; b) artificially, in the course of which at the location of the felled or dead and removed wood a new growing stock is generated by seed sowing, sapling or shoot planting (Act No LIV of 1996 on Forests and the Protection of Forests. Section V &sect; 41"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Hungary" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_23 a skos:Concept ;
    dct:spatial "India" ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "Bringing any land under forest cover, which was not previously under forest cover. [Source: Glossary of Technical Terms, Forest Research Institute, India. From: \"Vivek K. Varma\" <v.varma@landfood.unimelb.edu.au Date: Fri, 17 Jul 1998 02:28:29 -0400 (EDT)]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "India" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_24 a skos:Concept ;
    dct:date "2002"^^xsd:gYear ;
    dct:source "http://www.globalforestwatch.org/common/indonesia/sof.indonesia.english.low.pdf"^^xsd:anyURI ;
    dct:spatial "Indonesia" ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "The establishment by human action of forest cover on land that was not previously forested or was not forested within living memory"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Indonesia - 2002" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_27 a skos:Concept ;
    dct:spatial "Isle of Man" ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "\"Afforestation\" is also not generally defined, but is normally taken as meaning new planting of previously bare land. \"IOM Gov DAFF\" <daff@gov.im"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Isle of Man" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_28 a skos:Concept ;
    dct:spatial "Kyrgyzstan" ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "The creation and growing of artificial forest plantations on the territories formerly not covered with the forest. Source: Irina Yunusova irina@lesic.elcat.kg"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Kyrgyzstan" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_29 a skos:Concept ;
    dct:spatial "Latvia" ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "A complex of measures to afforest such land (area) not covered by forest where forest has not grown before. Source: \"Maksym Polyakov\" mpoliak@pcomp.nauu.kiev.ua"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Latvia" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_3 a skos:Concept ;
    dct:creator "v" ;
    dct:source "http://info.sjc.ox.ac.uk/forests/glossary.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "Place an area under forest law and administration; the creation of a forest by stipulated procedures (M, 26 – 30 (r)); (2"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "v" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_30 a skos:Concept ;
    dct:spatial "Lithuania" ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "Establishment of trees on a non-forest land. Source: A. Kuliesis, Director of Lithuanain Forest Inventory and Management Institute Email: Sekrtetore sek@mp.is.lt"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Lithuania" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_31 a skos:Concept ;
    dct:spatial "Malaysia" ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "The artificial establishment of forests by direct seeding or planting seedlings or cuttings on lands which previously (within the living memory or within 50 years) and did not carry any forests. From: hcthang@forestry.gov.my (Thang Hooi Chiew), Forestry Department Peninsular Malaysia"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Malaysia" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_32 a skos:Concept ;
    dct:spatial "Northern Mariana Islands" ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "The science and art of diversifying existing forestland with other suitable species for any generalized purpose beneficial to mankind, wildlife and ecosystem. Source: Estanislao Villagomez stanvill@gtepacifica.net Division of Agriculture"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Northern Mariana Islands" ;
    skos:prefLabel "Afforestation"@en .

ex:Afforestation_33 a skos:Concept ;
    dct:creator "1" ;
    dct:spatial "Pakistan" ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "To establish a forest on an area from which forest vegetation has always or long been absent. Definition adopted from the British Commonwealth Forest Terminology Part-I, 1953. Source: Mumtaz Ahmad, Section Forest Officer, Pakistan Min. of Environment, Local Government, and Rural Development"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Pakistan 1" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_34 a skos:Concept ;
    dct:creator "2" ;
    dct:spatial "Pakistan" ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "To establish a species or frees on an area in which it did not occur naturally. Definition adopted from the British Commonwealth Forest Terminology Part-I, 1953. Source: Mumtaz Ahmad, Section Forest Officer, Pakistan Min. of Environment, Local Government, and Rural Development"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Pakistan 2" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_35 a skos:Concept ;
    dct:creator "Papua New" ;
    dct:spatial "Guinea" ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "The replanting of trees in areas that did not support trees previously in living memory. Such areas include grasslands and savanna that are common in the Highlands and in the western side of the main island of New Guinea. Vitus Ambia, Papua New Guinea Forest Authority"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Papua New Guinea" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_36 a skos:Concept ;
    dct:spatial "Paraguay" ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "Forestación: La acción de establecer bosques, con especies nativas o exóticas en terrenos que carezcan de ellas o donde son insuficientes. Ley N&deg; 536 - DE FOMENTO A LA FORESTACION Y REFORESTACION. Capítulo I. Artículo 2do. cdcdpnvs@venus.pla.net.py (Nombre Apellido"@es ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Paraguay" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_37 a skos:Concept ;
    dct:spatial "Oman" ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "The act of installation, through artificial methods, of the forest vegetation on lands where forest was never present or it was removed for a long time. Sorin Sfirlogea <sorinsf@rosilva.ro National Forests Administration"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Romania" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_38 a skos:Concept ;
    dct:creator "Taiwan, ROC" ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "To forest in Nonforested land (grass lands or bare soil). Source: \"&ordf;L&deg;È&sect;&frac12;service\" <service@dns.forest.gov.tw"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Taiwan, ROC" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_39 a skos:Concept ;
    dct:spatial "United Kingdom" ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "The new planting of bare lands with trees, usually of a substantial area. (Forestry Commission 1998"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "United Kingdom" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_4 a skos:Concept ;
    dct:creator "historically" ;
    dct:source "http://www.hants.org.uk/newforest/bibliog.html"^^xsd:anyURI ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "To bring land within Forest Law or in current parlance to bring within the control of the Verderers and their Bye-Laws. It is a legal act"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "historically" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_40 a skos:Concept ;
    dct:spatial "Ukraine" ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "Creation of forest plantation on the lands which previously were not covered by forest. Note that ``forest plantations'' defined as ``forest stands created by planting of seedlings, saplings of trees or shrubs or by sowing of their seeds'', i.e. it here this means only origination of stands, not intensity of management. . [Source: State Standard of Ukraine, DSTU 2980-95 ``Forest plantations. Terms and definitions'', being in force since 01.01.96. From: \"Maksym Polyakov\" mpoliak@pcomp.usau.kiev.ua Date: Sat, 28 Mar 1998 21:09:08 +0200 (UKR)] (Czech Republic"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Ukraine" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_41 a skos:Concept ;
    dct:creator "UNDP" ;
    dct:date "1999"^^xsd:gYear ;
    dct:source "http://www.un.org.vn/undp/projects/profor/pdffiles/trexler.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "Generally refers to planting of trees on ground where trees have never existed or were last present hundreds of years ago. Afforestation carbon offset projects bear an additional burden of showing ecological compatibility"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UNDP 1999" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_42 a skos:Concept ;
    dct:creator "UN-DP" ;
    dct:date "1999"^^xsd:gYear ;
    dct:source "http://www.profor.info/pdf/InnovatForesFinanc.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "Generally refers to planting of trees on ground where trees have never existed or were last present hundreds of years ago. Afforestation carbon offset projects bear an additional burden of showing ecological compatibility"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-DP 1999" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_46 a skos:Concept ;
    dct:creator "USA – STATE -Maryland" ;
    dct:source "http://pilot.wash.lib.md.us/washco/forestcn.html"^^xsd:anyURI ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "The establishment of a forest, according to the definitions and procedures contained herein, on an area which is not presently in forest cover"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA – STATE -Maryland" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_48 a skos:Concept ;
    dct:creator "Venezuela" ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "AFORESTACION: plantación de árboles en tierras que antes no tuvieron bosques, por ejemplo, en sabanas, praderas y llanos naturales. Reglamento de la Ley Forestal de Suelos y Aguas (1977). Areas Naturales Protegidas de Venezuela. Series Aspectos Conceptuales y Metodológicos, DGSPOA/ACM/01, feb 1992. Via Profauna@marnr.gov.ve"@es ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Venezuela" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_49 a skos:Concept ;
    dct:creator "WAF" ;
    dct:date "2004"^^xsd:gYear ;
    dct:source "http://www.worldagroforestry.org/sea/Publications/files/book/BK0073-04.PDF"^^xsd:anyURI ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "The establishment of forest on land that has been without forest for a period of time and was previously under a different land-use"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "WAF 2004" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_5 a skos:Concept ;
    dct:creator "and" ;
    dct:spatial "Australia" ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "The establishment of a species of forest on an area where it does not occur naturally (British Commonwealth Terminology) (Ford-Robertson 1971"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Australia and New Zealand" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_51 a skos:Concept ;
    dct:source "http://www.deltaenviro.org.za/resources/envirofacts/afforestation.html"^^xsd:anyURI ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "Afforestation is the planting of trees for commercial purposes, usually on land supporting non-forest veld types, e.g. grassland or fynbos"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_52 a skos:Concept ;
    dct:creator "stocking" ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "An establishment system that consists in seeding or planting forest trees in order to create a new forest ecosystem. Lorenzo Ciccarese ciccarese@anpa.it"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "stocking" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_53 a skos:Concept ;
    dct:source "http://www.grida.no/climate/ipcc/tectran/362.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "Artificial establishment of forest stands on lands that previously have not supported forests for more than 50 years"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_54 a skos:Concept ;
    dct:source "http://www.bugwood.caes.uga.edu/glossary/"^^xsd:anyURI ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "Conversion of bare land into forest land by planting of forest trees"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_55 a skos:Concept ;
    dct:source "http://www.lehigh.edu/~kaf3/books/reporting/glossary.html"^^xsd:anyURI ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "Conversion of bare or cultivated land into forest"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_56 a skos:Concept ;
    dct:source "http://www.gcrio.org/OnLnDoc/senate_epw990603.html"^^xsd:anyURI ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "Conversion of non-forest to forest on lands that have, historically, not contained forests and did not in 1990"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_57 a skos:Concept ;
    dct:creator "the Forest Act" ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "Creation of forest plantation on the lands which previously were not covered by forest. The establishment of forest stand. [Source: Act on Forests and Amendments to Some Acts dated 3 November 1995. Ministry of Agriculture of the Czech Republic. Prague, 1996. 58 pp. From: \"Maksym Polyakov\" <mpoliak@pcomp.usau.kiev.ua Date: Mon, 15 Jun 1998 11:32:47 +0300 (MSD)]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "the Forest Act" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_58 a skos:Concept ;
    dct:creator "Hibberd a" ;
    dct:date "1991"^^xsd:gYear ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "Creation of new forest by planting\" . Lorenzo Ciccarese ciccarese@anpa.it"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Hibberd 1991a" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_59 a skos:Concept ;
    dct:source "http://www.plant-a-tree-today.org/webcontrol/ShowPicture.asp?Status=ShowLibraryPDF&LiId=40"^^xsd:anyURI ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "Direct human-induced conversion of non-forested land to forested land. In the context of the Kyoto Protocol to the UNFCCC, afforestation can take place on land not covered by forest for a period of at least 50 years"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_6 a skos:Concept ;
    dct:creator "Bolivia" ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "AFORESTACION: Siembra de árboles en tierras que nunca antes tuvieron bosques, por ejemplo, en sabanas, praderas y llanos naturales. Source: Luis Castello faopaf@caoba.entelnet.bo Adjunto sírvase encontrar la versión no oficial y premilinar del Glosario Forestal elaborado por el Proyecto de Apoyo a la Coordinación e Implementación del Plan de Acción Forestal para Bolivia"@es ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Bolivia" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_60 a skos:Concept ;
    dct:creator "L, 236" ;
    dct:source "http://info.sjc.ox.ac.uk/forests/glossary.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "Establish a tree crop on an area which has not carried wood for some time"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "L, 236" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_61 a skos:Concept ;
    dct:creator "EDT" ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "Establishing new forests on lands which have not contained forests before. [From: \"Igor Yakovlev\" yakovlev@mari-el.ru Date: Wed, 10 Jun 1998 02:51:19 -0400 ]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "EDT" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_62 a skos:Concept ;
    dct:creator "Schlamadinger" ;
    dct:date "1998"^^xsd:gYear ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "Establishing new forests on lands which, historically, have not contained forests"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Schlamadinger 1998" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_64 a skos:Concept ;
    dct:source "http://epdweb.engr.wisc.edu/dmc/courses/hazards/BB02-apx1.html"^^xsd:anyURI ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "Forestation -- the establishment of a forest, either natural or human-made, on an area that previously have had none"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_65 a skos:Concept ;
    dct:source "http://www.undp.org/seed/forest/pdf/InnovatForesFinanc.pdf"^^xsd:anyURI,
        "http://www.usask.ca/agriculture/caedac/dbases/glossary.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "Generally refers to the planting of trees on ground where trees have never existed or were last present hundreds of years ago. Afforestation carbon offset projects bear an additional burden of showing ecological compatibility. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_66 a skos:Concept ;
    dct:source "http://www.forestry.gov.uk/forestry/hcou-4ubj75"^^xsd:anyURI ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "Growing or planting of new woods or forests"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_67 a skos:Concept ;
    dct:source "http://greenplanet.eolss.net/EolssLogn/mss/C09/E4-27/E4-27-08/E4-27-08-04/E4-27-08-04-TXT.aspx#Glossary_"^^xsd:anyURI ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "Human-induced conversion of land to forest, where the land has not been forested for a period of at least fifty years"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_68 a skos:Concept ;
    dct:source "http://www.eia.doe.gov/oiaf/1605/vr95rpt/gloss.html"^^xsd:anyURI,
        "http://www.epa.gov/globalwarming/publications/outreach/general/glossary.pdf"^^xsd:anyURI,
        "http://www.theadvisorygroup.com/PDF2/publications/Carbon%20Sequestration%20Paper.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "Planting of new forests on lands that have not been recently forested. and and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_7 a skos:Concept ;
    dct:spatial "Bulgaria" ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "The creation of new forests includes the activities connected with the collection of seeds, production of seedlings and saplings, afforestation, selective cuttings, inventory of the young forests and preventing of the erosion. Areas for afforestation in the forest lands are: bare lands, non-regenerated cutting areas and burnt out lands. The afforestation in the forest lands aims: 1. Regeneration and helping the regeneration in mature high-stemmed or coppice forests; 2. Replenishment of interrupted plantations and stands; 3. Improving of the composition and the state of the stands; 4. Creation of forests on the place of bare areas, burnt out lands and withered plantations and stands; 5. Preserving from erosion, fires, snow accumulation, floods, snow-slips and land-slips; 6. Creation of intensive plantations with fast growing species for wood and bio-mass production; 7. Creation of industrial plantations for production of Christmas trees, timber assortments and other rough materials; 8. Creation of forest fruit plantations; 9. Creation of seed yielding and experimental plantations; 10. Creation of recreation forests and ornamental planting; 11. Re-cultivation of devastated terrain. Forest Research Institute forestin@bulnet.bg"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Bulgaria" ;
    skos:prefLabel "Afforestation"@en .

ex:Afforestation_70 a skos:Concept ;
    dct:source "http://www.sfrc.ufl.edu/Extension/ssfor11.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "Planting or seeding trees in an area previously devoid of trees, for example, pastures and agricultural fields"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_71 a skos:Concept ;
    dct:source "http://www.rona.unep.org/action/ap1.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "Planting trees where there were none before"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_72 a skos:Concept ;
    dct:source "http://fiesta.bren.ucsb.edu/~idgec/publications/reports/forest.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "Process of establishing forests on previously non-forested lands"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_73 a skos:Concept ;
    dct:source "http://www.graylab.ac.uk/cgi-bin/omd?afforestation"^^xsd:anyURI ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "The act of converting into forest or woodland"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_74 a skos:Concept ;
    dct:source "http://www.christiantech.com/cgi-bin/webster.exe?search_for_cgi-bin/texts/web1828=afforestation"^^xsd:anyURI ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "The act of turning ground into forest or wood land"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_75 a skos:Concept ;
    dct:source "http://harp.gsfc.nasa.gov/v0ims/glossary.of.terms.html"^^xsd:anyURI,
        "http://www.windows.umich.edu/glossary/glossary_afforestation.html"^^xsd:anyURI ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "The act or process of establishing a forest especially on land not previously forested. [Source: WWWebster Dictionary and EPO. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_76 a skos:Concept ;
    dct:source "http://www.doc.mmu.ac.uk/aric/diction.html"^^xsd:anyURI ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "The conversion of non-forested areas to forest by tree planting"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_77 a skos:Concept ;
    dct:creator "diameter at breast height" ;
    dct:source "http://www.ci.rockville.md.us/cityprojects/envguide/eggloss.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "The creation on a tract that is not presently in forest cover, of a biological community dominated by trees and other woody plants, at a density of at least 100 trees per acre with at least 50 percent of the trees having the capability of growing to a diameter, at 4.5 feet above the ground , of 2 inches or more within seven years"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "diameter at breast height" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_78 a skos:Concept ;
    dct:source "http://europa.eu.int/comm/development/forests/en/en4_6.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "The establishment of a more or less contiguous tree cover, normally by planting, in areas which have previously been without trees"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_79 a skos:Concept ;
    dct:source "http://www.dnr.state.md.us/criticalarea/glossary.html"^^xsd:anyURI ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "The establishment of a tree crop on an area from which it has always or very long been absent"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_8 a skos:Concept ;
    dct:creator "Cape Verde" ;
    dct:source "http://www.indexmundi.com/cape_verde/environment_current_issues.html"^^xsd:anyURI ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "converting a bare or agricultural space by planting trees and plants; reforestation involves replanting trees on areas that have been cut or destroyed by fire"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Cape Verde" ;
    skos:prefLabel "Afforestation"@en .

ex:Afforestation_80 a skos:Concept ;
    dct:source "http://biology.usgs.gov/s+t/SNT/noframe/zy198.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "The establishment of forest by natural succession or by the planting of trees on land where they did not grow formerly"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_81 a skos:Concept ;
    dct:creator "Source: Mintzer," ;
    dct:date "1992"^^xsd:gYear ;
    dct:source "http://www.globalchange.org/glossall/glossa-c.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "The establishment of forest cover on land not previously forested. Afforestation may be necessary to increase the net capacity of Earth's forests to absorb CO2 and other greenhouse gases"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Source: Mintzer, 1992" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_82 a skos:Concept ;
    dct:creator "Prüller" ;
    dct:date "1998"^^xsd:gYear ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "The establishment of forest on a previously non-forested site"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Prüller 1998" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_83 a skos:Concept ;
    dct:source "http://www.forestry.sa.gov.au/pdf/glossary.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "The planting of a crop or plantation of trees on land not currently covered with forest"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_84 a skos:Concept ;
    dct:source "http://www.bugwood.caes.uga.edu/glossary/"^^xsd:anyURI ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "The planting of a forest crop on land that has not previously, or not recently, carried a forest crop"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_85 a skos:Concept ;
    dct:source "http://www.dnr.state.md.us/criticalarea/glossary.html"^^xsd:anyURI ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "The planting of open areas which are not presently in forest cover"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_86 a skos:Concept ;
    dct:source "http://www.deltaenviro.org.za/resources/envirofacts/afforestation.html"^^xsd:anyURI ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "The planting of trees for commercial purposes, usually on land supporting non-forest veld types, e.g. grassland or fynbos. Source"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_87 a skos:Concept ;
    dct:source "http://www.wrm.org.uy/actors/WB/1991policy3.html"^^xsd:anyURI ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "The planting of trees in unforested areas"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_88 a skos:Concept ;
    dct:source "http://www.climateservices.com/glossary.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "The planting of trees on ground where trees have never existed or were last present hundreds of years ago. Afforestation carbon offset projects bear an additional burden of showing ecological compatibility"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_89 a skos:Concept ;
    dct:source "http://www.harcourt.com/dictionary/def/2/6/7/5/267500.html"^^xsd:anyURI ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "The process of converting bare or cultivated land into forest, by planting seeds or transplanting seedlings or mature trees"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_9 a skos:Concept ;
    dct:creator "BC" ;
    dct:source "http://www.cinar.gr/delfi"^^xsd:anyURI,
        "http://www.for.gov.bc.ca/pab/publctns/glossary/glossary.htm"^^xsd:anyURI ;
    dct:spatial "Canada" ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "The establishment of trees on an area that has lacked forest cover for a very long time or has never been forested. [Source: Glossary of Forestry Terms, Province of British Columbia, Ministry of Forests, via Igor A. Yakovlev] and The DELFI Vocabulary of Forest Fire Terms"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Canada - BC" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_90 a skos:Concept ;
    dct:creator "open land" ;
    dct:source "http://www.geocities.com/RainForest/Andes/7292/Terms.html"^^xsd:anyURI ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "To convert into a forest by planting trees"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "open land" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_91 a skos:Concept ;
    dct:creator "open land" ;
    dct:source "http://www.allwords.com/query.asp#AHD"^^xsd:anyURI ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "To convert into a forest by planting trees or their seeds"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "open land" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_92 a skos:Concept ;
    dct:creator "Hibberd b" ;
    dct:date "1991"^^xsd:gYear ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "Upland afforestation - A sudden and fundamental change of vegetation from moorland and bog to woodland\""@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Hibberd 1991b" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_93 a skos:Concept ;
    dct:creator "Setiadi" ;
    dct:date "1996"^^xsd:gYear ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "When revegetation is established outside the forest areas . Lorenzo Ciccarese ciccarese@anpa.it"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Setiadi 1996" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_94 a skos:Concept ;
    dct:source "http://nrcan.gc.ca/cfs/proj/ppiab/sof/sof.html"^^xsd:anyURI ;
    dct:spatial "Canada" ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "The establishment of a tree crop on an area from which it has always or very long been absent. Where such establishment fails and is repeated, the latter may properly be termed \"reafforestation\""@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Canada" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_95 a skos:Concept ;
    dct:spatial "Denmark" ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "Planting of agriculture-land with a forest obligation written in the cadastre. (From: PMP@sns.dk Date: Tue, 29 Sep 1998 09:31:59 +0100"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Denmark" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_97 a skos:Concept ;
    dct:creator "St. Lucia" ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "The planting of forest tree species in an area which was not occupied by forest before. (Source: Michael Andrew, chiefforest@maffe.org"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "St. Lucia" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:AndNonForestLand_1 a skos:Concept ;
    dct:spatial "Austria" ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Areas which are not under forest management and which have a crown cover of less than 30%; areas stocked by shrubs (except coppice stands and areas which have been identified as protective forests); rows of trees (except wind belts); short rotation plantations, for instance for fuelwood production (with a rotation period of less than 30 years); Christmas tree cultures, forest nurseries, plantations for seeds of forest trees or fruits. (Austrian Forestry Act (Federal Legal Gazette no. 440/1975, as amended Federal Legal Gazette 231/1977, 142/1978 and 576/1987) From: Weiss Peter weissp@ubavie.gv.at"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Austria" ;
    skos:prefLabel "and non-forest land"@en .

ex:ArtificialReforestation_1 a skos:Concept ;
    dct:spatial "Ukraine" ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "Artificial) reforestation -- creation of forest plantations on the lands which were not previously under forest (covered by forest) with the aim of formation economically valuable, high productive and biologically sustainable forest stands. Note that ``forest plantations'' defined as ``forest stands created by planting of seedlings, saplings of trees or shrubs or by sowing of their seeds'', i.e. it here this means only origination of stands, not intensity of management (Polyakov 1998"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Ukraine" ;
    skos:prefLabel "Artificial reforestation"@en .

ex:ClearingRodung_1 a skos:Concept ;
    dct:spatial "Austria" ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "clearing) (Rodung) - A land use change of forest land to other uses. Deforestation (clearing) is forbidden in Austria (due to former laws deforestation (clearing) is countrywide forbidden in Austria since about 150 years). However, if public interest in the different land use is higher than public interest in the conservation of the forest, the authority may give its approval for the deforestation (clearing). Usually, as a compensation other adequate areas have to be afforested. (Austrian Forestry Act (Federal Legal Gazette no. 440/1975, as amended Federal Legal Gazette 231/1977, 142/1978 and 576/1987) From: Weiss Peter weissp@ubavie.gv.at"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Austria" ;
    skos:prefLabel "clearing Rodung"@en .

ex:CoillteEstate_2 a skos:Concept ;
    dct:spatial "Ireland" ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Scrub and/or Amenity forests. (European Communities 1997a - p. 401"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Ireland" ;
    skos:prefLabel "Coillte estate"@ro .

ex:CommercialForest_1 a skos:Concept ;
    dct:source "http://www.nrcan.gc.ca/cfs/proj/ppiab/sof/sof98/spout2.shtml"^^xsd:anyURI ;
    dct:spatial "Canada" ;
    skos:definition "Forest land that is able to grow commercial timber within an acceptable time frame. [Canada's State of the Forest Report at ]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Canada" ;
    skos:prefLabel "Commercial forest"@en .

ex:Concept_1 a skos:Concept ;
    dct:creator "Convention to Combat Desertification" ;
    skos:definition "Before we can get into a discussion of Afforestation, Deforestation, and Afforestation, we need to have an understanding of some basic terms and concepts. These include land - (the terrestrial bio-productive system that comprises soil vegetation, other biota, and the ecological and hydrological processes that operate within the system ), land use, land cover, tree, forest, natural forest, semi-natural forest, plantation, stocking and forestry. Here are some of the definitions we found"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Convention to Combat Desertification" .

ex:Concept_10 a skos:Concept ;
    skos:definition "The amount of live trees on a given area in relation to what is considered the optimum. [Source: USDA Forest Service General Technical Report WO-44. Forest Stand Density and Stocking: concepts, terms, and use of the stocking guides. 8 p.]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "STOCKING (Stand Density, Crown Cover)"@en .

ex:Concept_11 a skos:Concept ;
    dct:creator "breast-height" ;
    skos:definition "The sum of areas of cross-cuts of all trees of a tree stand at height of 1.3 meters on 1 ha' is basal area. [From: \"Maksym Polyakov\" <mpoliak@pcomp.usau.kiev.ua Date: Wed, 17 Jun 1998 11:20:37 +0300 (MSD)]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "breast-height" ;
    skos:prefLabel "STOCKING (Stand Density, Crown Cover)"@en .

ex:Concept_12 a skos:Concept ;
    dct:source "http://www.crcd.org/voloak.html"^^xsd:anyURI ;
    skos:definition "Tree Stocking: An expression of the number and size of trees per acre"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "STOCKING (Stand Density, Crown Cover)"@en .

ex:Concept_13 a skos:Concept ;
    dct:creator "2" ;
    dct:source "http://www.ncfcnfr.net/glossary.html"^^xsd:anyURI ;
    skos:definition "Forest Management - The practical application of scientific, economic and social principles to the administration and working of a forest for specified objectives. Particularly, that branch of forestry concerned with the overall administrative, economic, legal and social aspects and with the essentially scientific and technical aspects, especially silviculture, protection and forest regulation"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "2" ;
    skos:prefLabel "FORESTRY"@de .

ex:Concept_14 a skos:Concept ;
    dct:source "http://www.forestinfo.org/Discover/glossary.htm"^^xsd:anyURI ;
    skos:definition "The art, science, and practice of managing forest landscapes to provide a sustained production of a variety of goods and services for society"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FORESTRY"@de .

ex:Concept_15 a skos:Concept ;
    dct:creator "WWWebster" ;
    skos:definition "The science of developing, caring for, or cultivating forest. The management of growing timber"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "WWWebster" ;
    skos:prefLabel "FORESTRY"@de .

ex:Concept_16 a skos:Concept ;
    dct:source "http://ifdn.com/teacher/glossary.htm#d"^^xsd:anyURI ;
    skos:definition "The science of planting, managing and protecting forest"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FORESTRY"@de .

ex:Concept_17 a skos:Concept ;
    dct:source "http://nhd.heinle.com/nhd-bin/searchNHD.pl"^^xsd:anyURI ;
    skos:definition "The scientific field of forest management"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FORESTRY"@de .

ex:Concept_18 a skos:Concept ;
    dct:creator "NASDA" ;
    dct:source "http://www.nasda-hq.org/NASDA_NASS/docs/EDUCATIO/REFERENC/TERMS___/TERMSDEF.PDF"^^xsd:anyURI ;
    skos:definition "An orchard; a small stand of trees"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "NASDA" ;
    skos:prefLabel "GROVE, THICKET"@vi .

ex:Concept_19 a skos:Concept ;
    dct:source "http://www.tnw.org.uk/Note17.html"^^xsd:anyURI ;
    skos:definition "A forestry plantation"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "GROVE, THICKET"@vi .

ex:Concept_2 a skos:Concept ;
    dct:creator "Kalensky et al" ;
    dct:date "2002"^^xsd:gYear ;
    skos:definition "Land cover or land use class - An abstract representation of specific land cover or land use defined by classification criteria. It is important to note that several land use classes may be associated with a single land cover class. For example, a specific map unit classified as forest may be associated with several land use classes, such as wood production, watershed protection, tourism, etc"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Kalensky et al. 2002" .

ex:Concept_20 a skos:Concept ;
    dct:source "http://www.newberry.org/k12maps/glossary/index.html"^^xsd:anyURI ;
    skos:definition "A group of similar trees growing in a confined area"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "GROVE, THICKET"@vi .

ex:Concept_21 a skos:Concept ;
    dct:source "http://dictionary.cambridge.org/define.asp?key=grove*1+0"^^xsd:anyURI ;
    skos:definition "A group of trees planted close together"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "GROVE, THICKET"@vi .

ex:Concept_22 a skos:Concept ;
    dct:source "http://www.lovett-pinetum.org/2whatis.htm"^^xsd:anyURI ;
    skos:definition "A pinetum is a grove or plantation where pine trees are cultivated, particularly for scientific, educational &/or esthetic purposes. It is a specialized type of arboretum --- a place where many kinds of trees are grown for the same purposes"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "GROVE, THICKET"@vi .

ex:Concept_23 a skos:Concept ;
    dct:source "http://www.notredame.ac.jp/cgi-bin/wn?grove"^^xsd:anyURI ;
    skos:definition "A small cultivated wood without undergrowth"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "GROVE, THICKET"@vi .

ex:Concept_24 a skos:Concept ;
    dct:source "http://www.notredame.ac.jp/cgi-bin/wn?grove"^^xsd:anyURI ;
    skos:definition "A small growth of trees without underbrush"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "GROVE, THICKET"@vi .

ex:Concept_25 a skos:Concept ;
    dct:source "http://www.wordsmyth.net/cgi-bin/simplesearch.cgi?matchent=grove&matchtype=exact&matchid=-1&retall=1"^^xsd:anyURI ;
    skos:definition "A small stand of fruit or nut trees; orchard"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "GROVE, THICKET"@vi .

ex:Concept_26 a skos:Concept ;
    dct:source "http://www.wordsmyth.net/cgi-bin/simplesearch.cgi?matchent=grove&matchtype=exact&matchid=-1&retall=1"^^xsd:anyURI ;
    skos:definition "A small wooded area, esp. one with little ground cover"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "GROVE, THICKET"@vi .

ex:Concept_27 a skos:Concept ;
    dct:source "http://www.graylab.ac.uk/cgi-bin/omd?grove"^^xsd:anyURI ;
    skos:definition "A smaller group of trees than a forest, and without underwood, planted, or growing naturally as if arranged by art; a wood of small extent"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "GROVE, THICKET"@vi .

ex:Concept_28 a skos:Concept ;
    dct:source "http://www.fgdc.gov/standards/documents/standards/vegetation/vegclass.pdf"^^xsd:anyURI ;
    skos:definition "Areas dominated by fruit or nut trees planted on a regular and generally consistent row and plant spacing. Stands are planted for the purpose of producing a fruit or nut crop. Examples include areas used for the production of apples, peaches, oranges, pecans, walnuts, cherries, and bananas"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "GROVE, THICKET"@vi .

ex:Concept_29 a skos:Concept ;
    dct:source "http://www.copper-beech.com/glossary.html"^^xsd:anyURI ;
    skos:definition "Sacred grove - a place apart, consecrated to a spirit or divinity, or to the memory of a hero; with trees, rocks and water, surrounding a shrine or an altar, in a temple or within a grotto or cave. This religious or spiritual quality separates, though not sharply, the 'sacred grove' from the gardens of Flora"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "GROVE, THICKET"@vi .

ex:Concept_3 a skos:Concept ;
    skos:broadMatch ex:Plantation ;
    skos:definition "See: Lund, H. Gyde. 2016 revised. Definitions of old growth, pristine, climax, ancient forests, degradation, desertification, forest fragmentation, and similar terms. [Online publication], Gainesville, VA: Forest Information Services. Misc. pagination. DOI: 10.13140/RG.2.1.2963.7361"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "PLANTATION (Forest Cultures)"@fr .

ex:Concept_30 a skos:Concept ;
    dct:source "http://nfdp.ccfm.org/silviterm/silvi_e/silvitermqtote.htm#T"^^xsd:anyURI ;
    skos:definition "Thicket - A dense growth of small trees or bushes"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "GROVE, THICKET"@vi .

ex:Concept_31 a skos:Concept ;
    dct:creator "–NSW" ;
    dct:source "http://www.forest.nsw.gov.au/education/glossary/default.asp#Ltr_W"^^xsd:anyURI ;
    dct:spatial "Australia" ;
    skos:definition "A group (or cluster) of upright trees"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Australia–NSW" ;
    skos:prefLabel "STAND"@de .

ex:Concept_32 a skos:Concept ;
    dct:creator "Czech Republic" ;
    dct:date "1995"^^xsd:gYear ;
    dct:source "http://www.uhul.cz/images/ke_stazeni/legislativa_jazyky/Lesni_zakon_en.pdf"^^xsd:anyURI ;
    skos:definition "stand shall mean the basic unit of spatial arrangement of the forest identifiable in the terrain and shown on a forestry map"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Czech Republic 1995" ;
    skos:prefLabel "STAND"@de .

ex:Concept_33 a skos:Concept ;
    dct:creator "USA-State-Oregon" ;
    dct:source "http://www.odf.state.or.us/DIVISIONS/management/state_forests/sfplan/eorfmp95-final/A_gloss.pdf"^^xsd:anyURI ;
    skos:definition "A term used in this plan to designate a contiguous area of land in the same vegetative series and having the same management history"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-State-Oregon" ;
    skos:prefLabel "STAND"@de .

ex:Concept_34 a skos:Concept ;
    dct:source "http://www.bib.fsagx.ac.be/coste21/glossary.html#d"^^xsd:anyURI ;
    skos:definition "A community of trees, including aboveground and belowground biomass and soils, sufficiently uniform in species composition, age, arrangement, and condition to be managed as a unit"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "STAND"@de .

ex:Concept_35 a skos:Concept ;
    dct:source "http://www.epa.gov/OWOW/NPS/MMGI/Chapter3/ch3-3.html"^^xsd:anyURI,
        "http://www.for.gov.bc.ca/hfp/pubs/stand_density_mgt/sdm-73.htm#s"^^xsd:anyURI,
        "http://www.fs.fed.us/r4/wcnf/projects/decisions/bear_hodges2/glossary,.pdf"^^xsd:anyURI ;
    skos:definition "A contiguous group of trees sufficiently uniform in species composition, arrangement of age classes, and condition to be a homogeneous and distinguishable unit. , and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "STAND"@de .

ex:Concept_36 a skos:Concept ;
    dct:source "http://www.maf.govt.nz/statistics/primaryindustries/forestry/forest-resources/national-exotic-forest-2000/nappendix1.htm"^^xsd:anyURI ;
    skos:definition "A defined area of standing trees or forest, usually of one species, age and tending regime"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "STAND"@de .

ex:Concept_37 a skos:Concept ;
    dct:source "http://www.fnr.purdue.edu/inwood/glossary.html"^^xsd:anyURI ;
    skos:definition "A geographically contiguous parcel of land containing one or more stand types and is usually constructed for administrative reasons"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "STAND"@de .

ex:Concept_38 a skos:Concept ;
    dct:source "http://www.privateforestry.org.au/glos_o-z.htm"^^xsd:anyURI ;
    skos:definition "A group of forest trees of sufficiently uniform species composition, age, and condition to be considered a homogeneous unit for management purposes"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "STAND"@de .

ex:Concept_39 a skos:Concept ;
    dct:source "http://www.harcourt.com/dictionary/def/4/1/0/8/4108500.html"^^xsd:anyURI ;
    skos:definition "A group of trees in a given area that consist of one species, size, or grade; used as the basic unit in forest mapping"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "STAND"@de .

ex:Concept_4 a skos:Concept ;
    dct:source "http://www.nrcan.gc.ca/cfs/proj/ppiab/ci/gloss_e.html"^^xsd:anyURI ;
    dct:spatial "Canada" ;
    skos:definition "A qualitative expression of the adequacy of tree cover on an area in terms of crown closure, number of trees, basal area or volume in relation to a pre-established norm. [Source: Criteria and Indicators of sustainable forest management in Canada: Glossary From: \"Maksym Polyakov\" <mpoliak@pcomp.usau.kiev.ua Date: Wed, 17 Jun 1998 11:20:37 +0300 (MSD)]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Canada" ;
    skos:prefLabel "STOCKING (Stand Density, Crown Cover)"@en .

ex:Concept_40 a skos:Concept ;
    dct:creator "Hunter" ;
    dct:date "1990"^^xsd:gYear ;
    dct:source "http://depts.clemson.edu/extfor/publications/fortp19/definitions.htm"^^xsd:anyURI ;
    skos:definition "A group of trees reasonably similar in age structure and species composition, usually occupying at least 5 acres"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Hunter 1990" ;
    skos:prefLabel "STAND"@de .

ex:Concept_41 a skos:Concept ;
    dct:source "http://www.tnw.org.uk/Note17.html"^^xsd:anyURI ;
    skos:definition "A group or area of trees"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "STAND"@de .

ex:Concept_42 a skos:Concept ;
    dct:source "http://ashland.or.us/Files/Fire%20city%20Plan%202002.htm"^^xsd:anyURI ;
    skos:definition "A grouping of trees in a forest of similar conditions that separate it from trees in other adjacent areas"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "STAND"@de .

ex:Concept_43 a skos:Concept ;
    dct:source "http://fwie.fw.vt.edu/rhgiles/appendices/glosss.htm"^^xsd:anyURI ;
    skos:definition "A plant and animal community"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "STAND"@de .

ex:Concept_44 a skos:Concept ;
    dct:source "http://www.ifdn.com/teacher/glossary.htm"^^xsd:anyURI ;
    skos:definition "A standing growth of trees or plants"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "STAND"@de .

ex:Concept_45 a skos:Concept ;
    dct:creator "e.g., 80-year aspen stand" ;
    dct:source "http://www.borealcentre.ca/glossary.html"^^xsd:anyURI ;
    skos:definition "A unit of forest classification generally based on the type and age of the dominant tree vegetation . Most stands are initiated through disturbance events such as fire"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "e.g., 80-year aspen stand" ;
    skos:prefLabel "STAND"@de .

ex:Concept_46 a skos:Concept ;
    dct:source "http://www.eresourcesystems.com/Help/Glossary/glossary.html"^^xsd:anyURI ;
    skos:definition "An aggregation of trees or other growth occupying a specific area and sufficiently uniform in composition to be distinguishable from the adjoining forest or other growth"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "STAND"@de .

ex:Concept_47 a skos:Concept ;
    dct:creator "species" ;
    dct:source "http://fwie.fw.vt.edu/rhgiles/appendices/glosss.htm"^^xsd:anyURI ;
    skos:definition "An aggregation of trees or other growth occupying a specific area and sufficiently uniform in composition , age arrangement, and condition as to be distinguishable from the forest or other growth on adjoining areas (a minimum of 1 acre of forest land that is at least 10 percent stocked by forest trees of any size). A forest stand is said to be \" pure\" if 80 percent or more of the trees present are of the same species. If less than 80 percent of all trees present are of the same species. the stand is said to be \" mixed.\""@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "species" ;
    skos:prefLabel "STAND"@de .

ex:Concept_48 a skos:Concept ;
    dct:source "http://www.dnr.state.mi.us/wildlife/Landowners_Guide/Introduction/Glossary.htm"^^xsd:anyURI ;
    skos:definition "An area composed of trees that are similar in type, or age, or size"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "STAND"@de .

ex:Concept_49 a skos:Concept ;
    dct:source "http://www.forestenterprises.co.nz/cfi/investmentstructure.htm"^^xsd:anyURI ;
    skos:definition "An area of trees with similar characteristics"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "STAND"@de .

ex:Concept_5 a skos:Concept ;
    dct:creator "BC" ;
    dct:source "http://www.for.gov.bc.ca/pab/publctns/glossary/glossary.htm"^^xsd:anyURI ;
    dct:spatial "Canada" ;
    skos:definition "A measure of the area occupied by trees, usually measured in terms of well- spaced trees per hectare, or basal area per hectare, relative to an optimum or desired level. [Source: Glossary of Forestry Terms, Province of British Columbia, Ministry of Forests, From: \"Maksym Polyakov\" <mpoliak@pcomp.usau.kiev.ua Date: Wed, 17 Jun 1998 11:20:37 +0300 (MSD)]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Canada-BC" ;
    skos:prefLabel "STOCKING (Stand Density, Crown Cover)"@en .

ex:Concept_50 a skos:Concept ;
    dct:source "http://www.timbervest.net/faqs_and_glossary/glossary.htm"^^xsd:anyURI ;
    skos:definition "An easily defined area of the forest that is relatively uniform in species composition or age and can be managed as a single unit"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "STAND"@de .

ex:Concept_51 a skos:Concept ;
    dct:creator "2 ha" ;
    dct:source "http://fscus.org/html/standards_policies/us_regional_standards/archives/ozark_ouachita4.html"^^xsd:anyURI ;
    skos:definition "An ecologically homogeneous area within an ecosystem or landscape, a minimum of 5 acres in size"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "2 ha" ;
    skos:prefLabel "STAND"@de .

ex:Concept_52 a skos:Concept ;
    dct:source "http://www.woodlands.co.uk/book/appendices.pdf"^^xsd:anyURI ;
    skos:definition "Community of trees with similar characteristics and managed as one unit"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "STAND"@de .

ex:Concept_53 a skos:Concept ;
    dct:source "http://media.payson.tulane.edu:8083/html/env/enven/vol205.htm#Annex"^^xsd:anyURI ;
    skos:definition "Group of trees which exhibit similar features, occupy an unbroken minimum area and all require similar silvicultural treatment. : Glossary of selected terms"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "STAND"@de .

ex:Concept_54 a skos:Concept ;
    dct:creator "of trees" ;
    dct:source "http://bioenergy.ornl.gov/faqs/glossary.html#T"^^xsd:anyURI ;
    skos:definition "Stand: A tree community that possesses sufficient uniformity in composition, constitution, age, spatial arrangement, or condition to be distinguishable from adjacent communities"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "of trees" ;
    skos:prefLabel "STAND"@de .

ex:Concept_55 a skos:Concept ;
    dct:creator "s" ;
    dct:source "http://www.eman-rese.ca/eman/ecotools/protocols/terrestrial/vegetation/glossary.html"^^xsd:anyURI ;
    skos:definition "Standing growth of plants; a particular example of a plant community, e.g. forest or grassland in which monitoring plot are established"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "s" ;
    skos:prefLabel "STAND"@de .

ex:Concept_56 a skos:Concept ;
    dct:creator "the Forest Act" ;
    skos:definition "The basic unit of spatial arrangement of the forest identifiable in the terrain and shown on a forestry map. [Source: Act on Forests and Amendments to Some Acts dated 3 November 1995. Ministry of Agriculture of the Czech Republic. Prague, 1996. 58 pp. From: \"Maksym Polyakov\" mpoliak@pcomp.usau.kiev.ua Date: Mon, 15 Jun 1998 11:32:47 +0300 (MSD)]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "the Forest Act" ;
    skos:prefLabel "STAND"@de .

ex:Concept_57 a skos:Concept ;
    dct:source "http://www.forestry.sa.gov.au/pdf/glossary.pdf"^^xsd:anyURI ;
    skos:definition "The crop of trees in a forest"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "STAND"@de .

ex:Concept_58 a skos:Concept ;
    dct:source "http://www.angelfire.com/on3/wildberks/Glossary.htm"^^xsd:anyURI,
        "http://www.woodlandowner.org.uk/glossary.htm#W"^^xsd:anyURI ;
    skos:definition "Trees of one type or species [e.g. coppice, alder] grouped together within a woodland. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "STAND"@de .

ex:Concept_59 a skos:Concept ;
    dct:source "http://www.unb.ca/web/forestry/centers/cwru/soe/gloss.htm"^^xsd:anyURI ;
    skos:definition "Unit of vegetation that is essentially homogeneous in all layers and differs from adjacent types qualitatively and quantitatively"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "STAND"@de .

ex:Concept_6 a skos:Concept ;
    dct:creator "Of growing stock trees" ;
    dct:source "http://ifdc.nres.uiuc.edu/publications/pdf/forestresources02/pg81-86.pdf"^^xsd:anyURI ;
    skos:definition "The degree of occupancy of land by growing stock trees, measured by basal area and/or the number of trees in a stand by size or age and spacing, compared to the basal area and/or number of trees required to fully utilize the growth potential of the land; that is, the stocking standard. A stocking percentage of 100 indicates full utilization of the site and is equivalent to 80 square feet of basal area per acre in trees 5.0 inches d.b.h. and larger. In a stand of trees less than 5 inches d.b.h., a stocking percentage of 100 would indicate that the present number of trees is sufficient to produce 80 square feet of basal area per acre when the trees reach 5 inches d.b.h"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Of growing stock trees" ;
    skos:prefLabel "STOCKING (Stand Density, Crown Cover)"@en .

ex:Concept_60 a skos:Concept ;
    dct:creator "deforested, afforested, and reforested" ;
    dct:source "http://www.carbonpositive.net/viewarticle.aspx?articleID=44"^^xsd:anyURI ;
    skos:definition "Afforestation, Deforestation, and Reforestation are actions or acts. There are probably fewer disagreements over these terms than on what to call the lands once the action is completed and how long the lands remain in those historical categories. A/R - Afforestation and reforestation. Term given to the class of projects devoted to the planting of trees on unforested land for carbon emissions reduction and other environmental benefits"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "deforested, afforested, and reforested" .

ex:Concept_61 a skos:Concept ;
    skos:definition "\"Forestation,\" \"degradation,\" and \"regeneration\" are action terms which are not included in the Kyoto Protocol but which we appear to need to include in the discussions of changes in carbon emissions and sinks. All of these are descriptors of actions ending in changes in either land cover, land use or both"@en ;
    skos:inScheme ex:ForestScheme .

ex:Concept_62 a skos:Concept ;
    dct:spatial "Chile" ;
    skos:definition "La acción de poblar con especies arbóreas o arbustivas terrenos que carezcan de ellas o que estando cubiertos de vegetación, ésta no sea susceptible de explotación económica, ni mejoramiento mediante manejo (Cerda 1998"@es ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Chile" ;
    skos:prefLabel "FORESTATION"@de .

ex:Concept_63 a skos:Concept ;
    dct:creator "North Amer" ;
    skos:definition "Afforestation, Reforestation) The establishment of forest, naturally or artificially, on an area, whether previously carrying forest or not (Ford-Robertson 1971"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "North Amer." ;
    skos:prefLabel "FORESTATION"@de .

ex:Concept_64 a skos:Concept ;
    dct:source "http://www.state.in.us/dnr/forestry/bmp/glossary.htm"^^xsd:anyURI ;
    skos:definition "All types of tree planting, whether conversion of open land or after a harvest"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FORESTATION"@de .

ex:Concept_65 a skos:Concept ;
    dct:creator "3" ;
    dct:source "http://nfdp.ccfm.org/silviterm/silvi_e/silvitermetohe.htm#F"^^xsd:anyURI ;
    skos:definition "The establishment of forest, naturally or artificially, on an area, whether previously carrying forest or not. cf. afforestation, deforestation, reforestation"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "3" ;
    skos:prefLabel "FORESTATION"@de .

ex:Concept_66 a skos:Concept ;
    skos:definition "There are other terms that one may need to understand. These are some that the RAD team members have offered"@en ;
    skos:inScheme ex:ForestScheme .

ex:Concept_67 a skos:Concept ;
    dct:source "http://orb.rhodes.edu/Medieval_Terms.html"^^xsd:anyURI ;
    skos:definition "Assart: To turn woodlands into pasture or cropland. To assart lands within a forest without license is a grave offence"@en ;
    skos:inScheme ex:ForestScheme .

ex:Concept_68 a skos:Concept ;
    dct:source "http://www.christiantech.com/cgi-bin/webster.exe?search_for_cgi-bin/texts/web1828=coafforest"^^xsd:anyURI ;
    skos:definition "Coafforest, v.t. To convert ground into a forest"@en ;
    skos:inScheme ex:ForestScheme .

ex:Concept_69 a skos:Concept ;
    dct:creator "Institute of Forestry, July" ;
    dct:date "1998"^^xsd:gYear ;
    dct:spatial "New Zealand" ;
    skos:definition "Coupe – An area within a forest which is harvested and regenerated. It is usually less than half a hectare where management is based on ecosystem sustainability. From: Indigenous Forest Policy"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "New Zealand Institute of Forestry, July 1998" .

ex:Concept_7 a skos:Concept ;
    dct:spatial "Russian Federation" ;
    skos:definition "Degree of a denseness of growing of trees in a tree stand describing a share of use by them of taken space. Usually under definition of stocking (polnota) understands a relative polnota of a tree stand - ratio of the sum of areas of cross-cuts of all trees of a tree stand at height of 1.3 meters (breast-height) on 1 ha to the sum of areas of cross-cuts of a normal tree stand (with a polnota 1,0), i.e. tree stand with optimum for the given species and types of forest growing conditions the sum of areas of cross-cuts, which undertakes from the tables of growth. . [From: \" Russian Forest Encyclopedia\" \"Igor Yakovlev\" yakovlev@mari-el.ru Date: Sat, 6 Jun 1998 21:16:59 +0400]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Russian Federation" ;
    skos:prefLabel "STOCKING (Stand Density, Crown Cover)"@en .

ex:Concept_70 a skos:Concept ;
    dct:creator "MSD" ;
    skos:definition "Damaged forest - Forest which is prevented by negative influences from natural development of the ecosystem or prevented from providing the functions of a forest. Damaged forest is forest for reclamation and is a threat to the environment under the terms of regulations on the protection of the environment. [From: Slovenian LAW ON FORESTS - Milan SINKO milan.sinko@UNI-LJ.SI via \"Maksym Polyakov\" <mpoliak@pcomp.usau.kiev.ua Date: Fri, 12 Jun 1998 16:11:17 +0300 ]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "MSD" .

ex:Concept_71 a skos:Concept ;
    skos:definition "Devegetated - having removed the vegetation from an area"@en ;
    skos:inScheme ex:ForestScheme .

ex:Concept_72 a skos:Concept ;
    dct:creator "by fire, human impact" ;
    dct:source "http://www.nature.nps.gov/nrbib/HTML%20files/33.htm#3259"^^xsd:anyURI ;
    skos:definition "Devegetation - destruction of vegetation"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "by fire, human impact" .

ex:Concept_73 a skos:Concept ;
    dct:source "http://www.christiantech.com/cgi-bin/webster.exe?search_for_cgi-bin/texts/web1828=disafforest"^^xsd:anyURI ;
    skos:definition "Disafforest, v.t. [dis and afforest.] To reduce from the privileges of a forest to the state of common ground; to strip of forest laws and their oppressive privileges"@en ;
    skos:inScheme ex:ForestScheme .

ex:Concept_74 a skos:Concept ;
    dct:source "http://www.christiantech.com/cgi-bin/webster.exe?search_for_cgi-bin/texts/web1828=afforestation"^^xsd:anyURI,
        "http://www.hants.org.uk/newforest/bibliog.html"^^xsd:anyURI ;
    skos:definition "Disafforested - Stripped of forest privileges . To remove land from the authority of the Verderers"@en ;
    skos:inScheme ex:ForestScheme .

ex:Concept_75 a skos:Concept ;
    dct:source "http://nrcan.gc.ca/cfs/proj/iepb/nfdp/regen/regen_e/s18.htm"^^xsd:anyURI ;
    skos:definition "Disturbance - Any removal of tree cover sufficient to create a site for an even-aged crop of regeneration. Even-aged Of a forest, stand, or forest type in which relatively small age differences exist between individual trees. The differences in age permitted are usually 10 to 20 years"@en ;
    skos:inScheme ex:ForestScheme .

ex:Concept_76 a skos:Concept ;
    dct:creator "the Forest Act" ;
    skos:definition "Established forest stand – The reaching such a state of forest stand where intensive protection is no longer required after afforestation and the number of individual trees and their distribution throughout the forested area, as well as the composition of the forest tree species, create all the prerequisites required for the establishment of a site suitable forest stand. [Source: Act on Forests and Amendments to Some Acts dated 3 November 1995. Ministry of Agriculture of the Czech Republic. Prague, 1996. 58 pp. From: \"Maksym Polyakov\" <mpoliak@pcomp.usau.kiev.ua Date: Mon, 15 Jun 1998 11:32:47 +0300 (MSD)]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "the Forest Act" .

ex:Concept_77 a skos:Concept ;
    dct:creator "MSD" ;
    skos:definition "Forest cultures - Artificially created or planted forest stands. [From: \"Maksym Polyakov\" mpoliak@pcomp.usau.kiev.ua Date: Thu, 11 Jun 1998 12:06:37 +0300 ]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "MSD" .

ex:Concept_78 a skos:Concept ;
    dct:creator "tree and shrubs" ;
    skos:definition "Forest fund - All the lands given to state forestry enterprises plus all the forests under responsibility of other bodies. Or, all the forest lands plus non-forest lands of state forestry enterprises. forest [lands]: covered by forest vegetation; not covered by forest vegetation but required to be afforested (cuttings [places after fellings], burnings, [loose forests], [empty places] etc., forest roads, cuttings [narrow straight road dividing quarters in forest], fire breaks; non-forest [lands]: under buildings connected with forest management, power lines, pipelines, other underground communications, etc.; agricultural lands (arable lands, hayfields, pastures, given for the purposes of forestry [forest management]; wetlands and waters within the parcels of forest fund given for the purposes of forestry.'' [From: ``The Forest Code of Ukraine'' Kiev, 1994, 56p. \"Maksym Polyakov\" mpoliak@pcomp.usau.kiev.ua Date: Thu, 11 Jun 1998 12:06:37 +0300 (MSD)]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "tree and shrubs" .

ex:Concept_79 a skos:Concept ;
    dct:creator "the Forest Act" ;
    skos:definition "Forest management – The regeneration, protection, tending and felling of forest stands and other activities securing the fulfillment of forest functions, [Source: Act on Forests and Amendments to Some Acts dated 3 November 1995. Ministry of Agriculture of the Czech Republic. Prague, 1996. 58 pp. From: \"Maksym Polyakov\" <mpoliak@pcomp.usau.kiev.ua Date: Mon, 15 Jun 1998 11:32:47 +0300 (MSD)]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "the Forest Act" .

ex:Concept_8 a skos:Concept ;
    dct:creator "MSD" ;
    dct:source "http://ww.ehnr.state.nc.us/EHNR/DFR/fm-22.htm"^^xsd:anyURI ;
    skos:definition "A relative number of trees or volume per acre. A forest stand is most often described as being well-stocked, poorly stocked or overstocked. [Source: Glossary of Forestry Terms Commonly Used in Forest Management Plans From: \"Maksym Polyakov\" <mpoliak@pcomp.usau.kiev.ua Date: Wed, 17 Jun 1998 11:20:37 +0300 ]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "MSD" ;
    skos:prefLabel "STOCKING (Stand Density, Crown Cover)"@en .

ex:Concept_80 a skos:Concept ;
    dct:spatial "Oman" ;
    skos:definition "Natural regeneration - -The act of installation, through natural methods, of the forest vegetation. Sorin Sfirlogea <sorinsf@rosilva.ro National Forests Administration"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Romania" .

ex:Concept_81 a skos:Concept ;
    dct:creator "MSD" ;
    skos:definition "Non covered by forest forest lands - Lands designated for forest growing, i.e. felled places, loose forest, `not closed yet young forest cultures'', etc. All these land were potentially needed to be reforested/afforested/reconstructed. [From: ``The Forest Code of Ukraine'' Kiev, 1994, 56p. \"Maksym Polyakov\" mpoliak@pcomp.usau.kiev.ua Date: Thu, 11 Jun 1998 12:06:37 +0300 ]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "MSD" .

ex:Concept_82 a skos:Concept ;
    skos:definition "Productive forest land - Land which has an annual yield capacity of at least 1 m3 wood including bark per hectare under favourable stand conditions. Classification should not be affected if the land is temporarily without trees. More critical factors are the yield capacity and that the land is not utilized for other purposes than wood production. [From: Stein Tomter stein.tomter@tor.nijos.no Date: Mon, 15 Jun 1998 14:50:20 +0200]"@en ;
    skos:inScheme ex:ForestScheme .

ex:Concept_83 a skos:Concept ;
    dct:source "http://www.rfa.gov.au/dfa/other_info/glossary.html"^^xsd:anyURI ;
    skos:definition "Regrowth forest - Native forest containing a substantial proportion of trees that are in the younger growth phase and are actively growing in height and diameter. Regrowth forests may contain scattered individuals or small occurrences of ecologically mature, or old growth, trees"@en ;
    skos:inScheme ex:ForestScheme .

ex:Concept_84 a skos:Concept ;
    skos:definition "Renewal - The natural or artificial renewal of any forest product and includes reforestation\" [Source: Chapter F-19.1: An Act respecting the management of Forest Resources...aka THE ACT From: Mark Johnston <johnston@larix.derm.gov.sk.ca Date: Tue, 16 Jun 1998 17:44:48 -0600]"@en ;
    skos:inScheme ex:ForestScheme .

ex:Concept_86 a skos:Concept ;
    dct:source "http://www.greenpeace.org/~comms/cbio/forp&g.html#annex"^^xsd:anyURI ;
    skos:definition "Restoration - The recreation of communities of organisms resembling, in structure, function and dynamics, those prior to degradation, and protected from further human degradation"@en ;
    skos:inScheme ex:ForestScheme .

ex:Concept_87 a skos:Concept ;
    dct:source "http://www.af.nfr.no/andre-doc/alternativ-agenda/Forests.html"^^xsd:anyURI ;
    skos:definition "Restored forests - Forests planted, seeded, or otherwise restored in such a manner as to emulate the original natural forests of an area"@en ;
    skos:inScheme ex:ForestScheme .

ex:Concept_88 a skos:Concept ;
    dct:creator "in contrast to trees-ASH" ;
    skos:definition "Shrubs - Woody perennials which ramify at very soil surface and have not any main stem at maturity. Shrubbery is an ecosystem dominated by shrubs of a maximum potential hight at maturity of approximately 6 m with a minimum projected crown cover of 20%. Anatoly SHVIDENKO <shvidenk@iiasa.ac.at"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "in contrast to trees-ASH" .

ex:Concept_89 a skos:Concept ;
    dct:creator "mean annual increment at culmination in fully stocked, natural stands" ;
    skos:definition "Timberland - Forest land capable of growing 20 cubic feet or more per acre per year of industrial wood and not in a reserved status through removal of the area from timber utilization by statute, ordinance, or administrative order; and not in a withdrawn status where it is pending consideration for reserved status. (Waddell and Bassett 1997"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "mean annual increment at culmination in fully stocked, natural stands" .

ex:Concept_9 a skos:Concept ;
    dct:source "http://216.239.39.100/search?q=cache:iFF2UlzBb4kC:socrates.lv-hrc.nevada.edu/fia/dab/core1-6/appendix7_12_00.doc+%22stand+density%22++definition+glossary&hl=en&ie=UTF-8"^^xsd:anyURI ;
    skos:definition "Stocking – The relative degree of occupancy land by trees, measured as basal area or the number of trees in a stand by size or age and spacing, compared to the basal area or number of trees required to fully utilize the growth potential of the land; that is, the stocking standard"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "STOCKING (Stand Density, Crown Cover)"@en .

ex:Concept_90 a skos:Concept ;
    dct:creator "Powell et al" ;
    dct:date "1993"^^xsd:gYear ;
    skos:definition "Unproductive forest land - Forest land which is incapable of producing annually 0.6 cubic meters of industrial wood/per acre under natural conditions, because of adverse site conditions, such as sterile soils, dry climate, poor drainage, high elevation, steepness, or rockiness. Urban forest land is also included"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Powell et al. 1993" .

ex:Concept_91 a skos:Concept ;
    dct:creator "Waddell and Bassett" ;
    dct:date "1997"^^xsd:gYear ;
    skos:definition "Withdrawn timberland - Timberland in National Forests that is being considered for permanent reserved status. Although this land has not been removed from timber utilization by statute, ordinance, or administrative order, it is not being actively managed as timberland"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Waddell and Bassett 1997" .

ex:Concept_92 a skos:Concept ;
    dct:source "http://www.polity.org.za/govdocs/green_papers/forest1.html#t1"^^xsd:anyURI ;
    dct:spatial "South Africa" ;
    skos:definition "Wooded grasslands - As in (South Africa) Woodlands, but 5-40% canopy cover; grasslands typically less than 6m tall"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "South Africa" .

ex:Concept_93 a skos:Concept ;
    dct:creator "45°" ;
    dct:source "http://www.bioone.org/doi/pdf/10.1659/0276-4741(2002)022"^^xsd:anyURI ;
    skos:definition "Inaccessible forest: A forest area is inaccessible if it is located on a slope of more than 100 per cent or if it is surrounded by steep slopes, landslides, or other physical obstacles. per cent5B0085:IONSFR per cent5D2.0.CO per cent3B2"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "45°" .

