    dct:date "1987"^^xsd:gYear ;
    dct:source "http://faolex.fao.org/docs/texts/tur20346.doc"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Tree and woodland communities, which are grown by human efforts, are regarded as Forest, together with their lands; • Privately owned lands containing trees and woodland species, which do not grow naturally in the neighbouring forest or any kind of trees or woodlands on privately owned land and smaller than three hectares are not considered as forest; FOREST LAW No. 6831, ARTICLE 1 (AS AMENDED BY LAW NO. 3373, 1987"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Turkey 1987" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "National"@en .

ex:Forest_1275 a skos:Concept ;
    dct:creator "Turkey" ;
    dct:date "2004"^^xsd:gYear ;
    dct:source "http://www.sayistay.gov.tr/english_tca/Performance/ProtectionOfForests.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A unity of life consisting of small systems made of various plants, animals, bacteria and microorganisms. Karabeyli, Levent et al. 2004. Protection of forests. Turkish Court of Accounts. Performance Audit Report. 78 p"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Turkey 2004" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "National"@en .

ex:Forest_1276 a skos:Concept ;
    dct:creator "Turkey" ;
    dct:date "2004"^^xsd:gYear ;
    dct:source "http://www.sayistay.gov.tr/english_tca/Performance/ProtectionOfForests.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "forest is a unity of life consisting of small systems made of various plants, animals, bacteria and microorganisms"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Turkey 2004" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "National"@en .

ex:Forest_1277 a skos:Concept ;
    dct:creator "Turkey" ;
    dct:date "2009"^^xsd:gYear ;
    dct:source "http://web.ogm.gov.tr/languages/English/dokumanlar/Publications/stateofforests.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "GDF. A forest ecosystem is a natural unit consisting of all plants of which the main element is forest trees, animals and micro-organisms (biotic factors) in an area functioning together with all of the non-living physical (abiotic factors) factors of the environment. …The forest area in terms of crown density is classified into two main groups. Forest area with the crown density of 11-100 percent is defined as productive forest area constituting about 50 percent of the country’s forest area while the area with the crown density of 1-10 percent, the remaining about 50 percent named as degraded forest area"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Turkey 2009" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "National"@en .

ex:Forest_1278 a skos:Concept ;
    dct:date "2010"^^xsd:gYear ;
    dct:source "http://www.envsec.org/publications/fact_finding_study_illegal_logging_eng_feb_11.pdf"^^xsd:anyURI ;
    dct:spatial "Ukraine" ;
    skos:broadMatch ex:Forest ;
    skos:definition "A forest is a type of natural complex combining mostly tree and bush vegetation with corresponding soils, herbaceous vegetation, fauna, micro-organisms and other natural components, which are interrelated in their development and affect each other and the environment"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Ukraine 2010" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "National"@en .

ex:Forest_1279 a skos:Concept ;
    dct:source "http://www.woodlander.co.uk/cgi-bin/viewrecordsalpha.asp?letter=F"^^xsd:anyURI ;
    dct:spatial "United Kingdom" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Historically in Britain a Forest, with a capital 'F', was a tract of land subject to special laws for hunting (as in \"Royal Forests\" and \"Chases\"). Some of these Forests contained little woodland. The modern usage of the word is far more general, relating to any extensive tract of tree-covered land. Large areas of more or less natural tree cover are always termed forest. In Britain, the word has recently been applied specifically to large conifer plantations, such as those in the uplands"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "United Kingdom" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "National"@en .

ex:Forest_128 a skos:Concept ;
    dct:source "http://www.inhs.uiuc.edu/chf/pub/virtualbird/glossary.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "An area covered with many trees and plants"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_1288 a skos:Concept ;
    dct:creator "Vietnam" ;
    dct:source "http://www.asb.cgiar.org/PDFwebdocs/REALU-Final%20Report%20-%20Vietnam.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "forest. According to Vietnam’s Forest Protection and Development Law 2004, “forest” is defined as ‘an ecosystem with trees, animals and biota, soil and other environmental factors, in which timber species, bamboo or other species provide a canopy cover of more than 10%. Plantation forest and natural forest are grouped into production forest, protection forest and special-use forest’"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Vietnam" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "National"@en .

ex:Forest_1289 a skos:Concept ;
    dct:creator "Yugoslavia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "the terrain on which forest trees grow. \"Srdjan BOJOVIC\" <bojos@ptt.yu"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Yugoslavia" ;
    skos:prefLabel "Forest"@no ;
    skos:scopeNote "Ecological"@en,
        "National"@en .

ex:Forest_129 a skos:Concept ;
    dct:source "http://www.forestry.ubc.ca/concert/ashton.html#21"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "An area grown with trees"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_1290 a skos:Concept ;
    dct:creator "BC" ;
    dct:date "2010"^^xsd:gYear ;
    dct:source "http://www.bclaws.ca/Recon/document/freeside/--%20f%20--/forest%20act%20%20rsbc%201996%20%20c.%20157/00_act/96157_01.xml"^^xsd:anyURI ;
    dct:spatial "Canada" ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"Provincial forest\" means forest land designated under section 5; FOREST ACT [RSBC 1996] CHAPTER 157 (Current to 19 Jan 2010"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Canada-BC 2010" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "State"@en .

ex:Forest_1291 a skos:Concept ;
    dct:creator "BC" ;
    dct:source "http://www.babineefmpp.com/glossary/F.html"^^xsd:anyURI ;
    dct:spatial "Canada" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest: as defined by the Forest Practices Code of British Columbia Act includes all of the following - forest land, whether Crown land or private land; Crown range; Crown land or private land that is predominantly maintained in one or more successive stands of trees, successive crops of forage, or wilderness"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Canada-BC" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "State"@en .

ex:Forest_1292 a skos:Concept ;
    dct:creator "BC" ;
    dct:source "http://www.for.gov.bc.ca/pab/publctns/westland/gloss.htm"^^xsd:anyURI ;
    dct:spatial "Canada" ;
    skos:broadMatch ex:Forest ;
    skos:definition "In British Columbia, provincial forests and other unalienated Crown lands for which the Ministry of Forests is responsible, including both forested lands and non-forested lands such as tundra, wetlands, rangelands, deserts, rock, and ice"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Canada-BC" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "State"@en .

ex:Forest_1293 a skos:Concept ;
    dct:creator "BC" ;
    dct:source "http://www.for.gov.bc.ca/hfp/Planning/RPGLOSS/F.htm"^^xsd:anyURI ;
    dct:spatial "Canada" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land classified under Section 4 of the Forest Act that the chief forester considers will provide the greatest contribution to the social and economic welfare of the Province if predominantly maintained in successive crops of trees or forage, or both, or maintained as wilderness"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Canada-BC" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "State"@en .

ex:Forest_1294 a skos:Concept ;
    dct:creator "–Saskatchewan" ;
    dct:date "1996"^^xsd:gYear ;
    dct:source "http://www.qp.gov.sk.ca/documents/english/statutes/statutes/f19-1.pdf"^^xsd:anyURI ;
    dct:spatial "Canada" ;
    skos:broadMatch ex:Forest ;
    skos:definition "“Forest land” means: (i) any Crown resource land that is designated as a provincial forest pursuant to the regulations; (ii) any Crown land described in a forest management agreement, a term supply licence or a forest product permit; (iii) any Crown land administered by the Ministry of Agriculture or the Ministry of Environment that: (A) in the opinion of the minister, has a forest ecosystem as the predominant ecosystem; or (B) is prescribed as forest fringe timber supply land; and (iv) an undeveloped road allowance that: (A) in the opinion of the minister, has a forest ecosystem as the predominant ecosystem; and (B) shares a boundary with lands described in subclauses (i) to (iii); but does not include any Crown mineral or Crown mineral lands as those terms are defined in The Crown Minerals Act"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Canada–Saskatchewan1996" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "State"@en .

ex:Forest_1295 a skos:Concept ;
    dct:creator "Maharashtra and Anr" ;
    dct:date "2010"^^xsd:gYear ;
    dct:source "http://www.nlsenlaw.org/land/case-laws/supreme-court-1/maharashtra-land-development-corporation-and-ors-v-state-of-maharashtra-and-anr/"^^xsd:anyURI ;
    dct:spatial "India" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest “land which is part of forest or lies within it or was part of forest or was lying within forest”"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "India Maharashtra and Anr.2010" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "State"@en .

ex:Forest_1296 a skos:Concept ;
    dct:creator "Himachal-Pradesh" ;
    dct:date "1999"^^xsd:gYear ;
    dct:source "http://www.docstoc.com/docs/20991283/GOVERNMENT-OF-HIMACHAL-PRADESH-FOREST-DEPARTMENT"^^xsd:anyURI,
        "http://www.hpforest.nic.in/FireRulesEng.pdf"^^xsd:anyURI ;
    dct:spatial "India" ;
    skos:broadMatch ex:Forest ;
    skos:definition "“Forest” means a reserved forest or protected forest, duly notified as such under the Act; “AUTHORITATIVE ENGLISH TEXT OF THIS DEPARTMENT NOTIFICATION No. FFE-A(C) 7-1/96-II DATED 17.11.1999 AS REQUIRED UNDER CLAUSE (3) OF ARTICLE 348 OF THE CONSTITUTION OF INDIA. GOVERNMENT OF HIMACHAL PRADESH FOREST DEPARTMENT NOTIFICATION No. FFE-A(C) 7-1/96-II Dated Shimla-2, the 17-11-1999 and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "India-Himachal-Pradesh 1999" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "State"@en .

ex:Forest_1297 a skos:Concept ;
    dct:creator "INDIA-Kerala" ;
    dct:date "1978"^^xsd:gYear ;
    dct:spatial "India" ;
    skos:broadMatch ex:Forest ;
    skos:definition "“Forest” means any reserved forest within the meaning of the Kerala Forest Act. 1961 (4 of 1962) and includes any forest vested in the Government under section 3 of the Kerala Private Forests (Vesting and assignment) Act. 1971 (26 of 1971). www.ielrc.org/content/e7805.pdf"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "INDIA-Kerala 1978" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "State"@en .

ex:Forest_1298 a skos:Concept ;
    dct:creator "INDIA-Mizoram" ;
    dct:date "2010"^^xsd:gYear ;
    dct:source "http://www.forest.mizoram.gov.in/index.php?option=com_content&task=view&id=127"^^xsd:anyURI ;
    dct:spatial "India" ;
    skos:broadMatch ex:Forest ;
    skos:definition "“Reserved Forest” means any area which is constituted as reserved forest under the Assam Forest Regulation, 1891 as adopted"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "INDIA-Mizoram 2010" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "State"@en .

ex:Forest_1299 a skos:Concept ;
    dct:creator "Papua" ;
    dct:date "2002"^^xsd:gYear ;
    dct:source "http://74.125.93.132/search?q=cache:bwzUkrDvEFsJ:www.papuaweb.org/dlib/lap/sullivan/perdasi-perdasus/forestry.rtf+%22forest+means%22&cd=215&hl=en&ct=clnk&gl=us&client=safari"^^xsd:anyURI ;
    dct:spatial "Indonesia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest area means a certain area which is designated and or stipulated by government to be retained as permanent forest"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Indonesia-Papua 2002" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "State"@en .

ex:Forest_13 a skos:Concept ;
    dct:source "http://www.biology-online.org/dictionary/Forest"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A large extent or precinct of country, generally waste and woody, belonging to the sovereign, set apart for the keeping of game for his use, not inclosed, but distinguished by certain limits, and protected by certain laws, courts, and officers of its own"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "General"@en .

ex:Forest_130 a skos:Concept ;
    dct:source "http://www.enchantedlearning.com/subjects/plants/glossary/indexf.shtml"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "An area in which trees are the dominant plant"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_1300 a skos:Concept ;
    dct:creator "Philippine Palawan" ;
    dct:date "1992"^^xsd:gYear ;
    dct:source "http://thelawofnature.ph/downloadables/legal-arsenal/CHAPTER_2-_LAND.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest land includes the public forest, the permanent forest or forest reserves, and forest reservations. Public forest is the mass of lands of the public domain which has not been subject to the present system of classification for the determination of which lands are needed for forest purposes and which are not. Permanent forest or forest reserves refers to those lands of the public domain which have been the subject of the present system of classification and declared as not needed for forest purposes"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Philippine Palawan 1992" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "State"@en .

ex:Forest_1301 a skos:Concept ;
    dct:creator "UK-Northern" ;
    dct:date "1977"^^xsd:gYear ;
    dct:source "http://www.forestserviceni.gov.uk/forest-service-bye-laws.pdf"^^xsd:anyURI ;
    dct:spatial "Ireland" ;
    skos:broadMatch ex:Forest ;
    skos:definition "the “Forest” means the lands under the control of the Department of Agriculture of Northern Ireland"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UK-Northern Ireland-1977" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "State"@en .

ex:Forest_1302 a skos:Concept ;
    dct:creator "USA-STATE-Alaska" ;
    dct:source "http://www.Colorado.Edu/INSTAAR/TEAML/atlas/chapters/definitions.html#Forest"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "In the Preliminary Classification for Alaskan Vegetation, vegetation with at least a 10% crown cover by trees; i.e., single stemmed woody plants at least 5 m in height at maturity"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Alaska" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "State"@en .

ex:Forest_1303 a skos:Concept ;
    dct:creator "USA-STATE-Hawaii" ;
    dct:date "2009"^^xsd:gYear ;
    dct:source "http://www.law.cornell.edu/uscode/16/usc_sec_16_00004503---b000-.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "The term “Forest” means the Hawaii Experimental Tropical Forest"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Hawaii 2009" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "State"@en .

ex:Forest_1304 a skos:Concept ;
    dct:creator "USA-STATE-Illinois" ;
    dct:date "1990"^^xsd:gYear ;
    dct:source "http://dnr.state.il.us/LEGAL/ADOPTED/1537.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"Forest\" means an area whose principal crop is trees. Illinois. 1990"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Illinois 1990" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "State"@en .

ex:Forest_1305 a skos:Concept ;
    dct:creator "USA-STATE-Kansas" ;
    skos:broadMatch ex:Forest ;
    skos:definition "An area of land proclaimed to be forest under a Forest Act or Ordinance. \"Terminology of Forest Science, Technology, Practice & Products\" SAF, 1971. Robert L. Atchison ratchiso@oznet.ksu.edu"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Kansas" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "State"@en .

ex:Forest_1306 a skos:Concept ;
    dct:creator "USA-STATE-Mississippi" ;
    dct:date "2008"^^xsd:gYear ;
    dct:source "http://msucares.com/pubs/publications/p1250.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "From a management standpoint, a forest is a collection of stands administered as a unit"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Mississippi 2008" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "State"@en .

ex:Forest_1307 a skos:Concept ;
    dct:creator "USA-STATE-Oregon" ;
    dct:date "1997"^^xsd:gYear ;
    dct:source "http://landru.leg.state.or.us/ors/308.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A parcel of land of more than 10 acres that has been zoned in the comprehensive plan for exclusive farm use, forest use or farm and forest use and that is, as of the assessment date for which value for the forest homesite is being determined: (A) Land that has as its highest and best use the growing and harvesting of trees of a marketable species; (B) Land that has been designated as forestland under ORS 321.257 to 321.381 or 321.805 to 321.825; or (C) Land that has been classified under ORS 321.705 to 321.765. 1997 Oregon Revised Statutes"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Oregon 1997" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "State"@en .

ex:Forest_1308 a skos:Concept ;
    dct:creator "USA-STATE-Oregon" ;
    dct:source "http://www.odf.state.or.us/Landbase/MgtRule.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Lands acquired under ORS 530.010 to530.040"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Oregon" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "State"@en .

ex:Forest_1309 a skos:Concept ;
    dct:creator "USA-STATE-Wisconsin" ;
    dct:date "1912"^^xsd:gYear ;
    dct:source "http://folio.legis.state.wi.us/cgi-bin/om_isapi.dll?clientID=171211&advquery=forest&headingswithhits=on&infobase=stats.nfo&record="^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "State forests lands include all lands granted to the state by an act of congress entitled, \"An act granting lands to the state of Wisconsin for forestry purposes,\" approved June 27, 1906; all lands donated to the state by the Nebagamon Lumber Company for forestry purposes; all lands acquired pursuant to chapter 450, laws of 1903, chapter 264, laws of 1905, chapter 638, laws of 1911, and chapter 639, laws of 1911, or under ss. 1494-41 to 1494-62, 1915 stats., and all lands subsequently acquired for forestry purposes. Unless an island is designated as state forest land by the department, state forest lands do not include lands granted to the state by an act of congress entitled, \"An act granting unsurveyed and unattached islands to the state of Wisconsin for forestry purposes,\" approved August 22, 1912. The department may designate as state forest lands any lands within state forest boundaries which were purchased with other conservation funds and where forestry would not conflict with a more intensive use. 28.02(1) {D}&recordswithhits=on&zz"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Wisconsin 1912" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "State"@en .

ex:Forest_131 a skos:Concept ;
    dct:source "http://www.forestry.sa.gov.au/pdf/glossary.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "An area of land covered by trees; forests can be natural or planted"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_1310 a skos:Concept ;
    dct:creator "NSW" ;
    dct:source "http://155.187.10.12/glossary/fl-nsw.html"^^xsd:anyURI ;
    dct:spatial "Australia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "A plant community dominated by long-boled trees in close proximity. cf. woodland. Flora of New South Wales"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Australia-NSW" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_1311 a skos:Concept ;
    dct:creator "–NSW" ;
    dct:source "http://www.dlwc.nsw.gov.au/care/veg/pdfs/clearing_vegtypes_mar02.pdf"^^xsd:anyURI ;
    dct:spatial "Australia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Closed Forest vegetation where trees cover more than 80% of the area under application. Open Forest vegetation where the trees cover more than 50% of the area under application"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Australia–NSW" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
