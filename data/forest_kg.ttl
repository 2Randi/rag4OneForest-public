ex:Woodland_81 a skos:Concept ;
    dct:creator ">15cm dbh" ;
    dct:source "http://www.montpellier.inra.fr/safe/publications/communications/Orlando/Policy%20support%20for%20Agroforestry%20in%20the%20European%20Union.pdf"^^xsd:anyURI ;
