ex:Forest_1254 a skos:Concept ;
    dct:creator "Kazakhatan" ;
    dct:source "http://faolex.fao.org/docs/texts/kaz41426E.doc"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"forest\" means a natural complex formed on a certain territory based on the aggregate of trees and shrubs vegetations and other wildlife components interacting with environment and having environmental, economic and social importance"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Kazakhatan" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "National"@en .

