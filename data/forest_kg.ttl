ex:Timberland_1 a skos:Concept ;
    dct:creator "USA-STATE-Florida-Hernando Co" ;
    dct:source "http://www.co.hernando.fl.us/pa/greenbelt.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Must be a minimum of 20 acres in size and in planted pines or a predominantly natural stand of pines. A forestry management plan must be implemented and followed and a copy of the plan kept on file with the Property Appraiser's Office. Larger tracts will be reviewed and approved based on the merchantability of the timber and whether or not management has been sufficient. This guideline covers both hard wood and mixed tracts. Christmas tree production will be considered as nursery land"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Florida-Hernando Co." ;
    skos:prefLabel "Timberland"@id ;
    skos:scopeNote "Land use"@en,
        "State"@en .

