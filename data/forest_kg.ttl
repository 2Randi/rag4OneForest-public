    skos:broadMatch ex:Deforestation ;
    skos:definition "The removal of forest stands. , and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_155 a skos:Concept ;
    dct:date "2001"^^xsd:gYear ;
    dct:source "http://www.hwwa.de/Projekte/Forsch_Schwerpunkte/FS/Klimapolitik/PDFDokumente/Michaelowa,%20Koch%20(2001).pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
