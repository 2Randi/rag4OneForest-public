    skos:broadMatch ex:Forest ;
    skos:definition "“Forest land” means any uncultivated land in Saskatchewan on which trees or shrubs are growing or standing or any barren, dry marsh or bog, and includes any highway over any such lands"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Canada-Saskatchewan" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
