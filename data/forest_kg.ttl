ex:Unforested_1 a skos:Concept ;
    skos:broadMatch ex:NonForest ;
    skos:definition "[adj.] Not covered with forest; \"unforested lands.\""@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "Unforested"@en .

ex:WoodedLand_1 a skos:Concept ;
    dct:spatial "Australia" ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Land with vegetation with a projected foliage cover of less than 10% (this is equivalent to a crown cover of 0.25 to 20%) and included Tall, Medium and Low Trees (>30, 10-30 and <10 m respectively) and Tall Shrubs (>2 m). The Tall Shrubs category excludes eucalypts as these are included under 'forest' as Mallees.\" Karol.Andrzejewski@affa.gov.au NFI (1999) definition of Other Wooded land"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Australia" ;
    skos:prefLabel "Wooded Land"@en .

ex:WoodlandOpen_1 a skos:Concept ;
    dct:creator "Isaac Mapaure. Researchgate. 23 Jan" ;
    dct:date "2014"^^xsd:gYear ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Woodland, open- An open woodland - canopy cover of 20-60% and a well developed grass layer. .g"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Isaac Mapaure. Researchgate. 23 Jan 2014" ;
    skos:prefLabel "Woodland open"@en .

ex:WoodlandOpen_2 a skos:Concept ;
    dct:source "https://www.researchgate.net/publication/229505636_The_impact_of_shrub_encroachment_on_savanna_bird_diversity_from_local_to_regional_scale"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "woodland, open OW = grasses plus other annual herbs, trees > 5 m representing < 25%"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "woodland open"@af .

ex:WoodlandShrubby_1 a skos:Concept ;
    dct:creator "SW = mix of grasses, shrubs and trees > 5 m, with woody cover representing between 25 and 50%" ;
    dct:source "https://www.researchgate.net/publication/229505636_The_impact_of_shrub_encroachment_on_savanna_bird_diversity_from_local_to_regional_scale"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "woodland, shrubby"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "SW = mix of grasses, shrubs and trees > 5 m, with woody cover representing between 25 and 50%" ;
    skos:prefLabel "woodland shrubby"@en .

ex:Woodland_1 a skos:Concept ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Woods, woodlands, woodlot are often used interchangably with forest and vice versa. As of 19 May 2026 there were 169 definitions listed for woodlands"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_10 a skos:Concept ;
    dct:creator "Ontario" ;
    dct:date "1990"^^xsd:gYear ;
    dct:source "http://www.ontarionature.org/pdf/Significant_Woodlands_Guidelines(Draft%20Aug%202004).pdf"^^xsd:anyURI,
        "https://www.ontario.ca/laws/statute/90f26"^^xsd:anyURI ;
    dct:spatial "Canada" ;
    skos:broadMatch ex:Woodland ;
    skos:definition "“woodlands” means land with at least, (a) 1,000 trees, of any size, per hectare, (b) 750 trees, measuring over five centimetres in diameter, per hectare, (c) 500 trees, measuring over 12 centimetres in diameter, per hectare, or (d) 250 trees, measuring over 20 centimetres in diameter, per hectare, ut does not include a cultivated fruit or nut orchard or a plantation established for the purpose of producing Christmas trees. (“terrain boisé”) 1998, c. 18, Sched. I, s. 20; 2000, c. 26, Sched. L, s. 4 (1); 2002, c. 17, Sched. C, s. 12 (1); 2009, c. 33, Sched. 22, s. 4 (1). (CANADA-Ontario 1998) Woodland (including “forest”) - A treed community with at least 34% tree cover. (Ecological Land Classification for southern Ontario, O.M.N.R., 1998"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Canada Ontario1990" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_100 a skos:Concept ;
    dct:source "http://www.echonet.org/Technotes/AgroforestryPrinciples.html#definitions"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "An area planted to trees for fuel, or timber"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_101 a skos:Concept ;
    dct:source "http://glossary.gardenweb.com/glossary/woodland.html"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "An area primarily covered with trees"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_102 a skos:Concept ;
    dct:source "http://www.becominghuman.org/resources/glossary.php?mode=definition&termID=268"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "An environment characterized by patchy stands of relatively short trees separated by grassy areas"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_103 a skos:Concept ;
    dct:source "http://www.worldagroforestrycentre.org/InformationResources/T-V.asp"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "An open stand of trees > 8 metres high and with a canopy cover of 40% or more, usually among grasses. Woodland is often described by its dominant species, for example, 'Acacia woodland', 'Acacia-Themeda woodland', 'Combretum woodland'"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_104 a skos:Concept ;
    dct:source "http://gisdasc.kgs.ukans.edu/metadata/landcover.html"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Any wooded areas having a canopy closure of 50% and greater"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_105 a skos:Concept ;
    dct:source "http://info.sjc.ox.ac.uk/forests/glossary.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Area occupied by trees"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_106 a skos:Concept ;
    dct:source "http://www.newberry.org/k12maps/glossary/index.html"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Area of land on which many trees grow"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_107 a skos:Concept ;
    dct:source "http://www.wrm.org.uy/actors/WB/1991policy3.html"^^xsd:anyURI,
        "https://www.uni-hohenheim.de/i490a/teaching/M4901-430/ws_03_04/reading_materials/New_Neef_Schwarzmeier_Studie.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Area that has some forest characteristics but does not meet the definition of forest given above. Includes areas occupied by windbreaks groups of trees, fallow land, and shrubland. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_108 a skos:Concept ;
    dct:creator "Köhl and Päivinen" ;
    dct:date "1996"^^xsd:gYear ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Area with tree crown cover of 5-20% of the surface. Trees should be able to grow to a height of more than 7 m. Included are 1) the area with young trees or coppice able to form open forest in the future, 2) area of potentially open forest which is temporarily unstocked due to regeneration or damage. Forest roads, firebreaks etc., as well as nurseries and storages less than 0.5 ha are included in open forest area"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Köhl and Päivinen 1996" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_109 a skos:Concept ;
    dct:source "http://www.gap.uidaho.edu/handbook/LandCoverMapping/UNESCO/"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Areas dominated by trees with a total canopy cover of 26-60 %, most tree crowns not touching each other. An herbaceous or shrub understory, or both, are usually present. An open stand of trees, sometimes called \"open forest.\""@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_11 a skos:Concept ;
    dct:creator "Ontario-Peel Region" ;
    dct:source "http://www.peelregion.ca/planning/officialplan/pdfs/P-09-02%20ROPA%2021%20Appendix%20I%20January%2027%202009%20-%202.pdf"^^xsd:anyURI ;
    dct:spatial "Canada" ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Woodlands are complex ecosystems comprised of communities of trees, shrubs, ground vegetation and immediate environmental conditions on which they depend. Woodlands are further defined as any area greater than 0.5 ha that has:a) a tree crown cover of over 60% of the ground, determinable from aerial photography, or b) a tree crown cover of over 25% of the ground, determinable from aerial photography, together with on-ground stem estimates of at least: • 1,000 trees of any size per hectare, or • 750 trees measuring over five centimetres in diameter, per hectare, or • 250 trees measuring over 20 centimetres in diameter, per hectare (densities based on the Forestry Act of Ontario 1998), Treed portions with less than the required stocking level will be considered part of the woodland as long as the combination of all treed units in the overall connected treed area meets the required stocking level. Woodlands experiencing changes such as harvesting, blowdown or other tree mortality are still considered woodlands. Such changes are considered temporary whereby the forest still retains its long-term ecological value. And, which have a minimum average width of 40 metres or more measured to crown edges. Woodlands include cultural woodlands, cultural savannahs and plantations except if the plantation is: a) managed for production of fruits, nuts, Christmas trees or nursery stock; b) managed for tree products with an average rotation of less than 20 years (e.g. hybrid willow or poplar); or c) established and continuously managed for the sole purpose of complete removal at rotation, as demonstrated with documentation acceptable to the Region or area municipality, without a woodland restoration objective"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Canada-Ontario-Peel Region" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_110 a skos:Concept ;
    dct:source "http://www.nafi.com.au/k12/ourforests/glossary.html"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Areas of trees whose tops collectively shade less that 30 percent of the ground"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_111 a skos:Concept ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Areas with an annual yield capacity between 0.1 and 1 m3 wood including bark per hectare under favourable stand conditions. As for productive forest land, consideration should be given to yield capacity and not a temporary absence of trees. [From: Stein Tomter stein.tomter@tor.nijos.no Date: Mon, 15 Jun 1998 14:50:20 +0200]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_112 a skos:Concept ;
    dct:creator "en" ;
    dct:source "http://mirror.globe-germany.de/sda-bin/wt/ghp/tg+L(en)+P(landcover/MUCglossary-full"^^xsd:anyURI,
        "http://www.geery.com/Norfork_MUC.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Comprised of open stands of trees more than 5 meters tall with crowns not touching. Greater than 40% of the ground is covered by the tree canopy. Definitions for Mainly Evergreen Woodland, Mainly Deciduous Woodland, and Extremely Xeromorphic Woodland are similar to forest definitions with sparser stocking of individual trees. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "en" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_113 a skos:Concept ;
    dct:source "http://mcmcweb.er.usgs.gov/phil/rbradford-paper.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Forest land and includes deciduous, evergreen, and mixed forest land and orchards"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_114 a skos:Concept ;
    dct:source "http://www.or.blm.gov/Medford/medford/glossary.html"^^xsd:anyURI,
        "http://www.streamnet.org/pub-ed/ff/Glossary/glossaryforest.html"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Forest land producing trees not typically used as saw timber products and not included in calculation of the commercial forest land ASQ. Medford Record of Decision and Resource Management Plan and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_115 a skos:Concept ;
    dct:source "http://www.streamnet.org/pub-ed/ff/Glossary/glossaryforest.html"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Forest land producing trees not typically used as saw timber products and not included in calculation of the commercial forest land allowable sale quantity"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_116 a skos:Concept ;
    dct:source "http://www.globaled.org/issues/152/a.html"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "In a woodland, trees are spaced further apart. In a forest, the treetops touch each other to form a canopy"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_117 a skos:Concept ;
    dct:source "http://www.botany.uwc.ac.za/envfacts/facts/deforestation.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "In a woodland, trees grow far apart, so that the canopy is open. In a forest the crowns of individual trees touch to form a single canopy"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_118 a skos:Concept ;
    dct:creator "see also: savanna" ;
    dct:source "http://explanation-guide.info/meaning/Forest.html"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "In ecological terms, a forest may be differentiated from a woodland: a forest is considered to have a more or less closed canopy, where the branches and foliage of trees meet or interlock; a woodland is considered to have an open canopy, where some sunlight penetrates between the trees"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "see also: savanna" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_119 a skos:Concept ;
    dct:source "http://www.arcticatlas.org/glossary/index"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "In the Preliminary Classification for Vegetation of Alaska, forest vegetation with 10 to 25% crown cover of the tree crowns"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_12 a skos:Concept ;
    dct:creator "Czech Republic" ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Land covered by trees and/or shrubs which is not destined to fulfil forest functions e.g., the belts on river banks. (European Communities 1997b - p. 1225"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Czech Republic" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_120 a skos:Concept ;
    dct:source "http://agglossary.uaex.edu/viewWGlossary1.asp"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Includes natural or planted woodlots or timber tract, cutover and deforested land with young growth that have or will have value for wood products, land planted for Christmas tree production, and pastured woodland"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_121 a skos:Concept ;
    dct:source "http://www.taxbar.com/tr/jaggers.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Land covered with wood i.e. trees; a wooded region or piece of ground. Shorter Oxford English Dictionary"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_122 a skos:Concept ;
    dct:source "http://www.co.hunterdon.nj.us/depts/taxboard/farmland.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Land devoted to the growing of trees"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_123 a skos:Concept ;
    dct:creator "or equivalent stocking level" ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Land either with a tree crown cover of 5-10 percent of trees able to reach a height of 5 m at maturity in situ; or a crown cover (or equivalent stocking level) of more than 10 percent of trees not able to reach a height of 5 m a maturity in situ (e.g. dwarf or stunted trees) and shrub or bush cover. Excludes: Areas having the tree, shrub or bush cover specified above but of less than 0.5 ha and width of 20 m, which are classed under \"other land\"; Land predominately used for agricultural practices (UN-ECE 1997"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "or equivalent stocking level" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_124 a skos:Concept ;
    dct:source "http://www.anzlic.org.au/icsm/topo/tddsect3.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Land having a cover of trees, shrubs, or both"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_125 a skos:Concept ;
    dct:creator "Wt" ;
    dct:source "http://www.usangu.org/reports/landres.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Land supporting a stand of trees up to 20 m in height, with an open or continuous but not thickly interlaced canopy, and a canopy cover of not less than 20%. Shrubs, if present, constitute less than one-tenth of the canopy cover. Grasses and other herbs dominate the ground cover. Epiphytic ferns are rare. Often subject to periodic burning. Tree thicket or coppice woodland (Wc) can be recognised. Sub-types by genera e.g. Brachystegia . Julbernardia woodland; Acacia seyal woodland"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Wt" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_126 a skos:Concept ;
    dct:source "http://www.tnw.org.uk/Note17.html"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Land that is mostly covered with dense growths of trees and shrubs. A generalised term"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_127 a skos:Concept ;
    dct:source "http://src.doc.ic.ac.uk/packages/Project-Gutenberg/etext99/world97.txt"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Land under open stands of trees. Paraphrased from"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_128 a skos:Concept ;
    dct:source "http://www.esd.ornl.gov/projects/qen/adams3.html"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Leaf /branch cover above 8m off ground, 60%-20%"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_129 a skos:Concept ;
    dct:source "http://www.extension.iastate.edu/naturemapping/naturemapping_process/habitat_codes.html#forest"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Open stands of tree species, 25-60% canopy cover"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_13 a skos:Concept ;
    dct:creator "East Africa" ;
    dct:date "1973"^^xsd:gYear ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Land with an open cover of trees, the crowns of which do not form a thickly interlaced canopy, and which as a rule is leafless for some period during the year. Climbers may be present. file:///C:/Users/Owner/Downloads/Friis_Forest_vegetation.pdf"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "East Africa 1973" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_130 a skos:Concept ;
    dct:source "http://www.birdlist.org/cam/themes/Volume_I_s.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Open stands of trees – Formed by trees at least 5 m tall, with most of their crowns not touching each other but covering at least 30% of the sky"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_131 a skos:Concept ;
    dct:creator "25- 59% cover" ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Open stands of trees with crowns not usually touching . www.tgic.state.tx.us/tgic/documents/plans/lulc-report.pdf"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "25- 59% cover" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_132 a skos:Concept ;
    dct:creator "generally forming 25-60% cover" ;
    dct:source "http://www.cws-scf.ec.gc.ca/fff/GLOSS_E.HTM#Forest"^^xsd:anyURI,
        "http://www.wec.ufl.edu/coop/gap/moreinfo.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Open stands of trees with crowns not usually touching . Canopy tree cover may be less than 25% in cases where it exceeds shrub, dwarf-shrub, herb, and nonvascular cover, respectively. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "generally forming 25-60% cover" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_133 a skos:Concept ;
    dct:source "http://192.83.171.71/newcrons/navig/en/theme8/milieu/10fo/notmeth.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Other wooded areas are the wooded formations of any kind less than 0,5 ha in size, as well as open woodlands having a crown density less than 20%, areas of brushwood, shrubland, stunted trees etc"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_134 a skos:Concept ;
    dct:creator "Päivinen et al" ;
    dct:date "1994"^^xsd:gYear ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Other wooded land - Land under natural or planted stands of trees, whether productive or not and exceeding 0.5 ha in extent. It includes areas occupied by roads, small cleared tracts and other small open areas within the forest which constitute an integral part of the forest"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Päivinen et al. 1994" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_135 a skos:Concept ;
    dct:creator "generally called forests" ;
    dct:source "http://www.ukwas.org.uk/standard/certification_standard/glossary.html"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Predominantly tree covered land whether in large tracts or smaller units (known by a variety of terms such as woodlands, woods, copses and shelterbelts"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "generally called forests" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_136 a skos:Concept ;
    dct:source "http://www.fsc-uk.demon.co.uk/Appendices.html"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Predominately tree covered land. Paraphrased from"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_137 a skos:Concept ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Small forest, a forest composed of young trees, or a forest from which fuelwood is cut. Colliers Encyclopedia"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_138 a skos:Concept ;
    dct:creator "Fergusen" ;
    dct:date "1916"^^xsd:gYear ;
    skos:broadMatch ex:Woodland ;
    skos:definition "The tract of wooded land which is maintained primarily to furnish fuel, posts, lumber and other wood products for use on the farm"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Fergusen 1916" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_139 a skos:Concept ;
    dct:source "http://agcensus.mannlib.cornell.edu/glossary.php#woodland"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "This category includes natural or planted woodlots or timber tracts, cutover and deforested land with young growth which has or will have value for wood products, and woodland pastured. Land covered by sagebrush or mesquite was to be reported as other pastureland and rangeland or other land. Land planted for Christmas tree production was to be reported in cropland harvested, and land in tapped maple trees reported as woodland not pastured"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_140 a skos:Concept ;
    dct:creator "ToF" ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Trees outside forests . Trees and tree environments on lands not defined as forest or other wooded lands. Include: (a) groups of trees covering an area of less 0.5 ha, including lines and shelterbelts along infrastructure features and agricultural fields; (b) scattered trees in agricultural landscapes; (c) tree plantations mainly for other purposes than wood, such a fruit orchards and palm plantations; and trees in parks and gardens and around buildings. ToF are not assigned an area in the overall land use classification, but occurs inside Other wooded land and Other land. Although the definition of ToF is based on the trees, the concept includes also the site and other vegetation at the location. (FAO 2000b"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "ToF" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_141 a skos:Concept ;
    dct:source "http://www.conservation.state.mo.us/landown/wild/guide/"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Upland and bottomland forests or idle areas over grown with trees having canopy greater than 10 percent and at least 100 feet wide. Fence rows and woody draws are not classified as woodland but are included as features in the cropland, pature/hayland or old field habitat types"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_142 a skos:Concept ;
    dct:creator "if closed" ;
    dct:source "http://www.fs.fed.us/research/publications/forest_production_for_tropical_america/appendix_d.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Vegetation dominated by woody plants, and included \"forest\" , \"bushwood\" (if shrubs were more abundant than trees), and \"shrubwood\" (if entirely of shrubs"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "if closed" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_143 a skos:Concept ;
    dct:source "http://www.arcticatlas.org/glossary/index"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Vegetation in which trees, often small and characteristically short-boled in relation to their crown depth, are present but form only on open or sparse canopy, the intervening areas being occupied by shrubs or herbs"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_144 a skos:Concept ;
    dct:source "http://www.goaforest.com/regulation/body_preservoftrees2.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Wood lot means any piece of land of which trees in each hectare being not less than twenty-five"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_145 a skos:Concept ;
    dct:creator "6" ;
    dct:source "http://home.gdbc.gov.bc.ca/TRIM/IDM_Project_Riparian_Zone_specs.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Wooded area - A land area which is at least six percent covered with trees that are two (2) metres or more in height"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "6" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_146 a skos:Concept ;
    dct:source "http://www.tpesp.es/informe/HTMNF/COMPENDI/CHAP8.HTM"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Wooded area - Corresponds to the FAO definition of forest and woodland. It refers to land under natural or planted stands of trees, whether productive or not, and includes land from which forests have been cleared but that will be reforested in the foreseeable future"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_147 a skos:Concept ;
    dct:source "http://192.83.171.71/newcrons/navig/en/theme8/milieu/10fo/notmeth.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Wooded area consists of forest area and other wooded areas"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_148 a skos:Concept ;
    dct:source "http://www.asiaforestnetwork.org/glossary.html#gft"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Woodland - woody vegetation formations with scattered trees generally with less than 40% crown cover, also known as open forests"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_149 a skos:Concept ;
    dct:source "http://www.millenniumassessment.org/documents/document.290.aspx.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Woodland refers to the type of land cover characterized by trees and shrubs"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_150 a skos:Concept ;
    dct:source "http://www.savannas.org.uk/savdef.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Woodlands - 50-100% tree canopy cover, and a graminaceous layer"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_151 a skos:Concept ;
    dct:source "http://web.uccs.edu/geogenvs/ges100-online/Chapt11.doc"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Woodlands - tree-dominated plant association. Trees spaced more widely apart. Ground cover not inhibited by lack of sunlight. Environment drier than forests"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_152 a skos:Concept ;
    dct:source "http://www.forestry.sa.gov.au/pdf/glossary.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Woodlots: term used for forest plantings on farms for wood production; also see farm forestry"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_17 a skos:Concept ;
    dct:date "2011"^^xsd:gYear ;
    dct:source "http://www6.nancy.inra.fr/lef_eng/LEF-Data-Group/Tools/Glossary"^^xsd:anyURI ;
    dct:spatial "France" ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Woods: Area of woodland exceeding 4 hectares with trees able to reach a height greater than 5 meters at maturity in situ, a tree canopy cover of more than 10% and a width of at least 20 meters. Woods are part of the forest area (NFI new inventory method) (2011"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "France 2011" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_18 a skos:Concept ;
    dct:creator "ICSU" ;
    dct:source "http://www.icsu-scope.org/downloadpubs/scope56/Chapter04.html"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Woodlands have 50-100% tree canopy cover by trees, and a sometimes sparse, but always significant gramineous layer"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "ICSU" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_19 a skos:Concept ;
    dct:date "2005"^^xsd:gYear ;
    dct:source "http://formin.finland.fi/public/download.aspx?ID=15959&GUID=%7B88EFD0B8-9F47-4528-A24F-66DDE0CFE370%7D"^^xsd:anyURI ;
    dct:spatial "Kenya" ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Woodland means an open stand of trees less than ten metres tall which has come about by natural regeneration"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Kenya 2005" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_2 a skos:Concept ;
    dct:creator "NSW" ;
    dct:source "http://www.forest.nsw.gov.au/education/glossary/default.asp#Ltr_W"^^xsd:anyURI ;
    dct:spatial "Australia" ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Plant communities dominated by trees whose crowns shade less than 30 per cent of the ground; wooded country with tree canopy covering an average of 10 to 30 per cent of the area; vegetation type that covers the driest and poorest soil areas of New South Wales"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Australia - NSW" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_20 a skos:Concept ;
    dct:creator "Millennium Eciosystem Assessment" ;
    skos:broadMatch ex:Woodland ;
    skos:definition "woodland’’ refers to the type of land cover characterized by trees and shrubs. www.maweb.org/documents/document.290.aspx.pdf. From Stefania Pizziran Resarch Gate 4 Feb 2014"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Millennium Eciosystem Assessment" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_21 a skos:Concept ;
    dct:creator "Miombo" ;
    dct:source "http://www.africa-insites.com/zambia/travel/General/vegetati.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Any woodland which is dominated by species of three related genera in the family Leguminosae: Brachystegia, Julbernardia and Isoberlinia. Miombo is regarded as woodland, in spite of its closed canopy (with crowns touching), because of its light foliage which allows sufficient light to reach the ground to support a continuous ground cover of grasses and other herbs. Source"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Miombo" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_22 a skos:Concept ;
    dct:creator "NASDA" ;
    dct:source "http://www.nasda-hq.org/NASDA_NASS/docs/EDUCATIO/REFERENC/TERMS___/TERMSDEF.PDF"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Wood lots or timber tracts, natural or planted. Exclude cropland (bearing orchards, etc.) and pasture, but include woodland occasionally grazed"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "NASDA" ;
    skos:prefLabel "Woodland"@en .

ex:Woodland_23 a skos:Concept ;
    dct:spatial "Norway" ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Other wooded land then corresponds to: \"Non-productive forest land\" and \"wooded mire\". Non-productive forest land should have an average potential production of between 0.1 and 1.0 m3 per ha and year, regardless of the current stocking and it should have mineral soil. Wooded mire has the same production potential as non-productive forest land, with a peat soil. From: marit-viktoria.pettersen@sftospost.md.dep.telemax.no (European Communities 1997b - p. 832"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Norway" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_24 a skos:Concept ;
    dct:creator "Oak" ;
    dct:source "http://www.devon-cc.gov.uk/biodiversity/oakwood.html"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Those Devon woods which are dominated by English oak, sessile oak or the hybrids between the two. Devon Biodiversity Action"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Oak" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_25 a skos:Concept ;
    dct:creator "Remote Sensing" ;
    dct:source "http://content.alterra.wur.nl/Internet/webdocs/ilri-publicaties/publicaties/Pub36/Proceeding%20of%20the%20workshop%20leeg-h3.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Area with tree crown cover of 5-20% of the surface. Trees should be able to grow to a height of more than 7 m (Koehl and Paivinen 1996) Woodlands, almost exclusively of Aleppo Pine, with at least 20% ground cover by trees"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Remote Sensing" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_26 a skos:Concept ;
    dct:spatial "Russian Federation" ;
    skos:broadMatch ex:Woodland ;
    skos:definition "OWL = includes areas of shrubs and bushes. For FRA 2000 - Source: UN/ECE 2000 p 85"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Russian Federation" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_29 a skos:Concept ;
    dct:spatial "South Africa" ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Tree canopy cover between 40-70%. A closed-to-open canopy community, typically consisting of a single tree canopy layer and a herb (grass) layer. Thompson 1996? www.sac.co.za/geoinfo/ field_guide.htm"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "South Africa" ;
    skos:prefLabel "Woodland"@en .

ex:Woodland_3 a skos:Concept ;
    dct:creator "– NSW" ;
    dct:source "http://www.dlwc.nsw.gov.au/care/veg/pdfs/clearing_vegtypes_mar02.pdf"^^xsd:anyURI ;
    dct:spatial "Australia" ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Woodland vegetation where trees cover 20-50% of the area under application (Crown separation ratio is 0.25-1). The trees are native but the shrubs or grasses may be native or exotic. Open Woodland where individual trees cover 0.2 - 20% of the area under application (Crown separation ratio is 1-20). The trees are native but the shrubs or grasses may be native or exotic"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Australia – NSW" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_30 a skos:Concept ;
    dct:creator "SRM" ;
    skos:broadMatch ex:Woodland ;
    skos:definition "1974) A land area occupied by trees, a forest, woods. (SRM 1974"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "SRM" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_31 a skos:Concept ;
    dct:creator "SRM" ;
    skos:broadMatch ex:Woodland ;
    skos:definition "1980) An area on which trees often small and characteristically short-boled relative to their depth of crown, usually form an open canopy, and the intervening areas are occupied by herbaceous and shrubby vegetation. (SRM 1980"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "SRM" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_32 a skos:Concept ;
    dct:date "2001"^^xsd:gYear ;
    dct:source "http://www.landcoalition.org/sites/default/files/legacy/legacypdf/08_gtz_land_tenure_systems.pdf"^^xsd:anyURI ;
    dct:spatial "Thailand" ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Other wooded area; woodland. Area that has some forest characteristics but does not meet the definition of forest given above. Includes areas occupied by windbreaks groups of trees, fallow land, and shrubland"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Thailand 2001" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_33 a skos:Concept ;
    dct:creator "Turkey" ;
    dct:date "2012"^^xsd:gYear ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Woodlands are defined as; ‘long-lived copse with the expanding top as a result of growth and overly developed side branches, showing the width growing manner in general, not reaching 8 m in length, at any age or diameter. According to the Regulation of the Forest Cadaster and 2/B Application dated 20.11.2012, (see the article 14, subparagraph B in the regulation"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Turkey 2012" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_34 a skos:Concept ;
    dct:creator "–National Biomass Study" ;
    dct:source "http://cdm.unfccc.int/UserManagement/FileStorage/SDRN4ZBQ7XGTGK2W2TH9Y83L11ANG7"^^xsd:anyURI ;
    dct:spatial "Uganda" ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Woodlands: These are wooded areas where trees and shrubs are predominant. There are wet and dry types. The wet type occurs as a zone along riverine forest and the dry type is found on grasscovered upland areas. To qualify as woodland the average height of the trees must exceed 4 m"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Uganda –National Biomass Study" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_35 a skos:Concept ;
    dct:date "2017"^^xsd:gYear ;
    dct:source "http://www.fao.org/3/a-i7849e.pdf"^^xsd:anyURI ;
    dct:spatial "Uganda" ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Wooded areas where trees and shrubs are predominant. There are wet and dry types. The wet type occurs as a zone along wetlands (riverine forest) and the dry type is found on grass-covered upland areas. To qualify as woodland the average height of the trees must exceed 4 m.” Woodland can be categorized as closed or open woodland according to its canopy cover. Closed woodland has a canopy cover > 40 percent and open woodland has a canopy cover of 10–40 percent"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Uganda 2017" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_36 a skos:Concept ;
    dct:creator "UK" ;
    dct:source "http://www.forestry.gov.uk/website/foreststats.nsf/byunique/sources.html"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "The definition of woodland in United Kingdom forestry statistics is land under stands of trees with a canopy cover of at least 20% (or having the potential to achieve this), including integral open space, and including felled areas that are awaiting restocking. . From Stefania Pizziran Research Gate 4 Feb 2014"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UK" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_37 a skos:Concept ;
    dct:creator "UK" ;
    dct:date "2010"^^xsd:gYear ;
    dct:source "http://www.highweald.org/downloads/publications/1068-rother-district-ancient-woodland-inventory/file.html"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "‘Ancient woodland in England is defined as an area that has been wooded continuously since at least 1600 AD. Ancient woodland is divided into ancient semi-natural woodland and plantations on ancient woodland sites. Both types of stand are classed as ancient woods.’"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UK 2010" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_38 a skos:Concept ;
    dct:creator "UK" ;
    dct:date "2010"^^xsd:gYear ;
    dct:source "http://www.highweald.org/downloads/publications/1068-rother-district-ancient-woodland-inventory/file.html"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Recent woodland (less than 400 years old), is where a wood has either been planted on an area of land, or where trees have been allowed to grow naturally through regeneration, usually as the result of a cessation in land use management"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UK 2010" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_39 a skos:Concept ;
    dct:creator "UK-Halton Borough" ;
    dct:source "http://www2.halton.gov.uk/pdfs/environment/planning/haltonudpappendices"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "An area that is largely occupied by growing trees"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UK-Halton Borough" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_4 a skos:Concept ;
    dct:creator "– South" ;
    dct:source "http://www.atlas.sa.gov.au/atlas1986/2ENVIRONMENT_RESOURCES/5VEGETATION.cfm"^^xsd:anyURI ;
    dct:spatial "Australia" ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Woodland is mapped where the trees are the tallest stratum but the foliage covers less than 30% of the ground"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Australia – South Australia" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_40 a skos:Concept ;
    dct:creator "UN-CCD" ;
    dct:source "http://www.unccd.int/actionprogrammes/asia/national/2000/yemen-eng.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "“Woodland”: Light canopy with single storey of small to medium sized trees with crowns more or less touching and a sparse grass stratum sometimes with herbaceous or shrub vegetation; United Nations Convention to Combat Desertification"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-CCD" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_42 a skos:Concept ;
    dct:creator "UN-ESCO" ;
    dct:date "1993"^^xsd:gYear ;
    dct:source "http://home.comcast.net/~gyde/1993annex3iufro.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Scrub woodland. Stunted woodland less than 8 m tall or vegetation intermediate between woodland and bushland"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-ESCO-1993" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_43 a skos:Concept ;
    dct:creator "UN-ESCO" ;
    dct:date "1993"^^xsd:gYear ;
    dct:source "http://home.comcast.net/~gyde/1993annex3iufro.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Transition woodland. Intermediate between forest and woodland"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-ESCO-1993" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_44 a skos:Concept ;
    dct:creator "UN-ESCO" ;
    dct:date "1993"^^xsd:gYear ;
    dct:source "http://home.comcast.net/~gyde/1993annex3iufro.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Woodland. An open stand of trees at least 8 m tall with a canopy cover of 40% or more. The field layer is usually dominated by grasses"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-ESCO-1993" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_48 a skos:Concept ;
    dct:creator "UN-HCR" ;
    dct:date "2005"^^xsd:gYear ;
    dct:source "http://postconflict.unep.ch/liberia/displacement/documents/UNHCR_IUCN_Forest_Management_Refugee_Returnee_Situations.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Open stand of trees up to approximately 18 metres in height in which tree crowns cover at least 30 per cent of the land area but are, generally, not overlapping. . UNHCR 2005"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-HCR 2005" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_49 a skos:Concept ;
    dct:source "http://www.forestry.gov.uk/forestry/HCOU-4X2K5J"^^xsd:anyURI ;
    dct:spatial "United Kingdom" ;
    skos:broadMatch ex:Woodland ;
    skos:definition "An area of trees, often used to describe small areas of deciduous trees. It can, however, also be used for larger areas and areas planted with conifers"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "United Kingdom" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_5 a skos:Concept ;
    dct:creator "Tasmania" ;
    dct:source "http://www.dpiw.tas.gov.au/inter.nsf/Attachments/LJEM-6K32GF/$FILE/Glossary,%20Appendices,%20Index.pdf"^^xsd:anyURI ;
    dct:spatial "Australia" ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Vegetation with trees more than 5 m high, and solid canopy cover of between 5% and 50%"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Australia - Tasmania" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_50 a skos:Concept ;
    dct:source "http://www.communities.gov.uk/documents/planningandbuilding/pdf/144275.pdf"^^xsd:anyURI ;
    dct:spatial "United Kingdom" ;
    skos:broadMatch ex:Woodland ;
    skos:definition "An area of trees, where a tree is a woody species capable of achieving >5m in height and 25% canopy cover under favourable growing conditions"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "United Kingdom" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_51 a skos:Concept ;
    dct:source "http://www.forestry.gov.uk/website/ForestStats2006.nsf/byunique/glossary.html"^^xsd:anyURI ;
    dct:spatial "United Kingdom" ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Land under stands of trees with a canopy cover of at least 20% (25% in Northern Ireland), or having the potential to achieve this, including integral open space, and including felled areas that are awaiting restocking"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "United Kingdom" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_6 a skos:Concept ;
    dct:date "2008"^^xsd:gYear ;
    dct:source "http://data.daff.gov.au/forestsaustralia/_pubs/sofr2008reduced.pdf"^^xsd:anyURI ;
    dct:spatial "Australia" ;
    skos:broadMatch ex:Woodland ;
    skos:definition "A sparse forest in which the tree crown cover, viewed from above, ranges between 20% and 50% of the land area"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Australia 2008" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_65 a skos:Concept ;
    dct:creator "USA-STATE-Arizona-Santa Cruz Country" ;
    dct:date "2008"^^xsd:gYear ;
    dct:source "https://sonoraninstitute.org/files/pdf/santa-cruz-river-riparian-vegetation-map-final-report-10162008.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Woodlands 10-60 % tree cover"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Arizona-Santa Cruz Country 2008" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_66 a skos:Concept ;
    dct:creator "USA-STATE-Hawaii" ;
    dct:source "http://www.fs.fed.us/psw/publications/documents/psw_gtr076/psw_gtr076.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "A unit of vegetation dominated by trees whose crowns generally are not touching. Plant communities with trees having a crown cover of 25 to 60 percent are considered woodlands"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Hawaii" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_67 a skos:Concept ;
    dct:creator "USA-STATE-Idaho" ;
    dct:date "2009"^^xsd:gYear ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Woodlands and Savannas are dominated by widely-spaced trees including junipers, oaks, mesquite and pines with an understory of grasses and forbs. Woodland ecosystems across the world take the names of the trees that dominate the landscape. Roselle, Lovina et al. 2009. Rangelands – An introduction to Idaho’s Wild Open Spaces. University of Idaho and Idaho Rangeland Resource Commission. 54 p"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Idaho 2009" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_68 a skos:Concept ;
    dct:creator "USA-STATE-Illinois" ;
    dct:source "http://www.gurnee.il.us/municipal_code/pdf_chapters/chapter45.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Woodlands a tract or parcel of land covered wholly or in substantial part with trees and related environs"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Illinois" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_69 a skos:Concept ;
    dct:creator "USA-STATE-na-Board of Tax Review" ;
    dct:source "http://www.in.gov/ibtr/files/07-004-02-1-5-00184.pdf"^^xsd:anyURI ;
    dct:spatial "India" ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Land that has at least 50% canopy cover qualifies as woodland for purposes of assessment. The amount of canopy cover usually is measured from aerial photographs"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Indiana-Board of Tax Review" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_7 a skos:Concept ;
    dct:source "http://www.rfa.gov.au/documents/janis/janis011.html#E9E11"^^xsd:anyURI ;
    dct:spatial "Australia" ;
    skos:broadMatch ex:Woodland ;
    skos:definition "A vegetation type dominated by woody vegetation having a mature or potential mature stand height exceeding 5 metres, with an overstorey canopy cover less than 20%"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Australia" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_70 a skos:Concept ;
    dct:creator "USA-STATE-Kansas" ;
    dct:source "http://www.kdwp.state.ks.us/PDF/EnvSrvs/docs/ESSsbjEvalTrrstrlHbts04.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Woodland is an area having woody plant species that produce canopy cover of at least 25% of the basal area. (2004"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Kansas" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_71 a skos:Concept ;
    dct:creator "USA-STATE-Nevada" ;
    dct:source "http://www.dcnr.nv.gov/nrp/y-tr1nrp.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "1997) Woodland — All forest land consisting of non-timber species not traditionally used for industrial products. Such species include juniper, pinon pine, cottonwood, willow, aspen, as well as others. (Nevada Forest Stewardship Program, Five Year Plan, 1997 -2002, December 1997, NDF Forest Stewardship Coordinating Committee"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Nevada" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_72 a skos:Concept ;
    dct:creator "USA-STATE-Oklahoma-Norman City" ;
    dct:source "http://www.ci.norman.ok.us/planning/greenbelt/pdf_files/GreenDreams.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Woodland forest is a transition zone between prairie and bottomland. It is dominated by shrubs, vigorous grasses,and native tree species"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Oklahoma-Norman City" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_73 a skos:Concept ;
    dct:creator "USA-STATE-Oregon-Portland" ;
    dct:source "http://www.portlandonline.com/shared/cfm/image.cfm?id=106047"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Woodland: Open stands of trees with crowns not usually touching (generally forming 25-60% of cover). Canopy tree cover may be less than 25% in cases where it exceeds shrub, dwarf-shrub, herb, and nonvascular cover, respectively. Natural Resource Inventory vegetation mapping project City of Portland Bureau of Planning. 18 p"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Oregon-Portland" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_74 a skos:Concept ;
