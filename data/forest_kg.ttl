ex:Scrubland_1 a skos:Concept ;
    dct:spatial "Finland" ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Potential capacity to produce a mean annual increment of at least 0.1 m3/ha but less than 1.0 m3/ha given an optimum tree species mix. (European Communities 1997a - p. 186"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Finland" ;
    skos:prefLabel "Scrubland"@en .

ex:Seminaturalforest_1 a skos:Concept ;
    skos:broadMatch ex:SemiNaturalForest ;
    skos:definition "See: Lund, H. Gyde. 2016 revised. Definitions of old growth, pristine, climax, ancient forests, degradation, desertification, forest fragmentation, and similar terms. [Online publication], Gainesville, VA: Forest Information Services. Misc. pagination. DOI: 10.13140/RG.2.1.2963.73612.10"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "SEMI-NATURAL FOREST"@no .

ex:StandDensity_1 a skos:Concept ;
    dct:source "http://216.239.39.100/search?q=cache:3wFtRKEEkxEC:www.gfc.state.ga.us/Publications/Educational/glossary.pdf+%22stand+density%22++definition+glossary&hl=en&ie=UTF-8#10"^^xsd:anyURI ;
    skos:definition "A measure of the amount of timber growing on a site expressed in number of trees, basal area, or volume"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "Stand Density"@en .

ex:StandDensity_2 a skos:Concept ;
    dct:creator "Wenger" ;
    dct:date "1984"^^xsd:gYear ;
    skos:definition "A quantitative measure of tree stocking usually expressed in terms of the absolute number of trees, basal area, volume, or other criteria on a per unit area basis"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Wenger 1984" ;
    skos:prefLabel "Stand density"@de .

ex:StandDensity_3 a skos:Concept ;
    dct:source "http://www.privateforestry.org.au/glos_o-z.htm"^^xsd:anyURI ;
    skos:definition "The quantity of trees per unit area, usually evaluated in terms of basal area, crown cover and stocking"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "Stand Density"@en .

ex:StandDensity_4 a skos:Concept ;
    dct:source "http://www.dof.state.va.us/mgt/glossary.shtml#S"^^xsd:anyURI ;
    skos:definition "The quantity of trees per unit area. Density usually is evaluated in terms of basal area or percent-crown cover. See basal area, crown cover, stocking"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "Stand Density"@en .

ex:StandDensity_5 a skos:Concept ;
    dct:creator "n.f" ;
    dct:source "http://nfdp.ccfm.org/silviterm/silvi_e/silvitermqtote.htm#S"^^xsd:anyURI ;
    skos:definition "[densité de peuplement ] - A quantitative measurement of tree stocking, expressed in terms of number of trees, total basal area, or volume, per unit of area. More precisely, a measure of the degree of crowding of trees within a stand, commonly expressed by various growing-space ratios of crown length to tree height; crown diameter to dbh or crown diameter to tree height; or of stem spacing to tree height. (3"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "n.f." ;
    skos:prefLabel "stand density"@sv .

ex:Stocking_1 a skos:Concept ;
    dct:source "http://www.dof.state.va.us/mgt/glossary.shtml#S"^^xsd:anyURI ;
    skos:definition "An indication of the number of trees in a stand as compared to the desirable number for best growth and management, such as well-stocked, overstocked, partially stocked"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "Stocking"@sv .

ex:Stocking_2 a skos:Concept ;
    dct:source "http://www.privateforestry.org.au/glos_o-z.htm"^^xsd:anyURI ;
    skos:definition "The number and density of trees in a forest stand. Stands are often classified as understocked, well-stocked or overstocked"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "Stocking"@sv .

ex:Stocking_3 a skos:Concept ;
    dct:source "http://216.239.39.100/search?q=cache:3wFtRKEEkxEC:www.gfc.state.ga.us/Publications/Educational/glossary.pdf+%22stand+density%22++definition+glossary&hl=en&ie=UTF-8#10"^^xsd:anyURI ;
    skos:definition "The number of trees in a forest stand. Often, stocking level is compared to the desirable number of trees for best growth and management, such as partially stocked, well stocked or over-stocked"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "Stocking"@sv .

ex:Stocking_4 a skos:Concept ;
    dct:creator "n.f" ;
    dct:source "http://nfdp.ccfm.org/silviterm/silvi_e/silvitermqtote.htm#S"^^xsd:anyURI ;
    skos:definition "[densité relative ] - A qualitative expression of the adequacy of tree cover on an area, in terms of crown closure, number of trees, basal area, or volume, in relation to a preestablished norm. In this context, \"tree cover\" includes seedlings and saplings; hence, the concept carries no connotation of a particular age. Stocking may be described in regionally or locally developed classes, or as a percentage of regional or local normal standards, which vary according to site-specific conditions. (5"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "n.f." ;
    skos:prefLabel "Stocking"@sv .

ex:Stocking_5 a skos:Concept ;
    dct:source "http://www.campbellgroup.com/timber_invest/glossary.htm"^^xsd:anyURI ;
    skos:definition "Degree of utilization of land by trees. Measured in terms of basal area and/or the number of trees in a stand compared to the basal area and/or number of trees required to fully utilize the growth potential of the land. A stocking percent of 100 indicates full utilization of the site and is equivalent to 80 square feet of basal area per acre in trees 5 inches in dbh and larger. A stocking percent of 100 in a stand of trees less than 5 inches in dbh would indicate that the present number of trees is sufficient to produce 80 square feet of basal area per acre when the trees reach S inches dbh. A stocking percent of over 100 is fully utilizing the site. Stocking classes - Fully stocked stands -Stands in which the stocking of trees is from 100 to 133 percent. Medium stocked stands -Stands in which the stocking of trees is from 60 to 100 percent. Nonstocked areas -Commercial forest land on which the stocking of trees is less than 16.7 percent. Overstocked stands -Stands in which the stocking of trees is 133 percent or more. Poorly stocked stands -Stands in which the stocking of trees is from 16.7 to 60 percent"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "Stocking"@sv .

ex:Timber_1 a skos:Concept ;
    dct:date "1941"^^xsd:gYear ;
    dct:spatial "Antigua and Barbuda" ;
    skos:broadMatch ex:Tree ;
    skos:definition "Any kind of growing tree except brushwood or trees growing on cultivated lands or on cleared lands or pasture lands on any estate. Forestry Act. 1941. Craig and Diann laynec@candw.ag"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Antigua and Barbuda 1941" ;
    skos:prefLabel "- Timber"@id .

ex:Timber_2 a skos:Concept ;
    dct:creator "– Tamil Nadu 1882" ;
    dct:source "https://www.forests.tn.gov.in/tnforest/app/webroot/img/document/legislations/01_Tamilnadu%20Forest%20Act%201882.pdf"^^xsd:anyURI ;
    dct:spatial "India" ;
    skos:broadMatch ex:Tree ;
    skos:definition "\" - \"Timber\" includes trees when they have fallen or have been felled, and all wood, whether cut up or fashioned or hollowed out for any purpose or not"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "India – Tamil Nadu 1882" ;
    skos:prefLabel "Timber"@id .

ex:TreeArabic_1 a skos:Concept ;
    dct:spatial "Morocco" ;
    skos:broadMatch ex:Tree ;
    skos:definition "Tree ( Arabic : Shajarah, French : Arbre, Spanish : Arbol) - Woody perennial plant with one main stem, and a total height greater than 7 m. Mohammed Ellatifi, m.ellatifi@ellatifi.8m.com"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Morocco" ;
    skos:prefLabel "Tree Arabic"@en .

ex:TreeArbre_1 a skos:Concept ;
    dct:spatial "France" ;
    skos:broadMatch ex:Tree ;
    skos:definition "tree = arbre : plante ligneuse dotée d'une écorce, d'une assise subérophellodermique et d'une tige capable d'atteindre 8 mètres de hauteur (les Palmiers ne sont donc pas des arbres) \"Michel Godron\" <michel.godron@libertysurf.fr"@fr ;
    skos:inScheme ex:ForestScheme ;
    skos:note "France" ;
    skos:prefLabel "tree arbre"@en .

ex:TreeLands_1 a skos:Concept ;
    dct:creator "Tamil Nadu and Pondicherry ?" ;
    dct:date "2008"^^xsd:gYear ;
    dct:source "http://www.saiindia.gov.in/english/home/public_folder/Professional_Practices_Group/State_Local_Manual/PUDUCHERRY_MANUAL/Wad%20Manual/Forest.pdf"^^xsd:anyURI ;
    dct:spatial "India" ;
    skos:broadMatch ex:Tree ;
    skos:definition "i.e., those areas which though outside the scope of the ordinary forest management are essential for the amelioration of physical conditions of the country"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "India Tamil Nadu and Pondicherry 2008?" ;
    skos:prefLabel "Tree lands"@nl .

ex:TreeMatureNative_1 a skos:Concept ;
    dct:date "2009"^^xsd:gYear ;
    dct:spatial "Argentina" ;
    skos:broadMatch ex:Tree ;
    skos:definition "Tree, mature native. - An autochthonous weedy species, with a central stem, whcih ramifies from above ground level. Includes palm trees. Presidential Regulation Order (Presidencia de la Nación Argentina 2009"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Argentina 2009" ;
    skos:prefLabel "Tree mature native"@en .

ex:Tree_10 a skos:Concept ;
    dct:creator "NSW" ;
    dct:source "http://155.187.10.12/glossary/fl-nsw.html"^^xsd:anyURI ;
    dct:spatial "Australia" ;
    skos:broadMatch ex:Tree ;
    skos:definition "A woody plant usually with a single distinct trunk and generally more than 5 m high"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Australia-NSW" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_100 a skos:Concept ;
    dct:creator "Turkey" ;
    skos:broadMatch ex:Tree ;
    skos:definition "The trees are the plants of at least 8 m., or more height, have crowns and the wooden stems, at any age or diameter. Source: Turkey's Forest Law No.6831 - \"Ersin Yýlmaz\" yilmazersin@hotmail.com"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Turkey" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_101 a skos:Concept ;
    dct:date "1947"^^xsd:gYear ;
    dct:spatial "Uganda" ;
    skos:broadMatch ex:Tree ;
    skos:definition "Includes trees palms, bamboo, canes shrubs bushes, climbers, seedlings, and re-growth of all ages and of all kinds, and any part thereof. THE FORESTS ACT, 1947. An Act To Consolidate the Law Relating to Forests and Forest Reserves"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Uganda 1947" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_102 a skos:Concept ;
    dct:creator "UN EP/EAP.AP" ;
    dct:source "http://www.eapap.unep.org/lc/cd/html/training/module1.html"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "Trees are woody plants land cover with a single well defined stem and more than 3 meters in height"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN EP/EAP.AP" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_106 a skos:Concept ;
    dct:source "http://www.forestry.cov.uk/website/foreststats./sources.html"^^xsd:anyURI ;
    dct:spatial "United Kingdom" ;
    skos:broadMatch ex:Tree ;
    skos:definition "A tree is defined by its species, a list of tree species is given in Chapter 4 of (. From Stefania Pizzirani, Research Gate. 4 Feb. 2014"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "United Kingdom" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_107 a skos:Concept ;
    dct:source "http://www.bailii.org/ew/cases/EWHC/Admin/2009/220.html"^^xsd:anyURI ;
    dct:spatial "United Kingdom" ;
    skos:broadMatch ex:Tree ;
    skos:definition "A tree is only a tree if its trunk had a diameter of at least seven inches. Lord Demning"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "United Kingdom" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_108 a skos:Concept ;
    dct:source "http://www.woodlander.co.uk/cgi-bin/viewrecordsalpha.asp?page=2&letter=t"^^xsd:anyURI ;
    dct:spatial "United Kingdom" ;
    skos:broadMatch ex:Tree ;
    skos:definition "Not easy to define, a tree is a woody plant that often grows to 6m (20ft) or more on a single stem. Compare with shrub"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "United Kingdom" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_109 a skos:Concept ;
    dct:creator "USA-Congress-OTA" ;
    dct:date "1984"^^xsd:gYear ;
    dct:source "http://govinfo.library.unt.edu/ota/Ota_4/DATA/1984/8426.PDF"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "A woody perennial plant having a single, usually elongate, main stem generally with few or no branches on its lower part"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-Congress-OTA 1984" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_11 a skos:Concept ;
    dct:creator "–Queensland" ;
    dct:date "1959"^^xsd:gYear ;
    dct:source "https://www.legislation.qld.gov.au/view/whole/html/inforce/2016-07-01/act-1959-058"^^xsd:anyURI ;
    dct:spatial "Australia" ;
    skos:broadMatch ex:Tree ;
    skos:definition "trees includes not only timber trees, but all other trees, and shrubs, bushes, seedlings, saplings, and re-shoots of every description and any parts thereof"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Australia–Queensland 1959" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_12 a skos:Concept ;
    dct:creator "Victoria" ;
    dct:source "http://www.dse.vic.gov.au/dse/nrenfor.nsf/FID/-9A9762E4B40E608F4A256AB1000306D0?OpenDocument"^^xsd:anyURI ;
    dct:spatial "Australia" ;
    skos:broadMatch ex:Tree ;
    skos:definition "Includes trees, shrubs, bushes, seedlings, saplings and reshoots whether alive or dead of any genus, species or variety usually growing in a forest and includes every part of such tree"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Australia-Victoria" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_124 a skos:Concept ;
    dct:creator "USA-STATE-Airports" ;
    dct:source "http://www.townofbourne.com/Town%20Offices/Bylaws/Chapter5.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "\"Tree\" means a tree or other object of natural growth"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Airports" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_125 a skos:Concept ;
    dct:creator "USA-STATE-Arizona-Tempe" ;
    dct:source "http://www.tempe.gov/tdsi/Planning/CPTED/cpted3.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "A woody plant which, at maturity, has one well-defined trunk at least two (2) inches in diameter, a height of at least ten (10) feet, and a formed crown of foliage"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Arizona-Tempe" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_126 a skos:Concept ;
    dct:creator "USA-STATE-Arkansas" ;
    skos:broadMatch ex:Tree ;
    skos:definition "a woody plant at least 8 feet tall with one well-defined stem and a more or less definitely formed crown. Other definitions say a woody plant from 12 - 15 feet tall with one well-defined stem and a more or less definitely formed crown. Several sources. The SAF definition is one stem and 15 feet. Other definitions ranged from 8 - 15 feet. Jim Grant jim.grant@mail.state.ar.us no official definitions in Arkansas law"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Arkansas" ;
    skos:prefLabel "Tree"@en .

ex:Tree_127 a skos:Concept ;
    dct:creator "USA-STATE-California" ;
    dct:source "http://mississauga.ca/CORPSVCS/clerk/bylaws/tree_residentinfo.PDF"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "A self-supporting woody plant which will reach a height of at least 4.5 m (15 ft) at maturity"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-California" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_128 a skos:Concept ;
    dct:creator "USA-STATE-Florida" ;
    skos:broadMatch ex:Tree ;
    skos:definition "Any self-supporting, woody plant that normally grows to a minimum height of 15 feet or greater with a mature crown spread of 15 feet or greater and having trunks that can be maintained with over five feet of clear wood. Mangroves shall be considered trees. 24.73.97.98/BDLG%5CTreePermApp.doc"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Florida" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_129 a skos:Concept ;
    dct:creator "USA-STATE-Hawaii" ;
    dct:source "http://www.fs.fed.us/psw/publications/documents/psw_gtr076/psw_gtr076.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "Tree--A woody plant that usually has an erect perennial stem or trunk at least 7.5 cm d.b.h. and a total height of at least 5 m"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Hawaii" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_13 a skos:Concept ;
    dct:creator "–Victoria" ;
    dct:date "1958"^^xsd:gYear ;
    dct:source "http://www8.austlii.edu.au/cgi-bin/viewdoc/au/legis/vic/consol_act/fa1958116/s3.html#state_forest"^^xsd:anyURI ;
    dct:spatial "Australia" ;
    skos:broadMatch ex:Tree ;
    skos:definition "\"tree\" or trees includes trees shrubs bushes seedlings saplings and reshoots whether alive or dead"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Australia–Victoria 1958" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_130 a skos:Concept ;
    dct:creator "USA-STATE-Illinois" ;
    dct:source "http://www.legis.state.il.us/ilcs/ch225/ch225act740.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "\"Tree\" or \"trees\" means any tree, standing or felled, living or dead, and includes both those trees included within the definition of \"timber\" in Section 2 of the \"Timber Buyers Licensing Act\" and Christmas trees. The term does not apply to trees or parts of trees that have been cut into firewood"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Illinois" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_131 a skos:Concept ;
    dct:creator "USA-STATE-na-Bloomington" ;
    dct:source "http://www.city.bloomington.in.us/code/TITLE12/Chapter_12_24_TREES/12_24_010_Definitions_.html"^^xsd:anyURI ;
    dct:spatial "India" ;
    skos:broadMatch ex:Tree ;
    skos:definition "A woody, perennial plant with one main stem or trunk which develops many branches"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Indiana-Bloomington" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_132 a skos:Concept ;
    dct:creator "USA-STATE-Iowa" ;
    dct:source "http://www2.legis.state.ia.us/wais/bin/waisgate?WAISdocID=4782917490+0+0+0&WAISaction=retrieve"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "Forest trees. The ash, black cherry, black walnut, butternut, catalpa, coffee tree, the elms, hackberry, the hickories, honey locust, Norway and Carolina poplars, mulberry, the oaks, sugar maple, cottonwood, soft maple, osage orange, basswood, black locust, European larch and other coniferous trees, and all other forest trees introduced into the state for experimental purposes, shall be considered forest trees within the meaning of this chapter. In forest reservations which are artificial groves, the willows, box elder, and other poplars shall be included among forest trees for the purposes of this chapter when they are used as protecting borders not exceeding two rows in width around a forest reservation, or when they are used as nurse trees for forest trees in such forest reservation, the number of such nurse trees not to exceed one hundred on each acre; provided that only box elder shall be used as nurse trees. Source: 427C.5"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Iowa" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_133 a skos:Concept ;
    dct:creator "USA-STATE-Kansas" ;
    skos:broadMatch ex:Tree ;
    skos:definition "A woody plant usually having one or more erect perennial stems, a stem diameter at breast height of at least 3 inches, a more or less definitely formed crown of foliage, and a height of at least 13 feet at maturity. Robert L. Atchison ratchiso@oznet.ksu.edu"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Kansas" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_134 a skos:Concept ;
    dct:creator "USA-STATE-Kentucky" ;
    skos:broadMatch ex:Tree ;
    skos:definition "A woody perennial plant, typically large and with a well-defined stem or stems carrying a more or less definite crown (usually more that 12 feet in height at maturity). The State of Kentucky does not have the terms Forest, Forestland, or Tree officially defined in State Statute or Regulation. The Division of Forestry utilizes the Society of American Forester's definitions for these terms as listed in John A. Helms' The Dictionary of Forestry. Steve.Kull@mail.state.ky.us"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Kentucky" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_135 a skos:Concept ;
    dct:creator "USA-STATE-Maryland" ;
    dct:date "2000"^^xsd:gYear ;
    skos:broadMatch ex:Tree ;
    skos:definition "Tree – trees are greater than 5.0 inches diameter at breast height (DBH) and greater than 20 feet tall dnrweb.dnr.state.md.us/download/education/wetlands.doc"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Maryland 2000" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_136 a skos:Concept ;
    dct:creator "USA-STATE-Maryland" ;
    dct:source "http://pilot.wash.lib.md.us/washco/forestcn.html"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "A large, branched woody plant having one or several self-supporting stems or trunks that reach a height of at least 20 feet at maturity"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Maryland" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_137 a skos:Concept ;
    dct:creator "USA-STATE-Maryland-Easton" ;
    dct:source "http://www.town-eastonmd.com/Planning/fco/fco_a002.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "\"Tree\" means a large, branched woody plant having one or several self-supporting stems or trunks that reach a height of at least 20 feet at maturity"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Maryland-Easton" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_138 a skos:Concept ;
    dct:creator "USA-STATE-Maryland-Laytonsville" ;
    dct:source "http://www.laytonsville.md.us/tree_ordinance.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "A perennial plant that has a woody stem or trunk, and which customarily grows to a height of not less than ten feet when fully grown"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Maryland-Laytonsville" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_139 a skos:Concept ;
    dct:creator "USA-STATE-Maryland-Rockville" ;
    dct:source "http://www.ci.rockville.md.us/cityprojects/envguide/eggloss.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "A large, woody plant having one or several self-supporting stems or trunks and numerous branches that reach a height of at least 20 feet at maturity"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Maryland-Rockville" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_14 a skos:Concept ;
    dct:date "2010"^^xsd:gYear ;
    dct:source "http://www.bahamasforestry.com/docs/ForestryAct2010.pdf"^^xsd:anyURI ;
    dct:spatial "Bahamas" ;
    skos:broadMatch ex:Tree ;
    skos:definition "Trees includes any perennial plant with a self supporting stem, shrubs, bushes, palms, stumps, seedlings, saplings and coppice shoots the species of which may reach a height of ten feet or more. Bahamas Forestry Act of 2010"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Bahamas 2010" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_140 a skos:Concept ;
    dct:creator "USA-STATE-Michigan" ;
    dct:source "http://mff.dsisd.net/PDF/0-IntroStuff/4-Glossary.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "TREE: It might seem silly, at first, to define a tree. Everyone knows what a tree is . . . don't they? The difference between and tree and shrub can be defined without difficulty. A tree is \"a woody perennial plant, typically large and with a well-defined stem or stems carrying a more or less definite crown --- note sometimes defined as attaining a minimum diameter of 5 inches and a minimum height of 15 feet at maturity, with no branches within 3 feet of the ground\" [Society of American Foresters, 1998]. The problem is that some species can grow as trees or shrubs depending on climate and site conditions. A good example is black cherry. Throughout most of its range, it grows as a tree. But put on a poor site or along the northern edge of its range and it grows as a shrub. Species that are obviously trees further south will sometimes occur only as shrubs in the far north"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Michigan" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_141 a skos:Concept ;
    dct:creator "USA-STATE-Missouri" ;
    skos:broadMatch ex:Tree ;
    skos:definition "Although we do not have \"official\" definitions, we commonly use the accepted SAF definitions for these terms. See Dictionary of Forestry; John A. Helms, editor; published 1998 by the Society of American Foresters. \"Mike Hoffmann\" <hoffmm@mail.conservation.state.mo.us>"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Missouri" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_142 a skos:Concept ;
    dct:creator "USA-STATE-Nevada" ;
    dct:source "http://www.nalms.org/glossary/lkword_f.htm"^^xsd:anyURI,
        "http://www.state.nv.us/cnr/ndwp/dict-1/WORD_T.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "A woody plant which at maturity is usually 6 meters (20 feet) or more in height and generally has a single trunk, unbranched for 1 m or more above the ground, and a more or less definite crown; e.g., red maple (Acer rubrum), northern white cedar (Thuja occidentalis). Water Words Dictionary and Lake and Water Words Glossary"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Nevada" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_143 a skos:Concept ;
    dct:creator "USA-STATE-New" ;
    dct:date "2007"^^xsd:gYear ;
    dct:source "http://www.conwaygreene.com/lpbin21/lpext.dll/Test/NMACRaw/1/51fd0/571dd/572c0/572d3?fn=document-frame.htm&f=templates&2.0"^^xsd:anyURI ;
    dct:spatial "Mexico" ;
    skos:broadMatch ex:Tree ;
    skos:definition "“ “Tree” means a woody perennial plant usually having a single main stem generally with few or no branches on its lower part; however, species such Gambel oak (quercus gambelii) and one seed juniper (juniperus monosperma) may be multi-stemmed and species such as fir (abies), spruce (picea) and juniper (juniperus) may have many branches on the stem’s lower part"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-New Mexico-2007" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_144 a skos:Concept ;
    dct:creator "USA-STATE-North Carolina" ;
    skos:broadMatch ex:Tree ;
    skos:definition "A woody perennial plant, typically large and with a single well defined stem carrying a more or less definite crown. Source: Terminology of Forest Science, Technology Practice and Products. Edited by F.C. Ford-Robertson. Society of American Foresters, Washington, D.C., 1971. David R. Brown <David.R.Brown@ncmail.net>"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-North Carolina" ;
    skos:prefLabel "Tree"@en .

ex:Tree_145 a skos:Concept ;
    dct:creator "USA-STATE-Oregon-Canby" ;
    dct:source "http://www.ci.canby.or.us/municipalcode/Title12%20StreetsSidewalks&PublicPlaced/12.32TreeRegulations.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "A woody perennial plant having a single elongated main stem generally with few or no branches on its lower part"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Oregon-Canby" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_146 a skos:Concept ;
    dct:creator "USA-STATE-South Dakota" ;
    dct:date "1996"^^xsd:gYear ;
    skos:broadMatch ex:Tree ;
    skos:definition "Tree: A woody plant usually having one or more erect perennial stems, a stem diameter at breast height of at least 3 inches, a more or less definitely formed crown of foliage, and a height of at least 13 feet at maturity. Source - Leatherberry, Earl C., Ronald J. Piva, and Gregory J. Josten. 2000. South Dakota's Forest Resources Outside the Black Hills National Forest, 1996. USDA Forest Service North Central Research Station, Res. Pap. NC-338. Greg.Josten@state.sd.us"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-South Dakota 1996" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_147 a skos:Concept ;
    dct:creator "USA-STATE-Virginia" ;
    dct:date "1997"^^xsd:gYear ;
    dct:source "http://www.dof.virginia.gov/edu/glossary.htm#F"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "A woody plant having a well-defined stem, more or less definitely formed crown and usually attaining a height of at least 10 feet"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Virginia 1997" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_148 a skos:Concept ;
    dct:creator "USA-STATE-Virginia" ;
    skos:broadMatch ex:Tree ;
    skos:definition "\"Forest trees\" means only those trees which are a part of and constitute a stand of potential, immature, or mature commercial timber trees. The term \"forest trees\" includes shade trees of any species around houses, along highways and within cities and towns if the trees constitute an insect or disease menace to nearby timber trees or timber stands. Under Authority of Department of Forestry. § 10.1-1178. Definitions. \"Starr, James\" starrj@dof.state.va.us"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Virginia" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_149 a skos:Concept ;
    dct:creator "USA-STATE-Washington" ;
    dct:source "http://app.leg.wa.gov/RCW/default.aspx?cite=76.09.020"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "\"Forest trees\" does not include hardwood trees cultivated by agricultural methods in growing cycles shorter than fifteen years if the trees were planted on land that was not in forest use immediately before the trees were planted and before the land was prepared for planting the trees. \"Forest trees\" includes Christmas trees, but does not include Christmas trees that are cultivated by agricultural methods, as that term is defined in RCW 84.33.035"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Washington" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_15 a skos:Concept ;
    dct:date "1927"^^xsd:gYear ;
    dct:spatial "Bangladesh" ;
    skos:broadMatch ex:Tree ;
    skos:definition "Tree includes palms, bamboos, stumps, brush-wood and canes. LEX-FAOC006895. BANGLADESH: Forest Act, 1927. Date of text: 1927"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Bangladesh 1927" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_150 a skos:Concept ;
    dct:creator "USA-STATE-Wisconsin" ;
    dct:source "http://www.legis.state.wi.us/rsb/code/nr/nr037.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "A woody plant which at maturity is 20 feet or more in height, with a single trunk, unbranched for at least several feet above the ground and having a more or less definite crown"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Wisconsin" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_151 a skos:Concept ;
    dct:creator "Venezuela" ;
    dct:date "1977"^^xsd:gYear ;
    skos:broadMatch ex:Tree ;
    skos:definition "ARBOL: planta perenne de tronco leñoso y elevado que se ramifica a cierta altura del suelo, con una altura superior a los 5 metros: constituye un elemento del bosque. Reglamento de la Ley Forestal de Suelos y Aguas (1977). Areas Naturales Protegidas de Venezuela. Series Aspectos Conceptuales y Metodológicos, DGSPOA/ACM/01, feb 1992. Via Profauna@marnr.gov.ve"@es ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Venezuela 1977" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_153 a skos:Concept ;
    dct:spatial "Yemen" ;
    skos:broadMatch ex:Tree ;
    skos:definition "Woody perennial plant with one main stem, and a total height greater than 5 m. Mohammed Ellatifi, m.ellatifi@ellatifi.8m.com"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Yemen" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_154 a skos:Concept ;
    dct:creator "and" ;
    dct:date "1973"^^xsd:gYear ;
    dct:source "http://www.parliament.gov.zm/sites/default/files/documents/acts/The%20Forest%20Act%202015.pdf"^^xsd:anyURI ;
    dct:spatial "Zambia" ;
    skos:broadMatch ex:Tree ;
    skos:definition "Includes bushes, climbers, coppice, palms, reshoots, saplings, seedlings and shrubs of all ages and of all kinds and nay part thereof. LEX-FAOC003914. ZAMBIA: Forests Act 1973 (Act No. 39). An Act to repeal and replace the Forest Act and to provide for the establishment and management of national forests and local forests, the conservation and protection of forests and trees, the licensing and sale of forest produce and other matters. “"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Zambia 1973 and 2015" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_155 a skos:Concept ;
    dct:creator "20 ft" ;
    dct:source "http://en.wikipedia.org/wiki/Tree"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "A large perennial woody plant. Though there is no set definition of size, it is generally at least 6 m high at maturity, and with branches supported on a single main stem. Compared with most other forms of plants, trees are long-lived"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "20 ft" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_156 a skos:Concept ;
    dct:creator "20 ft" ;
    dct:source "http://en.wikipedia.org/wiki/Tree"^^xsd:anyURI,
        "http://explanation-guide.info/meaning/Tree.html"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "A large perennial woody plant. Though there is no set definition of size, it is generally at least 6 m high at maturity, and with branches supported on a single main stem. Compared with most other forms of plants, trees are long-lived. A few species of trees grow to over 100 m (300 ft) tall and some live for several millennia. Trees are important components of the natural landscape and significant elements in landscaping. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "20 ft" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_157 a skos:Concept ;
    dct:source "http://ag.arizona.edu/arec/pubs/rmg/2._Rangeland_Management_/4Terms.pdf"^^xsd:anyURI,
        "http://www.agroselviter.unito.it/range/docs/4Terms.pdf"^^xsd:anyURI,
        "https://extension.usu.edu/rangelands/htm/intro-rangelands/range-terms"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "A large woody perennial plant, usually single stemmed, that has a definite crown shape and characteristically reaches a mature height of more than 10 feet. RANGELAND TERMINOLOGY"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "TREE"@vi .

ex:Tree_158 a skos:Concept ;
    dct:source "http://www.geog.ouc.bc.ca/conted/onlinecourses/enviroglos/t.html#anchor122359"^^xsd:anyURI,
        "http://www.physicalgeography.net/physgeoglos/anchor122359"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "A large woody plant that has a trunk which supports branches and leaves. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "TREE"@vi .

ex:Tree_159 a skos:Concept ;
    dct:source "http://www.naturedetectives.org.uk/NR/rdonlyres/D5E0AFFC-D1FD-447E-9E1B-2EE0F61EB1C8/0/2927Woodlandmaths.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "A large woody plant, usually with a main stem or trunk"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "TREE"@vi .

ex:Tree_16 a skos:Concept ;
    dct:date "1981"^^xsd:gYear ;
    dct:spatial "Barbados" ;
    skos:broadMatch ex:Tree ;
    skos:definition "Applies to any tree the circumference of which is one metre or more at a point half a metre or more from the ground but does not apply to a tree the killing of which if for the prevention of imminent danger or is in compliance with an obligation under any other enactment. LEX-FAOC002736. BARBADOS: Trees (Preservation) Act, 1981 (Act No. 49). Date of text: 07 December 1981"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Barbados 1981" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_160 a skos:Concept ;
    dct:source "http://www.privateforestry.org.au/glos_o-z.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "A perennial plant having a self-supporting woody main stem or trunk which usually develops woody branches. A tree, under the Soil Conservation Act, 1938, includes sapling, shrub and scrub in this definition"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "TREE"@vi .

ex:Tree_161 a skos:Concept ;
    dct:creator "or only foliage as in the palms" ;
    dct:source "http://www.botany.com/16.tr.html"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "A perennial plant that grows from the ground with a single, normally tall, woody, self-supporting trunk or stem and an elevated crown of branches and foliage"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "or only foliage as in the palms" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_162 a skos:Concept ;
    dct:source "http://www.wordsmyth.net/cgi-bin/simplesearch.cgi?matchent=trees&matchtype=exact&matchid=-1&retall=1&template=wordsmyth&senses=1"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "A perennial woody plant consisting of roots, a trunk, and branches, usu. growing to a substantial height"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "TREE"@vi .

ex:Tree_163 a skos:Concept ;
    dct:source "http://www.dictionary.com/cgi-bin/dict.pl?term=tree"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "A perennial woody plant having a main trunk and usually a distinct crown"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "TREE"@vi .

ex:Tree_164 a skos:Concept ;
    dct:creator "Moon and Brown" ;
    dct:date "1914"^^xsd:gYear ;
    skos:broadMatch ex:Tree ;
    skos:definition "A perennial woody plant with a single stem which from natural tendencies generally divides into two or more branches at some distance from the ground"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Moon and Brown 1914" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_165 a skos:Concept ;
    dct:source "http://www.fix.net/~ggoven/trees.html"^^xsd:anyURI,
        "http://www.optonline.com/comptons/ceo/04851_A.html"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "A plant is called a tree if it has a woody stem 8 feet or more in height. The stem often has no branches for several feet above the ground. At the top it has a crown of branches and leaves. Botanists do not separate shrubs and trees. Shrubs are smaller. They branch close to the ground and have many stems. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "TREE"@vi .

ex:Tree_166 a skos:Concept ;
    dct:source "http://www.dictionary.com/cgi-bin/dict.pl?term=tree"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "A plant or shrub resembling a tree in form or size"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "TREE"@vi .

ex:Tree_167 a skos:Concept ;
    dct:source "http://www.landhelp.info/FramifyGlossary.php"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "A plant that is usually more than 12 feet tall and has a single main woody stem with a distinct crown of leaves"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "TREE"@vi .

ex:Tree_168 a skos:Concept ;
    dct:creator "made by xylem cells" ;
    dct:source "http://www.enchantedlearning.com/subjects/plants/glossary/indext.shtml"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "A plant that produces wood . These tall plants grow taller each year"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "made by xylem cells" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_169 a skos:Concept ;
    dct:source "http://www.LittleExplorers.com/Tisfor.shtml"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "A plant with a trunk, leaves, and roots"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "TREE"@vi .

ex:Tree_17 a skos:Concept ;
    dct:date "2000"^^xsd:gYear ;
    dct:source "http://www.belizeaudubon.org/new_site/wp-content/uploads/2014/10/Forest_Act_213.pdf"^^xsd:anyURI ;
    dct:spatial "Belize" ;
    skos:broadMatch ex:Tree ;
    skos:definition "“trees” includes shrubs, bushes, palms, bamboos, creepers, canes, stumps, seedlings, saplings and coppice shoots"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Belize 2000" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_170 a skos:Concept ;
    dct:source "http://www.m-w.com/cgi-bin/dictionary?book=Dictionary&va=tree"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "A shrub or herb of arborescent form <rose trees <a banana tree"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "TREE"@vi .

ex:Tree_171 a skos:Concept ;
    dct:creator "15" ;
    dct:source "http://www.orgler.ws/huxley/Huxley%20Tree%20Ordinance%202001.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "A single stemmed, woody plant with a mature height of a minimum of fifteen feet; a small tree less than twenty-five feet (25’), a medium tree twenty-five to forty feet (25’-40’), and a large tree over forty feet (40’"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "15" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_172 a skos:Concept ;
    dct:source "http://www.notredame.ac.jp/cgi-bin/wn?tree#Overview"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "A tall perennial woody plant having a main trunk and branches forming a distinct elevated crown; includes both gymnosperms and angiosperms) of noun tree"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "TREE"@vi .

ex:Tree_173 a skos:Concept ;
    dct:source "http://www.cup.cam.ac.uk/elt/dictionary/default.asp?String=tree*1%2B0&ACT=SELECT"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "A tall plant which has a wooden trunk and branches that grow from its upper part. Other tall plants which do not have wooden trunks are also often referred to as trees - palm trees"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "TREE"@vi .

ex:Tree_174 a skos:Concept ;
    dct:source "http://www.linguistics.ruhr-uni-bochum.de:8099/cgi-bin/search.sh?tmpl=tmpls&itmpl=tmpls&form=tree"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "A tall plant with a hard trunk, branches, and leaves"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "TREE"@vi .

ex:Tree_175 a skos:Concept ;
    dct:creator "Scrabble words" ;
    skos:broadMatch ex:Tree ;
    skos:definition "A tall, woody plant"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Scrabble words" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_176 a skos:Concept ;
    dct:creator "The Left Handed Dictionary" ;
    dct:source "http://www.workinghumor.com/dictionary/index.php?s=tree&B1=Search%21"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "A thing that will stand in one place fifty years and then suddenly jump in front of a woman driver. Banana River Peelings"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "The Left Handed Dictionary" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_177 a skos:Concept ;
    skos:broadMatch ex:Tree ;
    skos:definition "A very large bush, shrub. Babylon.com"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "TREE"@vi .

ex:Tree_178 a skos:Concept ;
    dct:creator "stem" ;
    dct:source "http://woodmagic.forprod.vt.edu/Kids/glossary/"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "A very large plant that is at least 20 feet tall, it has only one main trunk that grows in circumference (around) every year. The stem is persistent (it does not die back), and the stem lives for many, many years. The stem also has a vascular system – it has cells that look and act like straws"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "stem" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_179 a skos:Concept ;
    dct:source "http://www.foreignword.com/Tools/dictsrch_aff.asp?menu=Y&query=forest&src=BP&srcbox=18&go=Translate&trg=AG"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "A very tall plant that has a wooden trunk, branches, and leaves"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "TREE"@vi .

ex:Tree_18 a skos:Concept ;
    dct:creator "Wallonie" ;
    dct:source "http://mrw.wallonie.be/cgi/dgrne/sibw/eunis.glo.pl?WORD=tree"^^xsd:anyURI ;
    dct:spatial "Belgium" ;
    skos:broadMatch ex:Tree ;
    skos:definition "A woody plant with a single main stem (the trunk), that is unbranched near the ground; some trees (e.g. oak, ([Quercus]) and ash ([Fraxinus])) have multi-trunked forms. At the end of each growing season there is no die-back of aerial parts, apart from the loss of foliage. Trees which are able to reach a height of 5m at maturity"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Belgium-Wallonie" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_180 a skos:Concept ;
    dct:source "http://ehe.nmsu.edu/directory/esource/Powerpoint/HORT%20302-02a%20Definitions%20&%20Tools.ppt"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "A woody perennial at least 10 ft. tall, usually with one main stem"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "TREE"@vi .

ex:Tree_181 a skos:Concept ;
    dct:source "http://www.m-w.com/cgi-bin/dictionary?book=Dictionary&va=tree"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "A woody perennial plant having a single usually elongate main stem generally with few or no branches on its lower part [Source: WWWebster]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "TREE"@vi .

ex:Tree_182 a skos:Concept ;
    dct:creator "20" ;
    dct:source "http://www.tiburon.org/Government/images/Departments/planning%20dept/plng%20forms/TreeOrd.htm#Section%2015A-2.%20Definitions"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "A woody perennial plant that has a trunk circumference of twenty inches measured at twenty-four (24) inches above the ground surface; or A woody perennial plant at least fifteen (15) feet in height that usually, but not necessarily, has a single trunk. In applying subsection (1) above, for trees with more than one trunk, the circumference measurement shall be ascertained from a single measurement around the outside perimeter of all trunks and shall not be calculated as the sum total of the circumferences of the individual trunks. References to \"tree\" shall include the plural"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "20" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_183 a skos:Concept ;
    dct:creator "Ford-Robertson," ;
    dct:date "1971"^^xsd:gYear ;
    skos:broadMatch ex:Tree ;
    skos:definition "A woody perennial plant with a single, well defined stem carrying a more-or-less-defined crown"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Ford-Robertson, 1971" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_184 a skos:Concept ;
    dct:source "http://www.anzlic.org.au/icsm/topo/tddsect3.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "A woody perennial plant, having a self-supporting main stem or trunk"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "TREE"@vi .

ex:Tree_185 a skos:Concept ;
    dct:creator "in temperate area of moderate rainfall" ;
    skos:broadMatch ex:Tree ;
    skos:definition "A woody perennial, usually seed-bearing plant 20 feet tall or more at maturity , in which the main stem (q.v.) dominates the lateral branches in growth, either through life (as in most conifers) to produce a conical or pyramidal outline, or only during early growth after a few years forking one to several times to produce several ascending, almost equally important branches that collectively form a flat or rounded crown. Encyclopedia Britannia 1970"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "in temperate area of moderate rainfall" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_186 a skos:Concept ;
    dct:creator "Quercus spp" ;
    dct:source "http://www.blm.gov/nstc/library/pdf/1734-6.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "A woody perennial, usually singlestemmed plant that has a definite crown shape and reaches a mature height of at least 4 meters. The distinction between woody plants known as trees and those called shrubs is gradual. Some plants, such as oaks , may grow as either trees or shrubs (SRM 1999"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Quercus spp." ;
    skos:prefLabel "TREE"@vi .

ex:Tree_187 a skos:Concept ;
    dct:source "http://www.habitat-restoration.com/paeglos.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "A woody plant 5 inches or greater in diameter at breast height and 20 feet or taller"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "TREE"@vi .

ex:Tree_188 a skos:Concept ;
    dct:source "http://www.tropicalforages.info/key/Forages/Media/Html/Glossary.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "A woody plant at least 3 metres high, usually with an evident trunk"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "TREE"@vi .

ex:Tree_189 a skos:Concept ;
    dct:creator "metres" ;
    dct:source "http://biotech.icmb.utexas.edu/search/dict-search.phtml?title=tree"^^xsd:anyURI,
        "http://www.graylab.ac.uk/cgi-bin/omd?tree"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "A woody plant at least 5 meters high, with a main stem the lower part of which is usually unbranched. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "metres" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_19 a skos:Concept ;
    dct:date "1969"^^xsd:gYear ;
    dct:source "http://extwprlegs1.fao.org/docs/pdf/bhu2744.pdf"^^xsd:anyURI ;
    dct:spatial "Bhutan" ;
    skos:broadMatch ex:Tree ;
    skos:definition "Tree include palms, bamboos, stumps, brushwood and canes"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Bhutan 1969" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_190 a skos:Concept ;
    dct:source "http://ext.msstate.edu/pubs/pub1250.htm"^^xsd:anyURI,
        "http://fwie.fw.vt.edu/rhgiles/appendices/glosst.htm"^^xsd:anyURI,
        "http://ruralsystemguide.com/Appendices/GlossF.html"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "A woody plant having a well-defined stem, more or less definitely formed crown and usually attaining a height of at least 10 feet"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "TREE"@vi .

ex:Tree_191 a skos:Concept ;
    dct:source "http://64.77.121.89/T-U-V-W-X.html"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "A woody plant having one well-defined stem and a more or less definitely formed crown, usually attaining a height of at least 8 ft"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "TREE"@vi .

ex:Tree_192 a skos:Concept ;
    dct:source "http://www.worldagroforestrycentre.org/sea/AgroModels/DBases/af/"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "A woody plant having one well-defined stem and a more or less definitely formed crown and roots, usually attaining a height of at least 2 metres"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "TREE"@vi .

ex:Tree_193 a skos:Concept ;
    dct:source "http://www.bugwood.caes.uga.edu/glossary/http://www.bugwood.caes.uga.edu/glossary/"^^xsd:anyURI,
        "http://www.worldagroforestrycentre.org/InformationResources/T-V.asp"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "A woody plant having one well-defined stem and a more or less definitely formed crown and roots, usually attaining a height of at least 2.5 metres. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "TREE"@vi .

ex:Tree_194 a skos:Concept ;
    dct:source "http://www.reference.com/browse/wiki/Tree"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "A woody plant that has many secondary branches supported clear of the ground on a single main stem or trunk with clear apical dominance"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "TREE"@vi .

ex:Tree_195 a skos:Concept ;
    dct:source "http://www.bugwood.caes.uga.edu/glossary/"^^xsd:anyURI,
        "http://www.worldagroforestrycentre.org/InformationResources/T-V.asp"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "A woody plant that produces one main trunk or bole and a more or less distinct and elevated head. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "TREE"@vi .

ex:Tree_196 a skos:Concept ;
    dct:source "http://www.rook.org/earl/bwca/lists/glossary/"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "A woody plant that usually grows to at least 20' in height at maturity, typically having a single trunk with no branches within 3' of the ground. Mitigin the Ojibwe. Boundary Waters Compendium Glossary"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "TREE"@vi .

ex:Tree_197 a skos:Concept ;
    dct:creator "20 feet" ;
    dct:source "http://www.aces.edu/waterquality/glossary/glossary_results.php3?rowid=5326"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "A woody plant which at maturity is usually 6 meters or more in height and generally has a single trunk, unbranched for 1 m or more above the ground, and a more or less definite crown; e.g., red maple (Acer rubrum), northern white cedar (Thuja occidentalis"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "20 feet" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_198 a skos:Concept ;
    dct:creator "SHRUB -- A woody plant with a framework of branches and little or no central stem" ;
    dct:source "http://www.boldweb.com/greenweb/glossary.htm#T"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "A woody plant with a distinct central trunk. Compare shrub"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "SHRUB -- A woody plant with a framework of branches and little or no central stem." ;
    skos:prefLabel "TREE"@vi .

ex:Tree_199 a skos:Concept ;
    dct:source "http://www.tnw.org.uk/Note17.html"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "A woody plant with a single main stem in natural growth"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "TREE"@vi .

ex:Tree_2 a skos:Concept ;
    dct:source "http://www.bartleby.com/61/52/T0335200.html"^^xsd:anyURI,
        "http://www.bartleby.com/61/roots/IE87.html"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "Etymology: Middle English, from Old English treow. dreu-. To be firm, solid, steadfast; hence specialized senses “wood,” “tree,” and derivatives referring to objects made of wood. and \\"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "TREE"@vi .

ex:Tree_20 a skos:Concept ;
    dct:spatial "Belize" ;
    skos:broadMatch ex:Tree ;
    skos:definition "Includes shrubs, bushes, palms, bamboos, creepers, canes, stumps, seedlings, saplings and coppice shoots. [LEX-FAOC002737] BELIZE: Forests Ordinance (Chapter 176"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Belize" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_200 a skos:Concept ;
    dct:source "http://endeavor.des.ucdavis.edu/cnps/intro.html#use"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "A woody plant with a tall final height; commonly with one stem [trunk] from the base"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "TREE"@vi .

ex:Tree_201 a skos:Concept ;
    dct:creator "trunk" ;
    dct:source "http://www.hww.ca/glossary.asp#letterT"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "A woody plant, usually four or more metres tall, with a single main stem and a more or less distinct crown of leaves"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "trunk" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_202 a skos:Concept ;
    dct:source "http://www.fnr.purdue.edu/inwood/glossary.html"^^xsd:anyURI,
        "http://www.inwoodlands.org"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "A woody, perennial plant which attains the height of 20 feet or higher and a DBH of 4 inches or larger and tends to have a single, central bole. / and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "TREE"@vi .

ex:Tree_203 a skos:Concept ;
    dct:source "http://www.gardenweb.com/glossary/tree"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "A woody, self-supporting perennial plant usually with a single main stem and generally growing more than 20 feet tall"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "TREE"@vi .

ex:Tree_204 a skos:Concept ;
    dct:creator "angiosperms, gymnosperms, and some pterophyta" ;
    dct:source "http://www.graylab.ac.uk/cgi-bin/omd?trees"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "A woody, usually tall, perennial higher plants having usually a main stem and numerous branches"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "angiosperms, gymnosperms, and some pterophyta" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_205 a skos:Concept ;
    dct:creator "including bamboos, palms, coconut, neem, peepal, fruit trees, etc" ;
    dct:source "http://envfor.nic.in/nfc/s-git.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "All perennial woody vegetation . It excludes non-perennial non-woody species (e.g., banana) and tall shrubs or climbers (e.g., lantana or canes). For the purpose of assessing tree cover, only those trees having diameter of 10 cm or more at breast height (1.37 m) have been considered. In case of trees having multiple branches below breast height, the individual stems with diameter over 10 cm at breast height have been considered as individual trees"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "including bamboos, palms, coconut, neem, peepal, fruit trees, etc." ;
    skos:prefLabel "TREE"@vi .

ex:Tree_206 a skos:Concept ;
    skos:broadMatch ex:Tree ;
    skos:definition "All plants which grow with a permanent single woody stem or trunk of some height, branching out at some distance from the ground. Encyclopedia Britannia 1910"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "TREE"@vi .

ex:Tree_207 a skos:Concept ;
    dct:source "http://www.botany.com/16.tr.html"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "An herb or shrub growing naturally in or trained into the form or a tree"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "TREE"@vi .

ex:Tree_208 a skos:Concept ;
    dct:source "http://www.harcourt.com/dictionary/def/1/0/5/7/10579900.html"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "An imprecise term for a perennial woody plant that is larger than a bush or shrub, generally understood to describe a large growth having one main trunk with few or no branches projecting from its base, a well-developed crown of foliage, and a height at maturity of at least 12 feet"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "TREE"@vi .

ex:Tree_209 a skos:Concept ;
    dct:source "https://secure.finishlinestudios.com/users/www_cityofbaraboo_com/files/code/chapters/43/Chapter26.doc"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "Any object of natural growth, except farm crops which are cut at least once a year, and except shrubs, bushes or plants which do not grow to a height of more than five feet"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "TREE"@vi .

ex:Tree_21 a skos:Concept ;
    dct:creator "Bolivia" ;
    skos:broadMatch ex:Tree ;
    skos:definition "ÁRBOL: Planta perenne de tronco leñoso y elevado que se ramifica a cierta altura del suelo; constituye un elemento de bosque, pero en forma individual tiene una existencia limitada. Source: Luis Castello faopaf@caoba.entelnet.bo Adjunto sírvase encontrar la versión no oficial y premilinar del Glosario Forestal elaborado por el Proyecto de Apoyo a la Coordinación e Implementación del Plan de Acción Forestal para Bolivia"@es ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Bolivia" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_210 a skos:Concept ;
    dct:source "http://www.wordsmyth.net/cgi-bin/simplesearch.cgi?matchent=trees&matchtype=exact&matchid=-1&retall=1&template=wordsmyth&senses=1"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "Any of a variety of shrubs, bushes, or plants similar to a tree in shape or size"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "TREE"@vi .

ex:Tree_211 a skos:Concept ;
    dct:creator "usually over twenty feet high" ;
    dct:source "http://machaut.uchicago.edu/cgi-bin/WEBSTER.sh?WORD=tree"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "Any perennial woody plant of considerable size and growing with a single trunk"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "usually over twenty feet high" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_212 a skos:Concept ;
    dct:creator "15" ;
    dct:source "http://www.eastgr.org/citycode/IIIPARKS/35.html"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "Any self-supporting woody plant of a species which normally grows to an overall height of fifteen feet or more. (Ord., 2-28-92; Ord., 8-14-92"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "15" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_213 a skos:Concept ;
    dct:source "http://www.ucmp.berkeley.edu/glossary/gloss8botany.html"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "Any tall plant, including many conifers and flowering plants, as well as extinct lycophytes and sphenophytes"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "TREE"@vi .

ex:Tree_214 a skos:Concept ;
    dct:source "http://www.railtrails.org/whatwedo/railtrailinfo/resources/glossary.html#F"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "Any woody plant that normally grows to a mature height greater than 20 feet and has a diameter of four inches or more at a point four feet above the ground"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "TREE"@vi .

ex:Tree_215 a skos:Concept ;
    dct:source "http://www.goaforest.com/regulation/body_preservoftrees2.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "Any woody plant whose branches spring from and are supported upon a trunk or body and whose trunk or body is not less than five centimetre in diameter at a height of thirty centimetres from the ground level and is not less than one metre in height from the ground level"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "TREE"@vi .

ex:Tree_216 a skos:Concept ;
    skos:broadMatch ex:Tree ;
    skos:definition "Anything that ordinarily one would call a tree. Source: Jon Robins \"Hedge of darkness\" in the Law - T2 section of The Times Newspaper, London, 05 August 2003, page 21. Via John Palmer j.palmer@nrint.co.uk"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "TREE"@vi .

ex:Tree_217 a skos:Concept ;
    dct:creator "Fergusen" ;
    dct:date "1916"^^xsd:gYear ;
    skos:broadMatch ex:Tree ;
    skos:definition "Differ from herbs in having woody structure and perennial life and from shrubs in developing single stems that elevate the crowns above other forms of vegetation"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Fergusen 1916" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_218 a skos:Concept ;
    dct:creator "20-25 ft" ;
    skos:broadMatch ex:Tree ;
    skos:definition "Erect plant with a single woody stem capable of reaching a height of at least 6-8 m at maturity. Academic American Encyclopedia"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "20-25 ft." ;
    skos:prefLabel "TREE"@vi .

ex:Tree_219 a skos:Concept ;
    skos:broadMatch ex:Tree ;
    skos:definition "Forest tree, a tree of the forest, especially a timber tree, as distinguished from a fruit tree. Webster's Revised Unabridged Dictionary, © 1996, 1998 MICRA, Inc"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "TREE"@vi .

ex:Tree_22 a skos:Concept ;
    dct:date "1968"^^xsd:gYear ;
    dct:source "http://www.mewt.gov.bw/uploads/files/forest_act.pdf"^^xsd:anyURI ;
    dct:spatial "Botswana" ;
    skos:broadMatch ex:Tree ;
    skos:definition "Includes palms, shrubs, bushes, climbers, seedlings, saplings and regrowth of all ages and of all kinds, and any part thereof. [LEX-FAOC002748] BOTSWANA: Forest Act. Date of consolidation/reprint: 1976. Date of original text: 10 March 1968"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Botswana 1968" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_220 a skos:Concept ;
    dct:source "http://crossword911.com/tree.html"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "Large plant with trunk"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "TREE"@vi .

ex:Tree_221 a skos:Concept ;
    dct:creator "http://www.globalff.org/Feature_Articles/Previous_Articles/pre-defo.htm and http://www.geocities.com/atlas/word/gff_deforest.html" ;
    dct:source "http://www.geocities.com/atlas/word/gff_deforest.html"^^xsd:anyURI,
        "http://www.globalff.org/Feature_Articles/Previous_Articles/pre-defo.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "Large, generally single-stemmed, woody plants. ( and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "http://www.globalff.org/Feature_Articles/Previous_Articles/pre-defo.htm and http://www.geocities.com/atlas/word/gff_deforest.html" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_222 a skos:Concept ;
    dct:source "http://www.cof.orst.edu/cof/teach/for442/odfdefin.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "Live tree - a tree that has 10 percent or greater live crown"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "TREE"@vi .

ex:Tree_223 a skos:Concept ;
    dct:source "http://fiesta.bren.ucsb.edu/~idgec/publications/reports/forest.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "Mature tree. Has a single well-defined stem and is taller than 7 meters, different from a mature shrub that is usually less than 7 meters"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "TREE"@vi .

ex:Tree_224 a skos:Concept ;
    dct:creator "20 ft" ;
    skos:broadMatch ex:Tree ;
    skos:definition "Perennial plant with woody stem - usually a single stem or trunk made up of wood and protected by an outer layer of bark. It absorbs water through a root system. There is no clear dividing line between shrubs and trees, but sometimes minimum height of 6 m is used to define a tree. Lindley and Moore 1998"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "20 ft." ;
    skos:prefLabel "TREE"@vi .

ex:Tree_225 a skos:Concept ;
    skos:broadMatch ex:Tree ;
    skos:definition "Perennial woody plant that typically has a single up-right stem or trunk. Colliers Encyclopedia"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "TREE"@vi .

ex:Tree_226 a skos:Concept ;
    dct:creator "the trunk or bole" ;
    dct:source "http://www.encyclopedia.com/articles/13034.html"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "Perennial woody plant with a single main stem from which branches and twigs extend to form a characteristic crown"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "the trunk or bole" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_227 a skos:Concept ;
    dct:creator "trunk" ;
    skos:broadMatch ex:Tree ;
    skos:definition "Perennial, woody species life form with a single stem , normally greater than 4 to 5 meters or 13 to 16 feet in height; under certain environmental conditions, some tree species may develop a multi-stemmed or short growth form (less than 4 meters or 13 feet in height). (Anderson et al. 1998"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "trunk" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_228 a skos:Concept ;
    dct:source "http://crossword911.com/tree.html"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "Plant with branches"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "TREE"@vi .

ex:Tree_229 a skos:Concept ;
    skos:broadMatch ex:Tree ;
    skos:definition "Plants having a well-developed, woody stem and usually more than 12 feet in height at maturity. www.socrates.lv-hrc.nevada.edu/fia/dab/core1-7/appendix7_12_00.doc"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "TREE"@vi .

ex:Tree_23 a skos:Concept ;
    dct:date "1988"^^xsd:gYear ;
    dct:spatial "Bulgaria" ;
    skos:broadMatch ex:Tree ;
    skos:definition "species with long-living stems, from 3-5 m up to 150 m high (Delkov, N., 1988, Dendrology). Forest Research Institute <forestin@bulnet.bg>"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Bulgaria 1988" ;
    skos:prefLabel "Tree"@en .

ex:Tree_230 a skos:Concept ;
    dct:creator "megaphylls" ;
    skos:broadMatch ex:Tree ;
    skos:definition "Plants having true xylem and phloem; with true leaves present and usually having more than one vein ; enations absent; stems branching in various ways or unbranched; reproducing by means of seeds developed from ovules. (lizell@thurston.com from Stern (1991"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "megaphylls" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_231 a skos:Concept ;
    dct:creator "live for several to many years" ;
    dct:source "http://www.chesco.com/~treeman/words/words-t.html"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "Plants that are perennial , woody (have tough cell walls of wood), shedding (use and shed woody and non-woody parts) and compartmented (made up of many compartments). Trees usually have a single stem over three yards tall. Shrubs usually have many stems less than three yards tall"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "live for several to many years" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_232 a skos:Concept ;
    dct:creator "Hamilton" ;
    dct:date "1991"^^xsd:gYear ;
    skos:broadMatch ex:Tree ;
    skos:definition "Self-supporting, woody plants with a single main stem and which commonly reach a height of over 5 meters"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Hamilton 1991" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_233 a skos:Concept ;
    dct:date "1957"^^xsd:gYear ;
    skos:broadMatch ex:Tree ;
    skos:definition "Single-stemmed woody plants (From: Barry Wyatt BKW@WPO.NERC.AC.UK - Dansereau, P"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "1957" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_234 a skos:Concept ;
    dct:source "http://www.ucmp.berkeley.edu/glossary/gloss5ecol.html"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "Tall plant with a central trunk. The term does not imply anything about relationships, but is a growth pattern that has evolved several times in plants"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "TREE"@vi .

ex:Tree_235 a skos:Concept ;
    dct:source "http://www.allwords.com/query.asp"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "Tall woody perennial plant that typically has one main stem or trunk and which, unlike a shrub, usually only begins to branch at some distance from the ground"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "TREE"@vi .

ex:Tree_236 a skos:Concept ;
    dct:source "http://www.christiantech.com/cgi-bin/webster.exe?search_for_cgi-bin_texts_web1828=tree"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "The general name of the largest of the vegetable kind, consisting of a firm woody stem springing from woody roots, and spreading above into branches which terminate in leaves. A tree differs from a shrub principally in size, many species of trees growing to the highth of fifty or sixty feet, and some species to seventy or eighty, and a few, particularly the pine, to a much greater highth"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "TREE"@vi .

ex:Tree_237 a skos:Concept ;
    dct:creator "Árbol" ;
    dct:source "http://www.guiaverde.com/arboles/glosario.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "Tree - Vegetal leñoso al menos de 5 m. de altura con el tallo simple, denominado tronco, hasta la llamada cruz, en donde se ramifica y forma la copa. Tiene considerable crecimiento en grosor. Se diferencia del arbusto en que suele ser más alto y no se ramifica hasta cierta altura"@es ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Árbol" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_238 a skos:Concept ;
    dct:creator "cover" ;
    dct:source "http://www.anzlic.org.au/icsm/topo/tddsect4.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "Tree - The amount or density of tall woody plants occupying the surface of a specified area"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "cover" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_239 a skos:Concept ;
    dct:creator "layer" ;
    dct:source "http://birdcare.com/bin/showdict?tree+layer"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "Tree - The highest vegetation zone, lying above the shrub layer, from about eight metres upwards. The tree tops themselves form the canopy. Birdwatcher's Dictionary"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "layer" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_24 a skos:Concept ;
    dct:source "http://www.pfc.cfs.nrcan.gc.ca/landscape/inventory/terms/haddon/glossary.html#T"^^xsd:anyURI ;
    dct:spatial "Canada" ;
    skos:broadMatch ex:Tree ;
    skos:definition "[arbre] A woody, perennial plant generally with a single, well-defined stem and a more or less definitely formed crown. Source: \"Forest Inventory Terms in Canada.\" From: \"Haddon, Brian\" <BHaddon@nrcan.gc.ca and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Canada" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_240 a skos:Concept ;
    dct:source "http://code.municipalworld.com/kitchener/690.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "Tree means any tree, sapling or shrub, now or hereafter growing on property of the City, unless a contrary intention appears"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "TREE"@vi .

ex:Tree_241 a skos:Concept ;
    dct:source "http://www.newrichmond.org/treeord.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "Tree means any tree"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "TREE"@vi .

ex:Tree_242 a skos:Concept ;
    dct:source "https://www.thoughtco.com/worlds-smallest-tree-species-1343503?utm_campaign=wilat&utm_medium=email&utm_source=cn_nl&utm_content=9497194&utm_term"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "Tree -The definition of a tree that most tree scholars recognize is \"a woody plant with a single erect perennial trunk that reaches at least 3 inches in diameter at breast height (DBH} when mature"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "TREE"@vi .

ex:Tree_244 a skos:Concept ;
    dct:creator "16 feet" ;
    dct:source "http://www.blm.gov/nstc/library/pdf/1734-7.pdf"^^xsd:anyURI,
        "http://www.blm.gov/nstc/library/pdf/samplveg.pdf"^^xsd:anyURI,
        "http://www.blm.gov/nstc/library/pdf/utilstudies.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "USA-FED-DI-BLM 1999, 2001) A woody perennial, usually single-stemmed plant that has a definite crown shape and characteristically reaches a mature height of at least 5 meters . Some plants, such as oaks (Quercus spp.), may grow as either trees or shrubs , , and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "16 feet" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_245 a skos:Concept ;
    dct:source "http://www.alienexplorer.com/ecology/e17.html"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "Usually trees are defined as having a large, single trunk rising above the ground. The trunk is composed of wood and is divided usually into a series of branches"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "TREE"@vi .

ex:Tree_246 a skos:Concept ;
    dct:source "http://www.eresourcesystems.com/Help/Glossary/glossary.html"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "Woody perennial having an elongated stem, usually standing over 15 feet tall at maturity"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "TREE"@vi .

ex:Tree_247 a skos:Concept ;
    dct:source "http://bpc.iserver.net/cgi-bin/hilite.pl/codes/scottsva/_DATA/TITLE17/Chapter_17_44__GENERAL_AND_SPECIAL/17_44_080_Tree_protection_regu.html"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "Woody perennial plant characterized by having a main stem or trunk or a multi-stemmed trunk system with more or less definitely formed crown, usually over ten feet high at maturity. This definition shall not include trees planted, grown and held for sale by licensed nurseries or the first removal or transplanting of such trees pursuant to and as part of the operation of a licensed nursery business"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "TREE"@vi .

ex:Tree_248 a skos:Concept ;
    dct:source "http://www.gap.uidaho.edu/handbook/LandCoverMapping/UNESCO/default.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "Woody perennial plants, usually single stemmed with definite crown shape and reaching a height of five meters in height when mature"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "TREE"@vi .

ex:Tree_249 a skos:Concept ;
    dct:source "http://corssword911.com/tree.html"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "Woody plant"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "TREE"@vi .

ex:Tree_25 a skos:Concept ;
    dct:creator "Alberta" ;
    dct:source "http://www.agric.gov.ab.ca/agdex/100/3400600.html"^^xsd:anyURI ;
    dct:spatial "Canada" ;
    skos:broadMatch ex:Tree ;
    skos:definition "Woody, single-stemmed perennial plants which reach a mature height of at least 3 m"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Canada-Alberta" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_250 a skos:Concept ;
    dct:creator "called a perennial" ;
    skos:broadMatch ex:Tree ;
    skos:definition "Woody plant that renews its growth every year . Most plants classified as trees have a single self-supporting trunk containing woody tissue and in most species the trunk produces secondary limbs, called branches. Encyclopedia Britannia 1995"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "called a perennial" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_251 a skos:Concept ;
    dct:source "http://www.pfmt.org/glossary/t.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "Woody plant that usually grows to at least 20 feet in height at maturity, typically having a single trunk with no branches within 3 feet of the ground"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "TREE"@vi .

ex:Tree_252 a skos:Concept ;
    dct:creator "13 ft" ;
    dct:source "http://www.google.com/search?q=cache:www.iversonsoftware.com/business/plant/Tree.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "Woody plant with a distinct main stem, or trunk. At maturity, trees are usually the tallest of plants, and their height and single main stem differentiate them from shrubs, which are shorter and have many stems. Trees are perennials, plants that live for at least three years. Some species of tree only grow to 4 m in height, but the tallest species may reach heights of more than 112 m (more than 367 ft"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "13 ft" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_253 a skos:Concept ;
    dct:source "http://www.aswm.org/lwp/nys/glossary.htm#T"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "Woody plants greater than 7 meters tall, and usually with one main trunk"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "TREE"@vi .

ex:Tree_254 a skos:Concept ;
    dct:creator "Lund" ;
    dct:date "1984"^^xsd:gYear ;
    skos:broadMatch ex:Tree ;
    skos:definition "Woody plants having a well-developed stem and which are usually more than 3.7 meters in height at maturity"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Lund 1984" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_255 a skos:Concept ;
    dct:creator "at maturity" ;
    skos:broadMatch ex:Tree ;
    skos:definition "Woody plants having one erect perennial stem or trunk at least 3 inches d.b.h., a more or less definitely formed crown of foliage, and a height of at least 13 feet (Little 1979"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "at maturity" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_256 a skos:Concept ;
    dct:creator "Perry et al" ;
    dct:date "2005"^^xsd:gYear ;
    skos:broadMatch ex:Tree ;
    skos:definition "Working trees - those intentionally established in rural and urban landscapes to achieve specific functions"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Perry et al. 2005" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_259 a skos:Concept ;
    dct:creator "TOF" ;
    dct:source "http://www.lars.cl/biblioteca/Coura_Samuel.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "Trees on land not defined as forest and other wooded land. This may include agricultural land, including meadows and pasture, built-on land and barren land. (da Costa Coura, Samuel Martins et al. 2006+ Evaluation of High Resolution Imagery to Identify Trees Outside Forest In Brazilian Atlantic Rain Forest"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "TOF" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_26 a skos:Concept ;
    dct:creator "British Columbia" ;
    dct:spatial "Canada" ;
    skos:broadMatch ex:Tree ;
    skos:definition "Any living, erect, woody plant which is: 5 metres (16.3 feet) or more in height; or 10 centimetres (3.9 inches) or more in diameter measured 1.5 metres above the ground. www.civicinfo.bc.ca/Local_Content/legal-information/622.doc"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Canada-British Columbia" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_260 a skos:Concept ;
    dct:creator "– Victoria" ;
    dct:date "1958"^^xsd:gYear ;
    dct:source "http://www8.austlii.edu.au/cgi-bin/viewdoc/au/legis/vic/consol_act/fa1958116/s3.html#state_forest"^^xsd:anyURI ;
    dct:spatial "Australia" ;
    skos:broadMatch ex:Tree ;
    skos:definition "\"timber\" includes fallen trees felled trees and all wood whether sawn split hewn or otherwise fashioned"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Australia – Victoria 1958" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_261 a skos:Concept ;
    dct:creator "–" ;
    dct:date "2000"^^xsd:gYear ;
    dct:source "http://www.belizeaudubon.org/new_site/wp-content/uploads/2014/10/Forest_Act_213.pdf"^^xsd:anyURI ;
    dct:spatial "Belize" ;
    skos:broadMatch ex:Tree ;
    skos:definition "“timber” or “lumber” includes trees when they have fallen or have been felled, and all wood, whether cut up or fashioned or hollowed out for any purpose or not"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Belize – 2000" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_262 a skos:Concept ;
    dct:creator "– Alberta" ;
    dct:date "2000"^^xsd:gYear ;
    dct:source "http://www.qp.alberta.ca/1266.cfm?page=F22.cfm&leg_type=Acts&isbncln=9780779784318"^^xsd:anyURI ;
    dct:spatial "Canada" ;
    skos:broadMatch ex:Tree ;
    skos:definition "“timber” means all trees living or dead, of any size or species and whether standing, fallen, cut or extracted"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Canada – Alberta 2000" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_263 a skos:Concept ;
    dct:creator "–BC" ;
    dct:date "1996"^^xsd:gYear ;
    dct:source "http://www.bclaws.ca/EPLibraries/bclaws_new/document/ID/freeside/96157_01#section1"^^xsd:anyURI ;
    dct:spatial "Canada" ;
    skos:broadMatch ex:Tree ;
    skos:definition "cx\"timber\" means trees, whether standing, fallen, living, dead, limbed, bucked or peeled"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Canada –BC 1996" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_264 a skos:Concept ;
    dct:creator "–" ;
    dct:date "2014"^^xsd:gYear ;
    dct:source "https://www.agriculture.gov.ie/media/migration/forestry/forestrythelaw/ForestryAct2014240517.pdf"^^xsd:anyURI ;
    dct:spatial "Ireland" ;
    skos:broadMatch ex:Tree ;
    skos:definition "“timber” means the wood produced by a tree, whether or not the tree is standing"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Ireland – 2014" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_265 a skos:Concept ;
    dct:creator "Tanzania – 200" ;
    dct:source "http://www.parliament.go.tz/Polis/PAMS/Docs/14-2002.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "2 ''timber'' means any wood or tree which has falled or has been felled or cut off and all wood whether unsawn, hewn, sawn or machined, split, or otherwise cut up or fashioned and shall include lumber, flooring strips, shingles, and sleepers but does not include any article manufactured from such wood or firewood"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Tanzania – 200" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_266 a skos:Concept ;
    dct:date "1964"^^xsd:gYear ;
    dct:source "http://www2.austlii.edu.au/~graham/AsianLII/Thai_Translation/National%20Reserve%20Forest%20Act.pdf"^^xsd:anyURI ;
    dct:spatial "Thailand" ;
    skos:broadMatch ex:Tree ;
    skos:definition "“Timber” includes all species of plant; whether having trunk or growing in cluster or creeping, live or dead, as well as root, node, stump, sucker, branch, bud, tuber, corn, remains, extremity or any part of plant that is cut, stabbed, sawed, spitted, trimmed, chopped, dug, or done in any manner what so ever"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Thailand 1964" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_27 a skos:Concept ;
    dct:creator "Calgary" ;
    dct:source "http://www.calgary.ca/docgallery/BU/cityclerks/23M2002.pdf"^^xsd:anyURI ;
    dct:spatial "Canada" ;
    skos:broadMatch ex:Tree ;
    skos:definition "Any perennial woody plant that normally has one or few upright stems and is maintained as a tree and includes plants designated as trees by the General Manager, Parks"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Canada-Calgary" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_28 a skos:Concept ;
    dct:creator "Ontario-Guelph" ;
    dct:source "http://www.city.guelph.on.ca/uploaddocuments/d2169+Tree.pdf"^^xsd:anyURI ;
    dct:spatial "Canada" ;
    skos:broadMatch ex:Tree ;
    skos:definition "“Tree” means and includes any Deciduous or Coniferous growing tree that has a minimum height of 4.5 metres (15 feet) and a minimum diameter or 75 millimetres (3 inches) at a point one metre above ground level"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Canada-Ontario-Guelph" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_29 a skos:Concept ;
    dct:creator "Ontario-Halton and York" ;
    dct:source "http://www.region.halton.on.ca/PPW/archives/by-79-83.pdf"^^xsd:anyURI,
        "http://www.region.york.on.ca/Services/Forestry/Tree+By-Law/default+tree+by+law.htm"^^xsd:anyURI ;
    dct:spatial "Canada" ;
    skos:broadMatch ex:Tree ;
    skos:definition "Any species of woody plant which has reached or can reach an average height of at least 5 metres (15 feet) at physiological maturity. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Canada-Ontario-Halton and York" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_30 a skos:Concept ;
    dct:creator "Ontario-Simcoe" ;
    dct:source "http://www.county.simcoe.on.ca/services/forestry/bylaw.shtml"^^xsd:anyURI ;
    dct:spatial "Canada" ;
    skos:broadMatch ex:Tree ;
    skos:definition "Any species of woody plant which has reached or can reach an average height of at least 5 metres (15 feet) at physiological maturity"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Canada-Ontario-Simcoe" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_31 a skos:Concept ;
    dct:creator "Ontario-Stratford" ;
    dct:date "2003"^^xsd:gYear ;
    dct:source "http://www.city.stratford.on.ca/documents/bylaws/by_law_5_2003.pdf"^^xsd:anyURI ;
    dct:spatial "Canada" ;
    skos:broadMatch ex:Tree ;
    skos:definition "Any shade or ornamental tree, all or part of which is located on, above or below a public highway"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Canada-Ontario-Stratford 2003" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_32 a skos:Concept ;
    dct:date "2008"^^xsd:gYear ;
    dct:source "http://www.conaf.cl/cms/editorweb/transparencia/potestades/Ley-20283_bn.pdf"^^xsd:anyURI ;
    dct:spatial "Chile" ;
    skos:broadMatch ex:Tree ;
    skos:definition "Árbol: planta de fuste generalmente leñoso, que en su estado adulto y en condiciones normales de hábitat puede alcanzar, a lo menos, cinco metros de altura, o una menor en condiciones ambientales que limiten su desarrollo. Tree: usually woody stem plant, which in its adult stage and normal habitat can reach, at least, five meters high, or minor in environmental conditions that limit their development"@es ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Chile 2008" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_33 a skos:Concept ;
    dct:spatial "Costa Rica" ;
    skos:broadMatch ex:Tree ;
    skos:definition "Planta perenne de tronco leñoso y elevado que se ramifica a mayor o menor altura del suelo, que es fuente de materia prima que origina industrias como aserraderos, fabricas de tableros, de chapa, de fósforos, de celulosa, de aceites esenciales, de resinas y taninos\"(Reglamento a la Ley Forestal 7575"@es ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Costa Rica" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_34 a skos:Concept ;
    dct:spatial "Cuba" ;
    skos:broadMatch ex:Tree ;
    skos:definition "Arbol: Planta de fuste generalmente leñoso, con la presencia de un solo tallo dominante en la base, que en su estado adulto y en condiciones normales de hábitat puede alcanzar, no menos de 5 metros de altura, o una menor en condiciones ambientales negativas que limiten su desarrollo. \"Nelida Puentes Alvarez\" npuentes@eco.upr.edu.cu"@es ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Cuba" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_35 a skos:Concept ;
    dct:spatial "Cyprus" ;
    skos:broadMatch ex:Tree ;
    skos:definition "A woody perennial plant, typically large and with a well-defined stem carrying a more or less definite crown and with a minimum height of 5 m. A.K. Christou \"Forestry Department - Research and Publicity Sector\" publicity@cytanet.com.cy"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Cyprus" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_36 a skos:Concept ;
    dct:date "1994"^^xsd:gYear ;
    dct:source "http://cdm.unfccc.int/filestorage/L/4/Q/L4QB30W8C5RYZMT6UKOFX1PV9GNIHS/Annex%205%20Legal%20aspects.pdf?t=OXR8bHpqZnlvfDByMiF2MIecUaf9gjv8IjJT"^^xsd:anyURI ;
    dct:spatial "Ethiopia" ;
    skos:broadMatch ex:Tree ;
    skos:definition "Trees. are defined as ..any woody plant regardless of its, species, age, size including bamboo, reeds and palms as well as other plants to be designated as .trees by the Ministry. (Art.2.4). The definition given to .forest. and .trees. in the SNNPRS Forestry Proclamation is similar to that given in the Federal Proclamation (Arts.2.3 and 2.8 of Proclamation No.77/2004"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Ethiopia 1994" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_37 a skos:Concept ;
    dct:date "2007"^^xsd:gYear ;
    dct:source "http://www.pfmp-farmsos.org/Docs/forest%20proclamation_english.pdf"^^xsd:anyURI ;
    dct:spatial "Ethiopia" ;
    skos:broadMatch ex:Tree ;
    skos:definition "\"tree\" means any woody plant regardless of its species, age or size and includes bamboo, reeds and palms as well as other plants to be designated as such by the Ministry"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Ethiopia 2007" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_38 a skos:Concept ;
    dct:source "http://www.dse.de/zel/landinfo/pas/tk247_lup_eth/forest_inventory.pdf"^^xsd:anyURI ;
    dct:spatial "Ethiopia" ;
    skos:broadMatch ex:Tree ;
    skos:definition "A ligneous perennial species with a single (and occasionally double) stem. The distinction b/n woody shrub and small tree also need the knowledge of the species, as well as the ecology"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Ethiopia" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_4 a skos:Concept ;
    skos:broadMatch ex:Tree ;
    skos:definition "As of 19 May 2026, there are nearly 250 definitons of trees listed below"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "TREE"@vi .

ex:Tree_40 a skos:Concept ;
    dct:date "1978"^^xsd:gYear ;
    dct:source "http://www.paclii.org/fj/legis/consol_act_OK/fa98/"^^xsd:anyURI ;
    dct:spatial "Fiji" ;
    skos:broadMatch ex:Tree ;
    skos:definition "\"trees\" include trees, shrubs and bushes of all kinds, seedlings, saplings and re-shoots of all ages, climbers and creepers and any part of the tree"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Fiji 1978" ;
    skos:prefLabel "Tree"@en .

ex:Tree_41 a skos:Concept ;
    dct:date "2000"^^xsd:gYear ;
    dct:spatial "Fiji" ;
    skos:broadMatch ex:Tree ;
    skos:definition "Includes trees, shrubs and bushes of all kinds, seedlings, saplings and re-shoots of all ages, climbers and creepers and any part of the tree. Malakai Sevudredre, Conservator of Forests, F.9641/2. 01/06/2000"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Fiji 2000" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_42 a skos:Concept ;
    dct:spatial "Finland" ;
    skos:broadMatch ex:Tree ;
    skos:definition "trees (5 m tall, clear trunk): Guide book for woody plants in Finland. Seppo Ruotsalainen <Seppo.Ruotsalainen@metla.fi"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Finland" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_43 a skos:Concept ;
    dct:source "http://extwprlegs1.fao.org/docs/pdf/gam19052.pdf"^^xsd:anyURI ;
    dct:spatial "Gambia" ;
    skos:broadMatch ex:Tree ;
    skos:definition "A woody perennial plant typically large that has the potential of growing to more than three meters and with a single well defined stem carrying a more or less defined crown, and includes palm. Source: Danso A. A. Forestry Department <forestry.dept@gamtel.gm and and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Gambia" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_44 a skos:Concept ;
    dct:date "1998"^^xsd:gYear ;
    dct:source "http://extwprlegs1.fao.org/docs/pdf/gam19052.pdf"^^xsd:anyURI ;
    dct:spatial "Gambia" ;
    skos:broadMatch ex:Tree ;
    skos:definition "\"forest tree\" includes all trees growing within a forest, whether planted or not, and all naturally grown trees outside a forest"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Gambia-1998" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_45 a skos:Concept ;
    dct:date "1999"^^xsd:gYear ;
    dct:spatial "Ghana" ;
    skos:broadMatch ex:Tree ;
    skos:definition "A tall plant that can usually last for long period of time. A tree also has a thick central wooden stem or the trunk from which branches grow, which normally bears the leaves. (Osei Kofi, Forestry Dept.- Letter 7 May 99"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Ghana 1999" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_46 a skos:Concept ;
    dct:date "1949"^^xsd:gYear ;
    dct:spatial "Grenada" ;
    skos:broadMatch ex:Tree ;
    skos:definition "Includes palms, bamboos, stumps, brushwood and canes. LEX-FAOC005062. GRENADA: Forest, Soil and Water Conservation Ordinance. An ordinance to make provision for the conservation of forest, soil, water and other natural resources of the Colony. Date of original text: 01 August 1949"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Grenada 1949" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_47 a skos:Concept ;
    dct:spatial "Guatemala" ;
    skos:broadMatch ex:Tree ;
    skos:definition "Planta leñosa con fuste y copa definida. (Decreto 106-96, capitulo II: definiciones; art. 4"@es ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Guatemala" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_48 a skos:Concept ;
    dct:creator "ICRAF" ;
    dct:date "2017"^^xsd:gYear ;
    dct:source "http://dx.doi.org/10.5716/WP16079.PDF"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "Woody, self-supporting perennial life forms, regardless of the plant family (thus including conifers, broadleaved trees and shrubs, palms and bamboos, but excluding, for example rattans (not self-supporting), sugarcane and tufted grasses (non-woody"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "ICRAF - 2017" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_49 a skos:Concept ;
    dct:date "1927"^^xsd:gYear ;
    dct:source "http://envfor.nic.in/legis/forest/forest4.html"^^xsd:anyURI,
        "http://extwprlegs1.fao.org/docs/pdf/ind3171.pdf"^^xsd:anyURI,
        "http://nbaindia.org/uploaded/Biodiversityindia/Legal/3.%20Indian%20forest%20act.pdf"^^xsd:anyURI ;
    dct:spatial "India" ;
    skos:broadMatch ex:Tree ;
    skos:definition "\"tree\" includes palms, bamboos, stumps, brush-wood and canes. , and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "India 1927" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_5 a skos:Concept ;
    dct:spatial "Argentina" ;
    skos:broadMatch ex:Tree ;
    skos:definition "Woody plant with a defined stem and canopy clearly formed with secondary growth and lignificated tissues. \"Mirta Rosa Larrieu\"milarr@sagyp.mecon.ar"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Argentina" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_50 a skos:Concept ;
    dct:creator "Andhra Pradesh" ;
    dct:date "1967"^^xsd:gYear ;
    dct:source "http://www.forests.ap.gov.in/apforest_act_1967.pdf"^^xsd:anyURI ;
    dct:spatial "India" ;
    skos:broadMatch ex:Tree ;
    skos:definition "‘tree’ includes bamboos, stems, brushwood and canes"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "India Andhra Pradesh 1967" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_51 a skos:Concept ;
    dct:creator "Kerala" ;
    dct:source "http://www.kerala.gov.in/law_reforms/12_treegroth.pdf"^^xsd:anyURI ;
    dct:spatial "India" ;
    skos:broadMatch ex:Tree ;
    skos:definition "Any woody plant whether fruit bearing or not and includes bamboos"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "India Kerala" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_52 a skos:Concept ;
    dct:creator "Madhya Pradesh" ;
    dct:date "1927"^^xsd:gYear ;
    dct:source "http://banajata.org/pdf/state-level/chattisgarh.pdf"^^xsd:anyURI ;
    dct:spatial "India" ;
    skos:broadMatch ex:Tree ;
    skos:definition "The act goes on to define the trees that include palms, bamboos, stumps, brushwood and canes"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "India Madhya Pradesh 1927" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_53 a skos:Concept ;
    dct:creator "Mizoram" ;
    dct:date "2010"^^xsd:gYear ;
    dct:source "http://www.forest.mizoram.gov.in/index.php?option=com_content&task=view&id=127"^^xsd:anyURI ;
    dct:spatial "India" ;
    skos:broadMatch ex:Tree ;
    skos:definition "‘Tree’ includes palms, bamboos, stumps, brushwood and canes; Mizoram (Forest) Act,19553"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "India Mizoram 2010" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_54 a skos:Concept ;
    dct:creator "Tamil Nadu 1882" ;
    dct:source "https://www.forests.tn.gov.in/tnforest/app/webroot/img/document/legislations/01_Tamilnadu%20Forest%20Act%201882.pdf"^^xsd:anyURI ;
    dct:spatial "India" ;
    skos:broadMatch ex:Tree ;
    skos:definition "Tree \"Tree\" includes stumps, bamboos and brushwood"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "India Tamil Nadu 1882" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_55 a skos:Concept ;
    dct:creator "Tamil Nadu and Pondicherry ?" ;
    dct:date "2008"^^xsd:gYear ;
    dct:source "http://www.saiindia.gov.in/english/home/public_folder/Professional_Practices_Group/State_Local_Manual/PUDUCHERRY_MANUAL/Wad%20Manual/Forest.pdf"^^xsd:anyURI ;
    dct:spatial "India" ;
    skos:broadMatch ex:Tree ;
    skos:definition "Includes any tree seedling, sapling, transplant or coppice shoot of any age and any root, branch or other part"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "India Tamil Nadu and Pondicherry 2008?" ;
    skos:prefLabel "Tree"@en .

ex:Tree_56 a skos:Concept ;
    dct:source "http://moef.gov.in/nfc/s-git.pdf"^^xsd:anyURI ;
    dct:spatial "India" ;
    skos:broadMatch ex:Tree ;
    skos:definition "In this report, denotes all perennial woody vegetation (including bamboos, palms, coconut, neem, peepal, fruit trees, etc.). It excludes non-perennial non-woody species (e.g., banana) and tall shrubs or climbers (e.g., lantana or canes). For the purpose of assessing tree cover, only those trees having diameter of 10 cm or more at breast height (1.37 m) have been considered. In case of trees having multiple branches below breast height, the individual stems with diameter over 10 cm at breast height have been considered as individual trees"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "India" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_57 a skos:Concept ;
    dct:source "http://moef.gov.in/nfc/s-git.pdf"^^xsd:anyURI ;
    dct:spatial "India" ;
    skos:broadMatch ex:Tree ;
    skos:definition "The term used in this report refers to the notional area covered by crown of trees that is too small to be delineated by digital interpretation of remote sensing data used for forest cover delineation"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "India" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_58 a skos:Concept ;
    dct:date "2014"^^xsd:gYear ;
    dct:source "https://www.agriculture.gov.ie/media/migration/forestry/forestrythelaw/ForestryAct2014240517.pdf"^^xsd:anyURI ;
    dct:spatial "Ireland" ;
    skos:broadMatch ex:Tree ;
    skos:definition "“tree” means a free standing woody perennial plant whose species has the potential to have a more or less definite crown and be capable of reaching a minimum height of 5 metres at maturity and includes a sapling and the species of birch and hazel"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Ireland 2014" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_59 a skos:Concept ;
    dct:date "2005"^^xsd:gYear ;
    dct:source "http://formin.finland.fi/public/download.aspx?ID=15959&GUID=%7B88EFD0B8-9F47-4528-A24F-66DDE0CFE370%7D"^^xsd:anyURI ;
    dct:spatial "Kenya" ;
    skos:broadMatch ex:Tree ;
    skos:definition "Tree means any timber producing plant, or shrubs, bush of any kind and includes a seedling, sapling or reshoot of any age or any part thereof"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Kenya 2005" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_6 a skos:Concept ;
    dct:creator "Tasmania" ;
    dct:date "1985"^^xsd:gYear ;
    dct:source "http://www.fpa.tas.gov.au/__data/assets/pdf_file/0019/58114/A_guide_to_planning_approvals_for_forestry_in_Tasmania_Nov_2011.pdf"^^xsd:anyURI ;
    dct:spatial "Australia" ;
    skos:broadMatch ex:Tree ;
    skos:definition "A tree is any living or dead woody plant and includes seedlings and regrowth"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Australia Tasmania 1985" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_60 a skos:Concept ;
    dct:spatial "Isle of Man" ;
    skos:broadMatch ex:Tree ;
    skos:definition "The term \"tree\" is generally not defined. In certain Acts the term is given a special meaning, e.g. - In the Forestry Act \"trees\" is defined as including shrubs. \"IOM Gov DAFF\" <daff@gov.im"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Isle of Man" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_61 a skos:Concept ;
    dct:spatial "Israel" ;
    skos:broadMatch ex:Tree ;
    skos:definition "Tree: A plant with woody stem (s), with height at maturity of 4 meters or higher. From: GilS@kkl.org.il"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Israel" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_62 a skos:Concept ;
    dct:spatial "Japan" ;
    skos:broadMatch ex:Tree ;
    skos:definition "A woody perennial plant whose cambium makes secondary growth (often includes tree ferns and bamboo). High tree : a tree with enough height ( usually more than 5m ) and with a stem readily distinguishable from branches. Low tree : a tree with a certain height limit and the general absence of a well-defined main stem. Yukichi Konohira <Konohira@cc.tuat.ac.jp"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Japan" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_63 a skos:Concept ;
    dct:spatial "Kyrgyzstan" ;
    skos:broadMatch ex:Tree ;
    skos:definition "A perennial plant with clearly defined stem, carrying side branches and with a top shoot. The whole system of branches together with the corresponding part of the stem forms the crown. Tree is a widely spread life form of plants, playing the major role in the forest and landscape formation. Source: Irina Yunusova irina@lesic.elcat.kg"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Kyrgyzstan" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_64 a skos:Concept ;
    dct:date "1998"^^xsd:gYear ;
    dct:spatial "Lesotho" ;
    skos:broadMatch ex:Tree ;
    skos:definition "Include any seedlings, saplings, transplant or coopice shoot of any age. Forestry Act 1998. Via David May ISTF CVP Lesotho"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Lesotho 1998" ;
    skos:prefLabel "Tree"@en .

ex:Tree_65 a skos:Concept ;
    dct:spatial "Lithuania" ;
    skos:broadMatch ex:Tree ;
    skos:definition "A woody perennial plant, typically large and with a well defined stem or stem carrying a more or less definite crown, attaining a minimum diameter 14 cm and a minimum height 11 m at maturity. Source: A. Kuliesis, Director of Lithuanain Forest Inventory and Management Institute Email: Sekrtetore sek@mp.is.lt"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Lithuania" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_66 a skos:Concept ;
    dct:spatial "Luxembourg" ;
    skos:broadMatch ex:Tree ;
    skos:definition "Eléments ligneux pérennes comportant un tronc principal unique ou , s'agissant de taillis, comprennant plusieurs tiges, un houppier plus ou moins caractérisé. Source: Definitions De La Foret Utilisees Dans Le Cadre De L'inventaire Forestier National Au Luxembourg (Marc Wagner"@fr ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Luxembourg" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_67 a skos:Concept ;
    dct:date "1984"^^xsd:gYear ;
    dct:source "http://extwprlegs1.fao.org/docs/pdf/mal3252.pdf"^^xsd:anyURI ;
    dct:spatial "Malaysia" ;
    skos:broadMatch ex:Tree ;
    skos:definition "A wood perennial with a well-defined stem or trunk which supports a crown of branches and leaves (except in coppice management systems) and of a species which is usually capable of reaching a height of 5 meter at maturity in most of its distribution area. However, the legal definition under the Malaysian National Forestry Act 1984, it is defined as to include roots, stumps, branches, stems, leaves, brush-wood, palms, bamboos, canes, and creepers. From: hcthang@forestry.gov.my (Thang Hooi Chiew), Forestry Department Peninsular Malaysia and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Malaysia 1984" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_68 a skos:Concept ;
    dct:date "1983"^^xsd:gYear ;
    dct:source "http://www.intnet.mu/iels/Forest_act_1983.htm"^^xsd:anyURI ;
    dct:spatial "Mauritius" ;
    skos:broadMatch ex:Tree ;
    skos:definition "\"Tree\" includes live or dead timber, shrubs, underwood, brushwood, bamboo, palm, branches and twigs. (The Forests and Reserves Act 1983"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Mauritius 1983" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_69 a skos:Concept ;
    dct:spatial "Mexico" ;
    skos:broadMatch ex:Tree ;
    skos:definition "Arbol).- Planta leñosa, usualmente de más de tres metros de alto, cuyo tallo forma en su base un tronco manifiesto y que más arriba se ramifica formando una copa. Source: Glosario de Términos de la Memoria del Inventario Nacional Forestal Periódico y del Reglamento de la Ley Forestal from Unidad del Inventario <varelah@servidor.unam.mx"@es ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Mexico" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_7 a skos:Concept ;
    dct:source "http://155.187.10.12/glossary/fl-aust.html"^^xsd:anyURI ;
    dct:spatial "Australia" ;
    skos:broadMatch ex:Tree ;
    skos:definition "A woody plant at least 5 metres high, with a main axis the lower part of which is usually unbranched"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Australia" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_70 a skos:Concept ;
    dct:date "1992"^^xsd:gYear ;
    dct:source "http://sunsite.nus.edu.sg/apcel/dbase/myanmar/primary/myafor.html#ch1"^^xsd:anyURI ;
    dct:spatial "Myanmar" ;
    skos:broadMatch ex:Tree ;
    skos:definition "Includes root, stump, stem, branch, bush, creeper, bamboo, cane, orchid and seedling. Source: FOREST LAW State Law and Order Restoration Council Law No. 8/92 (3 November 1992) and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Myanmar 1992" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_71 a skos:Concept ;
    dct:creator "Nalms" ;
    dct:source "http://www.nalms.org/glossary/lkword_t.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "A woody plant which at maturity is usually 6 meters (20 feet) or more in height and generally has a single trunk, unbranched for 1 m or more above the ground, and a more or less definite crown; e.g., red maple (Acer rubrum), northern white cedar (Thuja occidentalis"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Nalms" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_72 a skos:Concept ;
    dct:date "1949"^^xsd:gYear ;
    dct:spatial "New Zealand" ;
    skos:broadMatch ex:Tree ;
    skos:definition "Includes not only timber trees, but also all other kinds of trees, shrubs, and bushes, seedlings, saplings, cuttings, suckers, and shoots of every description. (from Forests Act 1949"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "New Zealand 1949" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_73 a skos:Concept ;
    dct:spatial "Northern Mariana Islands" ;
    skos:broadMatch ex:Tree ;
    skos:definition "A physical, living plant structure that utilizes solar energy in combination with water moisture and minerals in the ground to produce and contribute life sustaining oxygen for all other living organisms on the planet. Source: Estanislao Villagomez stanvill@gtepacifica.net Division of Agriculture"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Northern Mariana Islands" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_74 a skos:Concept ;
    dct:date "1927"^^xsd:gYear ;
    dct:spatial "Pakistan" ;
    skos:broadMatch ex:Tree ;
    skos:definition "Tree includes palms, bamboos, stumps, brush-wood and canes. Pakistan Forest Act of 1927. Source: Mumtaz Ahmad, Section Forest Officer, Pakistan Min. of Environment, Local Government, and Rural Development"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Pakistan 1927" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_75 a skos:Concept ;
    dct:creator "Papua New" ;
    dct:spatial "Guinea" ;
    skos:broadMatch ex:Tree ;
    skos:definition "Any woody perennial plant that has a single stem (except coppices) and with a diameter greater than 10 cm dbh and height of more than 5 metres and having a somewhat distinct crown shape. Vitus Ambia, Papua New Guinea Forest Authority"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Papua New Guinea" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_76 a skos:Concept ;
    dct:spatial "Oman" ;
    skos:broadMatch ex:Tree ;
    skos:definition "Wooden perennate plant, with a minimum 7 m height, able to accumulate vegetal biomass and to reproduce itself. Source: Sorin Sfirlogea <sorinsf@rosilva.ro National Forests Administration"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Romania" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_77 a skos:Concept ;
    dct:creator "SADC" ;
    dct:date "1997"^^xsd:gYear ;
    skos:broadMatch ex:Tree ;
    skos:definition "Self-supporting, single stemmed for with a few definitive trunks branching about ground level. Woody plants typically +/- 5 m in height. (Trevett 1997"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "SADC 1997" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_8 a skos:Concept ;
    dct:creator "–NSW – Penrith City" ;
    dct:spatial "Australia" ;
    skos:broadMatch ex:Tree ;
    skos:definition "A perennial plant with a self-supporting stem which: (a) has a girth of 30cm or more, measured at a distance of 40cm above ground; and (b) has a height in excess of 3m. www.penrithcity.nsw.gov.au/PCC/tree.htm"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Australia–NSW – Penrith City" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_81 a skos:Concept ;
    dct:creator "Science: botany" ;
    dct:source "http://www.biology-online.org/dictionary/Tree"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "A woody plant at least 5 metres high, with a main stem the lower part of which is usually unbranched"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Science: botany" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_82 a skos:Concept ;
    dct:source "http://www.fstcu.org/national/seychell/vegtypes.htm"^^xsd:anyURI ;
    dct:spatial "Seychelles" ;
    skos:broadMatch ex:Tree ;
    skos:definition "Bush vegetation: Mixture of cinnamon, prune de France and various tree species, generally lower than 10m. . By default, a tree would be 10 m or greater"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Seychelles" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_83 a skos:Concept ;
    dct:date "1988"^^xsd:gYear ;
    dct:spatial "Sierra Leone" ;
    skos:broadMatch ex:Tree ;
    skos:definition "Any woody vegetation. LEX-FAOC005732. SIERRA LEONE: Forestry Act, 1988. Being an Act to make new provisions in the Law relating to Forestry in Sierra Leone and for connected purpose"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Sierra Leone 1988" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_84 a skos:Concept ;
    dct:date "1999"^^xsd:gYear ;
    dct:spatial "Solomon Islands" ;
    skos:broadMatch ex:Tree ;
    skos:definition "Includes any root, stump, stem, branch, brushwood, ung(?) tree or sapling. . [LEX-FAOC018884] SOLOMON ISLANDS: Forests Act (No. 3 of 1999). Date of text: 24 September 1999"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Solomon Islands 1999" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_85 a skos:Concept ;
    dct:date "2004"^^xsd:gYear ;
    dct:source "http://www.parliament.gov.sb/files/legislation/Bills/2004/The%20Forests%20Bill%202004.pdf"^^xsd:anyURI ;
    dct:spatial "Solomon Islands" ;
    skos:broadMatch ex:Tree ;
    skos:definition "Trees include a seedling sapling and pole"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Solomon Islands 2004" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_86 a skos:Concept ;
    dct:spatial "South Africa" ;
    skos:broadMatch ex:Tree ;
    skos:definition "A woody single stemmed plant more than 3m in height or a woody multi-stemmed plant more than 5m in height. From: Graeme Wild <GraemeW@za.sappi.com"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "South Africa" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_87 a skos:Concept ;
    dct:creator "South" ;
    dct:date "2009"^^xsd:gYear ;
    dct:spatial "Sudan" ;
    skos:broadMatch ex:Tree ;
    skos:definition "“Tree” means forest trees including bushes, palms, bamboos, shrubs, brushwood, creepers and climbers at all stages of their growth; (GOSS, 2009"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "South Sudan 2009" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_88 a skos:Concept ;
    dct:creator "St. Lucia" ;
    skos:broadMatch ex:Tree ;
    skos:definition "A large woody plant with a clearly defined bale or stem and a well developed crown. Includes palms, bamboos, stumps, brushwood and canes. (Source: Michael Andrew, chiefforest@maffe.org"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "St. Lucia" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_89 a skos:Concept ;
    dct:creator "Standard" ;
    dct:source "http://www.wildlifetrust.org.uk/herts/reserves/glossary.html#Acid"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "Trees within a coppiced woodland which are allowed to grow to maturity and traditionaly then felled or large timber"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Standard" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_9 a skos:Concept ;
    dct:creator "NSW" ;
    dct:date "1938"^^xsd:gYear ;
    dct:source "http://www.forest.nsw.gov.au/education/glossary/default.asp#Ltr_W"^^xsd:anyURI ;
    dct:spatial "Australia" ;
    skos:broadMatch ex:Tree ;
    skos:definition "A perennial plant having a self-supporting woody stem or trunk which usually develops woody branches (under the Soil Conservation Act, 1938 a tree includes sapling, shrub or scrub"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Australia-NSW 1938" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_90 a skos:Concept ;
    dct:creator "Swazi Nation" ;
    dct:date "1910"^^xsd:gYear ;
    skos:broadMatch ex:Tree ;
    skos:definition "\"brushwood\" means any bushes, underwood or similar growths on Government land or on Swazi nation land which are not included in the terms \"indi- genous timber\" or \"government timber\"; www.sntc.org.sz/documents/ForestPreservationAct.do"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Swazi Nation 1910" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_91 a skos:Concept ;
    dct:creator "Swaziland" ;
    dct:date "1951"^^xsd:gYear ;
    skos:broadMatch ex:Tree ;
    skos:definition "Tree means the whole or any part of any tree as ordinarily understood or of shrub, bush, seedling, transplant, sapling, reshoot, underbrush or regrowth. LEX-FAOC012388. SWAZILAND: Private forests Act 1951 (No. 3 of 1951). An Act to provide for the better regulation and protection of private forests in Swaziland"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Swaziland 1951" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_92 a skos:Concept ;
    dct:creator "Swaziland" ;
    dct:source "http://www.sntc.org.sz/legislat/sntcact1.html"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "\"tree\" means a perennial plant having a self-supporting woody main stem or trunk and growing to a height of not less than five feet, but does not include bushes or shrubs"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Swaziland" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_93 a skos:Concept ;
    dct:date "2000"^^xsd:gYear ;
    dct:spatial "Sweden" ;
    skos:broadMatch ex:Tree ;
    skos:definition "able to reach 5 meters when soil fertility and surrounding environment optimal. For FRA 2000 - Source: UN/ECE 2000 p 87"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Sweden 2000" ;
    skos:prefLabel "- Tree"@en .

ex:Tree_94 a skos:Concept ;
    dct:creator "Taiwan, ROC" ;
    skos:broadMatch ex:Tree ;
    skos:definition "A woody plant having one well-defined stem and a more or less definitely formed crown, usually attaining a DBH of at least 10cm, and all bamboo stands. Source: \"&ordf;L&deg;È&sect;&frac12;service\" service@dns.forest.gov.tw"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Taiwan, ROC" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_95 a skos:Concept ;
    dct:creator "Tanzania" ;
    skos:broadMatch ex:Tree ;
    skos:definition "Includes palms, bamboos, canes, shrubs, bushes ,plants, poles, climbers, seedlings, saplings and regrowth thereof, all ages and all kinds and part. From: Tanzania Forest policy, Roger Malimbwi, Faculty of Forestry <forestry@sua.ac.tz"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Tanzania" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_96 a skos:Concept ;
    dct:creator "Tanzania" ;
    dct:date "2002"^^xsd:gYear ;
    dct:source "http://www.parliament.go.tz/Polis/PAMS/Docs/14-2002.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "''tree'' includes palms, bamboos, canes, shrubs, bushes, climbers, forest seedlings, transplants"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Tanzania 2002" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_97 a skos:Concept ;
    dct:spatial "Thailand" ;
    skos:broadMatch ex:Tree ;
    skos:definition "Plant with gbh15 cm divided into 3 classes: gbh 16-45 cm, gbh 46-100 cm; gbh 100 cm. Songkram Thammincha <fforskt@ku.ac.th"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Thailand" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_98 a skos:Concept ;
    dct:date "1961"^^xsd:gYear ;
    dct:spatial "Tonga" ;
    skos:broadMatch ex:Tree ;
    skos:definition "Includes palms, shrubs, bushes, climbers, seedlings, saplings, and re-shoots of all ages and of all kinds, and any part thereof. Forests Act 1961 (Chapter 126 of the 1988 Revised Edition of the Laws of Tonga). Via James Barton jpbarton@xtra.co.nz"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Tonga 1961" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_99 a skos:Concept ;
    dct:spatial "Trinidad and Tobago" ;
    skos:broadMatch ex:Tree ;
    skos:definition "all species of trees listed in the second schedule and bamboo, palms and brushwood found growing on state lands – Forests Act: Chapter 66:01. Narine Lackhan, Director of Forestry"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Trinidad and Tobago" ;
    skos:prefLabel "Tree"@en .

ex:Treed_1 a skos:Concept ;
    dct:creator "by crown cover" ;
    dct:source "https://www.for.gov.bc.ca/hfd/library/documents/bib106996.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A vegetated polygon with 10% or more of tree species of any size"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "by crown cover" ;
    skos:prefLabel "Treed"@en .

