    dct:spatial "Liberia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "forest, as being ‘a tract of land consisting of flora and fauna’ (s.1.3"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Liberia " ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "National"@en .

ex:Forest_1259 a skos:Concept ;
    dct:creator "ia" ;
    dct:date "2002"^^xsd:gYear ;
    dct:source "http://www.onlinenigeria.com/links/adv.asp?blurb=70"^^xsd:anyURI ;
