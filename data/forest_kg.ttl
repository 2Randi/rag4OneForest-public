    skos:broadMatch ex:Forest ;
    skos:definition "woods"@af ;
    skos:inScheme ex:ForestScheme ;
    skos:note "the trees and other plants in a large densely wooded area" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_274 a skos:Concept ;
    dct:creator "10 ft" ;
    dct:source "http://gis.esri.com/library/userconf/proc02/pap0811/p0811.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Woody vegetation > 3 meters in height. Canopy closure must be >35% (<35% = Category 3). Also included in this category are areas commonly referenced as \"swamp\" or forested wetland"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "10 ft" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_275 a skos:Concept ;
    dct:creator "Agroforest" ;
    dct:source "http://www.worldagroforestry.org/downloads/publications/PDFs/WP16263.PDF"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest which is managed more or less intensively by small holders producing timber and non-timber products. (Zomer RJ, Trabucco A, Coe R and Place F. 2009. Trees on Farm: Analysis of Global Extent and Geographical Patterns of Agroforestry. ICRAF Working Paper no. 89. Nairobi, Kenya: World Agroforestry Centre. 63 p"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Agroforest" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land use"@en .

ex:Forest_276 a skos:Concept ;
    dct:creator "American Legislative Exchange Council" ;
    dct:source "https://www.alec.org/model-policy/the-right-to-practice-forestry-act/"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "“Forest” means a parcel of land in which at least 80% of the parcel is producing or is capable of producing at least 20 cubic feet of merchantable timber per acre per year {or as defined by state statute}"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "American Legislative Exchange Council" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land use"@en .

ex:Forest_28 a skos:Concept ;
    dct:source "http://www.dorsetcoppicegroup.co.uk/resources/Dorset_Coppice_Group_Glossary.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Originally a tract of heath, moor or woodland controlled by the Crown for the purpose of conserving deer and other woodland animals"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "General"@en .

ex:Forest_280 a skos:Concept ;
    dct:creator "Terre forestiere, terreno forestal" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land under natural or cultivated stands of trees intended for forest use, including land cleared of trees but which will be reforested. Permanent meadows and pastures with scattered trees and shrubs do not constitute forest (Miani 1991 - Forestry Chronicle 70(6):669 1994"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Terre forestiere, terreno forestal" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land use"@en .

ex:Forest_281 a skos:Concept ;
    dct:creator "NRI" ;
    dct:source "http://goatconnection.com/articles/publish/article_86.shtml"^^xsd:anyURI,
        "http://www.pfb.com/resources/ag-information/glossary-of-ag-terms-F.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A classification of land use in the Natural Resources Inventory . It includes areas where trees cover at least 10% of the land and must be at least an acre in size. Forestland was found on 395 million acres, almost 30% of all private lands, in the 1992 NRI. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "NRI" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land use"@en .

ex:Forest_282 a skos:Concept ;
    dct:creator "or equivalent stocking level" ;
    skos:broadMatch ex:Forest ;
    skos:definition "A land area with a minimum 10 % tree crown coverage , or formerly having such tree cover and that is being naturally or artificially regenerated or that is being afforested (Päivinen et al. 1994"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "or equivalent stocking level" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land use"@en .

ex:Forest_283 a skos:Concept ;
    dct:date "1992"^^xsd:gYear ;
    skos:broadMatch ex:Forest ;
    skos:definition "A natural land that has not been subjected to human activities regarding change of use. Harrison"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "1992" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land use"@en .

ex:Forest_284 a skos:Concept ;
    dct:source "http://www.dictionary.com/cgi-bin/dict.pl?term=forestland"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A section of land covered with forest or set aside for the cultivation of forests"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land use"@en .

ex:Forest_285 a skos:Concept ;
    dct:source "http://www.eresourcesystems.com/Help/Glossary/glossary.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "All land which is capable of supporting a merchantable stand of timber and is not actively being used in a use which is incompatible with timber growing"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land use"@en .

ex:Forest_286 a skos:Concept ;
    dct:creator "a" ;
    dct:source "http://www.mrsc.org/mc/rcw/RCW%20%2076%20%20TITLE/RCW%20%2076%20.%2009%20%20CHAPTER/RCW%20%2076%20.%2009%20.020.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "All land which is capable of supporting a merchantable stand of timber and is not being actively used for a use which is incompatible with timber growing. Forest land does not include agricultural land that is or was enrolled in the conservation reserve enhancement program by contract if such agricultural land was historically used for agricultural purposes and the landowner intends to continue to use the land for agricultural purposes in the future. As it applies to the operation of the road maintenance and abandonment plan element of the forest practices rules on small forest landowners, the term \"forest land\" excludes: Residential home sites, which may include up to five acres; and (b) Cropfields, orchards, vineyards, pastures, feedlots, fish pens, and the land on which appurtenances necessary to the production, preparation, or sale of crops, fruit, dairy products, fish, and livestock exist"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "a" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land use"@en .

ex:Forest_287 a skos:Concept ;
    skos:broadMatch ex:Forest ;
    skos:definition "All lands bearing vegetative associations dominated by trees of any size, exploited or not, capable of producing wood or other forest products, of exerting an influence on climate or on water regime, or providing shelter for livestock or wildlife. Includes lands which have been clearcut or burned but which will be reforested in the foreseeable future. Excludes orchards, shelterbelts, groups of trees along roads or city parks. Encyclopedia Britannia 1970"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land use"@en .

ex:Forest_288 a skos:Concept ;
    dct:creator "World Forest Inventories" ;
    dct:date "1953"^^xsd:gYear ;
    skos:broadMatch ex:Forest ;
    skos:definition "All lands bearing vegetative associations dominated by trees of any size, exploited or not, capable of producing wood or of exerting an influence on the local climate or on the water regime. Included are: lands from which forests have been recently clear cut or burned but which will be reforested in the near future; public and private forests of any size; tree nurseries; forest roads; mangrove forests, forests of low growth and of dwarfed or stunted forms. Excluded are: brush lands, groups of trees outside the forest, trees along roads, etc., and on agricultural lands and parks. From: Alexander.Korotkov@unece.org. Date: Thu, 15 Oct 1998 17:09:40 +0200"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "World Forest Inventories 1953" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land use"@en .

ex:Forest_289 a skos:Concept ;
    dct:source "http://fwie.fw.vt.edu/rhgiles/appendices/glossf.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "An area managed for producing timber and other products, or maintained under woody vegetation for such indirect benefits as protection of watersheds or recreation"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land use"@en .

ex:Forest_29 a skos:Concept ;
    dct:source "http://www.bwf.org/laws/FSAO_15.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "The mass of land of the public domain comprising of the public forest, permanent/established forests or forest reserves and other forest reservations"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "General"@en .

ex:Forest_290 a skos:Concept ;
    dct:source "http://www.genesisny.net/Commodity/Timber/Timberglos.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "An area managed for the production of timber and other forest products or maintained as wood vegetation for such indirect benefits as protection of catchment areas or recreation"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land use"@en .

ex:Forest_291 a skos:Concept ;
    dct:creator "water" ;
    skos:broadMatch ex:Forest ;
    skos:definition "An area managed for the production of timber and other forest produce, or maintained under woody vegetation for such indirect benefits as protection of catchment areas or recreation. SAF 1971 (Helms 2002"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "water" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land use"@en .

ex:Forest_292 a skos:Concept ;
    dct:creator "both if plural" ;
    dct:source "http://www.safc.org/resources/glossary.htm#F"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "An area managed for the production of timber and other forest products, or maintained under woody vegetation for indirect benefits as protection of a watershed, recreation, or wildlife habitat. When used as a proper noun, it refers to the Chattahoochee or Oconee National Forest"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "both if plural" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land use"@en .

ex:Forest_293 a skos:Concept ;
    dct:source "http://nfdp.ccfm.org/silviterm/silvi_e/silvitermetohe.htm#F"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "An area managed for the production of timber and other forest produce, or maintained under woody vegetation for such indirect benefits as the protection of watersheds, the provision of recreation areas, or the preservation of natural habitat"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land use"@en .

ex:Forest_294 a skos:Concept ;
    dct:source "http://books.google.com/books?id=jhZsJc4z5RkC&pg=PA657&lpg=PA657&dq=hawaii+forestland&source=web&ots=YlCTj-qUZR&sig=PtkyXu4oaaWBg-3k45z2nub3mDs#PPA645,M1"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "An area which is for the most part set aside for the production of timber and other forest produce, or which is expected to exercise certain climatic effects, or to protect the locality against injurious influences. Encyclopedia Britannia 1910. p. 645"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land use"@en .

ex:Forest_295 a skos:Concept ;
    dct:creator "19th century" ;
    dct:source "http://dspace.wbpublibnet.gov.in/dspace/bitstream/10689/10100/4/Chapter%201_1%20-%20125p.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "An area, which has been set aside principally for the production of wood, and which, at any rate for the greater part, is covered with trees"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "19th century" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land use"@en .

ex:Forest_296 a skos:Concept ;
    dct:source "http://www.environmental-auditing.org/LinkClick.aspx?fileticket=fbx%2FbAIVeFU%3D&tabid=128&mid=568"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "An ecosystem characterized by more or less dense and extensive tree cover, often consisting of stands varying in characteristics such as species compositions, structure, age class and associated processes, and commonly including meadows, streams, fish, and wildlife. Thus forest could be defined as a set of land parcels that has or could have tree vegetation and is managed as a whole to achieve the objective of the owner"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land use"@en .

ex:Forest_297 a skos:Concept ;
    dct:creator "Asian Development Bank" ;
    dct:date "1995"^^xsd:gYear ;
    dct:source "http://www.bicusa.org/bicusa/issues/misc_resources/585.php"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "An ecosystem with a minimum of 10 percent crown cover of trees and/or bamboos, generally associated with wild flora, fauna and natural soil conditions and not subject to agriculture"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Asian Development Bank 1995" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land use"@en .

ex:Forest_298 a skos:Concept ;
    dct:source "https://www.forestasyst.org/glossary.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Any land with at least 10 percent coved by trees of any size, or having had such tree cover and not currently developed or under cultivation"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land use"@en .

ex:Forest_299 a skos:Concept ;
    dct:creator "26" ;
    dct:source "http://rredc.nrel.gov/biomass/forest/tim_glossary/t_glossary.html#F"^^xsd:anyURI,
        "http://www.rook.org/earl/bwca/lists/glossary/"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Area managed for the production of timber and other forest products or maintained as wood vegetation for such indirect benefits as protection of catchment areas or recreation . and Ford-Robertson 1971: 107, 298. Also Boundary Waters Compendium Glossary"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "26" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land use"@en .

ex:Forest_30 a skos:Concept ;
    dct:creator "Closed" ;
    dct:source "http://www.birdlist.org/cam/themes/Volume_I_s.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "forest – Formed by trees at least 5 m tall with their crowns interlocking, covering 65% of the sky or more"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Closed" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_300 a skos:Concept ;
    dct:source "http://sedac.ciesin.columbia.edu/tg/guide_frame.jsp?rd=LU&ds=1"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Areas with a? minimum of 10% crown cover of trees and/or bamboos, generally associated with wild flora and fauna and natural soil conditions, and are not subject to agricultural practices. Note that in some countries, some areas are statutorily defined as ?Forest Area? that contain no tree cover"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land use"@en .

ex:Forest_301 a skos:Concept ;
    dct:source "http://www.grida.no/baltic/related/balans_landcover_classification_methodology_ver2.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest is defined as >30% crown cover and the tree height shall be >7 m. Seedlings under forest are also included in this class. Areas occupied by forest and woodlands with a vegetation pattern composed of native or exotic coniferous trees, and which can be used for the production of timber or other forest products. The forest trees are under normal climatic conditions higher than 5 m with a canopy closure of 30% at least"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land use"@en .

ex:Forest_302 a skos:Concept ;
    dct:source "http://www.gcrio.org/CONSEQUENCES/spring95/Land.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest land is characterized by a predominance of tree cover and is further divided by the U.S. Census into timberland and non-timberland. By definition, the former must be capable of producing 20 cubic feet of industrial wood per acre per year and remain legally open to timber production"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land use"@en .

ex:Forest_303 a skos:Concept ;
    dct:source "http://www.mrsc.org/mc/rcw/RCW%20%2084%20%20TITLE/RCW%20%2084%20.%2033%20%20CHAPTER/RCW%20%2084%20.%2033%20.035.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest land is synonymous with \"designated forest land\" and means any parcel of land that is twenty or more acres or multiple parcels of land that are contiguous and total twenty or more acres that is or are devoted primarily to growing and harvesting timber. Designated forest land means the land only and does not include a residential homesite. The term includes land used for incidental uses that are compatible with the growing and harvesting of timber but no more than ten percent of the land may be used for such incidental uses. It also includes the land on which appurtenances necessary for the production, preparation, or sale of the timber products exist in conjunction with land producing these products"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land use"@en .

ex:Forest_304 a skos:Concept ;
    dct:source "http://www.ancienttrees.org/fulltext.php"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forestland means land, other than land owned by the federal government, that was, as of the effective date of this section, available for and capable of growing a crop of trees of any commercial species used to produce lumber and other forest products, including Christmas trees. Commercial species are those species so designated by the board"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land use"@en .

ex:Forest_305 a skos:Concept ;
    dct:creator "based on crown cover" ;
    dct:source "http://www.reo.gov/general/definitions_n-z.htm#R"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land at least 10 percent stocked by forest trees of any size, or formerly having had such tree cover and not currently developed for nonforest use. 2003"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "based on crown cover" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land use"@en .

ex:Forest_306 a skos:Concept ;
    dct:source "http://www.idahoforests.org/dict1.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land at least 10 percent stocked by tree stands of any size or that formerly had such tree cover and that will be regenerated with trees"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land use"@en .

ex:Forest_307 a skos:Concept ;
    dct:source "http://www.ilea.org/birdsey/glossary.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land at least 10 percent stocked by trees of any size, including land that formerly had such tree cover and that will be naturally or artificially regenerated. Forest land includes transition zones, such as areas between heavily forested and nonforested lands that are at leas t 10 percent stocked with forest trees and forest areas adjacent to urban and built-up lands. Also included are pinyon-juniper and chaparral areas in the West and afforested areas. The minimum area for classification of forest land is 1 acre. Roadside, streamside, and shelterbelt strips of timber must have a crown width of at least 120 feet to qualify as forest land. Unimproved roads and trails, streams, and clearings in forest areas are classified as forest if less than 120 feet wide"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land use"@en .

ex:Forest_308 a skos:Concept ;
    dct:source "http://maps.vcgi.org/indicators/metadata/cntyfrst.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land at least 10 percent stocked with trees of any size, or that formerly had tree cover and is not currently developed for a nonforest use. The minimum area for classification is one acre"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land use"@en .

ex:Forest_309 a skos:Concept ;
    dct:creator "36 CFR 219.3" ;
    dct:source "http://fwie.fw.vt.edu/rhgiles/appendices/glossf.htm"^^xsd:anyURI,
        "http://www.safc.org/resources/glossary.htm#D"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land at least 10-percent occupied by forest trees of any size or formerly having had such tree cover and not currently developed for non-forest use. Lands developed for non-forest use include area for crops, improved pasture, residential or administrative areas, improved roads of any width, adjoining road clearing, and power-line clearing of any width. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "36 CFR 219.3" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land use"@en .

ex:Forest_31 a skos:Concept ;
    dct:creator "Closed" ;
    dct:source "http://www.geery.com/Norfork_MUC.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Formed by trees at least 5 meters tall with their crowns interlocking. Total canopy cover is greater than 40%"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Closed" ;
    skos:prefLabel "forest"@da ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_310 a skos:Concept ;
    dct:creator "Note: Stocking is measured by comparing specified standards with basal area and /or number of trees, age or size, and spacing" ;
    dct:source "http://www.for.msu.edu/~kpw/glossary.htm"^^xsd:anyURI,
        "http://www.pfmt.org/glossary/f.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land at least 16.7 percent stocked by forest trees of any size, or formerly having had such tree cover, and not currently developed for nonforest use. The minimum area for classification of forest land is 1 acre. Roadside, streamside, and shelterbelt strips of timber must have a crown width of at least 120 feet to qualify as forest land. Unimproved roads and trails, streams, or other bodies of water or clearings in forest areas shall be classed as forest if less than 120 feet wide. Glossary of Forestry Terms and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Note: Stocking is measured by comparing specified standards with basal area and /or number of trees, age or size, and spacing." ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land use"@en .

ex:Forest_311 a skos:Concept ;
    dct:source "http://www.wvgazette.com/static/series/mining/reports/EIS/VIII.Glossary.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land bearing a stand of trees of any stature, including seedlings, and of species attaining a minimum of 6 feet average height at maturity or land from which such a stand has been removed but on which no other use has been substituted. The term is commonly limited to land not in farms; forests on farms are commonly called woodland or farm forests"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land use"@en .

ex:Forest_312 a skos:Concept ;
    dct:source "http://www.geocities.com/rboutilier000/wildlif1.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land bearing forest growth or land from which the forest has been removed but which shows surface evidence of past forest occupancy and is not now in other use"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land use"@en .

ex:Forest_313 a skos:Concept ;
    dct:source "http://www.lwvwa.org/forest/dynamic/glossary.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land capable of supporting trees and not actively in a use which is incompatible with timber growing. Washington's Dynamic Forests - League of Women Voters of Washington Education Fund"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land use"@en .

ex:Forest_314 a skos:Concept ;
    dct:creator "USA" ;
    dct:source "http://eurodic.ip.lu/cgi-bin/edicbin/expert.pl"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land carrying forest growth or, if totally lacking it (non-stocked , unstocked (Cw) forest land), bearing evidence of former forest and not now in other use Eurodicautom"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land use"@en .

ex:Forest_315 a skos:Concept ;
    dct:source "http://www.m-w.com/cgi-bin/dictionary?book=Dictionary&va=forestland"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land covered with forest or reserved for the growth of forests"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land use"@en .

ex:Forest_316 a skos:Concept ;
    dct:creator "10 base 100" ;
    dct:source "http://www.ciel.org/forestglossary.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land currently growing forest trees of any size with a total stocking value of at least 16.7 in the West), or lands formerly forested, currently capable of becoming forest land, and not currently developed for nonforest uses. These lands must be a minimum of 1 acre in area. Roadside, streamside, and shelterbelt strips of timber must have a crown width of at least 120 feet to qualify as forest land. Unimproved roads, trails, streams, and clearings within forest areas are classified as forest land if they are less than 120 feet wide. Recently clearcut areas that are currently nonstocked are classed as forest lands unless they are being used as agriculture. Forest land is divided into two categories (timberland and other forest land), and both of these categories may be further classified as reserved if harvesting is prohibited by statutory or administrative restrictions. Forest Glossary"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "10 base 100" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land use"@en .

ex:Forest_317 a skos:Concept ;
    dct:source "http://www.forestmeister.com/highlights.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land must be at least 10 acres of contiguous forest not developed for non-forest use"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land use"@en .

ex:Forest_318 a skos:Concept ;
    dct:source "http://www.planning.org/guidebookhtm/chapter_three.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land on which the land use of forestry occurs"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land use"@en .

ex:Forest_319 a skos:Concept ;
    dct:source "http://www.agry.purdue.edu/ext/forages/rotational/glossary.html"^^xsd:anyURI,
        "http://www.crops.org/cropgloss/index.php"^^xsd:anyURI,
        "http://www.forages.css.orst.edu/Topics/Pastures/Grazing/Terminology/grazterm_body.html#Vegetation"^^xsd:anyURI,
        "http://www.ifad.org/lrkm/glossary.htm#f"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land on which the vegetation is dominated by forest or, if trees are lacking, the land bears evidence of former forest and has not been converted to other vegetation. , , , and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land use"@en .

ex:Forest_32 a skos:Concept ;
    dct:creator "Closed" ;
    dct:source "https://www.uni-hohenheim.de/i490a/teaching/M4901-430/ws_03_04/reading_materials/New_Neef_Schwarzmeier_Studie.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest in which the stand density is greater than 20 percent of the area and tree crowns approach general contact with one another"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Closed" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_320 a skos:Concept ;
    dct:source "http://fwie.fw.vt.edu/rhgiles/appendices/glossf.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land primarily devoted to trees"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land use"@en .

ex:Forest_321 a skos:Concept ;
    dct:source "http://www.inac.gc.ca/building/forests/forest_j.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land primarily intended for growing, or currently supporting, forest. Includes land not now forested, i.e. clear-cut lands; northern lands that are forested but not intended for any use; and plantations"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land use"@en .

ex:Forest_322 a skos:Concept ;
    dct:source "http://www.pacificforest.org/about/glossary.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land that can support at least 10 percent native tree cover under natural conditions. Forestland may include areas of grassland, shrubland, wetland, or other land classes"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land use"@en .

ex:Forest_323 a skos:Concept ;
    dct:creator "Also see definitions of nonforest land, idle farmland and improved/maintained pasture" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land that is at least 10 percent stocked by forest trees of any size, or land formerly having such tree cover, and is not currently developed for a nonforest use. The minimum area for classification as forest land is one acre. Roadside, stream-side, and shelterbelt strips of timber must have a crown width at least 120 feet wide to qualify as forest land. Unimproved roads and trails, streams and other bodies of water, or natural clearings in forested areas shall be classified as forest, if less than 120 feet in width or an acre in size. Grazed woodlands, reverting fields, and pastures that are not actively maintained are included if the above qualifications are satisfied. www.socrates.lv-hrc.nevada.edu/fia/dab/core1-7/appendix7_12_00.doc"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Also see definitions of nonforest land, idle farmland and improved/maintained pasture." ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land use"@en .

ex:Forest_324 a skos:Concept ;
    dct:source "http://agglossary.uaex.edu/viewFGlossary1.asp#F"^^xsd:anyURI,
        "http://www.nationalaglawcenter.org/glossary/"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land that is at least 16.7 percent stocked by forest trees of any size, or land that formerly had such tree cover and is not currently being developed for nonforest uses. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land use"@en .

ex:Forest_325 a skos:Concept ;
    dct:source "http://www.forestmeister.com/laws/ch61.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land that is at least sixteen and seven-tenths per cent stocked, that contains at least seven and five-tenths square feet of basal area per acre by forest trees of any size; or that formerly had such tree cover and is not currently developed for non-forest use; or that is a plantation containing at least five hundred trees per acre"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land use"@en .

ex:Forest_326 a skos:Concept ;
    dct:source "http://www.streamnet.org/pub-ed/ff/Glossary/glossaryforest.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land that is now, or is capable of becoming, at least 10 percent stocked with forest trees and that has not been developed for nontimber use"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land use"@en .

ex:Forest_327 a skos:Concept ;
    dct:creator "i.e., spruce-fir stands, ponderosa pine, etc" ;
    dct:source "http://extension.usu.edu/forestry/UtahForests/Trees_ForestryTerms.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land that supports tree species of commercial value ; also referred to as timberland"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "i.e., spruce-fir stands, ponderosa pine, etc." ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land use"@en .

ex:Forest_328 a skos:Concept ;
    dct:creator "Maini" ;
    dct:date "1991"^^xsd:gYear ;
    dct:source "http://www.forestry.utoronto.ca/ac_staff/emeritus/My%20Webs/english.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land under natural or cultivated stands of trees intended for forest use, including land cleared of trees but which will be reforested. Permanent meadows and pastures with scattered trees and shrubs do not constitute forest land"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Maini 1991" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land use"@en .

ex:Forest_329 a skos:Concept ;
    dct:source "http://www.epa.gov/region3/mtntop/pdf/VIII.Glossary.pdf"^^xsd:anyURI,
        "http://www.osmre.gov/pdf/022399a.txt"^^xsd:anyURI,
        "http://www.wvgazette.com/static/series/mining/reports/EIS/VIII.Glossary.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land with at least 25 percent tree canopy or that has been stocked with at least 10 percent forest trees of any size, including land that formerly had such tree cover and that will be naturally or artificially reforested. , 2001 and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land use"@en .

ex:Forest_33 a skos:Concept ;
    dct:bibliographicCitation "Ref. Forest Encyclopaedia, Vol 1, Soviet Encyclopaedia, Moscow, 1985, page 503" ;
    dct:creator "Ecological definition" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest is one of major types of vegetation, which comprises an aggregate of woody, srubs, herbaceous and other (mosses, liches) plants, including fauna and microorganismus; all these components are biologically interacted during their development, and impact both each other and environment"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Ecological definition" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_330 a skos:Concept ;
    dct:creator "World Forest Inventories" ;
    dct:date "1947"^^xsd:gYear ;
    skos:broadMatch ex:Forest ;
    skos:definition "Lands bearing vegetative associations dominated by trees of any size, capable of producing timber or other forest products or of exerting an influence on the climate or on the water regime. Also, lands from which forests have been recently clear cut or burned but which will be reforested in the near future. From: Alexander.Korotkov@unece.org. Date: Thu, 15 Oct 1998 17:09:40 +0200"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "World Forest Inventories 1947" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land use"@en .

ex:Forest_331 a skos:Concept ;
    dct:source "http://www.oneworld.org/cse/html/cmp/climate/ew/art20001124_5.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Lands that have, or will have because of continued growth, more than 10 per cent canopy cover"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land use"@en .

ex:Forest_332 a skos:Concept ;
    dct:creator "Lund" ;
    dct:date "1984"^^xsd:gYear ;
    skos:broadMatch ex:Forest ;
    skos:definition "Lands that naturally have or can have at least 10 percent of the area covered by crowns of trees and are not currently developed for non-forest use. The minimum area for land classification is 0.4 ha. Unimproved roads, trails, streams, and stringers of vegetation are classed with surroundings if they are less than 36.6 meters in width"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Lund 1984" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land use"@en .

ex:Forest_333 a skos:Concept ;
    dct:source "http://www4.gu.edu.au:8080/adt-root/uploads/approved/adt-QGU20060303.132137/public/03Main.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "The amount of land appropriated by the consumption of paper and timber products"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land use"@en .

ex:Forest_334 a skos:Concept ;
    dct:source "http://www.sustainableforests.net/C&I_workshops/Glossary%20as%20990101.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Total area of existing forest, Area of forest land, Net area of forest land available for timber production without risk of biodiversity loss. This can be composed of natural or plantation forests but should be listed separately"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land use"@en .

ex:Forest_335 a skos:Concept ;
    dct:creator ">25% tree canopy cover" ;
    dct:source "http://www.statlab.iastate.edu/soils/nssh/622.htm#16"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Tree Cover Vegetative cover recognized as woody plants which usually have one perennial stem, a definitely formed crown of foliage, and a mature height of at least 4 meters. This category contains all trees, even those planted for the purpose of producing food or ornamentals, including Christmas trees. It also includes those lands which have been harvested of trees, even those that have been clear cut, but will return to tree cover"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note ">25% tree canopy cover" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land use"@en .

ex:Forest_336 a skos:Concept ;
    dct:creator "including all of us" ;
    dct:source "http://media.lpb.org/images/pdf/CaseyTreesGlossary.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Urban forest: An urban forest includes all of the natural resources in an urban area: plants, soil, water, and animals [Urban Forestry]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "including all of us" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land use"@en .

ex:Forest_337 a skos:Concept ;
    dct:source "http://www.wec.ufl.edu/coop/gap/moreinfo.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Vegetation dominated by trees with their crowns overlapping, generally forming 60 - 100% cover; includes reproductive stages or immature secondary growth stands that are temporarily less than 5 meters or 16.5 feet tall"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land use"@en .

ex:Forest_338 a skos:Concept ;
    dct:creator "Forestland" ;
    dct:source "http://ext.msstate.edu/pubs/pub1250.htm"^^xsd:anyURI,
        "http://msucares.com/pubs/pub1250.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land which is currently producing (or, in some cases, capable of producing) a forest. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Forestland" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "General"@en .

ex:Forest_339 a skos:Concept ;
    dct:source "http://www.oznet.ksu.edu/library/MISC2/SB661.PDF"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A biome with enough precipitation to support various tree species"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "General"@en .

ex:Forest_34 a skos:Concept ;
    dct:creator "Ecosystem" ;
    dct:source "http://www.forestry.utoronto.ca/ac_staff/emeritus/My%20Webs/english.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "An ecological system composed of interacting biotic and abiotic components of the environment in which trees are a major constituent, such that their canopies cover 20% or more of the area (Maini 1991"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Ecosystem" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_340 a skos:Concept ;
    dct:source "http://mff.dsisd.net/Environment/EcologyForests.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A collection of biological organisms and non-biological factors. From an ecological perspective, the definition of a forest includes all these things, from the trees to the bacteria, and the soil type to the microclimates"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "General"@en .

ex:Forest_341 a skos:Concept ;
    dct:source "http://www.wrm.org.uy/english/bulletin/bull16.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A complex, self-regenerating system, encompassing soil, water, microclimate, energy, and a wide variety of plants and animals in mutual relation. A commercial plantation, on the other hand, is a cultivated area whose species and structure have been simplified dramatically to produce only a few goods, whether lumber, fuel, resin, oil, or fruit"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "General"@en .

ex:Forest_342 a skos:Concept ;
    dct:source "http://forum.wordreference.com/showthread.php?t=186539"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A forest is temperate and little touched by humans. A jungle is tropical and untrammeled. Woods are forests that have been worked by humans"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "General"@en .

ex:Forest_343 a skos:Concept ;
    dct:source "http://www.google.com/search?client=safari&rls=en&q=forest+facts&ie=UTF-8&oe=UTF-8"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A forest, also referred to as a wood or the woods, is an area with a high amount of weed. People go to forests to get high. Wikipedia"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "General"@en .

ex:Forest_344 a skos:Concept ;
    dct:source "http://www.chesco.com/~treeman/words/words-t.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A highly ordered arrangement of living organisms living in, on and around trees in such an highly ordered fashion it assures high quality survival for all"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "General"@en .

ex:Forest_345 a skos:Concept ;
    dct:creator "protection, recreation, scenery, etc" ;
    skos:broadMatch ex:Forest ;
    skos:definition "A land comprehensive of vegetation, fauna and soil, providing wood and other goods, and values . Lorenzo Ciccarese ciccarese@anpa.it"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "protection, recreation, scenery, etc." ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "General"@en .

ex:Forest_346 a skos:Concept ;
    dct:source "http://ewg.gecp.virginia.edu/ewg_forest_us/general/glossary.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A landscape component, raw material, or an object of forestry management activities"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "General"@en .

ex:Forest_347 a skos:Concept ;
    dct:source "http://tropenbos.nl.php5.server34.firstfind.nl/tbi_publications/documents/Mirjam2.PDF"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A natural ecosystem in which trees are a significant component"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "General"@en .

ex:Forest_348 a skos:Concept ;
    dct:creator "Definition from some game" ;
    dct:source "http://www.battle1066.com/g118.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A Norman law which gave the right to keep wild animals on land for the purpose of hunting. Penalties for infringements included mutilation and death"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Definition from some game" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "General"@en .

ex:Forest_349 a skos:Concept ;
    dct:creator "Forest ecosystem" ;
    dct:source "http://ext.nrs.wsu.edu/publications/pdf/wildlife/misc0198.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A plant community dominated by woody plants, where the plnats interact with other living and nonliving components such as soil, water, air, animals, and microscopic orgnaisms"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Forest ecosystem" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "General"@en .

ex:Forest_35 a skos:Concept ;
    dct:creator "Ecosystem" ;
    dct:source "http://www.pbs.org/earthonedge/glossary.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land areas dominated by trees where the tree canopy covers at least 10% of the ground area"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Ecosystem" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_350 a skos:Concept ;
    dct:source "http://www.chesco.com/~treeman/words/words-t.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A system, where trees and their associates are so highly ordered in their connections that they all survive at a high quality state"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "General"@en .

ex:Forest_351 a skos:Concept ;
    dct:source "http://www.scribd.com/WorldBankPublications/d/16060052-Forest-Law-and-Sustainable-Development-Addressing-Contemporary-Challenges-Through-Legal-Reform"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "An ecosystem dominated by woody vegetation, potentially subject to the management or oversight of foresters. Christy, Lawrence C. et al. 2007. Forest law and sustainable development – Addressing contemporary Challenges through legal reform. Wolrd Bank, Law, Justice and Development Series. 228 p"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "General"@en .

ex:Forest_352 a skos:Concept ;
    dct:source "http://www.britell.com/lex.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "An extensive area preserving some or all of its primitive wildness, usually having wild animals"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "General"@en .

ex:Forest_353 a skos:Concept ;
    dct:creator "at least 76 centimeters, or 30 inches" ;
    dct:source "http://www.gsu.edu/~mstnrhx/ecogloss.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Biome with enough average annual precipitation to support growth of various species of trees and smaller forms of vegetation"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "at least 76 centimeters, or 30 inches" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "General"@en .

ex:Forest_354 a skos:Concept ;
    dct:source "http://www.reservenaturelle.fr/upload/cahier74bis.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest - Synonymous with wilderness. It covers vast areas, is seldom visited, and forms the ultimate refuge for numerous large mammals and predators"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "General"@en .

ex:Forest_355 a skos:Concept ;
    dct:source "http://www.americanforests.org/discover-forests/forest-facts/"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forests are complex ecosystems in which plants and animals coexist with one another"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "General"@en .

ex:Forest_356 a skos:Concept ;
    dct:source "http://www.planetpals.com/habitats.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forests are small biomes. They represent a third of the Earth's land"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "General"@en .

ex:Forest_357 a skos:Concept ;
    dct:creator "24\"/ year" ;
    dct:source "http://home.alltel.net/bsundquist1/se2.html#Dg"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forests generally occur only where precipitation exceeds 60 cm/ year (Ref.64 of DF91M1"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "24\"/ year" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "General"@en .

ex:Forest_358 a skos:Concept ;
    dct:creator "IFL" ;
    dct:source "http://www.kaieteurnewsonline.com/2011/02/01/real-or-imaginary-rates-of-deforestation/"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Intact forest landscape : a territory within today’s global extent of forest cover which contains forest and non-forest ecosystems minimally influenced by human economic activity, with an area of at least 500 km2 (50,000 ha) and a minimal width of 10 km (measured as the diameter of a circle that is entirely inscribed within the boundaries of the territory"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "IFL" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "General"@en .

ex:Forest_359 a skos:Concept ;
    dct:creator "climax or natural potential" ;
    dct:source "http://www.tamu.edu/classes/rang/rknight/rlem102/lecture3/rangeland-definitions.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land on which the native vegetation is forest"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "climax or natural potential" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "General"@en .

ex:Forest_36 a skos:Concept ;
    dct:bibliographicCitation "Ref. Kireev D.M. 1984. Ecological and Georaphical Terms in Forestry. Reference Glossary, Nauka, Novosibirsk, 1984, page 63" ;
    dct:creator "Landscape" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest is a natural and territorial complex of a different rank (from a facies to a geographical country) in which phytocoenoses are dominated by spontaneously developing tree vegetation"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Landscape" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_360 a skos:Concept ;
    dct:source "http://www.zoology.wisc.edu/courses/220/readings/Hardin/Hardin_population.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land that produces woody plants-bushes as well as trees-anything that can serve as fuel in the cooking of food"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "General"@en .

ex:Forest_361 a skos:Concept ;
    dct:source "http://www.asb.cgiar.org/pdfwebdocs/ASBPB13.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "The term ‘forest’ refers to woody vegetation, but it is also linked to specific institutions empowered to manage forests"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "General"@en .

ex:Forest_362 a skos:Concept ;
    dct:creator "ADB" ;
    dct:date "1997"^^xsd:gYear ;
    dct:source "http://figueresonline.com/csdafinal/English/publications/cdm/glossary.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "An ecosystem with a minimum of 10 percent crown cover of trees and/or bamboos, generally associated with wild flora, fauna and natural soil conditions and not subject to agriculture. Asian Development Bank"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "ADB 1997" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_363 a skos:Concept ;
    dct:creator "CBFP" ;
    dct:date "2006"^^xsd:gYear ;
    dct:source "http://carpe.umd.edu/resources/Documents/THE_FORESTS_OF_THE_CONGO_BASIN_State_of_the_Forest_2006.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Congo Basin Forest Partnership. Forests are habitats where trees are dominant, where tree crowns form a more or less continuous layer and where grasses are virtually absent in the under story. The few grasses which are found in forests have broad leaves and are very different from savannah species. Forests are sensitive to fire"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "CBFP 2006" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_364 a skos:Concept ;
    dct:creator "Convention on International Trade" ;
    dct:date "2000"^^xsd:gYear ;
    dct:source "http://www.nationmaster.com/country/gr-greece/env-environment"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest area is land under natural or planted stands of trees, whether productive or not. Convention on International Trade in Endangered Species of Wild Fauna and Flora, Report on National Reports Required Under Article VIII, Paragraph 7(a), of the Convention, Eleventh Meeting of the Conference of the Parties, Gigiri, Kenya, April 2000"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Convention on International Trade 2000" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_365 a skos:Concept ;
    dct:creator "Dry-zone African countries" ;
    skos:broadMatch ex:Forest ;
    skos:definition "An ecosystem with a minimum of 10 percent crown cover of trees, and other wooded lands are those which are covered by trees, bushes or scattered shrubs, whether natural or planted by people, and which may be cultivated (as agro-forestry lands) or not and which are generally associated with wild flora and fauna. \"Moussa, Omnia (FAORNE)\"Omnia.Moussa@fao.org"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Dry-zone African countries" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_366 a skos:Concept ;
    dct:creator "EarthSat GeoCover LC" ;
    dct:date "2002"^^xsd:gYear ;
    skos:broadMatch ex:Forest ;
    skos:definition "Trees > 3 m height, canopy closure > 35 % (Kalensky et al. 2002"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "EarthSat GeoCover LC 2002" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_367 a skos:Concept ;
    dct:creator "East Africa" ;
    dct:date "1943"^^xsd:gYear ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest is a continuous stand of trees which may attain a height of 50 m or more, with crowns touching or intermingling and often interlaced with lianas. file:///C:/Users/Owner/Downloads/Friis_Forest_vegetation.pdf"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "East Africa 1943" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_368 a skos:Concept ;
    dct:creator "ESA" ;
    dct:date "2009"^^xsd:gYear ;
    dct:source "http://www.esa.int/esaEO/SEM5N3TRJHG_index_0.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition ">15 % crown cover, >5 meters high. European Space Agency"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "ESA 2009" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_37 a skos:Concept ;
    dct:creator "NALMS" ;
    dct:source "http://www.nalms.org/glossary/lkword_f.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land which is at least 10 percent occupied by forest trees of any size or formerly having had such tree cover and not currently developed for non-forest use. Lands developed for non-forest use include areas for crops, improved pasture, residential, or administrative areas, improved roads of any width, and adjoining road clearing and power line clearing of any width"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "NALMS" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_376 a skos:Concept ;
    dct:creator "Europe" ;
    dct:source "http://etc.satellus.se/the_data/Technical_Guide/part_one_text2.htm#The"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Vegetation formation composed principally of trees, including shrub and bush understories. The surface area of the smallest unit mapped in the project is 25 hectares. nomenclature"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Europe" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_38 a skos:Concept ;
    dct:creator "Open" ;
    dct:source "https://www.uni-hohenheim.de/i490a/teaching/M4901-430/ws_03_04/reading_materials/New_Neef_Schwarzmeier_Studie.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest in which the tree canopy layer is discontinuous but covers at least 10 percent of the area and in which the grass layer is continuous"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Open" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_380 a skos:Concept ;
    dct:creator "Forest Focus" ;
    dct:source "http://www.efi.int/files/attachments/publications/tr_18.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest has in mature state a crown cover of at least 10%, trees of height minimum 5 m, and an area of at least 0.5 ha with a width of at least 20 m"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Forest Focus " ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_381 a skos:Concept ;
    dct:creator "FSC" ;
    dct:date "2011"^^xsd:gYear ;
    dct:source "http://www.fsc.org/fileadmin/web-data/public/document_center/Current_consultations/Report_P_C_Review_Workshop_2011-06-25_26_Final.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest” is not defined, as the “natural forest” and “plantation” covers the scope of forest areas for purpose of the P&C . Plantation Definition: Areas with tree cover in which the trees are established by either planting, sowing or using intensive silvicultural treatments, which lack most of the principal characteristics and key elements of native ecosystems, and which are characterized by either few species used in the treatments, even spacing, and/or even-ages, or by significant use of non-native or alien tree species. Plantations and native ecosystem elements and characteristics may be further defined by FSC approved national and regional standards of forest management. • Natural Forest Definition: Areas with tree cover that are not classified as plantations, in which all or almost all trees and other plants are indigenous species, and many of the principal characteristics and key elements of native ecosystems such as complexity, structure and diversity are present. Natural forests and native ecosystem elements and characteristics may be further defined by FSC approved national and regional standards of forest management"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "FSC 2011" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_382 a skos:Concept ;
    dct:creator "GLC legend" ;
    dct:date "2000"^^xsd:gYear ;
    dct:source "http://www.glcn.org/downs/pub/ppts/FRA-GLCN_india/Antonio%20DiGregorio/Review%20of%20LCCS.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "percent tree cover >15% / tree height >3m"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "GLC2000 legend 2005" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_383 a skos:Concept ;
    dct:creator "Global Forest Coalition" ;
    dct:date "2009"^^xsd:gYear ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forests are complex tree dominated ecosystems with particular structural biotic and abiotic components, assembled within temporal and spatial limits and with a self sustained successional dynamic determined by its own biodiversity, including the determining anthropogenic interfaces, particularly with Indigenous Peoples and peoples who adopted their knowledge. Source: yvetogo@hotmail.com, 30 April 2009"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Global Forest Coalition 2009" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_384 a skos:Concept ;
    dct:creator "Global Forest Watch" ;
    dct:date "2014"^^xsd:gYear ;
    dct:source "http://www.globalforestwatch.org/howto#terminology"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Various definitions exist for the term “forest,” and GFW does not aim to provide a consensus definition. Data sets hosted on GFW may define “forest” differently or pertain to different types of forest (primary, secondary, tree plantations, etc.). Through information found on the Data page, we aim to be transparent about the assumptions and definitions feeding into each data set. In our general writing, including the GFW blog, “forest” refers to a landscape with a high density of trees and value for biodiversity, carbon storage, and human use. GFW distinguishes tree cover from forest. Where found on the GFW website, “tree cover” refers to the biophysical presence of trees, which may be part of natural forests or tree plantations. The inclusion of all types of tree plantations in the “tree cover” definition notably distinguishes the term from some definitions of “forest.” Accordingly, “tree cover” and “forest” should not be used interchangeably. Different data sets further define “tree cover” with added parameters"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Global Forest Watch 2014" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_385 a skos:Concept ;
    dct:creator "GOFC/GOLD Land and Forest Cover Classification Scheme" ;
    dct:date "2002"^^xsd:gYear ;
    skos:broadMatch ex:Forest ;
    skos:definition "Canopy cover 10-25 %, Tree height <1 m - > 2m. (Kalensky et al. 2002"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "GOFC/GOLD Land and Forest Cover Classification Scheme 2002" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_386 a skos:Concept ;
    dct:creator "IADB" ;
    dct:date "2013"^^xsd:gYear ;
    dct:source "https://www.imf.org/external/np/seminars/eng/2013/caribbean/pdf/approach.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A vegetation type dominated by trees. Inter-American Development Bank"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "IADB 2013" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_387 a skos:Concept ;
    dct:creator "ICRAF" ;
    dct:date "2017"^^xsd:gYear ;
    dct:source "http://dx.doi.org/10.5716/WP16079.PDF"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land with trees under specified management authority; common definitions combine biophysical aspects of tree cover (minimum spatial tree cover over defined percentage of time at defined measurement scale) with institutional aspects (excluding trees that are considered to be agricultural"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "ICRAF- 2017" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_388 a skos:Concept ;
    dct:creator "ICSU" ;
    dct:source "http://www.icsu-scope.org/downloadpubs/scope56/Chapter04.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forests have complete tree canopy cover and three or more overlapping vegetation strata"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "ICSU" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_389 a skos:Concept ;
    dct:creator "IGBP" ;
    dct:date "2013"^^xsd:gYear ;
    dct:source "http://www.eapap.unep.org/lc/cd/html/training/module1.html"^^xsd:anyURI,
        "http://www.unep.org/dewa/Portals/67/pdf/Nile_Basin.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "In IGBP classification system, percent crown cover should be more than 60% and tree height should be more than 2 meters to be classified as forest"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "IGBP 2013" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_39 a skos:Concept ;
    dct:creator "Recommended Definition" ;
    dct:source "http://www.forestcarbonportal.com/resource/critical-need-new-definitions-forest-and-forest-degradation-global-climate-change-agreement"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "While a definition of \"forest\" that is globally acceptable and appropriate for monitoring using standard remote sensing options will necessarily be based on a small set of easily measured parameters, there are dangers when simple definitions are applied locally. At the very least, we recommend that natural forest be differentiated from plantations and that for defining \"forest\" the lower height limit defining \"trees\" be set at more than 5 m tall with the minimum cover of trees be set at more than 40%. These changes will help reduce greenhouse gas emissions from what is now termed forest \"degradation\" without increasing monitoring costs. Furthermore, these minor changes in the definition of \"forest\" will promote the switch from degradation to responsible forest management, which will help mitigate global warming while protecting biodiversity and contributing to sustainable development"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Recommended Definition" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_390 a skos:Concept ;
    dct:creator "IIASA" ;
    dct:source "http://www.iiasa.ac.at/Research/LUC/lucgis/docs/wp-96-026.htm#Land-Cover"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest, canopy coverage > 40%, trees > 6 m"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "IIASA" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_391 a skos:Concept ;
    dct:creator "IndexMundi" ;
    dct:source "http://www.indexmundi.com/facts/greece/forest-area"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest area is land under natural or planted stands of trees of at least 5 meters in situ, whether productive or not, and excludes tree stands in agricultural production systems (for example, in fruit plantations and agroforestry systems) and trees in urban parks and gardens"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "IndexMundi" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_395 a skos:Concept ;
    dct:creator "ISO" ;
    dct:date "2003"^^xsd:gYear ;
    skos:broadMatch ex:Forest ;
    skos:definition "An area of land tree crown cover more than ten per cent with the potential to reach a minimum height of two meters at maturity in situ. ISO TC207/WG5 N70 ISO/WD 14064-1.1 Secretariat: DSM/CSA. January 13, 2003. Principles and requirements for measuring, monitoring and reporting entity- and project-level greenhouse gas emissions and/or removals. 30 p"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "ISO 2003" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_398 a skos:Concept ;
    dct:creator "Millnnieum Assessment Organization" ;
    dct:source "http://www.millenniumassessment.org/documents/document.774.aspx.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest systems: Systems in which trees are the predominant life forms. Statistics reported in this assessment are based on areas that are dominated by trees (perennial woody plants taller than five meters at maturity), where the tree crown cover exceeds 10%, and where the area is more than 0.5 hectares. ‘‘Open forests’’ have a canopy cover between 10% and 40%, and ‘‘closed forests’’ a canopy cover of more than 40%. ‘‘Fragmented forests’’ refer to mosaics of forest patches and non-forest land"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Millnnieum Assessment Organization" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_399 a skos:Concept ;
    dct:creator "NationMaster" ;
    dct:date "2005"^^xsd:gYear ;
    dct:source "http://www.nationmaster.com/graph/env_for_are_of_lan_are-environment-forest-area-of-land"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land under natural or planted stands of trees, whether productive or not"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "NationMaster 2005" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_40 a skos:Concept ;
    dct:creator "Remote sensing" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land with tree crown cover of more than 20 % of the area. Trees should be able to grow to a height of 7 m. Minimum area outside continuous forest: 0.5 ha. Minimum width outside continuous forest: 15 m. (minimum size stand; for instance 15 m x 333 m). (Köhl and Päivinen 1996"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Remote sensing" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_400 a skos:Concept ;
    dct:creator "North Africa" ;
    skos:broadMatch ex:Forest ;
    skos:definition "An ecosystem with a predominance of trees constituting a minimum of 10 percent relatively dense crown cover. \"Moussa, Omnia (FAORNE)\" Omnia.Moussa@fao.org"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "North Africa" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_401 a skos:Concept ;
    dct:creator "RED" ;
    dct:date "2009"^^xsd:gYear ;
    dct:source "http://www.tropenbos.org/file.php/4/forests-dec21-final-web.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Continuously forested areas with a land spanning of more than one hectare with trees higher than five metres and a canopy cover of more than 30%, or trees able to reach those thresholds in situ"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "RED 2009" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_402 a skos:Concept ;
    dct:creator "SADC" ;
    dct:date "1997"^^xsd:gYear ;
    skos:broadMatch ex:Forest ;
    skos:definition "All wooded areas with greater than +/- 70% tree canopy cover, where the dominant canopy is greater than +/- 5m in thight (minimum height). Essentially indigenous tree species growing under natural or semi-natural conditions (although it may include some localised areas of self-seeded exotic species). Excludes planted forests (and woodlots). (Trevett 1997"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "SADC 1997" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_403 a skos:Concept ;
    dct:creator "Small Islands" ;
    dct:source "http://cfa.juice-e.co.uk/Example%20paper/Example%20paper.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest is defined as land with tree crown cover of more than 10 percent and area of more than 0.5 ha whose primary use is forestry. The trees should be able to reach a minimum height of 5 metres at maturity in situ"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Small Islands" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_407 a skos:Concept ;
    dct:creator "UN" ;
    dct:date "2009"^^xsd:gYear ;
    dct:source "http://www.equitybd.org/documents/cts_eng.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "the UN defines a forest as any area larger than 500 square metres with crown cover of 10 per cent and trees capable of growing two metres high. The differences between native forests and monoculture industrial tree plantations cannot be identified by this definition (UN-REDD, 2009"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN 2009" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_408 a skos:Concept ;
    dct:creator "UN-CBD" ;
    dct:date "2001"^^xsd:gYear ;
    dct:source "http://www.millenniumassessment.org/documents/document.290.aspx.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Ecosystems in which trees are the predominant life forms. Global Biodiversity Outlook (Secretariat of the Convention on Biological Diversity 2001"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-CBD 2001" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_409 a skos:Concept ;
    dct:creator "UN-CCD" ;
    dct:date "2000"^^xsd:gYear ;
    dct:source "http://www.unccd.int/actionprogrammes/asia/national/2000/yemen-eng.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Dense canopy with multi-layered structure including large trees in the upper storey; United Nations Convention to Combat Desertification"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-CCD 2000" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_41 a skos:Concept ;
    dct:creator "Riverine" ;
    dct:source "http://icaci.org/files/documents/ICC_proceedings/ICC2013/_extendedAbstract/131_proceeding.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "75-100% tree cover up to 20+ m. Shrub <10% if > 1m high"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Riverine" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_418 a skos:Concept ;
    dct:creator "UN-ESCO" ;
    dct:date "1973"^^xsd:gYear ;
    dct:source "http://pdf.usaid.gov/pdf_docs/PNADL906.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "The standard international definition of “forest” is an area with >25 percent canopy cover by trees (UNESCO 1973; “savannah” is usually considered to be a grass-dominated system with sparse trees [by the UNESCO definition, <25 percent cover]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-ESCO 1973" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_419 a skos:Concept ;
    dct:creator "UN-ESCO" ;
    dct:date "1993"^^xsd:gYear ;
    dct:source "http://home.comcast.net/~gyde/1993annex3iufro.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Continuous stand of trees at least 10 m tall, their crowns interlocking; - Rain forest, without any significant dry season and with trees usually more than 30 m high; - Dry forest, with dry season of several weeks or months; - Semi-evergreen forest, where some species are deciduous but understory mostly evergreen Deciduous forest, where trees lose their leaves simultaneously for months - Undifferentiated forest, with very heterogeneous patterns"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-ESCO 1993" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_442 a skos:Concept ;
    dct:creator "UN-HCR" ;
    dct:date "2005"^^xsd:gYear ;
    dct:source "http://postconflict.unep.ch/liberia/displacement/documents/UNHCR_IUCN_Forest_Management_Refugee_Returnee_Situations.pdf(UN-IPCC"^^xsd:anyURI,
        "http://www.ipcc.ch/pub/tar/wg1/518.htm"^^xsd:anyURI,
        "http://www.pnl.gov/aisu/pubs/eemw/papers/ipccreports/workinggroup2/689.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "An ecosystem with a minimum of 10 per cent crown cover of trees. 2001) A vegetation type dominated by trees and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-HCR 2005" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_443 a skos:Concept ;
    dct:creator "UN-OECD" ;
    dct:date "2005"^^xsd:gYear ;
    dct:source "http://stats.oecd.org/glossary/detail.asp?ID=6459"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land with tree crown cover (or equivalent stocking level) of more than 10 per cent and an area of more than 0.5 hectares. The trees should be able to reach a minimum height of 5 metres at maturity in situ"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-OECD 2005" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_444 a skos:Concept ;
    dct:creator "WAF" ;
    dct:date "2004"^^xsd:gYear ;
    dct:source "http://www.worldagroforestry.org/sea/Publications/files/book/BK0073-04.PDF"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "An ecosystem in which the dominant plants are trees covering a vast tract of land"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "WAF 2004" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_45 a skos:Concept ;
    dct:creator "Science: ecology" ;
    dct:source "http://www.biology-online.org/dictionary/Forest"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "An extensive wood; a large tract of land covered with trees"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Science: ecology" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_458 a skos:Concept ;
    dct:creator "A/R - SSC A/R" ;
    dct:source "http://cdm.unfccc.int/Reference/Guidclarif/glos_CDM_v04.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "“Forest” is a minimum area of land of 0.05-1.0 hectares with tree crown cover (or equivalent stocking level) of more than 10-30 per cent with trees with the potential to reach a minimum height of 2-5 metres at maturity in situ. A forest may consist either of closed forest formations where trees of various storeys and undergrowth cover a high proportion of the ground or open forest. Young natural stands and all plantations which have yet to reach a crown density of 10-30 per cent or tree height of 2-5 metres are included under forest, as are areas normally forming part of the forest area which are temporarily unstocked as a result of human intervention such as harvesting or natural causes but which are expected to revert to forest. A Party not included in Annex I may host an A/R CDM project activity if it has selected and reported to the Executive Board through its designated national authority for the CDM the parameters it has chosen for the definition of “forest” to be used for the purposes of hosting A/R project activities under the CDM. UNFCCC"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "A/R - SSC A/R" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land use"@en .

ex:Forest_46 a skos:Concept ;
    dct:creator "SRM" ;
    dct:source "http://home.comcast.net/~gyde/5-agency_paper-2.doc"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "1980) Land on which the native vegetation (Climax or natural potential) is dominated by trees with at least 25 percent crown coverage at maturity of the trees. (SRM 1980"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "SRM" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_462 a skos:Concept ;
    dct:creator "IFAD" ;
    dct:source "http://www.ifad.org/lrkm/glossary/glossary.htm#/"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land on which the vegetation is dominated by forest or, if trees are lacking, the land bears evidence of former forest and has not been converted to other vegetation. International Fund for Agricultural Development"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "IFAD" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land use"@en .

ex:Forest_468 a skos:Concept ;
    dct:creator "UN" ;
    dct:source "http://www.un.org/Pubs/CyberSchoolBus/infonation/e_terms.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land under natural or planted stands of trees, including land from which forest has been cleared but that will be reforested in the foreseeable future, and including areas occupied by roads, small cleared tracts and other small open areas within the forest"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land use"@en .

ex:Forest_469 a skos:Concept ;
    dct:creator "UN-CBD" ;
    dct:date "2010"^^xsd:gYear ;
    dct:source "http://www.google.com/url?sa=t&source=web&cd=51&ved=0CBgQFjAAODI&url=http%3A%2F%2Fwww.iucnael.org%2Fen%2Fdocuments%2Fdoc_download%2F560-lesniewska-definition-of-forests-in-international-environmental-law.html&rct=j&q=forest%20definition&ei=AqRmTpnYOsbe0QHf17yJBw&usg=AFQjCNGm0ZOpKMree20-X8hkABhetZUfiw"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest is a land area of more than 0.5 ha, with a tree canopy cover of more than 10%, which is not primarily under agriculture or other specific non-forest land use. In the case of young forest or regions where tree growth is climatically suppressed, the trees should be capable of reaching a height of 5m in situ, and of meeting the canopy cover requirement.’ Convention on Biological Diversity"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-CBD 2010" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land use"@en .

ex:Forest_47 a skos:Concept ;
    dct:creator "Sub" ;
    dct:source "http://www.forest.ru/eng/old-growth/eu-definition.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "natural woodland vegetation comprising native species forming forests of tall trees, with typical undergrowth, and meeting the following criteria: rare or residual, and/or hosting species of Community interest (28"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Sub" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_470 a skos:Concept ;
    dct:creator "UN-DP" ;
    dct:source "http://www.undp.kz/infobase/glossary_sector.html?glos_id%5B%5D=42"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Refers to land under natural or planted stands of trees, whether productive or not, including land from which forest has been cleared but which will be reforested in the foreseeable future, and including areas occupied by roads, small cleared tracts and other small open areas within the forest that constitute an integral part of the forest. Includes land under coniferous and non-coniferous forest, land under mixed forest and other wooded land"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-DP" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land use"@en .

ex:Forest_48 a skos:Concept ;
    dct:creator "Upland" ;
    dct:source "http://www.1000friendsofflorida.org/PUBS/stmarksGreen/apend2.asp"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "An upland area with a tree canopy closure of greater than or equal to ten percent. Included in this category are pine, hardwood, and mixed forest and those areas where timber harvesting and subsequent regeneration are taking place. For a given forest stand to be classed as one particular species group, the polygon which contains the species must have a tree canopy comprised of 66 percent or more of the total canopy. Otherwise, the forest polygon will be classed as a mixed species. Classification of Upland Forests is most often supplemented through the use of aerial imagery"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Upland" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_49 a skos:Concept ;
    dct:creator "woodlands" ;
    dct:source "http://content.alterra.wur.nl/Internet/webdocs/ilri-publicaties/publicaties/Pub36/Proceeding%20of%20the%20workshop%20leeg-h3.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "almost exclusively of Aleppo Pine, with at least 20% ground cover by trees"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "woodlands" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_50 a skos:Concept ;
    dct:source "http://www.marinreleaf.org/"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "“Urban forest\" means those native or introduced trees and related vegetation in the urban and near-urban areas including, but not limited to, urban watersheds, soils and related habitats, street trees, park trees, residential trees, natural riparian habitats, and trees on other private and public properties"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_502 a skos:Concept ;
    dct:creator "UN-Millinneium Ecosystem Assessment" ;
    dct:source "http://www.millenniumassessment.org/en/Products.EHWB.aspx#downloads"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A canopy cover of at least 40 percent by woody plants taller than 5 meters. The existence of many other definitions is acknowledged, and other limits (such as crown cover greater than 10 percent, as used by the Food and Agriculture Organization of the United Nations) will also be reported. Includes temporarily cut-over forests and plantations; excludes orchards and agroforests where the main products are food crops"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-Millinneium Ecosystem Assessment" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land use"@en .

ex:Forest_504 a skos:Concept ;
    dct:creator "AFF" ;
    dct:date "2011"^^xsd:gYear ;
    dct:source "http://www.afforum.org/index.php?option=com_docman&task=doc_download&gid=43&Itemid=b"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A forest ecosystem is defined as a dynamic complex of plant, animal and microorganism communities and the non-living environment acting as a functional unit within the forest environment"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "AFF 2011" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "International"@en .

ex:Forest_505 a skos:Concept ;
    dct:creator "Africa" ;
    dct:source "http://lucy.ukc.ac.uk/sonja/rf/ukpr/Report134.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "According to present African legislations, a forest is defined as a non-cultivated natural environment"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Africa" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "International"@en .

ex:Forest_506 a skos:Concept ;
    dct:creator "ISO" ;
    dct:date "1998"^^xsd:gYear ;
    dct:source "http://thuvienkhcnvl.dyndns.org/tailieukhcn/data/TieuChuantoanvan/ISO14000/ISO_TR_14061_1998.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "generally considered to be a plant community of predominantly trees and other woody vegetation growing together, its land, flora and fauna, their interrelationships, and the resources and values attributed to it. International Organization for Standardization"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "ISO 1998" ;
    skos:prefLabel "Forest"@no ;
    skos:scopeNote "Ecological"@en,
        "International"@en .

ex:Forest_507 a skos:Concept ;
    dct:creator "OAS" ;
    dct:date "1991"^^xsd:gYear ;
    dct:source "http://www.oas.org/dsd/publications/unit/oea66e/ch01.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "forest is an ecosystem that offers goods, including trees that provide lumber, fuel, and fruit. The forest may also provide services in the form of water storage and flood control, wildlife habitat, nutrient storage, and recreation"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "OAS 1991" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "International"@en .

ex:Forest_508 a skos:Concept ;
    dct:creator "Scandinavia" ;
    dct:source "http://www.metla.fi/eu/cost/e4/coste4.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "applied. In Scandinavia, the concept of forest is based on productivity as a result of conventional forest management objectives. The annual growth of timber must be greater than 1m3/ha if an area is to be described as productive forest. For forest land where the mean annual increment of growing stock is typically 0,1-1m3/ha, the term scrubland is used. Forest land where the increment is less than 0.1m3/ha is called wasteland. In layman’s language, the term forest implies productive forest land only"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Scandinavia" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "International"@en .

ex:Forest_51 a skos:Concept ;
    dct:source "http://europe.mtnforum.org/rs/econfreports/MountainPeopleForestsAndTrees.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A \"tree dominated ecosystem,\""@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_512 a skos:Concept ;
    dct:date "2005"^^xsd:gYear ;
    dct:source "http://www.nature-ic.am/res/pdfs/legislation/general/Forest%20Code%20of%20RA.pdf"^^xsd:anyURI ;
    dct:spatial "Armenia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest lands – forested lands and lands allocated or envisaged for flora and fauna protection, nature protection as well as non-forested lands allocated or envisaged for the running of forest economy. Forest Code of the Republic of Armenia"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Armenia 2005" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_513 a skos:Concept ;
    dct:source "http://www.fire.uni-Freiburg.de/iffn/iffn_26/IFFN_26.pdf"^^xsd:anyURI ;
    dct:spatial "Australia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "The definition of ‘forest’ used by forestry organisations, for fire-reporting purposes, has been the vegetation of the land under forestry jurisdiction"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Australia" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_514 a skos:Concept ;
    dct:date "1950"^^xsd:gYear ;
    dct:spatial "Bangladesh" ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"Forest\" includes any land recorded as forest in a record-or-rights prepared under Chapter IX of the Sylhet Tenancy Act, 1936 or under Chapter X of the Bengal Tenancy Act, 1885 or under Chapter IV of the East Bengal Estate Acquisition and Tenancy Act, 1950 or such other land containing tree growth as may by notification be declared as forest by the Provincial Government\"(Page-234). iucnbd@citechco.net"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Bangladesh 1950" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_515 a skos:Concept ;
    dct:date "1959"^^xsd:gYear ;
    dct:source "http://www.ihmsaw.org/resourcefiles/1260066650.pdf"^^xsd:anyURI ;
    dct:spatial "Bangladesh" ;
    skos:broadMatch ex:Forest ;
    skos:definition "The Private Forest Ordinance, 1959 defines forest as land recorded as forest under specific laws and such other land containing tree growth as may by notification be declared as forest by the Government"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Bangladesh 1959" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_516 a skos:Concept ;
    dct:date "1969"^^xsd:gYear ;
    dct:source "http://www.fao.org/docrep/007/ad103e/AD103E07.htm"^^xsd:anyURI ;
    dct:spatial "Bhutan" ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"forest\" as \"any land under forests in which no person has acquired a permanent, hereditary and transferable right of use and occupancy\""@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Bhutan 1969" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_517 a skos:Concept ;
    dct:date "1995"^^xsd:gYear ;
    dct:source "http://www.asianlii.org/bt/legis/laws/fancaob1995409/"^^xsd:anyURI,
        "http://www.nec.gov.bt/clearance/EA%20Guidelines/clearance-guideline_forestry.PDF"^^xsd:anyURI,
        "http://www.oag.gov.bt/images/acts/Forest%20and%20Nature%20Conservation%20Act.pdf"^^xsd:anyURI ;
    dct:spatial "Bhutan" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Any land and water body, whether or not under vegetation cover, in which no person has acquired a permanent and transferable right of use and occupancy, whether such land is located inside or outside the forest boundary pillars, and includes land registered in a person's name as Tsamgrog (grazing land) or Sokshing (woodlot for collection of leaf litter). LEX-FAOC007101. BHUTAN: Forest and Nature Conservation Act of Bhutan, 1995. An Act to provide for the protection and sustainable use of forests, wildlife and related natural resources of Bhutan for the benefit of present and future generations. Also 2004"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Bhutan 1995" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_518 a skos:Concept ;
    dct:date "1968"^^xsd:gYear ;
    dct:spatial "Botswana" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest reserve -any area hereafter declared as a Forest Reserve by the President in pursuance of the provision of this Act. LEX-FAOC002748. BOTSWANA: Forest Act. An Act to provide for better regulation and protection of forests and forest produce. 1968"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Botswana 1968" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_519 a skos:Concept ;
    dct:source "http://www.itto.int/direct/topics/topics_pdf_download/topics_id=2648&no=1&disp=inline"^^xsd:anyURI ;
    dct:spatial "Cambodia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Conversion forestland’ is defined as “idle land, comprised mainly of secondary vegetation, not yet designated for use by any sector that shall be classified as permanent forest reserves until the Royal Government decide[s] to use and develop the land for another purpose”"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Cambodia" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_52 a skos:Concept ;
    dct:source "http://www.landhelp.info/FramifyGlossary.php"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A biological community dominated by trees and other woody plants"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_520 a skos:Concept ;
    dct:creator "Celyon 1895" ;
    dct:source "http://books.google.com/books?id=E1JHAAAAYAAJ&pg=PA369&lpg=PA369&dq=%22forest+means%22&source=bl&ots=Wyb5K9BgeN&sig=UxCBQwHldjZw0oJjFHmGDauElOU&hl=en&ei=1hFXS57SKsSXtgfwmvm9BA&sa=X&oi=book_result&ct=result&resnum=18&ved=0CDUQ6AEwETi0AQ#v=onepage&q=%22forest%20means%22&f=false"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest means all land at the disposal of the crown. Ceylon. 1895"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Celyon 1895" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_521 a skos:Concept ;
    dct:creator "Central Africa Republic" ;
    dct:source "http://www.riddac.org/document/pdf/rca-loiforets.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Le domaine forestier de l'Etat comprend : - les réserves naturelles intégrales, - les parcs nationaux, - les réserves de faune, - les forêts récréatives, - les périmètres de protection, - les périmètres de reboisement et - les forêts de production. Loi Nº 90.003 Portant Code Forestier Centrafricain"@fr ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Central Africa Republic" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_522 a skos:Concept ;
    dct:date "1990"^^xsd:gYear ;
    dct:source "http://www.fao.org/forestry/FON/FONS/outlook/Africa/ACP/Lamb/Lamb-39.htm#P6708_430877"^^xsd:anyURI ;
    dct:spatial "Central African Republic" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Selon la Loi 90.003 du 9 Juin 1990 portant Code Forestier Centrafricain, le domaine forestier comprend: le domaine forestier de l'Etat et le domaine forestier des collectivités et des particuliers. Le domaine forestier de l'Etat comprend: les réserves naturelles intégrales; les parcs nationaux; les réserves de faune; les forêts récréatives; les périmètres de reboisement; et les forêts de production"@fr ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Central African Republic 1990" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_523 a skos:Concept ;
    dct:spatial "Cyprus" ;
    skos:broadMatch ex:Forest ;
    skos:definition "State Forest: State land declared as forest according to the Forest Law disregarding whether there is any vegetation on that land or not. A.K. Christou \"Forestry Department - Research and Publicity Sector\""@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Cyprus" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_524 a skos:Concept ;
    dct:creator "Czech Republic" ;
    dct:source "http://www.fris.sk/Phare/Projects/ManagementOfForestInEurope/PDF/annex2.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest stand with its environment and land designated for the fulfilment of forest functions. Forest stand means tree and shrub which, in their environment, fulfil forest functions. No area limit, classification into forest and non-forest according to the cadastre; the limit of 0.01 ha applied in the guidelines for forest management planning"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Czech Republic" ;
    skos:prefLabel "Forest"@no ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_525 a skos:Concept ;
    dct:source "http://www2.dmu.dk/1_viden/2_publikationer/3_arbrapporter/rapporter/ar211.pdf"^^xsd:anyURI ;
    dct:spatial "Denmark" ;
    skos:broadMatch ex:Forest ;
    skos:definition "the basic definition of a forest is that the forest area must be minimum 0.5 ha. There is no specific guideline on the crown cover or the height of the trees"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Denmark" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_526 a skos:Concept ;
    dct:date "1945"^^xsd:gYear ;
    dct:spatial "Dominica" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest reserves means any area declared by the Administrator in Council by notice in the Gazette to be a forest reserve. LEX-FAOC002895. DOMINICA: Forest Ordinance (Chapter 80). Date of original text: 31 December 1945. Date of consolidation/reprint: 06 August 1959"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Dominica 1945" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_527 a skos:Concept ;
    dct:date "2006"^^xsd:gYear ;
    dct:source "https://www.riigiteataja.ee/en/eli/504092017014/consolide"^^xsd:anyURI ;
    dct:spatial "Estonia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "‘Forest land’ means land that meets at least one of the following requirements: [RT I, 06.07.2017, 1 – entry into force 01.09.2017] 1) is entered in the cadastral register as a forest land parcel; [RT I 2008, 56, 314 – entry into force 01.01.2009]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Estonia 2006" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_528 a skos:Concept ;
    dct:date "2007"^^xsd:gYear ;
    dct:source "http://www.pfmp-farmsos.org/Docs/forest%20proclamation_english.pdf"^^xsd:anyURI ;
    dct:spatial "Ethiopia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"forest land\" means a land that is demarcated for the purpose of forest development and conservation"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Ethiopia 2007" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_529 a skos:Concept ;
    dct:date "1992"^^xsd:gYear ;
    dct:spatial "Fiji" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest or nature reserves from the following classes of land: (a) unalienated State land; (b) land leased to the State; and (c) unalienated native land, with the prior consent of the owners of the land and of the Native Land Trust Board. LEX-FAOC002912. FIJI: Forest Decree 1992 (Decree No. 31). Date of text: 12 May 1992"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Fiji 1992" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_53 a skos:Concept ;
    dct:creator "Density greater than 20-30% understood" ;
    dct:source "http://www.sfrc.ufl.edu/Extension/ssfor11.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A biological community of plants and animals which is dominated by trees and other woody plants. See Woodland"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Density greater than 20-30% understood" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_530 a skos:Concept ;
    dct:date "2002"^^xsd:gYear ;
    dct:source "http://www.fao.org/docrep/005/y2328e/y2328e03.htm"^^xsd:anyURI ;
    dct:spatial "Gabon" ;
    skos:broadMatch ex:Forest ;
    skos:definition "By law: In Gabon, Law n° 1/82 (forest and water guidelines) distinguishes two types of forest: protected forests and classified state forests. Protected forests, belonging to the private domain of the State, may be disposed of and are the preferred area for \"customary rights of usage\" The state forests include permanent production forests, reforestation plots, national parks for forest use, protection forests, recreational forests, botanical gardens, arboretums and sanctuaries for specific plant species, nature reserves for all plant species, rational game use areas. The law also specifies that customary use rights cannot be exercised within the classified state forests"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Gabon 2002" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_531 a skos:Concept ;
    dct:source "http://www.fao.org/forestry/FON/FONS/outlook/Africa/ACP/Lamb/Lamb-33.htm#P4712_334869"^^xsd:anyURI ;
    dct:spatial "Gabon" ;
    skos:broadMatch ex:Forest ;
    skos:definition "La Loi No 1/82 (loi dite d'orientation en matière des eaux et forêts) distingue 2 catégories de forêts: les forêts protégées et les forêts domaniales classées. Les forêts protégées font parties du domaine privé de l'état. Elles peuvent être aliénées et sont principalement le lieu d'élection des \"droits d'usage coutumier\". Selon la Loi, les villageois conservent pour leur subsistance, le libre exercice de leurs droits coutumiers sur tout le domaine forestier à condition que ces droits soient exercés de telle sorte que la pérennité de l'exploitation soit garantie. Les forêts domaniales classées sont définies par la Loi comme étant: les forêts de production à vocation permanente; les périmètres de reboisement; les parcs nationaux à vocation forestière; les forêts de protection; les forêts récréatives; les jardins botaniques; les arboretums et des sanctuaires de certaines espèces végétales; es réserves naturelles intégrales d'espèces végétales; les aires d'exploitation rationnelle de la faune. L'exploitation des forêts domaniales classées ne peut se faire qu'en régie ou par vente de coupe par adjudication publique. De plus, la Loi précise que l'exercice des droits d'usage coutumier est interdit dans les forêts domaniales classées"@fr ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Gabon" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_532 a skos:Concept ;
    dct:date "1999"^^xsd:gYear ;
    dct:source "http://www.efi.int/files/attachments/publications/annex_1_to_efi_technical_report_88__2013.pdf"^^xsd:anyURI ;
    dct:spatial "Georgia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "State Forest Fund (SFF): The integrity of state forest, land and other resources defined as SFF by the Georgian legislation (Forest Code of Georgia, 1999). Includes the land categories listed below: Forest: Part of geographic landscape, which includes the unity of trees (defined by the Georgian legislation as parts of forests), lands, bushes, grasses, animals and other objects, which are biologically inter-related and have an impact upon each other as well as environment. Forest lands: Open plantations, nurseries, clear-cut areas, fire damaged and dead stands, 0.1 ha and larger fields and forest farm yards. (President of Georgia, 1999"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Georgia 1999" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_533 a skos:Concept ;
    dct:date "1953"^^xsd:gYear ;
    dct:spatial "Guyana" ;
    skos:broadMatch ex:Forest ;
    skos:definition "The Minister may, by Order, declare any area of State land to be a State forest, excluding all land owned by any person in such area (sec. 3). LEX-FAOC004339. GUYANA : Forests Act. An Act to consolidate and amend the law relating to forests. Date of original text: 02 May 1953"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Guyana 1953" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_534 a skos:Concept ;
    dct:date "1926"^^xsd:gYear ;
    dct:spatial "Haiti" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Cette loi institue la classification comme \" Forêt Nationale Réservée\" de terrains appartenant au domaine national et indique le régime juridique leur afférent. LEX-FAOC002943. HAITI: Loi du 3 février 1926 sur les Forêts Nationales Réservées. Date of text: 03 February 1926"@fr ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Haiti 1926" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_535 a skos:Concept ;
    dct:creator "1879" ;
    dct:source "http://books.google.com/books?pg=RA6-PA56&lpg=RA6-PA56&dq=%22forest%20means%22&sig=0C-6Qq9owihmR0j54aj8YA7qI30&ei=aQhXS92fHJCXtgfdlpW0BA&ct=result&id=RiETAAAAYAAJ&ots=6GPnEMMlVl&output=text"^^xsd:anyURI ;
    dct:spatial "India" ;
    skos:broadMatch ex:Forest ;
    skos:definition "\" Reserved Forest\" means waste land which has been declared as* reserved forest at settlement or by any subsequent order of competent authority. * \"'Village Forest\" means such waste land as has been set apart under section 8 or section 9"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "India 1879" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_536 a skos:Concept ;
    dct:date "1927"^^xsd:gYear ;
    dct:spatial "India" ;
    skos:broadMatch ex:Forest ;
    skos:definition "“forest land” means a piece of land notified by the Government as the forest land to develop, protect and conserve forest and includes a rangeland and wasteland"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "India 1927" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_537 a skos:Concept ;
    dct:date "1927"^^xsd:gYear ;
    dct:source "http://www.itto.int/direct/topics/topics_pdf_download/topics_id=39100000&no=1&disp=inline"^^xsd:anyURI ;
    dct:spatial "India" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest is defined as a tract of land that is legally proclaimed to be a forest under the forest laws (mainly 1865 and 1927) and is notified as forest in the government gazette"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "India 1927" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_538 a skos:Concept ;
    dct:date "1947"^^xsd:gYear ;
    dct:source "http://www.ielrc.org/content/e4701.pdf"^^xsd:anyURI ;
    dct:spatial "India" ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"forest\" means any land which the State Government may, by notification, declare to be forest for the purposes of this Act and shall be deemed to include any land which is entered as forest or jungle or jungle- Jhori or described by any synonymous term in any record-of-rights finally published under any law for the time being in force unless it is proved that such entry in respect of the land is incorrect ; BIHAR PRIVATE Forest ACT 1947 [Act No IX of 1948]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "India 1947" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_539 a skos:Concept ;
    dct:date "1980"^^xsd:gYear ;
    dct:spatial "India" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Any land recorded as forest in any of the land records is legally a forest land. This legal connotation provides a working definition of forest land to the forest managers in India for all the practical purposes. This definition disregards whether there is any vegetation on that land or not. [Source: Forest Conservation Act, 1980, From: \"Vivek K. Varma\" v.varma@landfood.unimelb.edu.au Date: Fri, 17 Jul 1998 02:28:29 -0400 (EDT)]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "India 1980" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_54 a skos:Concept ;
    dct:creator "Helms, : 70" ;
    dct:date "1998"^^xsd:gYear ;
    dct:source "http://curis.ku.dk/ws/files/13035957/Christian_Gamborg.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A broad definition of forest is: “An ecosystem characterised by a more or less dense and extensive tree cover, often consisting of stands varying in characteristics such as species composition, structure, age class, and associated processes, and commonly including meadows, streams, fish and wildlife”"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Helms, 1998: 70" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_540 a skos:Concept ;
    dct:date "1980"^^xsd:gYear ;
    dct:source "http://forestsclearance.nic.in/writereaddata/FormA/UserAgencydoc/711712712128TYIMCompendium_on_FCA.pdf"^^xsd:anyURI ;
    dct:spatial "India" ;
    skos:broadMatch ex:Forest ;
    skos:definition "The term “Forest land’ mentioned in Section 2 of the Act refers to reserved forest, protected forest or any area recorded as forest in the Government records. Lands which are notified under Section 4 of the Indian Forest Act would also come within the purview of the Act. (Supreme Court’s Judgment in NTPC’s case). It would also include “Forest” as understood in the dictionary sense. (Supreme Court order dated: 12.12.1996 in WP No. 202/1995 – Annexure-I)… The term “forest” shall not be applicable to the plantations raised on private lands, except notified private forests"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "India 1980" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_541 a skos:Concept ;
    dct:date "2005"^^xsd:gYear ;
    dct:source "http://www.thehindu.com/2009/05/12/stories/2009051252140500.htm"^^xsd:anyURI ;
    dct:spatial "India" ;
    skos:broadMatch ex:Forest ;
    skos:definition "‘forest’ means ‘any land covered with trees and undergrowth and includes all statutorily recognised forests, whether designated as reserve, protected or otherwise, and any land recorded as forests in the government records irrespective of the owners.’ India 2005"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "India 2005" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_542 a skos:Concept ;
    dct:creator "proposed" ;
    dct:date "2007"^^xsd:gYear ;
    dct:source "http://moef.nic.in/divisions/fp/April_May_meet.doc"^^xsd:anyURI ;
    dct:spatial "India" ;
    skos:broadMatch ex:Forest ;
    skos:definition "‘An area owned by Govt and notified as forest under any act or recorded as a forest in any Govt record functioning as ecological, biological, livelihood-support and/or social resource’ Explanation: such forests will include areas having trees, scrub, grasslands, wetlands, water bodies, deserts, glaciers, geomorphic features or any other area fulfilling the functions of a forest"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "India 2007 proposed" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_543 a skos:Concept ;
    dct:creator "Proposed" ;
    dct:date "2007"^^xsd:gYear ;
    dct:source "http://www.mtnforum.org/sites/default/files/pub/4946.pdf"^^xsd:anyURI ;
    dct:spatial "India" ;
    skos:broadMatch ex:Forest ;
    skos:definition "MoEF has proposed a definition that says forest is “an area under Government control notified or recorded as forest under any Act, for conservation and management of ecological and biological resources.”"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "India 2007 Proposed" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_544 a skos:Concept ;
    dct:date "2007"^^xsd:gYear ;
    dct:source "http://moef.nic.in/divisions/fp/April_May_meet.doc"^^xsd:anyURI ;
    dct:spatial "India" ;
    skos:broadMatch ex:Forest ;
    skos:definition "“An area under Government control notified or recorded as forests under any Act for the conservation and management of ecological and biological resources.” Explanation: Such forests will include areas with trees, scrubland, grasslands, wetlands, water bodies, deserts, glaciers, geomorphic features or any other area that is necessary to maintain ecological security"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "India 2007" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_545 a skos:Concept ;
    dct:date "2008"^^xsd:gYear ;
    dct:source "http://mospi.nic.in/mospi_new/upload/nad10_2008_karnataka_final.pdf"^^xsd:anyURI ;
    dct:spatial "India" ;
    skos:broadMatch ex:Forest ;
    skos:definition "In India, forest area is defined by using the legal connotation. An area of land recorded as forest in revenue records or proclaimed to be forest under a forest law or Act is described as forest”. In other words, ‘forest area’ is an area recorded as forest in the government records. This is ifferent from the ‘forest cover’ which is based on the capability of remote sensing satellite sensor and is completely independent of the legality of land use or land ownership. This data is provided by the Forest Survey of India (FSI"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "India 2008" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_546 a skos:Concept ;
    dct:date "2009"^^xsd:gYear ;
    dct:spatial "India" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Notified’ forest is forest for which a state government has issued a notification in the Official Gazette declaring that the land has been constituted as forest"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "India 2009" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_547 a skos:Concept ;
    dct:date "2014"^^xsd:gYear ;
    dct:source "http://www.newindianexpress.com/nation/MoEF-Asks-States-to-Identify-Deemed-Forest-Areas/2014/08/26/article2398873.ece"^^xsd:anyURI ;
    dct:spatial "India" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Deemed Forests - basically not recorded forest areas as per government records"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "India 2014" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_548 a skos:Concept ;
    dct:source "http://www.krishiworld.com/html/land_utilisation6.html"^^xsd:anyURI ;
    dct:spatial "India" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forests include all lands classed as forest under any legal enactment dealing with forests or administered as forests, whether state owned or private, & whether wooded or maintained as potential forest land. The area of crops raised in the forests & grazing lands or the area open for grazing within the forests should remain included under the forest area"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "India" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_549 a skos:Concept ;
    dct:spatial "India" ;
    skos:broadMatch ex:Forest ;
    skos:definition "In India, the Recorded Forest Area is defined as \"all lands statutorily notified as forest though they may not necessarily bear tree cover\". T P Singh tpsingh@teri.res.in"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "India" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_55 a skos:Concept ;
    dct:source "http://fwie.fw.vt.edu/rhgiles/appendices/glossf.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A community dominated by dense, extensive tree cover"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_550 a skos:Concept ;
    dct:date "1967"^^xsd:gYear ;
    dct:source "http://www.jica.go.jp/project/indonesia/0065045I0/activities/pdf/output1_2_1_fulltext.pdf"^^xsd:anyURI ;
    dct:spatial "Indonesia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest under the BFL (Basic Forestry Law) is defined as any kind of land-cover area (with or without tress), which is stated by the government as forest. It may be in the form of forest area or area without trees which the government as forest has designated"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Indonesia 1967" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_551 a skos:Concept ;
    dct:date "1998"^^xsd:gYear ;
    dct:spatial "Indonesia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Hutan ialah suatu lapangan bertumbuhan pohon-pohon yang secara keseluruhan merupakan persekutuan hidup alam hayati beserta alam lingkungannya dan yang ditetapkan oleh Pemerintah sebagai hutan. (Translation: A forest is an area growing trees which as a whole forms a living natural community and natural living environment, which is designated by the government as being forest). Source: Decision of the Minister of Forestry and Plantations on social forest(ry) (Keputusan Menteri Kehutanan dan Perkebunan tentang hutan kemasyarakatan, Number 677/Kpts-II/1998) based on the Forestry Law provided by Nico Smith, MSc. Lecturer at FakultasI Kehutanan Universitas Muhammadiyah Sumatra Barat"@id ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Indonesia 1998" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_552 a skos:Concept ;
    dct:date "1999"^^xsd:gYear ;
    dct:source "http://insideindonesia.org/content/view/1245/47/"^^xsd:anyURI,
        "http://www.insideindonesia.org/edition-98/fighting-over-the-land-and-forest"^^xsd:anyURI ;
    dct:spatial "Indonesia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "‘forest area’ means a certain area designated or stipulated by the government to be retained as permanent forest, and ‘state forest’ means a forest located on ‘lands bearing no ownership rights’ (the Indonesian phrase is ‘tanah yang tidak dibebani hak atas tanah’). and Moniaga, Sandra 2009. Fighting over the land and forest. Inside Indonesia"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Indonesia 1999" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_553 a skos:Concept ;
    dct:date "1999"^^xsd:gYear ;
    dct:source "http://www.itto.int/direct/topics/topics_pdf_download/topics_id=2648&no=1&disp=inline"^^xsd:anyURI ;
    dct:spatial "Indonesia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "titled forest is a forest located on land on which the land title is registered"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Indonesia 1999" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_554 a skos:Concept ;
    dct:date "2000"^^xsd:gYear ;
    dct:source "http://www.fire.uni-freiburg.de/iffn/country/id/id_25.htm"^^xsd:anyURI ;
    dct:spatial "Indonesia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest area means a certain area which is designated and/or stipulated by government to be retained as permanent forest.\""@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Indonesia 2000" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_555 a skos:Concept ;
    dct:date "2009"^^xsd:gYear ;
    dct:source "https://www.elaw.org/system/files/REDD_PERMENHUT_P-30-2009_BILINGUAL.pdf"^^xsd:anyURI ;
    dct:spatial "Indonesia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest area means a certain area designated and or stipulated by the government to preserve its existence as a permanent forest"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Indonesia 2009" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_556 a skos:Concept ;
    dct:spatial "Israel" ;
    skos:broadMatch ex:Forest ;
    skos:definition "2. Land which was declared as Forest Land by any legal or official program or 3. Land managed by the Israeli Forest Department. From: GilS@kkl.org.il"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Israel" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_557 a skos:Concept ;
    dct:date "1923"^^xsd:gYear ;
    dct:spatial "Italy" ;
    skos:broadMatch ex:Forest ;
    skos:definition "In Italy, forests are part of the areas submitted to restraints imposed by a 1923 Italian law (R.D.L. 1923). This law obliges local authorities to demarcate all areas (not only wooded) that can not be subjected to land-use change, since they are important for slope stability, for mass and superficial erosion prevention and for regulating water regime. Regio Decreto Legislativo 30 Dicembre 1923, n. 3267. Riordinamento e riforma della legislazione in materia di boschi e terreni montani. Lorenzo Ciccarese ciccarese@anpa.it"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Italy 1923" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_558 a skos:Concept ;
    dct:date "1964"^^xsd:gYear ;
    dct:source "http://freeafrica.tripod.com/ogiekland/book/Chapter06.htm#ActForest"^^xsd:anyURI ;
    dct:spatial "Kenya" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest areas means an area of land declared under section 4 to be a forest area. Section 4(1) empowers the Minister from time to time, by notice in the Gazettee:- Declare any unalienated Government land to be a forest area:- Declare the boundaries of a forest and from time to time after those boundaries; Declare that a forest area shall cease to be a forest area"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Kenya 1964" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_559 a skos:Concept ;
    dct:date "2005"^^xsd:gYear ;
    dct:source "http://environment.yale.edu/tfd/uploads/TFD_ILCF_Kenya_BackgroundPaper.pdf"^^xsd:anyURI ;
    dct:spatial "Kenya" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Gazetted (state/public) forests are forest reserves managed by the state agency, the Kenya Forest Service (KFS"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Kenya 2005" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_56 a skos:Concept ;
    dct:source "http://www.pauldonahue.net/for_InkaNatura_guides/environmental_glossary.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A community dominated by dense, extensive tree cover….Plant community predominately of trees and other woody plants, growing more or less closely together.….Ecosystem characterized by more or less dense and extensive tree cover, i.e.,larger than what might be called a grove"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_560 a skos:Concept ;
    dct:date "2005"^^xsd:gYear ;
    dct:source "http://formin.finland.fi/public/download.aspx?ID=15959&GUID=%7B88EFD0B8-9F47-4528-A24F-66DDE0CFE370%7D"^^xsd:anyURI,
        "http://www.fankenya.org/downloads/ForestsAct2005.pdf"^^xsd:anyURI ;
    dct:spatial "Kenya" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest area means any land declared to be a forest land under this act. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Kenya 2005" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_561 a skos:Concept ;
    dct:date "2015"^^xsd:gYear ;
    dct:source "http://www.kenyaforestservice.org/documents/ForestConservationandManagementActNo34of2016.pdf"^^xsd:anyURI ;
    dct:spatial "Kenya" ;
    skos:broadMatch ex:Forest ;
    skos:definition "“Forest\" means land which is declared or registered as a forest"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Kenya 2015" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_562 a skos:Concept ;
    dct:creator "Kosovo" ;
    dct:date "2003"^^xsd:gYear ;
    dct:source "http://www.gazetazyrtare.com/e-gov/index.php?option=com_content&task=view&id=244&Itemid=28&lang=en"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"Forest\" is land registered as such in the cadastral records. \"Forestland\" is land that is being managed for the production of wood or other forest products or whose best use, given its natural characteristics and economic conditions, involves the growing of trees. . \"Forestland\" does not include --Orchards; Lands within the inhabited bounds of cities, towns, or villages, including urban parks; Parks or other areas for the protection of natural resources excluded from the jurisdiction of this law by laws other than this Law; Lands where trees have been planted in strips primarily to control erosion, create shelter from the wind, give shade, or improve aesthetics; -Roadsides that have been planted with trees; and Lands where the portion suitable for growing trees is less than 0.1 hectare. Law 2003/3 on Forests in Kosovo"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Kosovo 2003" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_563 a skos:Concept ;
    dct:creator "Laos" ;
    dct:date "1996"^^xsd:gYear ;
    skos:broadMatch ex:Forest ;
    skos:definition "All areas under the management of the Ministry of Agriculture and Forestry whether covered with forest or not, but not used for or defined as permanent agricultural land. www.iges.or.jp/fc/ir98-3-24.PDF"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Laos 1996" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_564 a skos:Concept ;
    dct:creator "Laos" ;
    dct:date "1996"^^xsd:gYear ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land with or without forest on it, which the state has determined as forest land. www.iges.or.jp/fc/ir98-3-24.PDF"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Laos 1996" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_565 a skos:Concept ;
    dct:creator "Laos" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Living natural resources \"necessary for the preservation of the environment, water sources, soil, wildlife and the livelihood of the pluri-ethnical population\". Forest lands are all areas under the management of the Ministry of Agriculture and Forestry, whether covered or not by forests, if not used or defined as permanent agricultural land. Source: LEX-FAOC004704. LAOS: Decree of the Prime Minister on the Management and Use of Forests and Forest Land (No. 169/PM"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Laos" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_566 a skos:Concept ;
    dct:creator "Lativa" ;
    dct:date "2000"^^xsd:gYear ;
    dct:source "http://www.iufro.org/download/file/5574/4510/61300-jundola01_pdf/"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "The definition of the notion “forest land” is given in Paragraph 1 of Article 3 of the Forest Law: as the land carrying forest, the land under forest infrastructure facilities, as well as overflowing clearings, bogs and gaps in the forest and areas contiguous to it"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Lativa 2000" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_567 a skos:Concept ;
    dct:source "http://darwin.defra.gov.uk/documents/13008/3153/13-008%20AR1%20Ann%201%20CF_Manual_LFRfinal.pdf"^^xsd:anyURI ;
    dct:spatial "Liberia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "“Communal Forest” means an area set aside legally or temporarily by regulation for the sustainable use of non-timber forest products by local communities on a non-commercial basis"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Liberia" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_568 a skos:Concept ;
    dct:source "http://darwin.defra.gov.uk/documents/13008/3153/13-008%20AR1%20Ann%201%20CF_Manual_LFRfinal.pdf"^^xsd:anyURI ;
    dct:spatial "Liberia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Law defines ‘communal forest’ as “A small described forest area immediately adjacent to one or more villages to be used exclusively by the local inhabitants and shall not be used for any commercial purposes.”"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Liberia" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_569 a skos:Concept ;
    dct:source "http://darwin.defra.gov.uk/documents/13008/3153/13-008%20AR1%20Ann%201%20CF_Manual_LFRfinal.pdf"^^xsd:anyURI ;
    dct:spatial "Liberia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "The Act creating a Protected Forest Area System in Liberia defines communal forests as “areas set aside legally or temporarily by regulation for sustainable use of forest products by local communities on a non-commercial basis”"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Liberia" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_57 a skos:Concept ;
    dct:source "http://155.187.10.12/glossary/croft.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A community dominated by trees with long trunks"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_570 a skos:Concept ;
    dct:source "http://www.fao.org/forestry/FON/FONS/outlook/Africa/ACP/Lamb/Lamb-37.htm#P5876_393136"^^xsd:anyURI ;
    dct:spatial "Madagascar" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Les ressources forestières de Madagascar comprennent les forêts et les produits issus de ces forêts. Les forêts sont composées de Réserves Naturelles Intégrales (RNI), de Réserves Spéciales (RS), de Parcs Nationaux (PN), de Stations Forestières (SF), de Forêts Classées (FC), de Réserves Forestières (RF), de Périmètres de Reboisement et de Restauration (PRR) et de Mangroves. Tous produits ligneux ou non-ligneux d'origine végétale fournis par la forêt notamment les bois, le charbon, les écorces, les fibres, les bambous, les résines, le miel, la flore dont les plantes médicinales et les plantes fourragères sont qualifiés de produits de la forêt"@fr ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Madagascar" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_571 a skos:Concept ;
    dct:date "1984"^^xsd:gYear ;
    dct:source "http://www.agc.gov.my/Akta/Vol.%207/Act%20313.pdf0"^^xsd:anyURI ;
    dct:spatial "Malaysia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"open forest\" means any permanent reserved forest or part thereof declared to be an open forest under section 45; \"closed forest\" means any permanent reserved forest or part thereof declared or deemed to be a closed forest under section 45"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Malaysia 1984" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_572 a skos:Concept ;
    dct:date "1956"^^xsd:gYear ;
    dct:spatial "Montserrat" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest reserves and Protected Forests shall be demarcated in accordance with section 16. LEX-FAOC017877. MONTSERRAT: Forestry Ordinance. Date of original text: 1956"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Montserrat 1956" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_573 a skos:Concept ;
    dct:date "1992"^^xsd:gYear ;
    dct:source "http://www.blc-burma.org/html/Myanmar%20Law/lr_e_ml92_08.html"^^xsd:anyURI ;
    dct:spatial "Myanmar" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest Land means land including reserved forest and protected public forest; The Forest Law"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Myanmar 1992" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_574 a skos:Concept ;
    dct:spatial "Myanmar" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land including reserved forest and protected public forest; Reserved Forest means land constituted as a reserved forest under this Law; Protected Public Forest means land declared to be protected public forest under this Law. Source: FOREST LAW State Law and Order"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Myanmar" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_575 a skos:Concept ;
    dct:date "2001"^^xsd:gYear ;
    dct:source "https://laws.parliament.na/cms_documents/forest-f6867dc9d1.pdf"^^xsd:anyURI ;
    dct:spatial "Namibia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "“Classified forest” means a forest reserve, a community forest or a forest management area"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Namibia 2001" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_576 a skos:Concept ;
    dct:date "1993"^^xsd:gYear ;
    dct:spatial "Nepal" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest land (national forests)= meant all forests, excluding private forests, within the kingdom of Nepal, whether marked or unmarked with forest boundary markers; the term includes waste or uncultivated lands or unregistered lands surrounded by or adjoining forests, as well as paths, ponds, lakes, rivers, or streams and reverine lands with forests.(Forest Act 1993) Krishna H Gautam <khg13@student.canterbury.ac.nz"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Nepal 1993" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_577 a skos:Concept ;
    dct:date "1927"^^xsd:gYear ;
    dct:source "http://nwfp.gov.pk/nwfpgov/Gov/Details.php?id=76"^^xsd:anyURI ;
    dct:spatial "Pakistan" ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"Reserved Forest\" means land which was, demaracted as such at the settlement, or which may be constituted as such under the provision of the Forest Act, 1927"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Pakistan 1927" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_578 a skos:Concept ;
    dct:date "1953"^^xsd:gYear ;
    dct:spatial "Pakistan" ;
    skos:broadMatch ex:Forest ;
    skos:definition "in a legal sense, an area of land proclaimed to be forest under a Forest Act or Ordinance. Definition adopted from the British Commonwealth Forest Terminology Part-I, 1953. Source: Mumtaz Ahmad, Section Forest Officer, Pakistan Min. of Environment, Local Government, and Rural Development"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Pakistan 1953" ;
    skos:prefLabel "Forest"@no ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_579 a skos:Concept ;
    dct:date "1959"^^xsd:gYear ;
    dct:source "http://bdlaws.gov.bd/print_sections.php?id=289&vol=&sections_id=11690"^^xsd:anyURI ;
    dct:spatial "Pakistan" ;
    skos:broadMatch ex:Forest ;
    skos:definition "“forest” includes any land recorded as forest in a record-of-rights prepared under Chapter IV of the State Acquisition and Tenancy Act, 1950 (E.B. Act XXVIII of 1951) or such other land containing tree growth as may by notification be declared as forest by the Government;] Pakistan. (East Pakistan Ordinance No.XXXIV OF 1959"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Pakistan 1959" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_58 a skos:Concept ;
    dct:source "http://www.atlanticeurope.com/geography/GeographyGlossary.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A community of trees and other plants, together with the animals that live in it. This natural community is called an ecosystem and it is self sustaining. Forests are most commonly found where there is enough water for their growth and so they are most common in moister rather than drier parts of the world. Geography Glossary"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_580 a skos:Concept ;
    dct:date "1992"^^xsd:gYear ;
    dct:source "http://www.cda.gov.pk/cda-latest/documents/docs/ICT-Zoning-regulations-1992.pdf"^^xsd:anyURI ;
    dct:spatial "Pakistan" ;
    skos:broadMatch ex:Forest ;
    skos:definition "“Forest\" means and includes all protected, reserved and designated forest, grass- land and range land"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Pakistan 1992" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_581 a skos:Concept ;
    dct:date "1975"^^xsd:gYear ;
    dct:source "http://bim.aseanbiodiversity.org/elib/reference/download.php?refNo=00541&fileId=541"^^xsd:anyURI ;
    dct:spatial "Philippines" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest lands include the public forest, the permanent forest or forest reserves, and forest reservations. a. Public forest is the mass of lands of the public domain which has not been the subject of the present system of classification for the determination of which lands are needed for forest purposes and which are not. b. Permanent forest or forest reserves refers to those lands of the public domain which have been the subject of the present system of classification and declared as not needed for forest purposes. Forestry Code, Revised (PD No. 705, 1975, as amended"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Philippines 1975" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_582 a skos:Concept ;
    dct:date "1975"^^xsd:gYear ;
    dct:source "http://www.cifor.org/publications/pdf_files/Books/Bchokkalingam0605-02.pdf"^^xsd:anyURI ;
    dct:spatial "Philippines" ;
    skos:broadMatch ex:Forest ;
    skos:definition "The term “forest land” refers to all property owned by the national government that is still in the public domain. It is a legal, not a botanical description"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Philippines 1975" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_583 a skos:Concept ;
    dct:date "1996"^^xsd:gYear ;
    dct:source "http://www.napocor.gov.ph/WMD%20WEBPAGE/mandates/memorandum/mo%2096-27.htm"^^xsd:anyURI ;
    dct:spatial "Philippines" ;
    skos:broadMatch ex:Forest ;
    skos:definition "FOREST LAND – refers to the public forest, or permanent forest inside the watershed reservations"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Philippines 1996" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_584 a skos:Concept ;
    dct:date "2009"^^xsd:gYear ;
    dct:source "http://www.apforgen.org/National%20status%20reports.pdf"^^xsd:anyURI ;
    dct:spatial "Philippines" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest reserves as forest land which has been reserved by the President of the Philippines for any specific purpose or purposes"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Philippines 2009" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_585 a skos:Concept ;
    dct:date "1975"^^xsd:gYear ;
    dct:spatial "Puerto Rico" ;
    skos:broadMatch ex:Forest ;
    skos:definition "The Governor may declare public land as Commonwealth Forests under section 3. Such areas shall be of particular interest for forestry use including development and protection of watersheds. These forests shall be controlled by the Secretary of Natural Resources. LEX-FAOC017870. PUERTO RICO: Puerto Rico Forest Act (No. 133 of 1975). Date of text: 01 July 1975"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Puerto Rico 1975" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_586 a skos:Concept ;
    dct:source "http://www.metla.fi/eu/cost/e43/minutes/wg1-min-florence.pdf"^^xsd:anyURI ;
    dct:spatial "Oman" ;
    skos:broadMatch ex:Forest ;
    skos:definition "National definition in use: designated areas, no sampling on other areas but for these areas some old data exist"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Romania" ;
    skos:prefLabel "Forest"@no ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_587 a skos:Concept ;
    dct:creator "Russia" ;
    dct:date "1997"^^xsd:gYear ;
    dct:source "http://www.iufro.org/download/file/5574/4510/61300-jundola01_pdf/"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Pursuant to the Russian Forest Code of 1997, the forest estate is defined as including “all forests”, excluding only defence lands, urban settlements and municipal forests, and its boundaries are identified by demarcation (sec. 7"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Russia 1997" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_588 a skos:Concept ;
    dct:date "1988"^^xsd:gYear ;
    dct:spatial "Sierra Leone" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Classified Forest – a national production forest, national protection forest or community forest. National production forest means a national forest of which the primary management objective is production of forest produce. National protection forest means a national forest of which the primary management objective is preservation of the forest environment and protection of soil, water, flora and fauna. Community forest means an area of land which is constituted as a community forest under section 18. LEX-FAOC005732. SIERRA LEONE: Forestry Act, 1988. Being an Act to make new provisions in the Law relating to Forestry in Sierra Leone and for connected purpose"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Sierra Leone 1988" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_589 a skos:Concept ;
    dct:source "http://www.fris.sk/Phare/Projects/ManagementOfForestInEurope/PDF/annex2.pdf"^^xsd:anyURI ;
    dct:spatial "Slovakia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest includes forest stands with its environment and other areas designated for the fulfillment of forest functions. Forest stand means tree and shrub species which, in their environment, fulfill forest functions. No area limit, classification into forest and non-forest according to the cadastre; limit of 0.01 ha in the Guidelines for forest managm. planning"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Slovakia" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_59 a skos:Concept ;
    dct:source "http://www.si.edu/crc/ep/forest/bin-pdf/Glossary.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A community of trees, shrubs, herbs, and associated plants and organisms covering a considerable area; that use oxygen, water, and soil nutrients as the community attains maturity and reproduces itself"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_590 a skos:Concept ;
    dct:date "1993"^^xsd:gYear ;
    dct:source "http://www.efi.int/files/attachments/publications/annex_1_to_efi_technical_report_88__2013.pdf"^^xsd:anyURI ;
    dct:spatial "Slovenia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "The term “forest” is defined also by the Law on Forests of Slovenia (Official Journal of the Republic of Slovenia, nr. 30/1993). Article two states: .... “A forest is an area of land, covered with forest trees in the form of stands or other forest growths which provide any of the functions of a forest. Forest, according to this law also includes overgrown plots of land which are defined as forest in the spatial part of the forest management plan. The forest infrastructure which is apportioned to individual plots is an integral part of the forest. The following are not forest within the meaning of this law: individual forest trees; groups of forest trees up to an area of 0.05 ha; non-autochthonous riverine and windbelt trees; avenues; pastures overgrown with forest trees if they are used for pasturing, irrespective of how they are described in the land register. Zavod za Gozdove Slovenije, (Institution for forest of Slovenia), 2011"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Slovenia 1993" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_591 a skos:Concept ;
    dct:creator "South" ;
    dct:date "2003"^^xsd:gYear ;
    dct:source "http://www.gurtong.net/Governance/ConstitutionLaws/LawsofSouthSudan/tabid/342/Default.aspx"^^xsd:anyURI ;
    dct:spatial "Sudan" ;
    skos:broadMatch ex:Forest ;
    skos:definition "“Forest Reserve” means any area set aside in accordance with the provisions of Section 16 of this Act, for the purpose of Conservation, Protection and management of natural forests, its habitat and Environment and in which tree cutting and certain other activities of forest or its habitat and Environment are prohibited or controlled in accordance with the provisions of Sections 17, and 20 of this Act. Wildlife Conservation Act of 2003"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "South Sudan 2003" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_592 a skos:Concept ;
    dct:source "http://www.fao.org/ag/agl/agll/landuse/clsys/Srilanka.htm"^^xsd:anyURI ;
    dct:spatial "Sri Lanka" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Dense Forest - High growing, natural trees with more than approx. 75 % crown coverage. Open Forest(- Dense natural vegetation cover with between 45 and 75 % Forest Plantations - Man-made, mostly monocultural forests of teak, eucalyptus, pines and other species"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Sri Lanka" ;
    skos:prefLabel "Forest"@no ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_593 a skos:Concept ;
    dct:creator "St. Lucia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "An area of land, with or without trees, declared to be a forest reserve, protected forest, or prohibited area (Source: Michael Andrew, chiefforest@maffe.org"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "St. Lucia" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_594 a skos:Concept ;
    dct:spatial "Sudan" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Government forest reserves managed by the forest department. It can be bare land intended to be planted with trees or shrubs in the future (K. H. Badi, Forest Deptartment, Sudan A. M.S. Bayoumi, Forest Department, Sudan"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Sudan" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_595 a skos:Concept ;
    dct:date "1992"^^xsd:gYear ;
    dct:source "http://www.burmalibrary.org/docs11/Forest-Law-1992.pdf"^^xsd:anyURI ;
    dct:spatial "Switzerland" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest Land means land including reserved forest and protected public forest. The Forest Law"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Switzerland 1992" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_596 a skos:Concept ;
    dct:creator "Taiwan" ;
    dct:date "2006"^^xsd:gYear ;
    dct:source "http://law.moj.gov.tw/PDAENG/NewsContent.aspx?msgid=2429"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forestland as used in Paragraph 1, Article 3 of this Act is defined as follows: 1. A land designated for forestry purpose under Article 3 of the Non-Urban Land Use and Control Rules and land subject to forestland control under Article 7 of the same Rules; 2. A land in a non-urban land area not subject to zoning, and land in an urban planning preservation, scenery and agricultural areas determined as forestland by the competent authorities of a province-level municipality or county/city government; 3. A land designated as conservation land under this Act; 4. A land used for forest recreation area in accordance with Article 17 of this Act; and 5. A land deemed located in a national park area under the National Park Law and determined as forestland by the competent authorities in consultation with the competent authority of the national park"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Taiwan 2006" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_597 a skos:Concept ;
    dct:creator "Taiwan" ;
    dct:date "2008"^^xsd:gYear ;
    dct:source "http://chiayi.forest.gov.tw/ct.asp?xItem=34177&CtNode=3036&mp=341"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "state forest means a forest belonging to the nation and in the territory of the nation, but without an owner. 2. A public forest means a forest held by a direct municipality, county (city), town, village or legal public entity. 3. A private forest means the ownership of a forest acquired by a private citizen or private legal entity. Chiayi Forest District Office. 2008"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Taiwan 2008" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_598 a skos:Concept ;
    dct:date "1993"^^xsd:gYear ;
    dct:spatial "Tajikistan" ;
    skos:broadMatch ex:Forest ;
    skos:definition "The composition of lands of the state forest reserve the following lands are allocated"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Tajikistan 1993" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_599 a skos:Concept ;
    dct:date "1941"^^xsd:gYear ;
    dct:source "http://www.forest.go.th/act/forest/fr3_e.htm"^^xsd:anyURI ;
    dct:spatial "Thailand" ;
    skos:broadMatch ex:Forest ;
    skos:definition "forest\" means land which has not been taken up or acquired by any other means under the Land Law"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Thailand 1941" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_60 a skos:Concept ;
    skos:broadMatch ex:Forest ;
    skos:definition "A community of trees, shrubs, herbs, microorganisms, and animals, the trees being the most obvious living structure. Academic American Encyclopedia"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_600 a skos:Concept ;
    dct:date "1941"^^xsd:gYear ;
    dct:source "http://enviroscope.iges.or.jp/modules/envirolib/upload/1504/attach/ir98-3-12.pdf"^^xsd:anyURI ;
    dct:spatial "Thailand" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forestry Act (1941): “Forest is a land without occupants in accordance with the land law” (Praraachabanyat Paamai Po. So. 2484, Matraa 4 (1) [Forestry Act of 1941, Article 4, Section 1]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Thailand 1941" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_601 a skos:Concept ;
    dct:date "1941"^^xsd:gYear ;
    dct:spatial "Thailand" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land not entitled under any Land Acts. Forest Law of 1941. Songkram Thammincha fforskt@ku.ac.th"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Thailand 1941" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_602 a skos:Concept ;
    dct:date "1941"^^xsd:gYear ;
    dct:source "http://eprints.lse.ac.uk/4743/1/The_Political_Ecology_of_the_Ecosystem_Approach_for_Forests(LSERO).pdf"^^xsd:anyURI,
        "http://personal.lse.ac.uk/FORSYTHT/Political%20Ecology%20of%20Ecosystem%20Approach.pdf"^^xsd:anyURI,
        "http://www9.ocn.ne.jp/~aslan/pgazpape.pdf"^^xsd:anyURI ;
    dct:spatial "Thailand" ;
    skos:broadMatch ex:Forest ;
    skos:definition "The Forest Act B.E. 2484 (1941) defines \"forest\" as any land which is not yet occupied by anyone according to the law. Since agricultural land and land upon which houses and other buildings are standing has presumably become private property, almost all other land except wasteland will be forest. , and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Thailand 1941" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_603 a skos:Concept ;
    dct:date "1967"^^xsd:gYear ;
    dct:spatial "Thailand" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land including mountain, stream, swamp, canal, river, lake, island, coastal areas not entitled under any Land Acts. Forest Reserve Act of 1967. Songkram Thammincha fforskt@ku.ac.th"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Thailand 1967" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_604 a skos:Concept ;
    dct:date "1996"^^xsd:gYear ;
    dct:source "http://www.farmersrights.org/pdf/asia/Thailand/Thailand-commforestdraft96.pdf"^^xsd:anyURI ;
    dct:spatial "Thailand" ;
    skos:broadMatch ex:Forest ;
    skos:definition "A community forest can be any area the community wants to be designated a community forest whether it is within the limits of a conservation zone such as a national park, wildlife sanctuary, watershed area; or non-conservation zone such as a national forest or public use area. Thailand's Community Forest Act Draft"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Thailand 1996" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_605 a skos:Concept ;
    dct:date "1961"^^xsd:gYear ;
    dct:spatial "Tonga" ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"Forest reserve\" means any demarcated forest or proclaimed forest reserve but shall not include a village forest reserve… \"Reserved area \" means any demarcated area of land or proclaimed area of land which may be under grass or scrub but which may be needed for afforestation in the future… The King in Council may declare any unalienated land to be a forest reserve or reserved area Forests Act 1961 (Chapter 126 of the 1988 Revised Edition of the Laws of Tonga). Via James Barton jpbarton@xtra.co.nz"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Tonga 1961" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_606 a skos:Concept ;
    dct:source "http://www.sawlog.ug/downloads/The%20Uganda%20Forestry%20policy.pdf"^^xsd:anyURI ;
    dct:spatial "Uganda" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forests include all alpine, tropical high and medium altitude forests, woodlands, wetland and riparian forests, plantations and trees, whether on land held in trust by government (gazetted Forest Reserves, National Parks and Wildlife Reserves) or nongazetted land (mailo, leasehold, freehold or customary lands). The Uganda Forestry Policy"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Uganda " ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_607 a skos:Concept ;
    dct:date "2010"^^xsd:gYear ;
    dct:source "http://www.envsec.org/publications/fact_finding_study_illegal_logging_eng_feb_11.pdf"^^xsd:anyURI ;
    dct:spatial "Ukraine" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest Code of Ukraine: • According to Article 8, state forests include all forests with the exception of municipal and private forests"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Ukraine 2010" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_608 a skos:Concept ;
    dct:creator "1598" ;
    dct:spatial "United Kingdom" ;
    skos:broadMatch ex:Forest ;
    skos:definition "A certen Territorie of wooddy grounds & fruitfull pastures, priviledged for wild beasts and foules of, Forrest, Chase, and Warren, to rest and abide in, in the safe protection of the King, for his princely delight and pleasure, ...\" (Kenneth Rosenbaum <kenro@igc.apc.org from Manwood (1598"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "United Kingdom 1598" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_609 a skos:Concept ;
    dct:source "http://machaut.uchicago.edu/cgi-bin/WEBSTER.sh?WORD=forest"^^xsd:anyURI,
        "http://www.graylab.ac.uk/cgi-bin/omd?forest"^^xsd:anyURI ;
    dct:spatial "United Kingdom" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Eng. Law) Large extent or precinct of country, generally waste and woody, belonging to the sovereign, set apart for the keeping of game for his use, not inclosed, but distinguished by certain limits, and protected by certain laws, courts, and officers of its own. Burrill. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "United Kingdom" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_61 a skos:Concept ;
    dct:creator "Gifford" ;
    dct:date "1902"^^xsd:gYear ;
    skos:broadMatch ex:Forest ;
    skos:definition "A community or society of living things, the most important of which is the tree. The forest is a unit or organized whole consisting of three distinct parts - the canopy, the floor, and the wood-mass"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Gifford 1902" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_610 a skos:Concept ;
    dct:source "http://www.dictionary.com/cgi-bin/dict.pl?term=forest"^^xsd:anyURI ;
    dct:spatial "United Kingdom" ;
    skos:broadMatch ex:Forest ;
    skos:definition "A defined area of land formerly set aside in England as a royal hunting ground"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "United Kingdom" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_611 a skos:Concept ;
    dct:spatial "United Kingdom" ;
    skos:broadMatch ex:Forest ;
    skos:definition "By the English law, a forest is a circuit of ground properly under the king's protection, for the peaceable living and abiding of beasts of hunting and the chase, and distinguished not only by having bounds and privileges, but also by having courts and offices. 12 do"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "United Kingdom" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_612 a skos:Concept ;
    dct:source "http://www.christiantech.com/cgi-bin/webster.exe?search_for_cgi-bin_texts_web1828=forest"^^xsd:anyURI ;
    dct:spatial "United Kingdom" ;
    skos:broadMatch ex:Forest ;
    skos:definition "In law, in Great Britain, a certain territory of woody grounds and pastures, privileged for wild beasts and fowls of forest, chase and warren, to rest and abide in, under the protection of the king, for his pleasure. In this sense, the word has no application in America"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "United Kingdom" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_613 a skos:Concept ;
    dct:creator "USA" ;
    dct:source "https://definitions.uslegal.com/n/national-forest-lands/"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Pursuant to 16 USCS § 460hhh (1), [Title 16. Conservation; Chapter 1. National Parks, Military Parks, Monuments, and Seashores; Spring Mountains National Recreation Area] the term National Forest lands means “lands included in the National Forest System (as defined in section 11(a) of the Forest and Rangeland Renewable Resources Planning Act"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_614 a skos:Concept ;
    dct:source "http://www.iufro.org/download/file/7408/5123/Uzekistan_pdf/"^^xsd:anyURI ;
    dct:spatial "Uzbekistan" ;
    skos:broadMatch ex:Forest ;
    skos:definition "The area of the State Forest Fund is termed forest land and includes land for afforestation, and non-forest land, where afforestation requires additional reclamational activities for site preparation. • Forest lands include such categories of lands as forest covered area, non-closed-up artificial (young) plantings, sparse crops, sparse forests, fire-sites, perished stands, cut sites, and glade abandoned sites. • Non-forest lands include arable land, hayfields, pastures, marshes, sands and other lands"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Uzbekistan" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_615 a skos:Concept ;
    dct:date "1973"^^xsd:gYear ;
    dct:spatial "Zambia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Local Forest – any area declared to be a Local Forest under section seventeen. LEX-FAOC003914. ZAMBIA: Forests Act 1973 (Act No. 39). An Act to repeal and replace the Forest Act and to provide for the establishment and management of national forests and local forests, the conservation and protection of forests and trees, the licensing and sale of forest produce and other matters"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Zambia 1973" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:Forest_616 a skos:Concept ;
    dct:date "1999"^^xsd:gYear ;
    dct:spatial "Afghanistan" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Open Forest (Between 20-60% Canopy Cover) - Mainly needleleaved, evergreen, open cover of trees, with less than 60% cover, occurring mainly in mountainous areas.; Closed Forest (More Than 60% Canopy Cover) - Mainly needleleaved, evergreen, closed cover of trees, with more than 60% cover, occurring mainly in mountainous areas. Source: FAO. 1999. Provincial Land Cover Atlas of Islamic State of Afghanistan. AFG/90/002 Utilization of Remote Sensing for the Inventory and Monitoring of Agricultural Land in Afghanistan. Food and Agricultural Organization of the United Nations (FAO), United Nations Development Programme (UNDP) and Afghan Geodesy and Cartography Head Office (AGCHO). FAO, Rome"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Afghanistan 1999" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_617 a skos:Concept ;
    dct:date "2004"^^xsd:gYear ;
    dct:spatial "Albania" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest is defined as an area covered at least 30% by dense trees on more than one tenth of a hectare [Law no. 9385 “On Forests and Forest Service]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Albania 2004" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_618 a skos:Concept ;
    dct:date "2008"^^xsd:gYear ;
    dct:source "http://illegallogging.rec.org/publications/AL_IL%20Diagnostic%20Audit_Final.pdf"^^xsd:anyURI,
        "http://www.profor.info/profor/sites/profor.info/files/Annex%208%20-%20SQA%20Albania_E.pdf"^^xsd:anyURI ;
    dct:spatial "Albania" ;
    skos:broadMatch ex:Forest ;
    skos:definition "2 Forest is defined as an area covered at least 30% by dense trees on more than one tenth of a hectare [Law no. 9385 “On Forests and Forest Service]. 3 Open forest or forest land is defined as an area covered by 5-30% by forest vegetation, unregistered in another land use cadastre. [Law no. 9385 “On Forests and Forest Service]. 4. Forest is defined as dense woodland with a density of trees and shrubs not less than 30%. 5. Forest land is defined an area with a density of trees and shrubs from 5-30%. and a"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Albania 2008" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_619 a skos:Concept ;
    dct:date "2011"^^xsd:gYear ;
    dct:source "http://www.efi.int/files/attachments/publications/annex_1_to_efi_technical_report_88__2013.pdf"^^xsd:anyURI ;
    dct:spatial "Albania" ;
    skos:broadMatch ex:Forest ;
    skos:definition "A forest is defined as land with tree crown cover of more than 10%, an area of more than 0.5 ha and an average width of more than 20 m. Trees should be able to reach a minimum height of 5 m at maturity in situ.FOREST EUROPE, UNECE AND FAO, 2011"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Albania 2011" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_62 a skos:Concept ;
    dct:creator "Graves and Guise" ;
    dct:source "http://www.foresthistory.org/ASPNET/Publications/CCCforestry/contents.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A complex association of trees, shrubs, and other plants in which each individual plays some part in the life of the community\""@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Graves and Guise" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_620 a skos:Concept ;
    dct:source "http://faolex.fao.org/faolex1/"^^xsd:anyURI ;
    dct:spatial "Albania" ;
    skos:broadMatch ex:Forest ;
    skos:definition "‘Forest’ is defined as dense woodland with a surface larger than 1000 m2 with a density of forest trees and shrubs not less than 30 %, which produces wood material and has influence on the surrounding environment. ‘Land with forest vegetation’ is defined as forest wood area with a density of forest trees and shrubs from 5 to 30 % which are not registered in the cadastra as other land estates. Forest estate includes also open areas up to 2 ha. such as openings, rocks and sandbank which are in forests, the surfaces occupied by forest shelterbelts, wood lots and shrub surfaces. LEX-FAOC004693. ALBANIA: Law No. 7623 for forestry and forest police service"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Albania" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_621 a skos:Concept ;
    dct:source "http://www.fris.sk/Phare/Projects/ManagementOfForestInEurope/PDF/annex2.pdf"^^xsd:anyURI ;
    dct:spatial "Albania" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Lands with tree crown cover of more than 30% and area of more than 0.1 ha. The trees should be able to reach a minimum height of 5 m in situ... Includes high forest, coppice and shrubs"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Albania" ;
    skos:prefLabel "Forest"@no ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_622 a skos:Concept ;
    dct:source "http://www.fao.org/forestry/fo/country/index.jsp?lang_id=1&geo_id=109"^^xsd:anyURI ;
    dct:spatial "American Samoa" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Includes: upland forests, coastal forests, mangrove forests, dwarf forests, moss forests, secondary vegetations and agroforest areas (including ones with coconuts and bananas"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "American Samoa" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_623 a skos:Concept ;
    dct:date "2003"^^xsd:gYear ;
    dct:source "http://www.fs.fed.us/research/sustain/2003SustainabilityReport/documents/SustainableForests.pdf"^^xsd:anyURI ;
    dct:spatial "Argentina" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Minimum area = 0.5 ha, minimum tree crown cover = 10%, minimum tree height = 5 m"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Argentina 2003" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_624 a skos:Concept ;
    dct:date "2007"^^xsd:gYear ;
    dct:source "http://www.greenspace.it/index.php?option=com_docman&task=doc_download&gid=16&Itemid=336&lang=it"^^xsd:anyURI ;
    dct:spatial "Argentina" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest Land Land with tree crown cover of more than 20 percent. The trees should be able to reach a minimum height of 7 meters at maturity in situ. It may consist of closed forest formation where trees of various storey and undergrowth cover a high proportion of the ground"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Argentina 2007" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_625 a skos:Concept ;
    dct:date "2007"^^xsd:gYear ;
    dct:source "https://www.researchgate.net/post/Which_conditions_are_used_to_define_an_ecosystem_as_a_woodland?ch=reg&cp=re221_b1m_p32&pli=1&loginT=TIy9Igbuj555qN69cnuPm4x7mnABAv97"^^xsd:anyURI ;
    dct:spatial "Argentina" ;
    skos:broadMatch ex:Forest ;
    skos:definition "The National Law 26.331 defines a woodland as a \"natural forestry ecosystem integrated by mature native trees, with different species of plants and animals, associated to the topsoil, subsoil, atmosphere, climate and hydric resources, [...] under a condition of dynamic equilibrium...\". Its regulation also defines as prime conditions that the woodlands should have trees of at least 3 m high and should occupy a surface superior to 10 has"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Argentina 2007" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_626 a skos:Concept ;
    dct:spatial "Argentina" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest Land: Native forest or plantation. \"Mirta Rosa Larrieu\" milarr@sagyp.mecon.ar"@fr ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Argentina" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_627 a skos:Concept ;
    dct:date "1994"^^xsd:gYear ;
    dct:spatial "Armenia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "The forest is one of the elements of the geographical landscape, and an entire whole of interconnected and interrelated trees, other plant species, soil, animals, microorganisms, and the components of the environment. Source: FOREST CODE OF ARMENIA (1994). Preamble. Karen Ter-Ghazaryan, Ministry of Nature Protection FREC@FREENET.AM"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Armenia 1994" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_628 a skos:Concept ;
    dct:date "1998"^^xsd:gYear ;
    dct:spatial "Aruba" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest: (thorny) woodlands, protected areas including mangrove areas, urban parks and trees for agricultural and commercial purposes are considered to fit the definition of forest as well. Even single trees are included in the definition if they form important esthetical elements in town or in the landscape. FAO Forestry paper 137/2, FORESTRY POLICIES IN THE CARIBEAN, volume 2: Reports of 28 selected countries and territories, FAO 1998. Facundo Franken, Department of Agriculture, Animal Production and Fisheries, Section Natural Resources Aruba"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Aruba 1998" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_629 a skos:Concept ;
    dct:date "1970"^^xsd:gYear ;
    dct:source "http://www.myenvironment.net.au/index.php/me/content/download/5678/33263/file/Uniting%20Church%20report.pdf"^^xsd:anyURI ;
    dct:spatial "Australia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "An area dominated by trees greater than 5m in height with canopy cover of 30% or greater (Specht 1970"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Australia 1970" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_63 a skos:Concept ;
    dct:source "http://www.hww.ca/glossary.asp#letterF"^^xsd:anyURI,
        "http://www.hww.ca/glossary.asp#letterR"^^xsd:anyURI,
        "http://www.minntrees.org/facts/ff17.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A complex community of plants and animals in which trees are the most conspicuous members. A mixed forest includes both coniferous and deciduous trees. , and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_630 a skos:Concept ;
    dct:date "1992"^^xsd:gYear ;
    dct:source "http://www.myenvironment.net.au/index.php/me/content/download/5678/33263/file/Uniting%20Church%20report.pdf"^^xsd:anyURI ;
    dct:spatial "Australia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "An area dominated by trees greater than 5m in height with canopy cover of 30% or greater, …including plantations (NFPS 1992"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Australia 1992" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_631 a skos:Concept ;
    dct:date "1992"^^xsd:gYear ;
    dct:source "http://www.australiansforanimals.org.au/afanewsjan.html"^^xsd:anyURI,
        "http://www.brs.gov.au/nfi/forestinfo/summary.html"^^xsd:anyURI ;
    dct:spatial "Australia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "An area, incorporating all living and non-living components, that is dominated by trees having usually a single stem and a mature or potentially mature stand height exceeding 2 metres, and with existing or potential projected crown cover of overstorey strata about equal to or greater than 20 percent. This definition includes both native and plantation regardless of age. (From: \"Ross Penny\"Ross.Penny@nre.vic.gov.au the definition of forest used by the National Forest Inventory (and based on the 1992 Australian National Forest Policy Statement). We include all of the 'tree-forming' mallees (a plant of the genus Eucalyptus) in our definition of forest. From: Roger.Hnatiuk@brs.gov.au. It is also sufficiently broad to encompass areas of trees that are sometimes described as woodlands. From:Jim.Stevenson@affa.gov.au This definition includes Australia's diverse native forests and plantations, regardless of age. It is also sufficiently broad to encompass areas of trees that are sometimes described as woodlands. and Karol.Andrzejewski@affa.gov.au NFI (1992) definition of Forest (from National Forest Policy Statement"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Australia 1992" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_632 a skos:Concept ;
    dct:date "1996"^^xsd:gYear ;
    dct:source "http://www.oecd.org/officialdocuments/publicdisplaydocumentpdf/?cote=OCDE/GD(96)5&docLanguage=En"^^xsd:anyURI ;
    dct:spatial "Australia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest is defined as areas dominated by trees having usually a single stem and a mature or potentially mature stand height exceeding 5 metres, and with existing or potential projective cover of overstorey strata about equal to or greater than 30 per cent; while woodland is similarly defined but with a projective cover of overstorey strata of less than 30 per cent"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Australia 1996" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_633 a skos:Concept ;
    dct:date "1998"^^xsd:gYear ;
    dct:source "http://adl.brs.gov.au/data/warehouse/pe_brs90000003841/sofr2008Full_11a.pdf"^^xsd:anyURI ;
    dct:spatial "Australia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "A land area, incorporating all living and non-living components, dominated by trees usually having a single stem and a mature or potentially mature stand height exceeding 2 metres, and with existing or potential crown cover of overstorey strata about equal to or greater than 20%. This definition includes native forests and plantations and areas of trees that are sometimes described as woodlands"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Australia 1998" ;
    skos:prefLabel "Forest"@no ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_634 a skos:Concept ;
    dct:date "2003"^^xsd:gYear ;
    dct:source "http://www.fs.fed.us/research/sustain/2003SustainabilityReport/documents/SustainableForests.pdf"^^xsd:anyURI ;
    dct:spatial "Australia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Minimum area = 0.5 ha, minimum tree crown cover = 20%, miniumum tree height – 2 m"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Australia 2003" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_635 a skos:Concept ;
    dct:date "2003"^^xsd:gYear ;
    dct:source "http://www.myenvironment.net.au/index.php/me/content/download/5678/33263/file/Uniting%20Church%20report.pdf"^^xsd:anyURI ;
    dct:spatial "Australia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Sclerophyll forest with canopy cover greater than 50% including all rainforest. Excludes mangroves and woodland mallee (TWS 2003a"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Australia 2003" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_636 a skos:Concept ;
    dct:date "2003"^^xsd:gYear ;
    dct:source "http://www.myenvironment.net.au/index.php/me/content/download/5678/33263/file/Uniting%20Church%20report.pdf"^^xsd:anyURI ;
    dct:spatial "Australia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "An area dominated by trees having usually a single stem, greater than 2m in height with canopy cover of 20% or greater… including plantations. (NFI 2003) Current definition"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Australia 2003" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_637 a skos:Concept ;
    dct:date "2004"^^xsd:gYear ;
    dct:source "http://adl.brs.gov.au/data/warehouse/brsShop/data/callitris.pdf"^^xsd:anyURI ;
    dct:spatial "Australia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "An area dominated by trees having usually a single stem and a mature or potentially mature stand height exceeding two meters, and with existing or potential projected cover of overstorey strata about equal to or greater than 20 percent"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Australia 2004" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_638 a skos:Concept ;
    dct:date "2005"^^xsd:gYear ;
    dct:source "http://wwwdocs.fce.unsw.edu.au/fce/Research/ResearchMicrosites/CAER/WorkingPaperSeries/WPS0705.pdf"^^xsd:anyURI ;
    dct:spatial "Australia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "forest area (defined as land with actual or potential tree cover greater than 20% canopy cover and 2 m in height"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Australia 2005" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_639 a skos:Concept ;
    dct:date "2009"^^xsd:gYear ;
    dct:source "http://www.daff.gov.au/rfa/glossary"^^xsd:anyURI ;
    dct:spatial "Australia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "A vegetation type dominated by woody vegetation having a mature or potential mature stand height exceeding 5 metres, with an overstorey canopy cover greater than 20%"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Australia 2009" ;
    skos:prefLabel "Forest"@no ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_64 a skos:Concept ;
    dct:creator "Pinchot" ;
    dct:date "1914"^^xsd:gYear ;
    skos:broadMatch ex:Forest ;
    skos:definition "A complex community with life of its own. It has a soil and atmosphere of its own, chemically and physically different from any other, with plants and shrubs as will as trees which are peculiar to it. It has resident population of insects and higher animals entirely distinct from that outside"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Pinchot 1914" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_640 a skos:Concept ;
    dct:date "2009"^^xsd:gYear ;
    dct:source "http://greensmps.org.au/webfm_send/266"^^xsd:anyURI ;
    dct:spatial "Australia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest means a vegetation community dominated by trees with a projective foliage cover greater than 20%"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Australia 2009" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_641 a skos:Concept ;
    dct:creator "Old" ;
    dct:source "http://www.rfa.gov.au/documents/janis/janis011.html#E9E11"^^xsd:anyURI ;
    dct:spatial "Australia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "A vegetation type dominated by woody vegetation having a mature or potential mature stand height exceeding 5 metres, with an overstorey canopy cover greater than 20%"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Australia Old" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_642 a skos:Concept ;
    dct:creator "Old" ;
    dct:source "http://www.rfa.gov.au/dfa/other_info/glossary.html"^^xsd:anyURI,
        "http://www.rfa.gov.au/rfa/national/dfa/other/glossary.html"^^xsd:anyURI ;
    dct:spatial "Australia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "An area incorporating all living and non-living components that is dominated by trees usually with a single stem and a mature or potentially mature stand height exceeding five metres. The existing or projected foliage cover of overstorey strata should be equal to or greater than 30 per cent. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Australia- Old" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_643 a skos:Concept ;
    dct:source "http://www.rfa.gov.au/rfa/vic/east/raa/esfm/gloss1.html"^^xsd:anyURI ;
    dct:spatial "Australia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "An area, incorporating all living and nonliving components, that is dominated by trees having usually a single stem and a mature or potentially mature stand height exceeding 5 metres, and with existing or potential projective cover of overstorey strata about equal to or greater than 30 per cent. This definition includes Australia's diverse native forests and plantations, regardless of age. It is also sufficiently broad to encompass areas of trees that are sometimes described as woodlands"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Australia" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_644 a skos:Concept ;
    dct:date "1999"^^xsd:gYear ;
    dct:source "http://www.nfn.org.au/kyoto/gp9.html"^^xsd:anyURI ;
    dct:spatial "Australia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "An ecosystem characterised by a more or less dense and extensive tree cover. It means natural forest and does not include plantations or agroforests (National Forest Summit, Australia 1999"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Australia1999" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_645 a skos:Concept ;
    dct:date "1996"^^xsd:gYear ;
    dct:source "http://books.google.com/books?id=zeTU8QauENcC&pg=PA192&lpg=PA192&dq=Germany+Forest+definition+define+%22forest+is%22+law+act+code&source=bl&ots=1jUsKaLHy4&sig=uRBHD83hyloLheFqPmfiDgK687o&hl=en&sa=X&ei=OcY-T7PEOcX10gHzx8jzBw&ved=0CDgQ6AEwAw#v=onepage&q=Germany%20Forest%20definition%20define%20%22forest%20is%22%20law%20act%20code&f=false"^^xsd:anyURI ;
    dct:spatial "Austria" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forests are areas of min. 1000 m2 and cover percentage 30% with tree species"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Austria 1996" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_646 a skos:Concept ;
    dct:date "1997"^^xsd:gYear ;
    dct:source "http://www.metla.fi/eu/cost/e43/minutes/wg1-min-florence.pdf"^^xsd:anyURI ;
    dct:spatial "Austria" ;
    skos:broadMatch ex:Forest ;
    skos:definition "All areas of the country covered by woody plants specified in the appendix of forest law 1975 are forest are if minimum area of 500 m2, width = 10 m of are covered by woody plants and minimum crown coverage of 30 % (ocular estimation) (European Communities 1997a - p 43). and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Austria 1997" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_647 a skos:Concept ;
    dct:date "2001"^^xsd:gYear ;
    dct:source "http://www.efi.int/files/attachments/publications/annex_1_to_efi_technical_report_88__2013.pdf"^^xsd:anyURI ;
    dct:spatial "Austria" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Minimum area: 0.05 ha; Minimum width: 10 m; The cultural type registered in the land register is insignificant; minimum crown coverage of 30 % (occular estimation). Schieler and Hauk 2001"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Austria 2001" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_65 a skos:Concept ;
    dct:source "http://edugreen.teri.res.in/explore/forestry/what.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A complex ecosystem consisting mainly of trees that buffer the earth and support a myriad of life forms"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_650 a skos:Concept ;
    dct:date "2010"^^xsd:gYear ;
    dct:source "http://www.bahamasforestry.com/docs/ForestryAct2010.pdf"^^xsd:anyURI ;
    dct:spatial "Bahamas" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest means any area consisting mainly of trees including forest cover, all other vegetation, wetlands, coil and ground beneath it. Bahamas Forestry Act of 2010"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Bahamas 2010" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_651 a skos:Concept ;
    dct:date "2011"^^xsd:gYear ;
    dct:source "http://www.tradingeconomics.com/bahamas/forest-area-percent-of-land-area-wb-data.html"^^xsd:anyURI ;
    dct:spatial "Bahamas" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest area is land under natural or planted stands of trees of at least 5 meters in situ, whether productive or not, and excludes tree stands in agricultural production systems (for example, in fruit plantations and agroforestry systems) and trees in urban parks and gardens"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Bahamas 2011" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_652 a skos:Concept ;
    dct:source "http://bahamasforestry.com/glossary.php"^^xsd:anyURI ;
    dct:spatial "Bahamas" ;
    skos:broadMatch ex:Forest ;
    skos:definition "a biological community dominated by trees and other woody plants"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Bahamas" ;
    skos:prefLabel "Forest"@no ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_653 a skos:Concept ;
    dct:date "2002"^^xsd:gYear ;
    dct:source "http://www.efi.int/files/attachments/publications/annex_1_to_efi_technical_report_88__2013.pdf"^^xsd:anyURI ;
    dct:spatial "Belarus" ;
    skos:broadMatch ex:Forest ;
    skos:definition "The collection of forest trees and other plants, soil, animals, microorganisms and other natural ingredients that have internal linkages and communication with the external environment; virgin, natural forest has not experienced significant human impact, which varies over many generations forest trees only under the influence of natural processes; small-leaved, forest, formed mainly small-leaved tree species (birch, aspen and alder gray); coniferous, forest, formed mostly shade-tolerant conifers (spruce, fir, cedar, etc.); deciduous, forest, formed by mainly deciduous trees (oak, beech, ash, maple, etc.). Ministry of Forestry of the Republic of Belarus, 2002"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Belarus 2002" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_654 a skos:Concept ;
    dct:spatial "Belarus" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Cover Min. Area (ha) = Min. Crown Cover (%) = Min. Tree Height (m) = Min. Strip Width (m) = ns"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Belarus" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_655 a skos:Concept ;
    dct:creator "Flanders" ;
    dct:source "http://www.efi.int/files/attachments/publications/annex_1_to_efi_technical_report_88__2013.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Belgium 2000) - Flanders Forest area included in the forest mapping meets art. 3 of the Forest Decree and is at least 0.5 ha, 25 m wide and has a closure of at least 20%. Shrublands with an area less than 0.5 hectares are not included in the forest mapping, but fall under the rules of the Forest Decree. Bogaert D. Agentschap voor Natuur en Bos, 2000"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Flanders" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_656 a skos:Concept ;
    dct:creator "Wallonia" ;
    dct:source "http://www.efi.int/files/attachments/publications/annex_1_to_efi_technical_report_88__2013.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Belgium 2006)- Area of land of at least 0.1 ha and with at least 10% covered by a forest canopy (trees must be able to reach a minimum of 5 m).IPRFW, Walloon Permanent Forest Resources Inventory, 1994-2006"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Wallonia" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_657 a skos:Concept ;
    dct:date "1999"^^xsd:gYear ;
    dct:source "http://www.ymparisto.fi/download.asp?contentid=25582&lan=en"^^xsd:anyURI ;
    dct:spatial "Belgium" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forests in general are considered to be surfaces covered with trees which function as ecosystems and can fulfil several functions such as wood production, recreation, nature conservation, landscape, soil and water protection and shelter (Natural resources 1999"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Belgium 1999" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_66 a skos:Concept ;
    dct:creator "often alien" ;
    dct:source "http://www.un.org/esa/socdev/unpfii/documents/6session_crp6.doc"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A complex, self-regenerating system, encompassing soil, water, microclimate, energy, and a wide variety of plants and animals in a mutual relationship. Plantations, on the other hand, have one or a few species of trees/crops , planted in homogenous blocks of the same age. Plantation trees are much closer to industrial agricultural crops than to forests (as usually understood) or a traditional agricultural field"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "often alien" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_660 a skos:Concept ;
    dct:spatial "Benin" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Une surface terrestre couverte de formations forestières d'origine anthropique ou non. Cest une surface où seule les activités forestières ne peuvent être menées. Note: Sur cette surface, les activités agricoles sont interdites. (Z. Yacoubou, Unité de Recherche Forestière, Cotonou, République du Benin"@fr ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Benin" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_661 a skos:Concept ;
    dct:creator "Bolivia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "BOSQUE: Ecosistema vegetal caracterizado por sus especies maderables de regular a gran tamaño, además de variadas especies menores distribuidas en sinusias. Cobija un gran número de especies animales que dependen de él. La complejidad y biodiversidad de los bosques aumenta de las zonas frías a las tropicales. Dicho de otra manera, agrupación de arboles que forman espesura y que pierden poco a poco su individualidad para concurrir a la formación de un nuevo ser único; tiene formaciones de existencias y propiedades que le son peculiares, funcionando a manera de un organismo complejo, del cual son factores la vegetación, la atmósfera y el suelo. Source: Luis Castello faopaf@caoba.entelnet.bo Adjunto sírvase encontrar la versión no oficial y premilinar del Glosario Forestal elaborado por el Proyecto de Apoyo a la Coordinación e Implementación del Plan de Acción Forestal para Bolivia"@es ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Bolivia" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_662 a skos:Concept ;
    dct:creator "Bolivia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "FLORESTA: Terreno poblado de árboles (bosque). Source: Luis Castello faopaf@caoba.entelnet.bo Adjunto sírvase encontrar la versión no oficial y premilinar del Glosario Forestal elaborado por el Proyecto de Apoyo a la Coordinación e Implementación del Plan de Acción Forestal para Bolivia"@es ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Bolivia" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_663 a skos:Concept ;
    dct:creator "Bosnia – FbiH – RS" ;
    dct:source "http://www.fris.sk/Phare/Projects/ManagementOfForestInEurope/PDF/annex2.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land covered with forest trees in a group larger than 0.1 hectare"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Bosnia – FbiH – RS" ;
    skos:prefLabel "- Forest"@no ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_664 a skos:Concept ;
    dct:source "http://www.iufro.org/download/file/5579/4508/61300-zidlochovice03_pdf/"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Bosnia-Herzegovina The forest, in terms of this Law has a new definition. It refers to any ground surface covered with forest trees or forest shrubs exceeding any contiguous area of 500 m2 and having a width of at least 10 meters"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_665 a skos:Concept ;
    dct:date "2001"^^xsd:gYear ;
    dct:source "http://www.iufro.org/download/file/5574/4510/61300-jundola01_pdf/"^^xsd:anyURI ;
    dct:spatial "Bulgaria" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest\" is defined as any land exceeding 1 decare, covered or planted with forest trees or brushwood and located outside the boundaries of settlements (sec. 3). However, single trees in farmlands, afforested areas adjacent to monuments, forest belts on lands within cooperative and state farms, and forest stands planted by enterprises, organizations or cooperatives on their lands, are not part of the national forest stock (sec. 4"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Bulgaria 2001" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_666 a skos:Concept ;
    dct:date "2007"^^xsd:gYear ;
    dct:source "http://unfccc.int/files/national_reports/initial_reports_under_the_kyoto_protocol/application/msword/initial_report-bulgaria.doc"^^xsd:anyURI ;
    dct:spatial "Bulgaria" ;
    skos:broadMatch ex:Forest ;
    skos:definition "For defining forest, in Bulgaria is used the definition in the Forest Act: Forest is area, covered with forest tree species on area not less than 0.1 ha"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Bulgaria 2007" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_667 a skos:Concept ;
    dct:date "2007"^^xsd:gYear ;
    dct:source "http://unfccc.int/files/national_reports/initial_reports_under_the_kyoto_protocol/application/msword/initial_report-bulgaria.doc"^^xsd:anyURI ;
    dct:spatial "Bulgaria" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Min. Area (ha) = 0.1 Min. Crown Cover (%) = Min. Tree Height (m) = 3 Min. Strip Width (m) = 10 Forest is area, covered with forest tree species on area not less than 0.1 ha. (2007"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Bulgaria 2007" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_669 a skos:Concept ;
    dct:spatial "Bulgaria" ;
    skos:broadMatch ex:Forest ;
    skos:definition "every land covered with forest tree species and having area above 1 dka (0.1ha). The width of the area should be no smaller than 10 m. Forest Research Institute forestin@bulnet.bg"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Bulgaria" ;
    skos:prefLabel "Forest"@no ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_67 a skos:Concept ;
    dct:source "http://www.kyagr.com/enviro_out/pesticide/pdf/302KAR28.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A concentration of trees and related vegetation in nonurban areas characterized by natural terrain and drainage patterns"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_670 a skos:Concept ;
    dct:source "http://www.fris.sk/Phare/Projects/ManagementOfForestInEurope/PDF/annex2.pdf"^^xsd:anyURI ;
    dct:spatial "Bulgaria" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land covered by trees and shrubs (natural or artificially planted). The minimum area is 0.1 ha"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Bulgaria" ;
    skos:prefLabel "Forest"@no ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_671 a skos:Concept ;
    dct:spatial "Cambodia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Natural ecosystem, generally associated with wild vegetation (not indicate the crown cover of trees), fauna including natural soil and wild watercourses located in that area, and not subject to agricultural or other practices. All the forest land, including the forest plantation (see further) are the ownerships of State and under the supervision of the State. The term Forest Land subdivided into two categories: 1) - classified forest land: Production Forest, Conservation Forest and Reforestation areas. 2) - Protection forest land: the forest land not yet identified and classified as in the first category (O. Syphan, Forestry Department, Phnom Penh, Cambodia"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Cambodia" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_672 a skos:Concept ;
    dct:source "http://ekh.unep.org/files/SEF%20II%20Report%20-%20Cambodia.pdf"^^xsd:anyURI ;
    dct:spatial "Cambodia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest: is a combination of evergreen forest, semi-evergreen forest, deciduous forest, re-growth of secondary forest, forest plantation and bamboo"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Cambodia" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_673 a skos:Concept ;
    dct:date "1994"^^xsd:gYear ;
    dct:source "http://www.communitycarbonforestry.org/NewPublications/ESP%20article%20CAMERON.pdf"^^xsd:anyURI ;
    dct:spatial "Cameroon" ;
    skos:broadMatch ex:Forest ;
    skos:definition "CDM Executive Board. Section 2 of the 1994 forestry law (No. 94-1 of 20 January 1994) defines a forest as, ‘‘any land covered by vegetation with a predominance of trees, shrubs and other species capable of providing products other than agricultural produce’’"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Cameroon 1994" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_674 a skos:Concept ;
    dct:source "http://www2.worldbank.org/hm/hmlandpolicy/0248.html"^^xsd:anyURI ;
    dct:spatial "Cameroon" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest means any land covered by vegetation, with predominance of trees, shrubs and other species capable of providing products other than agricultural products"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Cameroon" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_675 a skos:Concept ;
    dct:date "2003"^^xsd:gYear ;
    dct:source "http://www.fs.fed.us/research/sustain/2003SustainabilityReport/documents/SustainableForests.pdf"^^xsd:anyURI ;
    dct:spatial "Canada" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Minimum area = 0.5 ha, minimum tree crown cover = 20%, minimum tree height = 5 m"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Canada 2003" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_676 a skos:Concept ;
    dct:date "2011"^^xsd:gYear ;
    dct:source "http://nfdp.ccfm.org/glossary_e.php"^^xsd:anyURI ;
    dct:spatial "Canada" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest land—Areas of land where tree canopies cover more than 10 percent of the total area and the trees, when mature, can grow to a height of more than 5 metres. Does not include land that is predominantly urban or used for agricultural purposes"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Canada 2011" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_677 a skos:Concept ;
    dct:date "2011"^^xsd:gYear ;
    dct:source "http://nfdp.ccfm.org/terms/terms_e.php?letter=f"^^xsd:anyURI ;
    dct:spatial "Canada" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Generally, an ecosystem characterized by a more or less dense and extensive tree cover. More particularly, a plant community predominantly of trees and other woody vegetation, growing more or less closely together"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Canada 2011" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_678 a skos:Concept ;
    dct:source "http://carbon.cfs.nrcan.gc.ca/definitions_e.html"^^xsd:anyURI ;
    dct:spatial "Canada" ;
    skos:broadMatch ex:Forest ;
    skos:definition "A vegetation type dominated by trees. Many definitions of the term forest are used throughout the world. For reporting on managed forest carbon stock changes, Canada uses the definitions of 1 ha minimum area, 25% canopy cover of trees that have the potential to reach 5 m height at maturity"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Canada" ;
    skos:prefLabel "Forest"@no ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_679 a skos:Concept ;
    dct:source "http://www.pfc.cfs.nrcan.gc.ca/landscape/inventory/terms/haddon/glossary.html#F"^^xsd:anyURI ;
    dct:spatial "Canada" ;
    skos:broadMatch ex:Forest ;
    skos:definition "forest: [forêt] A plant community predominantly of trees and other woody vegetation, growing more or less closely together"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Canada" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_68 a skos:Concept ;
    dct:source "http://www.bugwood.caes.uga.edu/glossary/"^^xsd:anyURI,
        "http://www.worldagroforestrycentre.org/sea/AgroModels/DBases/af/"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A continuous stand of trees > 10 m high, with interlocking crowns. There are many kinds of forests and ways to classify them, for example, by ecozone, vegetation type, climate, dominant species, conformation. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_680 a skos:Concept ;
    dct:date "2009"^^xsd:gYear ;
    dct:source "http://www.seaturtle.org/mtrg/projects/cayman/Cayman_NBAP.pdf"^^xsd:anyURI ;
    dct:spatial "Cayman Islands" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest and woodland defined as a class of vegetation characterized by a closed tree canopy, with interlocking crowns generally providing 60-100% cover. “Woodland”, by comparison, is characterized by an open canopy, with tree crowns constituting just 25-60% cover. The canopy height of forest and woodland ranges from about 16m, down to about 4.5m in height, below which shrubland species dominate. Burton (2008b"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Cayman Islands 2009" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_681 a skos:Concept ;
    dct:date "1979"^^xsd:gYear ;
    dct:source "http://derechoambiental.udp.cl/wp-content/uploads/2009/08/chile-case-cdm-ar-projects-as-published-by-iucn.pdf"^^xsd:anyURI ;
    dct:spatial "Chile" ;
    skos:broadMatch ex:Forest ;
    skos:definition "“a piece of land with vegetable formations in which trees predominate and that extend for at least 5,000m2, with a minimum width of 40m, with a tree top greater than 10% in arid and semiarid areas, or greater than 25% in more favourable conditions”"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Chile 1979" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_682 a skos:Concept ;
    dct:date "2002"^^xsd:gYear ;
    dct:source "http://www.fao.org/docrep/005/y2328e/y2328e03.htm"^^xsd:anyURI ;
    dct:spatial "Chile" ;
    skos:broadMatch ex:Forest ;
    skos:definition "By forest cover: In Chile, forest land is any area covered by plant formations with a predominance of trees, covering an area greater than 5 000 m2 and 40 m wide, with crown cover of more than 10 per cent (arid and semi-arid zones) or 25 percent in more favoured zones"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Chile 2002" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_683 a skos:Concept ;
    dct:date "2003"^^xsd:gYear ;
    dct:source "http://www.fs.fed.us/research/sustain/2003SustainabilityReport/documents/SustainableForests.pdf"^^xsd:anyURI ;
    dct:spatial "Chile" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Minimum area = 0.5 ha, minimum tree crown cover = 25%, minimum tree height = 2 m"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Chile 2003" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_684 a skos:Concept ;
    dct:date "2008"^^xsd:gYear ;
    dct:source "http://redd.unfccc.int/files/2016_submission_frel_chile_english.pdf"^^xsd:anyURI,
        "http://www.conaf.cl/cms/editorweb/transparencia/potestades/Ley-20283_bn.pdf"^^xsd:anyURI ;
    dct:spatial "Chile" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Bosque: sitio poblado con formaciones vegetales en las que predominan árboles y que ocupa una superficie de por lo menos 5.000 metros cuadrados, con un ancho mínimo de 40 metros, con cobertura de copa arbórea que supere el 10% de dicha superficie total en condiciones áridas y semiáridas y el 25% en circunstancias más favorables. Forest Law 20.283 22 , enacted in 2008 - Forest: site populated with vegetation in which trees predominate occupying an area of at least 5,000 square meters, with a minimum width of 40 meters, with tree crown cover exceeding 10% of the total area in arid and semi-arid conditions and 25% under more favorable circumstances. and"@es ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Chile 2008" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_685 a skos:Concept ;
    dct:spatial "Chile" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Any place covered with plant formations (predominantly trees) over 5,000 m2 and 40 m width, and arboreal cover over 10% of the area (arid and semiarid zones) or 25% of the area in zones with more advantageous conditions. Patricio Gonzalez pgonzale@infor.cl"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Chile" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_686 a skos:Concept ;
    dct:date "2000"^^xsd:gYear ;
    dct:source "http://www.fao.org/forestry/fo/country/index.jsp?lang_id=1&geo_id=102"^^xsd:anyURI ;
    dct:spatial "China" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Min. area = 0.067 ha, Min. Crown Cover = 20 %, Min. Height = 5 m, Min. Strip Width = 10. Includes bamboo and trees. Updated by Zhang Xiaoquan – (23 Jan 02). Trees > 2 cm dia"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "China 2000" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_687 a skos:Concept ;
    dct:date "2003"^^xsd:gYear ;
    dct:source "http://books.google.com/books?id=iU6ctBak3-gC&pg=PA142&lpg=PA142&dq=%22For+management+purposes,+State+Forests+are+divided%22&source=bl&ots=yvf2xSmFSt&sig=RmwVGV7UljL1nK9cjAb0NK8VVdY&hl=en&sa=X&ei=QsM6T-mOKaG90QG6zfHdCw&ved=0CCMQ6AEwAA#v=onepage&q=%22For%20management%20purposes%2C%20State%20Forests%20are%20divided%22&f=false"^^xsd:anyURI ;
    dct:spatial "China" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest land of arbour species spanning more than 0.0667 ha with a crown cover of more than 20%"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "China 2003" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_688 a skos:Concept ;
    dct:date "2003"^^xsd:gYear ;
    dct:source "http://www.fs.fed.us/research/sustain/2003SustainabilityReport/documents/SustainableForests.pdf"^^xsd:anyURI ;
    dct:spatial "China" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Minimum area = 0.5 ha, minimum tree crown cover = 20%, minimum tree height = 2 m"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "China 2003" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_689 a skos:Concept ;
    dct:date "2004"^^xsd:gYear ;
    dct:source "http://www.forest.gov.tw/ct.asp?xItem=21160&CtNode=1870&mp=3"^^xsd:anyURI ;
    dct:spatial "China" ;
    skos:broadMatch ex:Forest ;
    skos:definition "‘forest(s)’ means the land(s) and its collateral trees and bamboo, collectively. According to the delineation of ownership, forest(s) shall be distinguished as national forest(s), public forest(s), and private forest(s); forests principally belong to the nation"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "China 2004" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_69 a skos:Concept ;
    dct:source "http://www.thealmightyguru.com/Pointless/NatureDefinitions.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A dense grove of trees and underbrush covering a large tract. Grove - A small wood without underbrush. Wood - A dense grove of trees usually greater in extent than a grove and smaller than a forest. Thicket - A dense growth of shrubbery or small trees"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_690 a skos:Concept ;
    dct:date "2006"^^xsd:gYear ;
    dct:source "http://www.environmental-auditing.org/LinkClick.aspx?fileticket=fbx%2FbAIVeFU%3D&tabid=128&mid=568"^^xsd:anyURI ;
    dct:spatial "China" ;
    skos:broadMatch ex:Forest ;
    skos:definition "The definition of forest in China was adjusted from a minimum of 30 percent to 20 percent of cover in 1994. In 2004, the definition of forest was modified again to include special purpose scrubs, which grow in area with annual rainfall below 400 mm or above; the tree line in a mountain with a minimum canopy cover of 30% and in which its primary function is environmental protection. (Zhang, et al, 2006"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "China 2006" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_691 a skos:Concept ;
    dct:date "2009"^^xsd:gYear ;
    dct:source "http://www.portalforestal.com/informacion/noticias/3965-la-cobertura-forestal-de-china-alcanza-el-2036-por-ciento-del-territorio.html"^^xsd:anyURI ;
    dct:spatial "China" ;
    skos:broadMatch ex:Forest ;
    skos:definition "En China, se consideran zonas forestales aquellas con una superficie de más de 1 mu (0,667 hectáreas) de árboles con una densidad de copa del 20 por ciento o superior. 18 de Noviembre de 2009"@es ;
    skos:inScheme ex:ForestScheme ;
    skos:note "China 2009" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_692 a skos:Concept ;
    dct:spatial "China" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Area with forest cover equal to or greater than 0.2 ha. Yongqi Zheng Chinese Academy of Forestry. Zhengyq@rif.forestry.ac.cn"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "China" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_693 a skos:Concept ;
    dct:date "2000"^^xsd:gYear ;
    dct:source "http://www.fao.org/forestry/fo/country/index.jsp?lang_id=1&geo_id=12"^^xsd:anyURI ;
    dct:spatial "Congo" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Min. Crown Cover = 10%"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Congo 2000" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_694 a skos:Concept ;
    dct:creator ", Republic of" ;
    dct:spatial "Congo" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Area generally occupied by natural forestry stands. (A. Moutanda, Conférence des Responsables de Recherche Agronomique Africains (CORAF), Pointe Noire, Congo"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Congo, Republic of" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_695 a skos:Concept ;
    dct:creator ", Republic of" ;
    dct:date "2014"^^xsd:gYear ;
    dct:source "http://redd.unfccc.int/files/2016_submission_frel_republicofcongo.pdf"^^xsd:anyURI ;
    dct:spatial "Congo" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Dans le cadre du NERF de la République du Congo, la définition à prendre en compte est celle qui a été officiellement adoptée en Mars 2014 (rapport d’atelier sur la définition forêt, CN-REDD 2014b).Cette définition précise que « la forêt est un espace couvrant sur une superficie minimale de 0,5 hectare (0,50 ha), avec des arbres ayant une hauteur minimale de 3 mètres (3 m) et un taux minimal de couverture de houppier de 30%»"@fr ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Congo, Republic of 2014" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_696 a skos:Concept ;
    dct:creator "Forestal o Bosque" ;
    dct:source "http://www.fao.org/forestry/fo/country/index.jsp?lang_id=1&geo_id=172"^^xsd:anyURI ;
    dct:spatial "Costa Rica" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Todo tipo de vegetación natural la cual puede estar en espacios abiertos como lo es el bosque secundario, o bosque cerrado como el bosque maduro. El bosque secundario es clasificado como tal en la zona seca: (1) si tiene una altura mayor de 6 metros, por que el comportamiento arbóreo en estas zonas, con vegetación de menos de esta altura es rala y aun se detecta pasto Jaraugua mezclado con la vegetación arbórea. Y (2) si densidad de la vegetación arbórea y arbustiva debe ser suficientemente de la manera que elimine el pasto, y sustituido por enredaderas y arbustos. En climas húmedos la regeneración de bosques secundarios ocurre mas rápidamente comparado con las áreas secas, y la densidad inicial de la vegetación arbórea es mayor"@es ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Costa Rica - Forestal o Bosque" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_697 a skos:Concept ;
    dct:source "http://wiki.awf.forst.uni-goettingen.de/wiki/index.php/Forest_Definition"^^xsd:anyURI ;
    dct:spatial "Costa Rica" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Central American country, “forest” is defined for fiscal etc. reasons in the national forest act (Act 3 Ley Forestal No. 7575) as a native ecosystem, with human interventions or not, regenerated through succession or other forest techniques, covering an area of 2 or more hectares, characterized by the presence of mature trees of different ages, species or aspects, with one or more layers covering more than 70% of the surface area and with more than 70 trees per hectare of dbh 15cm or more”"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Costa Rica " ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_698 a skos:Concept ;
    dct:source "http://web.idrc.ca/en/ev-43425-201-1-DO_TOPIC.html"^^xsd:anyURI ;
    dct:spatial "Costa Rica" ;
    skos:broadMatch ex:Forest ;
    skos:definition "The Forestry Law considers as forest any extension of land of two ha or greater with at least 60 trees per hectare"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Costa Rica " ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_699 a skos:Concept ;
    dct:creator "Bosque" ;
    dct:date "1996"^^xsd:gYear ;
    dct:spatial "Costa Rica" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Ecosistema nativo o autoctono, intervenido o no, regenerado por sucesion natural u otras tecnicas forestales, que ocupa una superficie de dos o mas hectareas, caracterizada por la presencia de arboles maduros de diferentes edades, especies y porte variado, con uno o mas doseles que cubran mas del 70% de esa superficie y donde existan mas de sesenta arboles por hectarea de quince o mas centimetros de diametro medido a la altura del pecho (DAP). From the \"Ley Forestal 7575 de Costa Rica de 1996\" \"Eva Muller\" coseform@sol.racsa.co.cr. Variation: Ecosistema nativo o autóctono, intervenido o no, regenerado por sucesión natural u otras técnicas forestales, que ocupa una superficie de dos o más hectáreas, caracterizada por la presencia de árboles maduros de diferentes edades, especies y porte variado, con uno o más doseles que cubran más del setenta por ciento (70%) de esa superficie y donde existan más de setenta árboles por hectárea de quince o más centímetros de diámetro medido a la altura de pecho (DAP). (Ley Forestal No. 7575, Costa Rica ) Christoph Kleinn, CATIE"@es ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Costa Rica 1996 Bosque" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_70 a skos:Concept ;
    skos:broadMatch ex:Forest ;
    skos:definition "A dense growth of trees and underbrush covering a large tract [Source: WWWebster Dictionary]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_700 a skos:Concept ;
    dct:creator "Ecosistema boscoso" ;
    dct:date "1996"^^xsd:gYear ;
    dct:spatial "Costa Rica" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Composicion de plantas y animales diversos, mayores y menores, que interaccionan: nacen, crecen, se reproducen y mueren, dependen unos de otros a lo largo de su vida. Despues de miles de anos, esta composicion ha alcanzado un equilibrio que, de no ser interrumpido, se mantendra indefinidamente y surfrira transformaciones muy lentamente. From the \"Ley Forestal 7575 de Costa Rica de 1996\" \"Eva Muller\" coseform@sol.racsa.co.cr"@es ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Costa Rica 1996 Ecosistema boscoso" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_701 a skos:Concept ;
    dct:creator "?" ;
    dct:date "2003"^^xsd:gYear ;
    dct:source "http://web.idrc.ca/en/ev-43425-201-1-DO_TOPIC.html"^^xsd:anyURI ;
    dct:spatial "Costa Rica" ;
    skos:broadMatch ex:Forest ;
    skos:definition "The Forestry Law defines a forest as an autochthonous native ecosystem, intervened or not, regenerated by natural succession or other forestry techniques, occupying a surface of two or more ha, characterized by the presence of mature trees of different ages, species and size, with one or more canopies covering over 70% of this surface and having more than 60 trees/ha of 15 cm or more in diameter (Art .3"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Costa Rica 2003?" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_702 a skos:Concept ;
    dct:date "2012"^^xsd:gYear ;
    dct:source "http://www.un-redd.org/FRELPublication/tabid/794487/Default.aspx"^^xsd:anyURI ;
    dct:spatial "Costa Rica" ;
    skos:broadMatch ex:Forest ;
    skos:definition "The definition submitted to the CDM (minimum canopy cover of 30%, minimum height of 5 meters, minimum size of 1 hectare) is used as a preliminary definition for its REDD+ program, but Costa Rica has also reserved the right to change the definition and revise its reference level once a final decision is made and adopted"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Costa Rica 2012" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_703 a skos:Concept ;
    dct:date "2014"^^xsd:gYear ;
    dct:source "http://redd.unfccc.int/files/2016_submission_frel_costa_rica.pdf"^^xsd:anyURI,
        "http://theredddesk.org/countries/costa-rica/legal-frameworks"^^xsd:anyURI ;
    dct:spatial "Costa Rica" ;
    skos:broadMatch ex:Forest ;
    skos:definition "According to Costa Rica’s Emissions Reduction Project Idea Note (ER-PIN) for design purposes of the National Forest Inventory and the MRV for REDD+, Costa Rica has used the definition of forest that it uses for CDM projects: “Forest is an area of land with a minimum size of 1.0 ha, with a canopy cover over 30%, and presenting trees with the potential to reach a minimum height of 5 meters at maturity in situ. A forest may consist of tight formations where trees of various strata and undergrowth cover a high proportion of the ground, or open formations with canopy cover over 30%. Young natural stands and all plantations that have not yet reached a canopy cover of 30%, or a height of 5 meters are considered forest”. . the definition of “forest” used in the construction of the proposed FREL is:  Minimum area: 1.00 ha;  Minimum forest canopy cover: 30%;  Minimum height of trees: 5.00 m. This definition is consistent with the definition of “forest” that Costa Rica reported under the Clean Development Mechanism (CDM) and is also consistent with the definition of “forest” used in the context of the national GHG inventory. However, this definition is not consistent with Costa Rica’s reports to FAO’s Forest Resources Assessment (FRA"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Costa Rica 2014" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_704 a skos:Concept ;
    dct:creator "Cote d’Ivoire" ;
    dct:date "1965"^^xsd:gYear ;
    skos:broadMatch ex:Forest ;
    skos:definition "Sont considérées comme forêts les formations végétales dont les fruits exclusifs ou principaux sont les bois d'ébénisterie, d'industrie et de service, les bois de chauffage et à charbon et qui accessoirement peuvent produire d'autres matières telles que bambous, écorces, latex, résines, gommes, graines et fruits. TITRE I DEFINITIONS, Article 1. - LOI NO 65/425 DU 20 DEC 1965. portant Code Forestier"@fr ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Cote d’Ivoire 1965" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_705 a skos:Concept ;
    dct:date "1995"^^xsd:gYear ;
    dct:spatial "Croatia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land coherently stocked with trees, shrubs and ground vegetation, where wood mass is permanently produced, and benefits of general welfare are expressed by ecological (protective) and social forest functions\". (\"Sumarski List\", Hrvatsko Sumarsko Drustvo, Journal of the Forestry Society of Croatia. No 9-10, Godina CXIX, Zagreb, 1995"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Croatia 1995" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_706 a skos:Concept ;
    dct:date "2010"^^xsd:gYear ;
    dct:source "http://www.efi.int/files/attachments/publications/annex_1_to_efi_technical_report_88__2013.pdf"^^xsd:anyURI,
        "http://www.fao.org/docrep/013/al485E/al485e.pdf"^^xsd:anyURI ;
    dct:spatial "Croatia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest is defined as the land covered by forest trees formed as forest stand over an area larger than 10 ars (1 ar = 100 square meters). Separate forest tree groups over an area up to 10 ars, forest nurseries, wind barrier belts, tree avenues, and parks in settlements are not considered forests. and Faculty of forestry University of Zagreb, Ministry for regional development of forestry and water management, 2010"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Croatia 2010" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_707 a skos:Concept ;
    dct:source "http://books.google.com/books?id=iU6ctBak3-gC&pg=PA132&lpg=PA132&dq=Croatia++Forest++definition+define+%22forest+is%22+law&source=bl&ots=yvf2xQpJPr&sig=mQUVqbZLIEa6C88qGsh1mYS9UDY&hl=en&sa=X&ei=SoI6T_26K4Tg0QGAmoHFCw&ved=0CCMQ6AEwAA#v=onepage&q=Croatia%20%20Forest%20%20definition%20define%20%22forest%20is%22%20law&f=false"^^xsd:anyURI ;
    dct:spatial "Croatia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest is defined by Croatian Forest law as land with tree cover occupying areas greater than 0.1 ha"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Croatia" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_708 a skos:Concept ;
    dct:spatial "Cuba" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Bosque: formaciones naturales (bosques naturales) o artificiales (plantaciones) integradas por árboles, arbustos y otras especies de plantas y animales superiores e inferiores, que constituyen un ecosistema de relevancia económica y social por las funciones que desempeña. \"Nelida Puentes Alvarez\" npuentes@eco.upr.edu.cu"@es ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Cuba" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_709 a skos:Concept ;
    dct:date "1992"^^xsd:gYear ;
    dct:spatial "Cyprus" ;
    skos:broadMatch ex:Forest ;
    skos:definition "An area of at least 1 ha covered with forest tree vegetation and crown cover more than 10 percent. A.K. Christou \"Forestry Department - Research and Publicity Sector\" publicity@cytanet.com.cy. Cyprus (open woodland) Forest area with only few trees per ha (that is crown cover about 1-2 percent) (UN/ECE 1992 p. 125"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Cyprus 1992" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_71 a skos:Concept ;
    dct:source "http://www.answers.com/topic/forest"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A dense growth of trees, plants, and underbrush covering a large area"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_710 a skos:Concept ;
    dct:date "2002"^^xsd:gYear ;
    dct:source "http://www.efi.int/files/attachments/publications/annex_1_to_efi_technical_report_88__2013.pdf"^^xsd:anyURI ;
    dct:spatial "Cyprus" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Old definition: Forest Land with tree crown cover of more that 10 % and area of more than 1 ha. Cyprus Department of forests ministry of agriculture, natural resources and environment, 2006. Kyriacou K. 2002"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Cyprus 2002" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_711 a skos:Concept ;
    dct:date "2006"^^xsd:gYear ;
    dct:source "http://www.efi.int/files/attachments/publications/annex_1_to_efi_technical_report_88__2013.pdf"^^xsd:anyURI ;
    dct:spatial "Cyprus" ;
    skos:broadMatch ex:Forest ;
    skos:definition "It corresponds to FRA definition except the threshold value for minimum area, which is 1 ha, with trees higher than 5 m and a crown cover of more than 10%, or trees able to reach these thresholds in situ. Land predominantly under agricultural or urban use not included. Cyprus Department of forests ministry of agriculture, natural resources and environment, 2006. Kyriacou K. 2002"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Cyprus 2006" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_712 a skos:Concept ;
    dct:source "http://books.google.com/books?id=iU6ctBak3-gC&pg=PA142&lpg=PA142&dq=%22For+management+purposes,+State+Forests+are+divided%22&source=bl&ots=yvf2xSmFSt&sig=RmwVGV7UljL1nK9cjAb0NK8VVdY&hl=en&sa=X&ei=QsM6T-mOKaG90QG6zfHdCw&ved=0CCMQ6AEwAA#v=onepage&q=%22For%20management%20purposes%2C%20State%20Forests%20are%20divided%22&f=false"^^xsd:anyURI ;
    dct:spatial "Cyprus" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Spanning more than 0.5 ha with trees higher than 5 m and a crown cover of more than 10%, or trees able to reach these thresholds in situ, Land predominantly under agricultural or urban use not included"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Cyprus" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_713 a skos:Concept ;
    dct:creator "Czech Republic" ;
    dct:date "2004"^^xsd:gYear ;
    dct:source "http://www.efi.int/files/attachments/publications/annex_1_to_efi_technical_report_88__2013.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest land: land with forest stands and land after cutting ready for reforestation, forest line and soft roads of width less than 4 m. Forest roads, water surfaces, land above timber line and other land serving for forest management. Minimum area is 0.01 ha and with a minimum width of 20 m. NIL definition: Forest - areas (subplot), which are forest land as defined in the Forest Act No. 289/95 Coll. § 3, paragraph 1, letter a) and the Ministry of Agriculture Decree No. 84/1996 (which are divided into forest land stand soil and forest-free areas). Are also included in this category sites that have the character of the forest and not defined in the above legislation (e.g. forests on agricultural land). Ustav pro Hospodarskou Upravu Lesu (UHUL), 2004"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Czech Republic 2004" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_715 a skos:Concept ;
    dct:creator "Czech Republic" ;
    dct:source "http://www.metla.fi/eu/cost/e43/minutes/wg1-min-florence.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "National definition, threshold value 20 % crown cover, 400 sq. m. area, minimum height limit, no comparable data available"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Czech Republic" ;
    skos:prefLabel "Forest"@no ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_716 a skos:Concept ;
    dct:creator "Democratic Republic of" ;
    dct:source "http://www.mappingforrights.org/files/Rights%20and%20mapping%20in%20DRC%20%20-%20FINAL.pdf"^^xsd:anyURI ;
    dct:spatial "Congo" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Article 1 defines forest as any land with trees or bushes that can produce forest products, act as home to wildlife or have an effect on climate or soils, or any land that previously had such vegetation on it"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Democratic Republic of Congo" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_717 a skos:Concept ;
    dct:date "2004"^^xsd:gYear ;
    dct:source "http://en.itst.dk/spectrum-equipment/Auctions-and-calls-for-tenders/800-mhz/filarkiv/800MHz%20consultation%20document.pdf"^^xsd:anyURI ;
    dct:spatial "Denmark" ;
    skos:broadMatch ex:Forest ;
    skos:definition "A forest is a tree-grown area which is larger than ½ hectare and is more than 20 metres wide. The trees shall be able to grow to a highstemmed closed forest inside a reasonable timespan, cf. the Danish Nature Agency's guidelines of 1 October 2004 on the Forest Act"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Denmark 2004" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_72 a skos:Concept ;
    dct:source "http://www.bridgingthewatershed.org/glossary.html#d"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A dense growth of trees, together with other plants, covering a large area"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_720 a skos:Concept ;
    dct:spatial "Denmark" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest means areas of 3 ha or more with woody plants which may on the site of growth develop into tall standard (above 6 m). Woody plants also include many-stemmed mountain pine. www.mst.dk/rules/Ministerial%20Orders%20no%20longer%20in%20force/Chemicals%20not%20in%20force/05030500.doc"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Denmark" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_721 a skos:Concept ;
    dct:creator "n Republic" ;
    dct:date "2000"^^xsd:gYear ;
    dct:source "http://www.fao.org/forestry/fo/country/index.jsp?lang_id=1&geo_id=12"^^xsd:anyURI ;
    dct:spatial "Dominica" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Min. Cover = 10 %"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Dominican Republic 2000" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_722 a skos:Concept ;
    dct:date "2013"^^xsd:gYear ;
    dct:source "http://cdm.unfccc.int/DNA/index.html"^^xsd:anyURI,
        "http://redd.unfccc.int/files/submission_frel_ecuador.pdf"^^xsd:anyURI ;
    dct:spatial "Ecuador" ;
    skos:broadMatch ex:Forest ;
    skos:definition "A national forest definition was adopted () in the context of identifying forest land in Ecuador’s land-use maps. According to this definition all land units bearing “a single minimum tree crown cover value of 30%; a single minimum land area value of 1.00 hectare; and, a single minimum tree height value of 5.00 meters” are considered as forest. This definition is consistent with Ministerial Agreement Number 033 of April the 5th, 2013 (MAE, 2013b) and with the definition of forest land used in the national greenhouse gas inventory. This definition differs from the definition applied by FAO’s Global Forest Resources Assessment (FRA 2010"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Ecuador 2013" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_723 a skos:Concept ;
    dct:date "2003"^^xsd:gYear ;
    dct:source "http://www.egyptchm.org/chm/implementation/pdf/arid_lands.pdf"^^xsd:anyURI ;
    dct:spatial "Egypt" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forests include all areas dominated by evergreen or deciduous trees with a canopy cover of greater than 60% and a height exceeding 2 meters. Both broadleaf and needleleaf trees are included"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Egypt 2003" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_724 a skos:Concept ;
    dct:date "2000"^^xsd:gYear ;
    dct:source "http://www.fao.org/forestry/fo/country/index.jsp?lang_id=1&geo_id=62"^^xsd:anyURI ;
    dct:spatial "Eritrea" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest and woodland 10 % canopy closure. Source: ECE-FAO Partnership Programme: Kenya Workshop on Forestry Statistics. Appendix 6 and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Eritrea 2000" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_725 a skos:Concept ;
    dct:date "1998"^^xsd:gYear ;
    dct:source "http://www.keskkonnainfo.ee/publications/16285_PDF.pdf"^^xsd:anyURI ;
    dct:spatial "Estonia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest Act (FA) (1998) forest is defined as a site of woody vegetation with an area of at least 0,5 ha which meets at least one of the following criteria: 1) the height of the trees is at least 1,3 m and the canopy density at least 30 per cent; 2) it is managed for obtaining timber or other forest produce, or woody vegetation is maintained there for the use in the ways specified in this Act"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Estonia 1998" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_726 a skos:Concept ;
    dct:date "2007"^^xsd:gYear ;
    dct:source "http://stud.epsilon.slu.se/1798/1/Link_M_100910.pdf"^^xsd:anyURI ;
    dct:spatial "Estonia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "According to the act, forest land is land listed in the land register as forest and or land of at least 0.1 hectares where woody plants with a height of at least 1.3 m and with crown closure of at least 30% grow (Forest Act, 2007"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Estonia 2007" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_729 a skos:Concept ;
    dct:date "2010"^^xsd:gYear ;
    dct:source "http://www.efi.int/files/attachments/publications/annex_1_to_efi_technical_report_88__2013.pdf"^^xsd:anyURI ;
    dct:spatial "Estonia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest land (reference definition, applied parallel with National definition since 2005) Land with tree crown cover (or equivalent stocking level) of more than 10% and area of more than 0.5 ha. The trees should be able to reach a minimum height of 5 m at maturity in situ (incl. temporarily unstocked areas). Pärt E., Adermann V., Merenäk M., 2010"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Estonia 2010" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_73 a skos:Concept ;
    dct:source "http://www.dorsetcoppicegroup.co.uk/resources/Dorset_Coppice_Group_Glossary.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A densely wooded area"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_730 a skos:Concept ;
    dct:spatial "Estonia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Collection of trees which density is at least 30% and growing stock is more than 30 cubic metres per hectare. Forest Survey Centre From: \"Sulev Svilponis\" Sulev@ekm.envir.ee . Definitions are unofficial translations"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Estonia" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_731 a skos:Concept ;
    dct:source "http://www.fris.sk/Phare/Projects/ManagementOfForestInEurope/PDF/annex2.pdf"^^xsd:anyURI ;
    dct:spatial "Estonia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "forest land with vegetation growing on it and with wildlife living in it. The lower area limit is 0.5 ha"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Estonia" ;
    skos:prefLabel "Forest"@no ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_732 a skos:Concept ;
    dct:date "2013"^^xsd:gYear ;
    dct:source "http://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:32013D0529"^^xsd:anyURI ;
    dct:spatial "Estonia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Area (ha) 0.5; Tree crown cover (%) 30; Tree height (m) 2"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Estonia 2013" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_733 a skos:Concept ;
    dct:date "1994"^^xsd:gYear ;
    dct:source "http://cdm.unfccc.int/filestorage/L/4/Q/L4QB30W8C5RYZMT6UKOFX1PV9GNIHS/Annex%205%20Legal%20aspects.pdf?t=OXR8bHpqZnlvfDByMiF2MIecUaf9gjv8IjJT"^^xsd:anyURI ;
    dct:spatial "Ethiopia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "The Forestry Conservation, Development and Utilization Proclamation. was issued at the Federal level in 1994 (Proclamation No.94/1994). The term.forest. is defined as ..a community of plants either naturally grown or developed by planting and in many respects are trees and other plants having a woody character. (Art.2.3). Forests are thus defined into natural forests (e.g. naturally growing indigenous trees) and forests established by planting (e.g. afforestation or reforestation). The definition given to .forest. and .trees. in the SNNPRS Forestry Proclamation is similar to that given in the Federal Proclamation (Arts.2.3 and 2.8 of Proclamation No.77/2004"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Ethiopia 1994" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_734 a skos:Concept ;
    dct:date "1998"^^xsd:gYear ;
    dct:source "http://www.fao.org/docrep/003/X6684E/X6684E10.htm#P2311_178011"^^xsd:anyURI ;
    dct:spatial "Ethiopia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Natural high forest. Min. av. height 7 m. Canopy closure 68%. Source: ECE-FAO Partnership Programme: Kenya Workshop on Forestry Statistics. Appendix 6"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Ethiopia 1998" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_735 a skos:Concept ;
    dct:date "2007"^^xsd:gYear ;
    dct:source "http://www.pfmp-farmsos.org/Docs/forest%20proclamation_english.pdf"^^xsd:anyURI ;
    dct:spatial "Ethiopia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"forest\" means a community of plants, either naturally grown or developed by planting and mainly consisting of trees and other plants having woody character"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Ethiopia 2007" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_736 a skos:Concept ;
    dct:date "2015"^^xsd:gYear ;
    dct:source "http://redd.unfccc.int/files/2016_submission_frel_ethiopia.pdf"^^xsd:anyURI ;
    dct:spatial "Ethiopia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "In February 2015 Ethiopia adopted a new forest definition as follows: 'Land spanning at least 0.5 ha covered by trees and bamboo ), attaining a height of at least 2m and a canopy cover of at least 20% or trees with the potential to reach these thresholds in situ in due course’ (Minutes of Forest sector management, MEFCC, Feb. 2015 (UNFCCC-Ethiopia, 2016"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Ethiopia 2015" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_737 a skos:Concept ;
    dct:date "2017"^^xsd:gYear ;
    dct:source "http://redd.unfccc.int/files/ethiopia_frel_3.2_final_modified_submission.pdf"^^xsd:anyURI ;
    dct:spatial "Ethiopia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "In February 2015 Ethiopia adopted a new forest definition (MEF 2015) as follows: 'Land spanning more than 0.5 ha covered by trees (including bamboo) (with a minimum width of 20m or not more than two‐thirds of its length) attaining a height of more than 2m and a canopy cover of more than 20% or trees with the potential to reach these thresholds in situ in due course (Minutes of Forest sector management, MEFCC, Feb. 2015). Ethiopia is in the process of approving this as its national legal definition"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Ethiopia 2017" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_738 a skos:Concept ;
    dct:date "1992"^^xsd:gYear ;
    dct:spatial "Fiji" ;
    skos:broadMatch ex:Forest ;
    skos:definition "In the National Forest Inventory (1991-1992) on a scale of 1:50,000 the minimum forested area shows on the map is 4 ha. There is no legal definition of what a forest is, although it is classified into three: Dense forest - Crown density by trees and/or ferns 75-100% and grown coverage of grass, palm and /or bamboo 0-25%. Medium dense - Crown density by trees and/or ferns 45-80% and ground coverage by grass, palm and/or bamboo 20-55%. Scattered forest (including scattered coconut stands), dens bushland (thickets) with single trees - crown density by trees and/or ferns 15-50% and ground coverage by grass, palm and/or bamboo 50-80%. Malakai Sevudredre, Conservator of Forests, F.9641/2. 01/06/2000"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Fiji 1992" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_739 a skos:Concept ;
    dct:date "2007"^^xsd:gYear ;
    dct:source "http://geodata.rrcap.unep.org/all_reports/PECCO_Draft_30dec2010.docx"^^xsd:anyURI ;
    dct:spatial "Fiji" ;
    skos:broadMatch ex:Forest ;
    skos:definition "The re-defined threshold for forest is from 4 hectares in the 1991 NFI down to 0.5 hectares in the 2007 NFI"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Fiji 2007" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_74 a skos:Concept ;
    dct:source "http://mojavedesert.net/glossary/forest.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A diverse community of plants and animals in which trees are the most conspicuous members"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_740 a skos:Concept ;
    dct:date "2010"^^xsd:gYear ;
    dct:source "http://www.cbd.int/doc/world/fj/fj-nr-04-en.pdf"^^xsd:anyURI ;
    dct:spatial "Fiji" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest Densities: 1. dense forest: crown density by trees and/ or ferns 75-100% and round coverage by grass, palm and/ or bamboo 0-25% 2. medium dense forest: crown density by trees and/ or ferns 45-80% and ground coverage by grass, palm and/ or bamboo 20-55% 3. scattered forest: shrub forest (including scattered coconut stands), dense bushland (thickets) with single trees. Crown density by trees and/or ferns 15-50% and ground coverage by grass, palm and/ or bamboo 50-85%"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Fiji 2010" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_741 a skos:Concept ;
    dct:date "2015"^^xsd:gYear ;
    dct:source "http://www.parliament.gov.fj/wp-content/uploads/2017/03/Bill-No-13-Forest.pdf"^^xsd:anyURI ;
    dct:spatial "Fiji" ;
    skos:broadMatch ex:Forest ;
    skos:definition "“natural forest” means a forest composed of indigenous trees and not classified as forest plantation"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Fiji 2015" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_743 a skos:Concept ;
    dct:creator "Former USSR" ;
    dct:date "1992"^^xsd:gYear ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land bearing stands of the main forest-forming species as well as forest plantations, nurseries, and the like. Forests do not include roads or other land not subject to afforestation. …Other wooded land includes scrub and plantation in which trees are rare. This category also conventionally includes clearings, burnt areas, and glades subject to stocking in the future…. (UN/ECE 1992 p. 275"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Former USSR 1992" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_744 a skos:Concept ;
    dct:date "1992"^^xsd:gYear ;
    dct:spatial "France" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest greater than or equal to 4 ha. (UN/ECE 1992 p. 156"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "France 1992" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_745 a skos:Concept ;
    dct:date "1997"^^xsd:gYear ;
    dct:spatial "France" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Identified from aerial photos, from ocular estimates. Lands with either measured trees (diameter 7.5 cm) have a crown cover percentage reaching at least 10% (ground projection of crowns) - or there are more than 500 stems per ha that are viable trees (able to make a stand): seedlings, plants or shoots, vigorous, well shaped and regularly distributed. Cover at least 5 acres, the average width of canopy being at least 15 m. Rest of definition appears to include orchards. (European Communities 1997a - p. 254-255). Forest also includes poplar stands of between 0.05 and 0.5 ha. UN/ECE 2000 p 77"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "France 1997" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_746 a skos:Concept ;
    dct:date "2005"^^xsd:gYear ;
    dct:source "http://icaci.org/documents/ICC_proceedings/ICC2011/Oral%20Presentations%20PDF/A3-Data%20integration/CO-028.pdf"^^xsd:anyURI ;
    dct:spatial "France" ;
    skos:broadMatch ex:Forest ;
    skos:definition "According to the national forest definition the minimum forest area is 0.05 ha, with the canopy cover of 10% , minimum height of tree 5-7 m and the minimum width of strip 25 m.(FRA,2005"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "France 2005" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_749 a skos:Concept ;
    dct:date "2010"^^xsd:gYear ;
    dct:source "http://www.efi.int/files/attachments/publications/annex_1_to_efi_technical_report_88__2013.pdf"^^xsd:anyURI ;
    dct:spatial "France" ;
    skos:broadMatch ex:Forest ;
    skos:definition "A forest is defined as land with tree crown cover of more than 10%, an area of more than 0.5 ha and an average width of more than 20 m. Trees should be able to reach a minimum height of 5 m at maturity in situ.Institute National de l’Information Geographique et Forestiere, 2010"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "France 2010" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_75 a skos:Concept ;
    dct:source "http://members.tripod.com/~nefpc/clearcut.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A diverse mix of trees and herbaceous plants, a home to wildlife, and a sanctuary for the spirit"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_750 a skos:Concept ;
    dct:date "2000"^^xsd:gYear ;
    dct:source "http://www.fao.org/forestry/fo/country/index.jsp?lang_id=1&geo_id=112"^^xsd:anyURI ;
    dct:spatial "French Polynesia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Includes natural forest and forest plantations but excluding cocco plantations"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "French Polynesia 2000" ;
    skos:prefLabel "Forest"@no ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_751 a skos:Concept ;
    dct:date "2001"^^xsd:gYear ;
    dct:source "http://books.google.com/books?id=KDcRI1Nj9n0C&pg=PA31&lpg=PA31&dq=Gabon+forest+definition+define+%22forest+is%22+law,+code,+act&source=bl&ots=KcKcJElGQp&sig=VXqWDovWVaNhzxlOslyQu7G0HME&hl=en&sa=X&ei=mbE-T-C9JYXu0gGrv83MCA&ved=0CCMQ6AEwAA#v=onepage&q=Gabon%20forest%20definition%20define%20%22forest%20is%22%20law%2C%20code%2C%20act&f=false"^^xsd:anyURI ;
    dct:spatial "Gabon" ;
    skos:broadMatch ex:Forest ;
    skos:definition "An area with a plant cover that provides wood and nonagricultural plant products and which shelters wildlife and directly or indirectly affects the soil, climate or water supply"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Gabon 2001" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_752 a skos:Concept ;
    dct:spatial "Gambia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "A land area with at least 10% tree cover, naturally grown or planted, and or 50% or more shrub and tree generation cover and includes government forest parks, community forests and protected forests irrespective of their tree and shrub cover;..... Source: Danso A. A. Forestry Department forestry.dept@gamtel.gm"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Gambia" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_753 a skos:Concept ;
    dct:source "http://books.google.com/books?id=dZh6-ekpSawC&pg=PA104&lpg=PA104&dq=Ethiopia+Forest+definition+define+%22forest+is%22+law+act&source=bl&ots=Wx8pSUKv7a&sig=I5dj10rusCk4zljYh9dOAZi5Vgw&hl=en&sa=X&ei=jC8-T9mtFqHz0gH49OCpBw&ved=0CCMQ6AEwAA#v=onepage&q=Ethiopia%20Forest%20definition%20define%20%22forest%20is%22%20law%20act&f=false"^^xsd:anyURI ;
    dct:spatial "Gambia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "all lands at leas10 % tree cover and 50% vegetative cover"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Gambia" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_754 a skos:Concept ;
    dct:date "1998"^^xsd:gYear ;
    dct:source "http://extwprlegs1.fao.org/docs/pdf/gam19052.pdf"^^xsd:anyURI ;
    dct:spatial "Gambia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"Forest\" means a land area with at least 10% tree cover, naturally grown or planted, and or 50% or more shrub and tree regeneration cover and includes Government forest parks, community forests and protected forests irrespective of their tree and shrub cover; provided that vegetation on fallow land is not a forest except as specified in section 5 of this Act"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Gambia1998" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_755 a skos:Concept ;
    dct:date "1999"^^xsd:gYear ;
    dct:spatial "Georgia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "A part of geographical landscape, comprising attributed to forest by Georgian legislation, land under these trees, as well as shrubs, grass, animals and other components biologically linked in the process of their development, affecting each other and the environment. Source: Forest Code (June, 1999) Kate Metreveli, Head of the WB Forestry, Project Preparation Unit. kattimet@geo.net.ge"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Georgia 1999" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_756 a skos:Concept ;
    dct:date "1999"^^xsd:gYear ;
    dct:source "http://www.efi.int/files/attachments/publications/annex_1_to_efi_technical_report_88__2013.pdf"^^xsd:anyURI ;
    dct:spatial "Georgia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "The integrity of state forest, land and other resources defined as SFF by the Georgian legislation (Forest Code of Georgia, 1999). Includes the land categories listed below: Forest: Part of geographic landscape, which includes the unity of trees (defined by the Georgian legislation as parts of forests), lands, bushes, grasses, animals and other objects, which are biologically inter-related and have an impact upon each other as well as environment. Forest lands: Open plantations, nurseries, clear-cut areas, fire damaged and dead stands, 0.1 ha and larger fields and forest farm yards. (President of Georgia, 1999"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Georgia 1999" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_757 a skos:Concept ;
    dct:date "2008"^^xsd:gYear ;
    dct:source "http://www.unece.org/fileadmin/DAM/env/pp/compliance/C2009-35/Communication/Annex_1_ACCCC200835_GeorgianForestCode.doc"^^xsd:anyURI ;
    dct:spatial "Georgia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "a part of geographical landscape, comprising trees attributed to forest by Georgian legislation, land under these trees, as well as shrubs, grass, animals, and other components biologically linked in the process of their development, affecting each other and the environment"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Georgia 2008" ;
    skos:prefLabel "- Forest"@no ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_758 a skos:Concept ;
    dct:date "2010"^^xsd:gYear ;
    dct:source "http://www.efi.int/files/attachments/publications/annex_1_to_efi_technical_report_88__2013.pdf"^^xsd:anyURI ;
    dct:spatial "Georgia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "A forest is defined as land with tree crown cover of more than 10%, an area of more than 0.5 ha and an average width of more than 20 m. Trees should be able to reach a minimum height of 5 m at maturity in situ. FAO, 2010"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Georgia 2010" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_759 a skos:Concept ;
    dct:date "1975"^^xsd:gYear ;
    dct:source "http://www.fao.org/legal/legstud/ls88/ls88e.pdf"^^xsd:anyURI ;
    dct:spatial "Germany" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forests are all tracts of land where forest trees grow, including functionally related parts (e.g. clearings and openings, forest roads"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Germany 1975" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_76 a skos:Concept ;
    dct:creator "also called a wood, woodland, wold, weald, holt, frith, or firth" ;
    skos:broadMatch ex:Forest ;
    skos:definition "A forest is an area with a high density of trees"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "also called a wood, woodland, wold, weald, holt, frith, or firth" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_760 a skos:Concept ;
    dct:date "1999"^^xsd:gYear ;
    dct:spatial "Ghana" ;
    skos:broadMatch ex:Forest ;
    skos:definition "A large area of land thickly covered with trees, bushes, shrubs and thickets. (Osei Kofi, Forestry Dept.- Letter 7 May 99"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Ghana 1999" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_761 a skos:Concept ;
    dct:creator "?" ;
    dct:date "2006"^^xsd:gYear ;
    dct:source "https://cdm.unfccc.int/DNA/DNA/allCountriesARInfos.html"^^xsd:anyURI ;
    dct:spatial "Ghana" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Canopy = 15%; Area = 0.1 ha; Tree height = 5 m"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Ghana 2006?" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_762 a skos:Concept ;
    dct:date "1945"^^xsd:gYear ;
    dct:source "http://lambda.qsensei.com/content/b7spn"^^xsd:anyURI ;
    dct:spatial "Greece" ;
    skos:broadMatch ex:Forest ;
    skos:definition "All land which has been forest or areas of equal ecological value with forest vegetation (like areas with wild bushes and sporadic trees with a density of their canopy ground projection larger than 25% of the area), as of 1945, is characterized as “forest” and is protected by the Law. Potsiou, Chryssy A.; Dimitriadi, Katerina. 2008. Tools for Legal Integration and Regeneration of Informal Development in Greece: A Research Study in the Municipality of Keratea. Surveying and Land Information Science 68(2): 103-118"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Greece 1945" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_763 a skos:Concept ;
    dct:date "2000"^^xsd:gYear ;
    dct:spatial "Greece" ;
    skos:broadMatch ex:Forest ;
    skos:definition "FRA 2000. Land with tree crown cover (or equivalent stocking level) of more than 10%and area of more than 0.5 ha. The trees should be able to reach a minimum height of 5 meters (m) at maturity in situ. FOREST EUROPE, UNECE AND FAO, 2011"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Greece 2000" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_764 a skos:Concept ;
    dct:date "2002"^^xsd:gYear ;
    dct:source "http://www.ymparisto.fi/download.asp?contentid=25582&lan=en"^^xsd:anyURI ;
    dct:spatial "Greece" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Greece’s national definition of forest (an area of at least 0.5 ha or a strip of land 30 m wide with at least 10% tree coverage and forest type vegetation"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Greece 2002" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_765 a skos:Concept ;
    dct:date "2003"^^xsd:gYear ;
    dct:source "http://tempus.marstu.net/presentations/mouflis1(eng)_s2.pdf"^^xsd:anyURI ;
    dct:spatial "Greece" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest is defined as an area made up of wild trees species creating a canopy with a crown density >25%. Forestland is defined as an area made up of wild woody vegetation (scattered trees, shrubs, or open land within forests and open land above tree line) with > 25% vegetation. There is a controversy over the threshold percent cover to characterize as forest or forest land (protection afforded by law) as formerly 15 % was used. Law 86/1969: “Forest Code”. Law 998/1979, 3208/2003.. Mouflis, George et al. n.d. Session 1: Vegetation, bioclimatic zones, forest service and forest management in Greece. Training, Networking and capacity building for Sustainable forest in Povolgie. Aristotle University of Thessaloniki. 48 slides"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Greece 2003" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_766 a skos:Concept ;
    dct:date "2006"^^xsd:gYear ;
    dct:source "http://www.ec-gis.org/Workshops/12ec-gis/presentations/Plenary%20room/THU_Nat_SDI_2/palaskas.pdf"^^xsd:anyURI ;
    dct:spatial "Greece" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest –forest area: (Greek Constitution )The organic group of wild plants with wooded stem which form (with in site living flora and fauna) a special biocommunityand environment. Forest area if wooded vegetation is sparse (recent quantitative criteria L.3208/03: 25% cover, height of vegetation, species). Palaskas, Dimitrios Sp; Stamou, Nikolaos I. 2006. Social and economic benefits from compiling the Forest Data Bank Project (Dasologio) in Greece. 12th EC GI & GIS Workshop -Innsbruck, June 21-23 2006. 20 slides"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Greece 2006" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_767 a skos:Concept ;
    dct:date "2006"^^xsd:gYear ;
    dct:source "http://www.isprs.org/proceedings/XXXVI/4-C42/Papers/13_Automated%20classification%20IC%20I%20-%20Forest/OBIA2006_Mallinis_et_al.pdf"^^xsd:anyURI ;
    dct:spatial "Greece" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Specifically in order for a patch to be characterized as “forest” or “woodland”, its size should exceed 0,3 hectares or unless so, it should be at least 30 meters wide or in close interdependence and interaction with other forest areas. Furthermore the forest canopy cover should exceed 30 percent. The distinction among the two categories is based on criteria relating to the existence of stratums of forest canopy and the canopy cover of each layer. In general woodlands correspond mainly to areas covered with a discontinuous tree layer, shrubs and herbaceous vegetation. Mallinis,G. et al. 2006? An object oriented approach for the discrimination of forest areas under the criteria of forest legislation in Greece using very high resolution data. The International Archives of the Photogrammetry, Remote Sensing and Spatial Information Sciences, Vol. 34, Part XXX"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Greece 2006" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_769 a skos:Concept ;
    dct:date "2011"^^xsd:gYear ;
    dct:spatial "Greece" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land with tree crown cover (or equivalent stocking level) of more than 10%and area of more than 0.5 ha. The trees should be able to reach a minimum height of 5 meters (m) at maturity in situ. FOREST EUROPE, UNECE AND FAO, 2011"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Greece 2011" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_77 a skos:Concept ;
    dct:source "http://www.zamsoc.org/wp-content/uploads/2012/02/Dry-Forests-Report-Full-document.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A forest has a canopy of trees whose crowns interlock at 10 m or higher, with variable lower layers"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_770 a skos:Concept ;
    dct:date "2012"^^xsd:gYear ;
    dct:spatial "Greece" ;
    skos:broadMatch ex:Forest ;
    skos:definition "A forest is an area where wild trees with wooden trunk exist and forest lands where wild plants with hard branches like bushes, low or tall, even rocky areas that are surrounded by areas with such vegetation. Any piece of land if not cultivated can become a forest land. Chryssy Potsiou . chryssyp@survey.ntua.gr 5 Feb. 2012"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Greece 2012" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_771 a skos:Concept ;
    dct:source "http://www.lasy.gov.pl/dokumenty/in_english/files/forest_and_forestry_in_eu-pdf/at_download/file"^^xsd:anyURI ;
    dct:spatial "Greece" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest is defined as land with tree crown cover (stand density) of more than about 20% of the area, and with trees which usually grow to more than about 7 m in height and are able to produce wood. This includes both, closed forest formations where trees of various storeys and undergrowth cover a high proportion of the ground, and open forest formations with a continuous grass layer in which tree synusia cover at least 10% of the ground"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Greece" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_772 a skos:Concept ;
    dct:source "http://bookshop.europa.eu/is-bin/INTERSHOP.enfinity/WFS/EU-Bookshop-Site/en_GB/-/EUR/ViewPDFFile-OpenPDFFile?FileName=LBNA24300ENC_002.pdf&SKU=LBNA24300ENC_PDF"^^xsd:anyURI ;
    dct:spatial "Greece" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forests are characterised by forest trees (high and coppice forests) that produce or are able to produce at least 1 m3 of commercial timber per hectare per year"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Greece" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_773 a skos:Concept ;
    dct:date "1996"^^xsd:gYear ;
    dct:spatial "Guatemala" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Native or autochthon ecosystem, intervened or not, regenerated through natural succession or other forestry mechanisms, that does occupy an area greater than 2 ha, characterized by the presence of mature trees of different ages, species and appearance, with one or more layers. \"Ecosistema en donde los árboles son las especies dominantes y permanentes\"(Ley Forestal, Decreto 101-96, capitulo II: Art. 4"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Guatemala 1996" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_774 a skos:Concept ;
    dct:creator "Guatemla - ?" ;
    dct:date "2007"^^xsd:gYear ;
    dct:source "https://cdm.unfccc.int/DNA/DNA/allCountriesARInfos.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Cover = 30%; Area = 0.5 ha; Tree height = 5 m"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Guatemla - 2007?" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_775 a skos:Concept ;
    dct:creator "Bissau" ;
    dct:date "2000"^^xsd:gYear ;
    dct:source "http://www.fao.org/forestry/fo/country/index.jsp?lang_id=1&geo_id=67"^^xsd:anyURI ;
    dct:spatial "Guinea" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Min. crown cover = 10 %"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Guinea Bissau 2000" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_776 a skos:Concept ;
    dct:date "2009"^^xsd:gYear ;
    dct:source "https://www.forestry.gov.gy/wp-content/uploads/2016/07/Forests-Act-2009.pdf"^^xsd:anyURI ;
    dct:spatial "Guyana" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest means an ecosystem dominated by woody plants, consisting of closed forest formations, where trees of various stories sand undergrowth cover a high proportion of the ground; or open forest with continuous vegetation cover in which tree crown cover exceeds 10 percent and includes mangrove forest and any wetlands or open lands within a forest which form an integral part of the ecosystem; forest produce in the ecosystem; and biological, soil and water resources of the ecosystem"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Guyana 2009" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_777 a skos:Concept ;
    dct:date "2015"^^xsd:gYear ;
    dct:source "http://redd.unfccc.int/files/guyanas_proposal_for_reference_level_for_redd__-_final_sept_2015.pdf"^^xsd:anyURI ;
    dct:spatial "Guyana" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Guyana has elected to classify land as forest if it meets the following criteria: • Tree cover of minimum 30% • Minimum height of 5 m • Minimum area of 1 ha. .It was recommended that based on Guyana’s forest characteristics, where there is largely undisturbed primary forest and the remaining being sustainably managed forests, where trees are predominantly 5 m in height, the minimum threshold for this variable is recommended to be 5m. From a monitoring perspective. The use of the upper limit (5m) would require the lowest transaction cost with no added value of going down to 2m"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Guyana 2015" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_778 a skos:Concept ;
    dct:spatial "Honduras" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Terrenos que sostienen una asociación vegetal dominada por árboles o arbustos de cualquier tamaño ya sea que crezcan espontáneamente o que procedan de siembra o plantación, que fueren capaces de producir madera, leña u otros productos forestales, de ejercer influencia sobre el clima, suelos, sobre el régimen de aguas o sobre el medio ambiente en general, o de proveer refugio al ganado y la vida silvestre. (Reglamento General Forestal Titulo I, Capítulo I, Art. 1"@es ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Honduras" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_779 a skos:Concept ;
    dct:date "2006"^^xsd:gYear ;
    dct:source "http://www.efi.int/files/attachments/publications/annex_1_to_efi_technical_report_88__2013.pdf"^^xsd:anyURI ;
    dct:spatial "Hungary" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Definition: Forest should be consisted more than 50% of the tree species (listed in the Forest Act) and forest cover is more than 30%. Mezőgazdasági Szakigazgatási Hivatal (MGSZH), 2006"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Hungary 2006" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_78 a skos:Concept ;
    skos:broadMatch ex:Forest ;
    skos:definition "A forest is a dense growth of trees, together with other plants, covering a large area of land. The science concerned with the study, preservation, and management of forests is forestry"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_780 a skos:Concept ;
    dct:creator "NRI" ;
    dct:date "2009"^^xsd:gYear ;
    dct:source "http://afoludata.jrc.ec.europa.eu/metaed/project_collection/JRC_54744_Mascaref_Full_Report_for_print.pdf"^^xsd:anyURI ;
    dct:spatial "Hungary" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Crown cover > 30%, tree height > 5m, area > 0.5 ha"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Hungary 2009 NRI" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_781 a skos:Concept ;
    dct:source "http://www.fao.org/forestry/foris/webview/forestry2/index.jsp?siteId=5081&sitetreeId=18927&langId=1&geoId=0"^^xsd:anyURI ;
    dct:spatial "Hungary" ;
    skos:broadMatch ex:Forest ;
    skos:definition "By law forest means area covered by woody vegetation with area bigger than 0,15 ha. Other wooded lands not included can be only row of trees, alleys, etc. having no adequate system (ortho-photos, software, etc.) its quantity can be only wrong estimated"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Hungary" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_782 a skos:Concept ;
    dct:source "http://www.metla.fi/eu/cost/e43/minutes/wg1-min-florence.pdf"^^xsd:anyURI ;
    dct:spatial "Hungary" ;
    skos:broadMatch ex:Forest ;
    skos:definition "National definition based on limited species list & canopy cover limit (15 %), information for other land uses available"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Hungary" ;
    skos:prefLabel "Forest"@no ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_783 a skos:Concept ;
    dct:date "2011"^^xsd:gYear ;
    dct:source "http://www.efi.int/files/attachments/publications/annex_1_to_efi_technical_report_88__2013.pdf"^^xsd:anyURI ;
    dct:spatial "Iceland" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest area is a land with a minimum area of 0.5 ha, with a minimum 10% crown cover, and minimum height of trees of 5 m at maturity in situ. FOREST EUROPE, UNECE and FAO 2011"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Iceland 2011" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_784 a skos:Concept ;
    dct:date "2011"^^xsd:gYear ;
    dct:source "http://www.efi.int/files/attachments/publications/annex_1_to_efi_technical_report_88__2013.pdf"^^xsd:anyURI ;
    dct:spatial "Iceland" ;
    skos:broadMatch ex:Forest ;
    skos:definition "National definition: areas with trees higher than 2 m and 10% crown cover are defined as forests in Iceland"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Iceland 2011" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_785 a skos:Concept ;
    dct:creator "1865" ;
    dct:source "http://www.mtnforum.org/sites/default/files/pub/4946.pdf"^^xsd:anyURI ;
    dct:spatial "India" ;
    skos:broadMatch ex:Forest ;
    skos:definition "forest was first defined in the Indian Forest Act, 1865 as “land covered with trees, brushwood and jungle,”"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "India 1865" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_786 a skos:Concept ;
    dct:date "1996"^^xsd:gYear ;
    dct:source "http://iasc2008.glos.ac.uk/conference%20papers/papers/P/Patnaik_130901.pdf"^^xsd:anyURI ;
    dct:spatial "India" ;
    skos:broadMatch ex:Forest ;
    skos:definition "An extensive are covered by trees and bushes with no agriculture"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "India 1996" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_787 a skos:Concept ;
    dct:date "2003"^^xsd:gYear ;
    dct:source "http://www.itto.int/direct/topics/topics_pdf_download/topics_id=39100000&no=1&disp=inline"^^xsd:anyURI ;
    dct:spatial "India" ;
    skos:broadMatch ex:Forest ;
    skos:definition "The 2003 forest cover analysis by the Forest Survey of India using satellite data, including forests of a defined area of more than 1 ha and 10% of tree canopy cover"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "India 2003" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_788 a skos:Concept ;
    dct:date "2006"^^xsd:gYear ;
    dct:source "http://www.mtnforum.org/sites/default/files/pub/4946.pdf"^^xsd:anyURI ;
    dct:spatial "India" ;
    skos:broadMatch ex:Forest ;
    skos:definition "The Act has defined forest land as land of any description falling within any forest area and includes most types of forests. The Scheduled Tribes and Other Traditional Forest Dwellers (Recognition of Forest Rights) Act, 2006"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "India 2006" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_789 a skos:Concept ;
    dct:date "2008"^^xsd:gYear ;
    dct:source "http://mospi.nic.in/mospi_new/upload/nad10_2008_karnataka_final.pdf"^^xsd:anyURI ;
    dct:spatial "India" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest cover consists of all lands having tree canopy density of more than 10 percent that can be interpreted from satellite data. The resolution and limitations of the sensor are crucial in estimation of area under forest cover"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "India 2008" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_79 a skos:Concept ;
    dct:source "http://www.planetpals.com/habitats.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A forest is an area with a high density of trees. Forests are also referred to as:a wood, woodland, wold, weald, holt, and firth"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_790 a skos:Concept ;
    dct:date "2017"^^xsd:gYear ;
    dct:source "https://scroll.in/article/868606/hold-the-celebrations-marginal-increase-in-indias-forest-cover-is-masking-massive-deforestation"^^xsd:anyURI ;
    dct:spatial "India" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest cover- any area more than one hectare in size that has more than 10% green canopy. Apart from traditional or natural forests that meet the criteria, this definition also includes plantations like tea and coffee gardens as well as orchards. The report classifies forest cover into three categories on the basis of their density measured in terms of canopy cover – the percentage of green cover on land as seen from satellite images. Dense forests are those where the canopy cover is 70% or more, moderately dense forests where the canopy cover is between 70% and 40%, and open forests where the canopy cover is between 40% and 10%. The remaining land is either classified as scrub land – forests that have degraded to less than 10% canopy cover – or non-forest lands, which do not have green cover at all"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "India 2017" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_791 a skos:Concept ;
    dct:source "http://sudiv.gov.in/PDFFiles%5CNSR%5CNational%20Status%20Report%20(ITTO)%20-%2023.9.06%5CCompiled%20Report%5CCompiled%20report%20_F_.pdf"^^xsd:anyURI ;
    dct:spatial "India" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest Cover is defined as an area more than 1 ha in extent and having tree canopy density of 10 percent and above. This definition is based on the resolution of digital satellite data (pixel size 23.5m X 23.5m), scale of interpretation (1:50,000) and the technique used for image processing"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "India" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_792 a skos:Concept ;
    dct:source "http://www.thestatesman.net/index.php?option=com_content&view=article&id=382252&catid=52"^^xsd:anyURI ;
    dct:spatial "India" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest land is one with standing trees"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "India" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_793 a skos:Concept ;
    dct:date "1998"^^xsd:gYear ;
    dct:source "http://europe.mtnforum.org/rs/econfreports/MountainPeopleForestsAndTrees.pdf"^^xsd:anyURI ;
    dct:spatial "Indonesia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "an area growing trees which as a whole forms a living natural community and a natural living environment, which is designated by the government as being a forest\" (Nico Smith 1999"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Indonesia 1998" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_794 a skos:Concept ;
    dct:date "2002"^^xsd:gYear ;
    dct:source "http://www.freewebs.com/irwantoforester/definition2.html"^^xsd:anyURI,
        "http://www.globalforestwatch.org/common/indonesia/sof.indonesia.english.low.pdf"^^xsd:anyURI ;
    dct:spatial "Indonesia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land on which trees form the dominant vegetation type. The Indonesian government uses a land use definition of forest in the various land use classes that comprise “Permanent Forest Status” (see below). However, up to 20 percent of Permanent Forest Status land has been deforested. and SaveForest. n.d..Definitions"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Indonesia 2002" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_795 a skos:Concept ;
    dct:source "http://www2.bonet.co.id/dephut/41-99-1.htm"^^xsd:anyURI ;
    dct:spatial "Indonesia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "A unit of ecosystem in the form of lands comprising biological resources, dominated by trees in their natural forms and environment, which can not be separated each other"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Indonesia" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_796 a skos:Concept ;
    dct:date "2004"^^xsd:gYear ;
    dct:source "http://redd.unfccc.int/files/national_frel_for_redd__in_indonesia_2015.pdf"^^xsd:anyURI ;
    dct:spatial "Indonesia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "As a formal right, forest in this document is defined as “Land spanning more than 0.25 hectares with trees higher than 5 meters at maturity and a canopy cover of more than 30 percent, or trees able to reach these thresholds in situ”. This is the definition of forest stated in the Minister of Forestry Decree No 14/2004 on A/R CDM (MoFor, 2004). The definition of forest used in the MoFor decree was established to meet the requirement of climate change mitigation scheme under CDM and thus relevant to be used in FREL construction. This definition was used by the Ministry of Forestry for the purpose of ground-truthing in order to support satellite image classification"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Indonesia 2004" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_797 a skos:Concept ;
    dct:date "2015"^^xsd:gYear ;
    dct:source "http://redd.unfccc.int/files/national_frel_for_redd__in_indonesia_2015.pdf"^^xsd:anyURI ;
    dct:spatial "Indonesia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "In this document, the term “working definition” of forest was used to produce land-cover maps through visual interpretation of satellite images in a scale that minimum area for polygon delineation is 0.25 cm2 at 1: 50,000 of scale which equals to 6.25 ha"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Indonesia 2015" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_798 a skos:Concept ;
    dct:creator "Iran" ;
    dct:date "1962"^^xsd:gYear ;
    skos:broadMatch ex:Forest ;
    skos:definition "FOREST LAND: It is an area which comply with one of the following; a-Lands in which the forest characteristries like seedlings or sprouts or stumps collectively or sparsely exist, provided before the Forest Nationalization (January 1962), they were not under fallow or cultivation of annuals. b-Lands in which natural trees and shrubs sparsely exist, and their crown cover is 1-5% \"M.Zobeiri\" zobeiri@nrf.ut.ac.ir"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Iran 1962" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_799 a skos:Concept ;
    dct:creator "Iran" ;
    dct:source "http://neda.net/faro/forestry1.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A vegetation cover where trees are its main elements. They are divided into various types according to superficial and inner situation, and dominated by especial ecological conditions in respect of flora, fauna, climatic and edaphic factors"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Iran" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_80 a skos:Concept ;
    dct:creator "26" ;
    dct:source "http://www.genesisny.net/Commodity/Timber/Timberglos.html"^^xsd:anyURI,
        "http://www.pkarticleshub.com/2012/02/04/forests-"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A forest is an ecosystem-a community of plants and animals interacting with one another and with the physical environment. –-an-imperative-resource"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "26" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_800 a skos:Concept ;
    dct:creator "Iran" ;
    skos:broadMatch ex:Forest ;
    skos:definition "FOREST: It is a land mainly covered by trees, shrubs and other woody plants. Forest density is classified as follow: 1 Very dense: crown cover of woody elements (trees, shrubs) more than 75%, 2 Dense - 50 -75%, 3 Middle dense - 25 -50%, 4 Sparse 5 -25%, 5 Very - 1 - 5% \"M.Zobeiri\" <zobeiri@nrf.ut.ac.ir"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Iran" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_801 a skos:Concept ;
    dct:date "2002"^^xsd:gYear ;
    dct:source "http://www.ymparisto.fi/download.asp?contentid=25582&lan=en"^^xsd:anyURI ;
    dct:spatial "Ireland" ;
    skos:broadMatch ex:Forest ;
    skos:definition "There are no legal definitions for the terms forest and forestry in Ireland. A practical definition for forest is an area of at least 0.5 ha (sometimes, in the case of broadleaves, 0.2 ha) with a minimum width of 40 m over no more than two-thirds of its length, with at least 50% canopy cover by trees"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Ireland 2002" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_803 a skos:Concept ;
    dct:date "2010"^^xsd:gYear ;
    dct:source "http://www.efi.int/files/attachments/publications/annex_1_to_efi_technical_report_88__2013.pdf"^^xsd:anyURI ;
    dct:spatial "Ireland" ;
    skos:broadMatch ex:Forest ;
    skos:definition "To define area as a forest it has to pass these minimum requirements: - tree crown cover: 10%- land area: 0.5 ha - tree height: 2 m. Further IFI has added practical requirements that are in accordance to international definitions: - minimum width of forest: 20 m - maximum permanent gap in forest. 0.5 ha. Tomppo E., Gschwantner T., Lawrence M., 2010"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Ireland 2010" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_804 a skos:Concept ;
    dct:date "1984"^^xsd:gYear ;
    dct:spatial "Isle of Man" ;
    skos:broadMatch ex:Forest ;
    skos:definition "The term \"forest\" only appears in the Forestry Act 1984, where it is not defined. The context of its usage means a large woodland. \"IOM Gov DAFF\" <daff@gov.im"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Isle of Man 1984" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_805 a skos:Concept ;
    dct:spatial "Israel" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest Land: 1. Land covered with forest. From: GilS@kkl.org.il"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Israel" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_806 a skos:Concept ;
    dct:spatial "Israel" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest: A vegetation formation in which trees have more than 10% crown cover. From: GilS@kkl.org.il"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Israel" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_807 a skos:Concept ;
    dct:date "1988"^^xsd:gYear ;
    dct:spatial "Italy" ;
    skos:broadMatch ex:Forest ;
    skos:definition "A wooded land with an area =0,2 Ha; with a canopy width =20m; with a cover closure =20% MAF, Ministero dell'Agricoltura e delle Foreste (1988). Inventario Forestale Nazionale 1985. Istituto Sperimentale per l'Assessamento forestale e per l'Alpicoltura. 2 vols. Rome. Lorenzo Ciccarese ciccarese@anpa.it"@it ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Italy 1988" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_808 a skos:Concept ;
    dct:date "1998"^^xsd:gYear ;
    dct:spatial "Italy" ;
    skos:broadMatch ex:Forest ;
    skos:definition "An area (min. area: 2000 m2; min. cover: 20%; min. width: 20 m.) having one (or more) of these features: aimed to provide wooden products and non-wooden (commonly considered-forest) products, such as berries, mushrooms, resins, etc; covered with woods or shrubs, having direct and indirect functions in protecting human activities from disturbances; with tree and shrub crown cover, which preservation is needed for naturalistic, scenic and recreational purposes. MAF, Ministero dell'Agricoltura e delle Foreste (1988). Inventario Forestale Nazionale 1985. Istituto Sperimentale per l'Assessamento forestale e per l'Alpicoltura. 2 vols. Rome.. Lorenzo Ciccarese ciccarese@anpa.it. and: Vittorio Tosi ISAFA Biometria <isafa.biofor@tqs.it (MAF 1988"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Italy 1998" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_809 a skos:Concept ;
    dct:date "2007"^^xsd:gYear ;
    dct:source "http://www.efi.int/files/attachments/publications/annex_1_to_efi_technical_report_88__2013.pdf"^^xsd:anyURI ;
    dct:spatial "Italy" ;
    skos:broadMatch ex:Forest ;
    skos:definition "National definition: forest is a land covered by trees more than 2000 m2, 20% of canopy, with a minimun width of 20 m. Ministero Delle Politiche Agricole, Alimentari e Forestali Corpo Forestale Dello Stato. CRA (Istituto Sperimentale per l’Assestamento Forestale e per l’Alpicoltura), 2007"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Italy 2007" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_81 a skos:Concept ;
    dct:source "http://en.wikipedia.org/wiki/Forest"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A forest is usually an area filled with trees but any tall densely packed area of vegetation may be considered a forest, even underwater vegetation such as kelp forests, or non-vegetation such as fungi,[2] and bacteria"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_811 a skos:Concept ;
    dct:date "1987"^^xsd:gYear ;
    dct:source "http://www.fao.org/ag/agl/agll/landuse/clsys/Jamaica.htm"^^xsd:anyURI ;
    dct:spatial "Jamaica" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest stands including both coniferous (softwood) and broad leaf evergreens. Crown closure must equal or exceed 75%. Source: Land use map 1983/1984, 1:500 000, Rural Physical planning division, Ministry of Agriculture, Hope Gardens, Kingston 6, Jamaica, 03/1987"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Jamaica 1987" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_812 a skos:Concept ;
    dct:date "1992"^^xsd:gYear ;
    dct:spatial "Jamaica" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Jamaica has several definitions depending on remote sensing source used. Using the largest scale definition, forest land appears to be areas covered with trees at least 5-7 m tall, with a crown closure of 75% and a minimum area of 4 ha. See: 1) Land use classification 1:100 000 scale (National level, Landsat TM) and 1:15 000 scale (Watershed level, aerial photographs 1:15 000 and biophysical inventory): STRATES100-15.CDR; 2) Definition of land use types 1:100 000 scale: STRATES100.XLS; 3) Stratification of vegetation/land use (Photo-interpretation - 1:15 000 aerial photographs): STRAT-SUM1A.XLS; 4) Correlation between land use types 1:15 000 and rapid ecological assessment vegetation types (Jamaica, 1992): STRATES15A.XLS; 5) Definition of land use types 1:15 000 scale: VEG-DEF.DOC. Source: (forestman@cwjamaica.com"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Jamaica 1992" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_813 a skos:Concept ;
    dct:creator "academic definition - forest land" ;
    dct:spatial "Japan" ;
    skos:broadMatch ex:Forest ;
    skos:definition "A place covered by a group of trees with more or less height, density, and extent. Yukichi Konohira <Konohira@cc.tuat.ac.jp"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Japan - academic definition - forest land" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_814 a skos:Concept ;
    dct:creator "academic definition - forest" ;
    dct:spatial "Japan" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Both trees growing in a group and the land where they stand. Yukichi Konohira <Konohira@cc.tuat.ac.jp"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Japan - academic definition - forest" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_815 a skos:Concept ;
    dct:date "1951"^^xsd:gYear ;
    dct:source "http://www.iufro.org/download/file/5574/4510/61300-jundola01_pdf/"^^xsd:anyURI ;
    dct:spatial "Japan" ;
    skos:broadMatch ex:Forest ;
    skos:definition "A forest is a group of living trees or bamboos and the land on which the group of trees or bamboos is growing. The exception is land with trees that are managed for agriculture, residence, or similar purposes"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Japan 1951" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_816 a skos:Concept ;
    dct:date "2003"^^xsd:gYear ;
    dct:source "http://www.fs.fed.us/research/sustain/2003SustainabilityReport/documents/SustainableForests.pdf"^^xsd:anyURI ;
    dct:spatial "Japan" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Minimum area = 0.3 ha, minimum tree crown cover = 30%, minimum tree height = 5 m"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Japan 2003" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_817 a skos:Concept ;
    dct:spatial "Japan" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest: In addition to Forest Row, forestland is with tree crown cover of more than 30 percent. Definition of Forest Resource Inventory Book, Forest Agency. From: Masahiro Amano <masahiro@ss.ffpri.affrc.go.jp"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Japan" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_818 a skos:Concept ;
    dct:creator "?" ;
    dct:date "1965"^^xsd:gYear ;
    dct:source "http://www.kalro.org:8080/repository/bitstream/0/5057/1/REPRINT%20COLLECTION%2063%20Split%2035.pdf"^^xsd:anyURI ;
    dct:spatial "Kenya" ;
    skos:broadMatch ex:Forest ;
    skos:definition "A closed stand of trees of one or more storeys, with an interlaced upper canopy, rising to 7·5-40 m or more in height. The ground cover is dominated by herbs and shrubs, and lianes and epiphytes are characteristic. Dwarf forests are as defined but rise to less than 7·5 m in height"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Kenya 1965?" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_819 a skos:Concept ;
    dct:date "1995"^^xsd:gYear ;
    dct:source "http://cmsdata.iucn.org/downloads/forestcover.pdf"^^xsd:anyURI ;
    dct:spatial "Kenya" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Kenya’s woody vegetation includes forests, woodlands, bushland and wooded grasslands. Wass (1995) defines forests as continuous stands of trees at least 10 meters tall, with interlocking crowns; woodlands as open stands of trees, at least 8 meters tall, with a canopy cover of 40% or more with the field layer usually dominated by grasses; bushlands as open stands of bushes and climbers, usually between 3 and 7 meters tall with a canopy cover of 40% or more and wooded grasslands as land covered with grasses and other herbs, with woody plants covering between 10% and 40% of the ground"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Kenya 1995" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_82 a skos:Concept ;
    dct:source "http://www.reference.com/browse/wiki/Forest"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A forest is an area with a high density of trees"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_820 a skos:Concept ;
    dct:date "2005"^^xsd:gYear ;
    dct:source "http://www.fankenya.org/downloads/ForestsAct2005.pdf"^^xsd:anyURI ;
    dct:spatial "Kenya" ;
    skos:broadMatch ex:Forest ;
    skos:definition "“forests” refers to any land containing a vegetation association dominated by trees of any size, whether exploitable or not, capable of producing wood or other products, potentially capable of influencing climate, exercising an influence on the soil, water regime, and providing habitat for wildlife, and includes woodlands; “forest area” means any land declared to be a forest land under this Act"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Kenya 2005" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_821 a skos:Concept ;
    dct:date "2005"^^xsd:gYear ;
    dct:source "http://formin.finland.fi/public/download.aspx?ID=15959&GUID=%7B88EFD0B8-9F47-4528-A24F-66DDE0CFE370%7D"^^xsd:anyURI ;
    dct:spatial "Kenya" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Mini-forest refers to a crop of trees occupying less than 10 ha of land"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Kenya 2005" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_822 a skos:Concept ;
    dct:date "2015"^^xsd:gYear ;
    dct:source "http://www.kenyaforestservice.org/documents/ForestConservationandManagementActNo34of2016.pdf"^^xsd:anyURI ;
    dct:spatial "Kenya" ;
    skos:broadMatch ex:Forest ;
    skos:definition "woody vegetation growing in close proximity in an area of over 0.5 of a hectares including a forest in the process of establishment, woodlands, thickets"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Kenya 2015" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_823 a skos:Concept ;
    dct:spatial "Kenya" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Min. av. height 2 m, 40% canopy cover. Note these figures vary by vegetation type. The most liberal thresholds are shown here. Source: ECE-FAO Partnership Programme: Kenya Workshop on Forestry Statistics. Appendix 6"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Kenya" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_824 a skos:Concept ;
    dct:creator "Kirbati" ;
    dct:date "2010"^^xsd:gYear ;
    dct:source "http://www.sprep.org/att/irc/ecopies/countries/kiribati/115.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "At the regional level forest is defined as; ‘trees that have a certain size of canopy, they are not agricultural and are not located in urban areas’"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Kirbati 2010" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_825 a skos:Concept ;
    dct:creator "Kosovo" ;
    dct:date "2010"^^xsd:gYear ;
    dct:source "http://www.efi.int/files/attachments/publications/annex_1_to_efi_technical_report_88__2013.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land with tree crown cover (or equivalent stocking level) of more than 10% and area of more than 0.5 ha. The trees should be able to reach a minimum height of 5 m at maturity in situ. Gashi F., 2010"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Kosovo 2010" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_826 a skos:Concept ;
    dct:creator "New National Forest Inventory" ;
    dct:spatial "Kyrgyzstan" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Vegetation existing of forest species with the objective of timber production and various protective and other functions. The horizontal forest area has a minimum crown cover density of 20%, a minimum width of 25 meters and a minimum height of 2.0 meters. Source: Irina Yunusova irina@lesic.elcat.kg"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Kyrgyzstan - New National Forest Inventory" ;
    skos:prefLabel "Forest"@no ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_827 a skos:Concept ;
    dct:date "1999"^^xsd:gYear ;
    dct:spatial "Kyrgyzstan" ;
    skos:broadMatch ex:Forest ;
    skos:definition "New Forest Code - One of the main types of vegetation on the Earth, comprising trees, shrubs, grassland and other plants, including animals and microorganisms, which are biologically interrelated in their evolution and exert influence on one another and the environment. Forest soil is an integral part of the forest whole. Forest is an integral and a very important component of biosphere and geographic landscape. It plays an important role in maintaining the hydrological regime of rivers, preventing erosion and deflation of soils, combating hot dry winds. Source: Irina Yunusova <irina@lesic.elcat.kg"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Kyrgyzstan 1999" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_828 a skos:Concept ;
    dct:date "2000"^^xsd:gYear ;
    dct:source "http://kirfor.ucentralasia.org/bitcache/833d526f022370574cea70a841a6474fef581009?vid=610&disposition=attachment&op=download"^^xsd:anyURI ;
    dct:spatial "Kyrgyzstan" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest in strict sense (conifer/broadleaf/mixed - see definitions at 3.3) is defined as vegetation consisting of forest species (according to the species list in annex 2) with the objective of timber production and various protection and other functions. The horizontal forest area has a minimum crown cover density of 20 % (see Figure 2-4, Figure 2-5 and Figure 2-6), a minimum width of 25 metres and a minimum height of 2.0 metres. In case of forest cultures no minimum height has to be considered"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Kyrgyzstan 2000" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_829 a skos:Concept ;
    dct:spatial "Kyrgyzstan" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest -One of the main types of vegetation, comprised of the concomitance (?) of trees, shrub, grass and other plants, also including animals and microorganisms , biologically interrelated in their development and influencing each other and environment. At the same time forest is a very important part of the biosphere and an element of geographical landscape. Forest is a raw material source. Source: Irina Yunusova <irina@lesic.elcat.kg"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Kyrgyzstan" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_83 a skos:Concept ;
    dct:creator "or ‘weald’" ;
    dct:source "http://crosword911.com/forest.jsp?=aHR0cDovL2VuLndpa2lwZWRpYS5vcmcvd2lraS9Gb3Jlc3Q="^^xsd:anyURI,
        "http://en.wikipedia.org/wiki/Forest"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A forest, also referred to as a wood or the woods and less often as a ‘wold” , ‘holt’, or ‘firth” (or “firth”), is an area with a high density of trees. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "or ‘weald’" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_830 a skos:Concept ;
    dct:creator "Lao" ;
    dct:date "1992"^^xsd:gYear ;
    dct:source "http://www.forestcarbonpartnership.org/fcp/sites/forestcarbonpartnership.org/files/Documents/PDF/Sep2010/Final_R-PPdraft3-09-10_submission_with_annexes.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forests – areas suitable for forest production and having a tree cover with a crown density of at least 20%, and supporting trees with a dbh more than 10cm, covering at least 0.5 ha (LSFP 92"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Lao 1992" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_831 a skos:Concept ;
    dct:creator "Lao" ;
    dct:date "2000"^^xsd:gYear ;
    dct:source "http://www.fao.org/forestry/fo/country/index.jsp?lang_id=1&geo_id=39"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Min. Cover = 20%"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Lao 2000" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_832 a skos:Concept ;
    dct:creator "Lao" ;
    dct:date "2011"^^xsd:gYear ;
    dct:source "http://www.recoftc.org/site/uploads/content/pdf/ASFN%20v10%20-web%20version%20(compressed)_139.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Lao PDR uses a definition of forest cover of 20% canopy density, which is different from the definition used by FAO (personal communication, Mr. Khamseneas, Planning Division, Department of Forestry (DoF). February 2011"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Lao 2011" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_833 a skos:Concept ;
    dct:creator "Lao" ;
    dct:date "2015"^^xsd:gYear ;
    dct:source "http://www.uncclearn.org/sites/default/files/inventory/fao13102015_4.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "In Lao PDR forests are defined as areas of at least 0.5 ha in size, with crown cover above 20%; with trees that will reach higher than 5 meters when mature. Dense forests have crown cover greater than 70%, medium-stocked between 40% and 70% and degraded forests have crown cover between 20% and 40%"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Lao 2015" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_834 a skos:Concept ;
    dct:date "1937"^^xsd:gYear ;
    dct:source "http://www.iufro.org/download/file/5574/4510/61300-jundola01_pdf/"^^xsd:anyURI ;
    dct:spatial "Latvia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "The Law on Forest Protection of Oct. 14, 1937 defined the forest by the following traits: i) land areas overgrown by forest ; ii) meadows, pastureland and other non-cultivated lands overgrown by forest, stocked to no less than a half of full density and encircled by forest; iii) felling coupes, irrespective of the situation with forest regeneration there; iv) all lands, irrespective of the tree age and density, where the owner has ceased other management activities to let the forest grow there. Stands on swampy sites, provided the tree height at the age of 60 years remained below 7 m, were not counted as forest"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Latvia 1937 " ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_835 a skos:Concept ;
    dct:date "2000"^^xsd:gYear ;
    dct:source "http://www.fao.org/docrep/article/WFC/XII/0504-C3.htm"^^xsd:anyURI ;
    dct:spatial "Latvia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "According to the Forest Law of the Republic of Latvia adopted in 2000 (Item 2, Paragraph 3, Section 1) Item 1 states: \"The forest is an ecosystem in all its stages of development. Trees with the height of at least seven metre prevail, and the present or potential tree crown cover accounts for at least 20% of the forest stand area.\""@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Latvia 2000" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_836 a skos:Concept ;
    dct:date "2000"^^xsd:gYear ;
    dct:source "http://www.efi.int/files/attachments/publications/annex_1_to_efi_technical_report_88__2013.pdf"^^xsd:anyURI ;
    dct:spatial "Latvia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest (area>0.1 ha, potential height of trees>7 m, present or potential projection of crowns >20%). Latvijas Valsts mezi, 2000"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Latvia 2000" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_837 a skos:Concept ;
    dct:date "2001"^^xsd:gYear ;
    dct:source "http://www.iufro.org/download/file/5574/4510/61300-jundola01_pdf/"^^xsd:anyURI ;
    dct:spatial "Latvia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "“forest” is defined as “an ecosystem in all its development stages, dominated by trees, the height of which in the particular forest site may reach at least seven metres, and the present or potential tree crown cover accounts for at least 20% of the stand area.”"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Latvia 2001" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_838 a skos:Concept ;
    dct:date "2007"^^xsd:gYear ;
    dct:source "http://circa.europa.eu/Public/irc/dsis/pip/library?l=/environmental_expenditur/country_studies/projects_awarded_2005/lv_296_forestpdf/_EN_1.0_&a=d"^^xsd:anyURI ;
    dct:spatial "Latvia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest is an ecosystem in all stages of its development, dominated by trees the height of which at the particular location may reach at least seven meters and the present or potential projection of the crown of which is at least 20 per cent of the area occupied by the forest stand. The following shall not be regarded as forest: Areas separate from forests, covered with trees, the size of which does not exceed 0.1 ha; Rows of trees of artificial or natural origin, the width of which is less than 20 meters; Orchards, parks, cemeteries and forest tree seed orchards"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Latvia 2007" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_839 a skos:Concept ;
    dct:date "2007"^^xsd:gYear ;
    dct:source "http://circa.europa.eu/Public/irc/dsis/pip/library?l=/environmental_expenditur/country_studies/projects_awarded_2005/lv_296_forestpdf/_EN_1.0_&a=d"^^xsd:anyURI ;
    dct:spatial "Latvia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forestland is land covered by forest, land under forest infrastructure facilities, as well as adjacent overflowing clearings, marshes and glades"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Latvia 2007" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_84 a skos:Concept ;
    dct:creator "dead, dying & living" ;
    dct:source "http://www.chesco.com/~treeman/words/words-f.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A highly ordered arrangement of living organisms living in, on and around trees in such an highly ordered fashion it assures high quality survival for all"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "dead, dying & living" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_840 a skos:Concept ;
    dct:source "http://www.metla.fi/eu/cost/e43/minutes/wg1-min-florence.pdf"^^xsd:anyURI ;
    dct:spatial "Latvia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest -National definition in use: crown cover 20 %, 7 m height limit"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Latvia" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_841 a skos:Concept ;
    dct:source "http://www.capeaction.org.za/uploads/BD_in_SEA_manual.pdf"^^xsd:anyURI ;
    dct:spatial "Lebanon" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest refer to forest land spanning more than 0.5 hectares with trees higher than 5 meters and a canopy cover of more than 10%, or trees able to reach these threshold in situ. It does not include land that is predominantly under agricultural or urban land use"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Lebanon" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_842 a skos:Concept ;
    dct:date "1997"^^xsd:gYear ;
    dct:spatial "Liechtenstein" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Focuses on growing stock and applies to measurable criteria - width of forest area, crown closure and top height. Width of growing stock with canopy closure = 100% is at least 25 m and with crown closure = 20% at least 50 m. Canopy closure between 20 % and 100 % depending on width of growing stock. Minimum top diameter 3 m (exceptions afforestation, young growth, mountain alder, mountain pine) (European Communities 1997b - p. 1067"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Liechtenstein 1997" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_843 a skos:Concept ;
    dct:date "2000"^^xsd:gYear ;
    dct:source "http://www.efi.int/files/attachments/publications/annex_1_to_efi_technical_report_88__2013.pdf"^^xsd:anyURI ;
    dct:spatial "Liechtenstein" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Minimum area of land: 0.0625 ha (with a minimum width of 25 m), minimum crown cover: 20%, minimum height of the dominant trees: 3 m (dominant trees must have the potential to reach, 3 m at maturity in situ). Amt für Wald, Natur und Landschaft (AWNL), 2000"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Liechtenstein 2000" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_845 a skos:Concept ;
    dct:date "2013"^^xsd:gYear ;
    dct:source "http://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:32013D0529"^^xsd:anyURI ;
    dct:spatial "Lithuania" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Area (ha) 0.1; Tree crown cover (%) 30; Tree height (m) 5"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Lithuania 2013" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_846 a skos:Concept ;
    dct:source "http://sapiens.revues.org/734"^^xsd:anyURI ;
    dct:spatial "Lithuania" ;
    skos:broadMatch ex:Forest ;
    skos:definition "forest can also be defined as “at least 0.1 ha area grown-up with trees the height of which reaches 5 m or more under natural conditions, as well as thinned out or even having lost the vegetation naturally or because of human activities” (Forest act of Republic of Lithuania"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Lithuania" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_847 a skos:Concept ;
    dct:date "2003"^^xsd:gYear ;
    dct:source "http://www.efi.int/files/attachments/publications/annex_1_to_efi_technical_report_88__2013.pdf"^^xsd:anyURI ;
    dct:spatial "Luxembourg" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land with tree crown cover (or equivalent stocking level) of more than 10% and area of more than 0.5 ha. The trees should be able to reach a minimum height of 5 m at maturity in situ. Le gouvernement du Grand Duchè du Luxembourg, 2003"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Luxembourg 2003" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_849 a skos:Concept ;
    dct:creator "Macedonia" ;
    dct:date "1997"^^xsd:gYear ;
    dct:source "http://www.foper.org/download/alumni/todorov_thesis.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest, as defined in this law, is land with forest types of trees and bushes, forest moor lands and meadows, forest roads, forest nurseries and other areas closely related to forests. As defined in this Law, alleys, plantations with fast-growing types of trees, parks with populated areas, field protection belts, protective vegetation in the coastal belts of the water flows outside from the forests, isolated groups of forest trees on area of maximum 2 acres, and border trees between agricultural land are not considered forests. Law on Forests of 1997"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Macedonia 1997" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_85 a skos:Concept ;
    dct:creator "or equivalent stocking level" ;
    dct:source "http://figueresonline.com/csdafinal/English/publications/cdm/glossary.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A land area with a minimum 10% tree crown coverage , or formerly having such tree cover and that is being naturally or artificially regenerated or is being afforested"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "or equivalent stocking level" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_850 a skos:Concept ;
    dct:creator "Malaw" ;
    dct:date "2000"^^xsd:gYear ;
    dct:source "http://www.fao.org/forestry/fo/country/index.jsp?lang_id=1&geo_id=39"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Min Area = 100 ha, Min. Crown Cover = 80%"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Malaw 2000" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_851 a skos:Concept ;
    dct:date "1997"^^xsd:gYear ;
    dct:spatial "Malawi" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest/woodland contains <20 % open area. (Trevett 1997"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Malawi 1997" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_852 a skos:Concept ;
    dct:date "2006"^^xsd:gYear ;
    dct:source "http://www.environmental-auditing.org/LinkClick.aspx?fileticket=fbx%2FbAIVeFU%3D&tabid=128&mid=568"^^xsd:anyURI ;
    dct:spatial "Malaysia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "The areas under oil palm, rubber and tree crops are frequently regarded as forest. The official definition of a forest used in Malaysia differs from the Food and Agriculture Organization (FAO) definition, which excludes areas under agricultural crops (e.g., oil palm). (JoeangoHutan, 2006"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Malaysia 2006" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_853 a skos:Concept ;
    dct:spatial "Malaysia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "An ecosystem with a minimum of 10 percent crown cover of trees and / or bamboos, generally associated with wild flora, fauna and natural soil conditions, and not subject to agricultural practices. This definition is also applied to the term \"forest land\". From: hcthang@forestry.gov.my (Thang Hooi Chiew), Forestry Department Peninsular Malaysia"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Malaysia" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_854 a skos:Concept ;
    dct:date "2016"^^xsd:gYear ;
    dct:source "http://redd.unfccc.int/files/modified_submission_malaysia_frel_final.pdf"^^xsd:anyURI ;
    dct:spatial "Malaysia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "The forest definition used in the development of the reference level is based on the national legislation and is consistent with the national greenhouse gas inventory. However, the definition used by the FAO is not used as some agricultural land, like the state land and rubber plantations would be considered as forest but these areas are not managed in a sustainable manner neither subjected by the National Forestry Act. The smallholders following the rubber management manage rubber plantations, while the state land forest is a land bank for future development. However, these areas maintain the forest threshold values Malaysia submitted under the Kyoto Protocol, a minimum area of 0.5 ha. 30% canopy cover and 5m height at maturity. The National Forest Act prescribes that only the land under this Act will remain as forest reserves and management in a sustainable manner"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Malaysia 2016" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_855 a skos:Concept ;
    dct:date "2000"^^xsd:gYear ;
    dct:source "http://www.fao.org/forestry/fo/country/index.jsp?lang_id=1&geo_id=68"^^xsd:anyURI ;
    dct:spatial "Mali" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Cover = 20 %"@no ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Mali 2000" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_856 a skos:Concept ;
    dct:source "http://www.un.org/esa/forests/pdf/aheg/aheg1/Mali_E.pdf"^^xsd:anyURI ;
    dct:spatial "Mali" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Any area of land covered in vegetation of which the exclusive, primary and secondary products are wood, resins, gum, fruits, bamboo, creepers, raffia, or any other plants not classed as agricultural products"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Mali" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_857 a skos:Concept ;
    dct:date "1982"^^xsd:gYear ;
    dct:spatial "Mauritania" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Sont considérées comme forêts les formations végétales dont les produits princilpaux sont les bois, ou d'autres matières telles aue Ecorce, Tanin, Gomme. ARTICLE 2. LEX-FAOC002244. MAURITANIA: Ordonnance n&ordm; 82-171 portant Code forestier. Date of text: 15 December 1982"@fr ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Mauritania 1982" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_858 a skos:Concept ;
    dct:date "1983"^^xsd:gYear ;
    dct:source "http://www.intnet.mu/iels/Forest_act_1983.htm"^^xsd:anyURI ;
    dct:spatial "Mauritius" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Includes a national forest and all land which is not under cultivation and which is covered by trees (The Forests and Reserves Act 1983"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Mauritius 1983" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_859 a skos:Concept ;
    dct:creator "– SARH" ;
    dct:date "1994"^^xsd:gYear ;
    dct:spatial "Mexico" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Arbolado). Los terrenos ar bolados enlosques las copas de los arboles cubren mas del 20% de la superficie (SARH 1994"@es ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Mexico – SARH 1994" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_86 a skos:Concept ;
    dct:source "http://www.metla.fi/silvafennica/full/sf42/sf422247.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A land spanning more than 0.5 ha with trees higher than 5 metres and a crown cover of more than 10%, or trees able to reach these thresholds in situ. For tree rows or shelterbelts, a minimum width of 20 m is required. It does not include land that is predominantly under agricultural or urban land use.”"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_860 a skos:Concept ;
    dct:creator "SARH" ;
    dct:date "1994"^^xsd:gYear ;
    dct:spatial "Mexico" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Area forestall). Terrenos cuyas caracteristics topograficas y condiciones ecologicas, permiten que sustente como forma optima de uso del suelo a la vegetacion arborea, ar bustiva o her bacea natural (SARH 1994"@es ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Mexico - SARH 1994" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_861 a skos:Concept ;
    dct:creator "– SARH" ;
    dct:date "1994"^^xsd:gYear ;
    dct:spatial "Mexico" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Bosque). Comunidad vegetal en la que prodominan los arboles y otras especies lenosas. (SARH 1994"@es ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Mexico – SARH 1994" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_862 a skos:Concept ;
    dct:date "2003"^^xsd:gYear ;
    dct:source "http://www.fs.fed.us/research/sustain/2003SustainabilityReport/documents/SustainableForests.pdf"^^xsd:anyURI ;
    dct:spatial "Mexico" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Minimum area = 25 ha, minimum tree crown cover =10%, minimum tree height = 3 m"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Mexico 2003" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_863 a skos:Concept ;
    dct:date "2010"^^xsd:gYear ;
    dct:source "http://www.istf-bethesda.org/specialreports/mendoza/Mendoza-eng.pdf"^^xsd:anyURI ;
    dct:spatial "Mexico" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Mexican forest law specifies that a forest is at least one hectare with more than 15% actual or potential woody crown cover (with a few exceptions"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Mexico 2010" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_864 a skos:Concept ;
    dct:creator "–INEG I" ;
    dct:date "1995"^^xsd:gYear ;
    dct:spatial "Mexico" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Superficie de bosque). Son los terrenos cuibertos coan arboles, generamente de gran altura, que se encuentran en zonas con clima teplado-frio, donde las especiaes principales pueden ser: pino, Encino, oyamel, cedro, etc. (INEGI 1995"@es ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Mexico –INEG 1995I" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_865 a skos:Concept ;
    dct:creator "–INEG I" ;
    dct:date "1995"^^xsd:gYear ;
    dct:spatial "Mexico" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Superficie de selva). Son los terrenos cubiertos con arboles y vegetacion abundante y tupida de rapido crecimiento que se encuentran en clima calido humedo, donde las principales especies encontradas pueden ser: caoga, palo de agua, ramon, cedro rojo, pochote, etc. (INEGI 1995"@es ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Mexico –INEG 1995I" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_866 a skos:Concept ;
    dct:creator "–INEG I" ;
    dct:date "1997"^^xsd:gYear ;
    dct:spatial "Mexico" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Selva). Vegetacion arborea en climas calido —humedos a calidos semisecos. Se carateriza por tener generalmente una gran variedad de especies de origen tropical. INEGI 1997. Minimum mapping area 25 ha (INEGI n.d"@es ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Mexico –INEG 1997I" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_867 a skos:Concept ;
    dct:creator "–INEGI" ;
    dct:date "1997"^^xsd:gYear ;
    dct:spatial "Mexico" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Bosque). Vegetacion arborea, princialment de zones templadas y semifrias, en climas subhumedos a muy humedos (INEGI 1997). Minimum mapping area 25 ha (INEGI n.d"@es ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Mexico –INEGI 1997" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_868 a skos:Concept ;
    dct:creator "INEGI y SEMARNAP" ;
    dct:date "1999"^^xsd:gYear ;
    dct:spatial "Mexico" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Superficie con bosque). Es la superfice cubierta con v egetacion aroforea, generalmente de gran altura, pertenecienta a regions de clima templado o frio y ese encuentra constituida, principalmente por coniferas y latifoliadas; las especies mas communes son el pino, enciono y oyamel (INEGI y SEMARNAP 1999"@es ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Mexico -INEGI y SEMARNAP 1999" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_869 a skos:Concept ;
    dct:creator "INEGI y SEMARNAP" ;
    dct:date "1999"^^xsd:gYear ;
    dct:spatial "Mexico" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Superficie con selva). Area cubierta con vegetacion densa, abundante y tupida con variadas especies de rapido crecimiento que se encuentran en zonas con clima calido-humedo, con altas precipitaciones pluviales. Entre las especies que se pueden encontrar ees esta clasificacion estan: caoba, palo de agua, ramon, cedro rojo, pochote, etc. (INEGI y SEMARNAP 1999"@es ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Mexico -INEGI y SEMARNAP 1999" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_87 a skos:Concept ;
    dct:source "http://www.foreignword.com/Tools/dictsrch_aff.asp?menu=Y&query=forest&src=BP&srcbox=18&go=Translate&trg=AG"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A large area covered chiefly with trees and undergrowth or a large number or dense mass of vertical objects"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_870 a skos:Concept ;
    dct:creator "–SARH" ;
    dct:date "1994"^^xsd:gYear ;
    dct:spatial "Mexico" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Cubierta forestal). Termino amplio que comprende toda la vegetacion espontanea natural (arboles, palmeras, arbustos, matorrales deserticos, hier bas, etc.) que ocupa un area en un momento dado (SARH 1994"@es ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Mexico –SARH 1994" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_871 a skos:Concept ;
    dct:spatial "Mexico" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Bosque).- Vegetación forestal, principalmente de zonas de clima templado, en la que predominan especies leñosas perennes que se desarrollan en forma espontánea, con una cobertura de copa mayor al 10% de la superficie que ocupa, siempre que formen masas mayores a 1 500 metros cuadrados. Esta definición es adecuada en aspectos físicos y biológicos, ya que relaciona la cantidad de tierras forestales con la superficie total del país, lo que daría una idea del porcentaje de áreas cubiertas de vegetación arbolada y uso de la tierra; la cual no debe ser menor del 10% en un país. El umbral de su limite mínimo y máximo debe estar con relación a las necesidades que tiene cada país o en el ámbito mundial sobre aspectos como necesidades de fijación de carbono, regulación de ciclos climáticos e hidrológicos, (clima y topografía), fijación del suelo, etc. Source: Glosario de Términos de la Memoria del Inventario Nacional Forestal Periódico y del Reglamento de la Ley Forestal from Unidad del Inventario <varelah@servidor.unam.mx"@es ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Mexico" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_872 a skos:Concept ;
    dct:source "http://www.semarnap.gob.mx/indices/tematico/bosques/introduccion.htm"^^xsd:anyURI ;
    dct:spatial "Mexico" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Terrenos forestales)- Los terrenos forestales son definidos por la Ley Forestal como todos aquellos que están cubiertos por vegetación forestal, excluyendo aquellos situados en áreas urbanas. Los terrenos de aptitud preferentemente forestal son aquellos que no estando cubiertos por vegetación forestal, por sus condiciones de clima, suelo y topografía, puedan incorporarse al uso forestal, excluyendo los situados en áreas urbanas y los que sin sufrir degradación permanente, puedan ser utilizados en la agricultura la ganadería"@es ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Mexico" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_873 a skos:Concept ;
    dct:spatial "Mexico" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Terrenos forestales)- Son terrenos forestales los que están cubiertos por bosques, selvas o vegetación forestal de zonas áridas. Source: Glosario de Términos de la Memoria del Inventario Nacional Forestal Periódico y del Reglamento de la Ley Forestal from Unidad del Inventario varelah@servidor.unam.mx"@es ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Mexico" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_874 a skos:Concept ;
    dct:creator "Moldova" ;
    dct:date "2011"^^xsd:gYear ;
    dct:source "http://www.efi.int/files/attachments/publications/annex_1_to_efi_technical_report_88__2013.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land with tree crown cover (or equivalent stocking level) of more than 10 % and area of more than 0.5 ha. The trees should be able to reach a minimum height of 5 m at maturity in situ. FOREST EUROPE, UNECE and FAO, 2011"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Moldova 2011" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_875 a skos:Concept ;
    dct:creator "?" ;
    dct:date "2007"^^xsd:gYear ;
    dct:source "https://cdm.unfccc.int/DNA/DNA/allCountriesARInfos.html"^^xsd:anyURI ;
    dct:spatial "Mongolia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Cover = 10 %; area = 1 ha; tree height = 2 m"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Mongolia 2007?" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_876 a skos:Concept ;
    dct:date "2000"^^xsd:gYear ;
    dct:source "http://www.unece.org/fileadmin/DAM/publications/timber/QL_SoEF_Montenegro_final.pdf"^^xsd:anyURI ;
    dct:spatial "Montenegro" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest land definition based on the 2000 Forest law: “A forest relates to any area larger than 0.05 ha, covered with forest trees, having a protective function, and intended for forest production or it has special purpose, no matter of tree cover and size (high forest, copice forests and other types of forest vegetation such as shrubs, shrubberies and maquis).” Also forest bare land is part of the forest land according to that definition"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Montenegro 2000" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_877 a skos:Concept ;
    dct:date "1997"^^xsd:gYear ;
    dct:spatial "Mozambique" ;
    skos:broadMatch ex:Forest ;
    skos:definition "High forest 18 m, low forest < 18 m. Canopy cover 25 %. (Trevett 1997"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Mozambique 1997" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_878 a skos:Concept ;
    dct:date "2007"^^xsd:gYear ;
    dct:source "https://cdm.unfccc.int/DNA/DNA/allCountriesARInfos.html"^^xsd:anyURI ;
    dct:spatial "Mozambique" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Cover = 30%; Area = 1 ha; tree height = 5 m"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Mozambique 2007" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_879 a skos:Concept ;
    dct:creator "?" ;
    dct:date "2007"^^xsd:gYear ;
    dct:source "https://cdm.unfccc.int/DNA/DNA/allCountriesARInfos.html"^^xsd:anyURI ;
    dct:spatial "Myanmar" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Cover = 10%; Area = 0.1 ha; Tree height = 2 m"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Myanmar 2007?" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_88 a skos:Concept ;
    dct:source "http://www.cup.cam.ac.uk/esl/dictionary/default.asp?String=forest*1%2B0&ACT=SELECT"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A large area full of trees, usually wild"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_880 a skos:Concept ;
    dct:date "1997"^^xsd:gYear ;
    dct:spatial "Namibia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest = areas with tree height 5 m, Savanna/shrub = areas with tree height <5 m. Canopy cover 20%. Moses Chakanga. chakanga@forestry.met.gov.na and (Trevett 1997"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Namibia 1997" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_881 a skos:Concept ;
    dct:creator "&" ;
    dct:date "1964"^^xsd:gYear ;
    dct:source "http://rmportal.net/tools/biodiversity-support-program/cbnfm/USAID-BDB-cd-2-data/pnabb308-nepal.pdf/attachment_download/file"^^xsd:anyURI ;
    dct:spatial "Nepal" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Crown cover greater than 50 percent. Wallace, Michael B. 1988. Forest degradation in Nepal: Institutional context and policy alternatives. Research Report Series No. 6. 46 p"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Nepal 1964 &1977" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_882 a skos:Concept ;
    dct:date "1993"^^xsd:gYear ;
    dct:source "http://www.biodiv-nepal.gov.np/dofchapter.html"^^xsd:anyURI,
        "http://www.recoftc.org/site/fileadmin/docs/Country_profile/forest_act_combined.pdf"^^xsd:anyURI ;
    dct:spatial "Nepal" ;
    skos:broadMatch ex:Forest ;
    skos:definition "An area fully or partly covered by trees (Forest Act 1993). Krishna H Gautam <khg13@student.canterbury.ac.nz and. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Nepal 1993" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_883 a skos:Concept ;
    dct:date "1999"^^xsd:gYear ;
    dct:source "http://eprints.usq.edu.au/568/1/Livelihood_Paper-Final.pdf"^^xsd:anyURI ;
    dct:spatial "Nepal" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest is defined as the land with a forest cover, i.e. with trees whose crown cover more than 10 percent of the area and not used primarily for the purpose other than forestry and shrub is same as forest but well defined stem can not be found (MFSC, 1999"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Nepal 1999" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_884 a skos:Concept ;
    dct:date "2000"^^xsd:gYear ;
    dct:source "http://www.fao.org/forestry/fo/country/index.jsp?lang_id=1&geo_id=35"^^xsd:anyURI ;
    dct:spatial "Nepal" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Crown Cover 10%. . Wallace (1988) also indicates a 50% threshold for crown cover"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Nepal 2000" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_885 a skos:Concept ;
    dct:date "1997"^^xsd:gYear ;
    dct:spatial "Netherlands" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land areas of 0.5 ha and more with a width of at least 30 m that are covered with trees or brushes; with a at maturity, a crown closure of 20% and over, the crown closure may (temporary) be lower than this figure because of final fellings for example; the tree and brush species should be able to form forests. (European Communities 1997b - p. 727"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Netherlands 1997" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_886 a skos:Concept ;
    dct:date "2006"^^xsd:gYear ;
    dct:source "http://www.efi.int/files/attachments/publications/annex_1_to_efi_technical_report_88__2013.pdf"^^xsd:anyURI ;
    dct:spatial "Netherlands" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land with tree crown cover (or equivalent stocking level) of more than 10 % and area of more than 0.5 ha. The trees should be able to reach a minimum height of 5 m at maturity in situ. Landbouw, natuur en Voedselkwaliteit, 2006"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Netherlands 2006" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_887 a skos:Concept ;
    dct:date "2006"^^xsd:gYear ;
    dct:source "http://www.efi.int/files/attachments/publications/annex_1_to_efi_technical_report_88__2013.pdf"^^xsd:anyURI ;
    dct:spatial "Netherlands" ;
    skos:broadMatch ex:Forest ;
    skos:definition "National definition: Under forest is normally closed forests with a mean crown projection of less than 60%. There is no longer any old natural forest present in the Netherlands, and virtually all forest is planted. Only in some heaths and marshes is there any spontaneous natural regeneration. About 7% of forest area is such naturally regenerating young forest. Landbouw, natuur en Voedselkwaliteit, 2006"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Netherlands 2006" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_889 a skos:Concept ;
    dct:date "1998"^^xsd:gYear ;
    dct:spatial "New Zealand" ;
    skos:broadMatch ex:Forest ;
    skos:definition "A tree-covered area greater than 5 hectares with an average canopy height of at least 6 metres and a minimum 20 percent tree crown coverage. In \"closed forests\" the trees occur in single or multiple stories with crowns interlocking.From: Indigenous Forest Policy (New Zealand Institute of Forestry, July 1998"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "New Zealand 1998" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_89 a skos:Concept ;
    dct:source "http://www.cup.cam.ac.uk/elt/dictionary/default.asp?String=forest*1%2B0&ACT=SELECT"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A large area of land covered with trees and plants, usually larger than a wood, or the trees and plants themselves"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_890 a skos:Concept ;
    dct:date "2003"^^xsd:gYear ;
    dct:source "http://www.fs.fed.us/research/sustain/2003SustainabilityReport/documents/SustainableForests.pdf"^^xsd:anyURI ;
    dct:spatial "New Zealand" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Minimum area = 0.5 ha, minimum tree crown cover =20%, minimum tree height = 6 m"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "New Zealand 2003" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_891 a skos:Concept ;
    dct:creator "ia" ;
    dct:date "2005"^^xsd:gYear ;
    dct:source "http://www.redd-monitor.org/2009/09/08/redd-will-fail-with-the-current-definition-of-forest/"^^xsd:anyURI ;
    dct:spatial "Niger" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest in terms of its resources from a research conducted in the forest communities of Cross Rivers State of Nigeria in 2005 which was sponsored by United States Agency for International Development (USAID). “Forest” means a land area covered by trees and other plant species and inhabited by animal species in its natural state or which could be State Forest Reserve, Community Forest, Private Forest or Forest designated as World Heritage, managed or manageable or exploited by human species in a sustainable manner”"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Nigeria 2005" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_892 a skos:Concept ;
    dct:spatial "Northern Mariana Islands" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Natural or man-made group of trees (diverse species) growing within a minimum area of 100 sq. ft. Source: Estanislao Villagomez stanvill@gtepacifica.net Division of Agriculture"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Northern Mariana Islands" ;
    skos:prefLabel "Forest"@no ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_893 a skos:Concept ;
    dct:date "2010"^^xsd:gYear ;
    dct:source "http://www.klif.no/publikasjoner/2639/ta2639.pdf"^^xsd:anyURI ;
    dct:spatial "Norway" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest land is defined according to the Global Forest Resources Assessment (FRA) 2004.Forest land is land with tree crown cover of more than 10 per cent and area of more than 0.5 ha. The trees should be able to reach a minimum height of 5 m at maturity in situ. No minimum width for Forest land is considered in the Norwegian inventory causing a small discrepancy according to the definition in FRA 2004"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Norway 2010" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_894 a skos:Concept ;
    dct:date "1953"^^xsd:gYear ;
    dct:spatial "Pakistan" ;
    skos:broadMatch ex:Forest ;
    skos:definition "A plant community predominantly of trees and other woody vegetation, usually with a closed canopy. Definition adopted from the British Commonwealth Forest Terminology Part-I, 1953. Source: Mumtaz Ahmad, Section Forest Officer, Pakistan Min. of Environment, Local Government, and Rural Development"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Pakistan 1953" ;
    skos:prefLabel "Forest"@no ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_895 a skos:Concept ;
    dct:date "2007"^^xsd:gYear ;
    dct:source "http://www.intercooperation.org.pk/uploads/CDM-FINAL%20report.pdf"^^xsd:anyURI,
        "https://cdm.unfccc.int/DNA/DNA/allCountriesARInfos.html"^^xsd:anyURI ;
    dct:spatial "Pakistan" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Pakistan is an area comprising not less than 0.05 ha with tree crown cover of more than 30% with trees with the potential to reach a minimum height of 3 meters. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Pakistan 2007" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_896 a skos:Concept ;
    dct:date "1992"^^xsd:gYear ;
    dct:spatial "Panama" ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"Cobertura Boscosa\" se definieron dos dases, la piimera como: a) \"Cobertura Boscosa poco Intervenida\" la cual corresponds a una superficie densamente cubierta por copas de una gran cantidad de arboles, independientemente del tipo de bosque y/o especies forestales que pudieran encontrarse; y una segunda categoria definida como: b) \"Cobertura Boscosa Fuertemente Intervenida\", la cual corresponds a superfides boscosas en donde la cobertura de copas fluctúa entre 45% y 60% del terreno, independientemente de las especies que la componen. Source: Informe de Cobertura Boscosa 1992. Junio 1995. Republic of Panama, Instituto Nacional de Recursos Naturales Renovables, Direccion Nacional de Cuencsa Hidrograficas"@es ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Panama 1992" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_897 a skos:Concept ;
    dct:creator "Papua New" ;
    dct:spatial "Guinea" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Natural communities of flora (trees) and fauna (birds, animals) in a natural setting. Forest has a crown closure of 10% and above as opposed to non-forest and an area of more than 100 hectares as being the standard. Forest can imply both natural forest and plantations but more so the former (natural). Vitus Ambia, Papua New Guinea Forest Authority"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Papua New Guinea" ;
    skos:prefLabel "Forest"@no ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_898 a skos:Concept ;
    dct:spatial "Peru" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Comunidades vegetales naturales en las que predominan especies leñosas referidas a determinada superficie del suelo, así como las plantaciones forestales. (Ley Forestal y de Fauna Silvestre, Art. 8"@es ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Peru" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_899 a skos:Concept ;
    dct:creator "FREL" ;
    dct:date "2014"^^xsd:gYear ;
    dct:source "http://redd.unfccc.int/files/2015_submission_frel_peru_en.pdf"^^xsd:anyURI ;
    dct:spatial "Peru" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Activity data used for constructing the proposed FREL is based on the following definition of \"forest\" of the National Forest Inventory (MINAM and MINAGRI, 2014.a) taking the minimum area to the technological requirements of a methodology: • Minimum Mapping Unit: 1 Landsat pixel (0.09 hectares); • Minimum tree height at maturity in situ: 5.00 . The Ministry of the Environment chose the third definition for REDD+ reporting purposes taking into consideration the scale of land-use change in the Amazon and the technical specifications of the activity data processing chain. This definition captures the spatiotemporal patterns of predominantly smaller deforestation events. Moreover, the definition is compatible with the forest definition applied in the National Forest Inventory which requires a larger minimum forest area to accommodate the inventory clusters. Both forest definitions, the one used in the NFI and the definition used to provide activity data on deforestation, are used in the National GHG Inventories 2010 (submitted as part of the BUR in 2014) and 2012 submitted within the Third National Communication in 2015. The Government of Peru will harmonize its forest definitions, once new remote sensing technologies provide the data and means to accurately capture land-use changes dynamics across different biomes"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Peru 2014 FREL" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_9 a skos:Concept ;
    dct:source "http://www.ceres.org/conference/notes/sustainable_forestry.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A certain territory of woody ground and fruitful pastures privileged for wild beasts and fowl of forest, chase and warren to rest and abide in, in the safe protection of the king for his pleasure"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "General"@en .

ex:Forest_90 a skos:Concept ;
    dct:source "http://machaut.uchicago.edu/cgi-bin/WEDT1.sh?word=forest&searchtype=default&constraint=1"^^xsd:anyURI,
        "http://www.wordsmyth.net/cgi-bin/simplesearch.cgi?matchent=forest&matchtype=exact&matchid=-1&retall=1"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A large area of land densely covered with trees and other plants and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_900 a skos:Concept ;
    dct:creator "– Amazon" ;
    dct:date "2015"^^xsd:gYear ;
    dct:source "http://redd.unfccc.int/files/2015_submission_frel_peru_en.pdf"^^xsd:anyURI ;
    dct:spatial "Peru" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Currently being implemented, the National Forest Inventory applies specific forest definitions for the three biomes Costa, Sierra, and the Amazon. In case of the Amazon, the following parameters are used: • Minimum area: 0.50 hectares; • Minimum width: 20.00 m • Minimum tree height at maturity in situ: 5.00 m; • Minimum crown cover: 10%"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Peru 2015 – Amazon" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_901 a skos:Concept ;
    dct:creator "CDM" ;
    dct:date "2015"^^xsd:gYear ;
    dct:source "http://redd.unfccc.int/files/2015_submission_frel_peru_en.pdf"^^xsd:anyURI ;
    dct:spatial "Peru" ;
    skos:broadMatch ex:Forest ;
    skos:definition "The Peruvian Designated National Authority (DNA) of the Clean Development Mechanism (CDM) reported to the UNFCCC the following definition of “forest”, which is used in the context of afforestation and reforestation project activities under the CDM. • Minimum area: 0.50 hectares; • Minimum tree height at maturity in situ: 5.00 m; • Minimum crown cover: 30%"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Peru 2015 - CDM" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_902 a skos:Concept ;
    dct:date "2000"^^xsd:gYear ;
    dct:source "http://www.nscb.gov.ph/glossary/AGRI.ASP"^^xsd:anyURI ;
    dct:spatial "Philippines" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Refers to land with an area of more than 0.5 hectare and tree crown cover (or equivalent stocking level) of more than 10 percent. The trees should be able to reach a minimum height of 5 meters at maturity in situ. It consists either of closed forest formations where trees of various storeys and undergrowth cover a high proportion of the ground or open forest formations with a continuous vegetation cover in which tree crown cover exceeds 10 percent. Young natural stands and all plantations established for forestry purposes, which have yet to reach a crown density of more than 10 percent or tree height of 5 meters are included under forest. These are normally forming part of the forest area, which are temporarily unstocked as a result of human intervention or natural causes but which are expected to revert to forest. It includes forest nurseries and seed orchards that constitute an integral part of the forest; forest roads, cleared tracts, firebreaks and other small open areas; forest within protected areas; windbreaks and shelter belts of trees with an area of more than 0.5 hectare and width of more than 20 meter; plantations primarily used for forestry purposes, including rubber wood plantations. It also includes bamboo, palm and fern formations (except coconut and oil palm). Reference: Food and Agriculture Organization, 2000"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Philippines 2000" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_903 a skos:Concept ;
    dct:source "http://www.haribon.org.ph/attachments/article/425/Forest%20Resources%20Bill_HB3638%20with%20primer.pdf"^^xsd:anyURI ;
    dct:spatial "Philippines" ;
    skos:broadMatch ex:Forest ;
    skos:definition "A forest is best described as an ecosystem wherein trees are the dominant life form, as a community of plants and animals interacting with one another and its physical environment, and as consisting of trees with overlapping crown of 60-100% forest cover, as defined by the United States National Vegetation Classification system (Section 4"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Philippines" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_904 a skos:Concept ;
    dct:source "http://www.nscb.gov.ph/glossary/enr.htm"^^xsd:anyURI,
        "http://www.nscb.gov.ph/ru12/DEFINE/DEF-ENV.HTM"^^xsd:anyURI ;
    dct:spatial "Philippines" ;
    skos:broadMatch ex:Forest ;
    skos:definition "areas of one hectare or more which are at least 10 percent stocked with forest trees (including seedlings and saplings), with palm, bamboo, or brush. Narrow strips of land bearing forest must be at least 60 meters wide and one hectare in size to qualify as forest. Industrial plantations and tree farms, one hectare or more in sizes, are also included. and (Forest Management Bureau"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Philippines" ;
    skos:prefLabel "Forest"@no ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_905 a skos:Concept ;
    dct:source "http://law.upd.edu.ph/plj/images/files/PLJ%20volume%2066/PLJ%20volume%2066%20first%20quarter%20-05-%20Antonio%20G.M.%20La%20Vi"^^xsd:anyURI ;
    dct:spatial "Philippines" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Senate Bill No. 1404 defines \"forest cover\" as follows: \"forest cover includes pine forest, mossy forest, dipterocarp forest (closed and open canopy) and mangrove vegetation: ña%20-%20Conservation%20and%20Democratization.pdf"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Philippines" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_907 a skos:Concept ;
    dct:source "http://www.fris.sk/Phare/Projects/ManagementOfForestInEurope/PDF/annex2.pdf"^^xsd:anyURI ;
    dct:spatial "Poland" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Continuous area of at least 0.1 ha covered by forest vegetation (forest stands) = trees and shrubs with herbaceous ground cover"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Poland" ;
    skos:prefLabel "Forest"@no ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_908 a skos:Concept ;
    dct:creator "?" ;
    dct:date "1991"^^xsd:gYear ;
    dct:source "http://icaci.org/documents/ICC_proceedings/ICC2011/Oral%20Presentations%20PDF/A3-Data%20integration/CO-028.pdf"^^xsd:anyURI ;
    dct:spatial "Poland" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest Act of 28 September 1991. (OJ 1991 No 101 item. 444) for the forest land is considered a homogeneous area of at least 0.10 ha, which is covered by forest vegetation (forest crop), i.e. trees, shrubs and forest undergrowth or temporarily deprived of that what is intended for forest production(…) (Forest Act, 1991"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Poland? 1991" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_909 a skos:Concept ;
    dct:creator "?" ;
    dct:source "http://icaci.org/documents/ICC_proceedings/ICC2011/Oral%20Presentations%20PDF/A3-Data%20integration/CO-028.pdf"^^xsd:anyURI ;
    dct:spatial "Poland" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest and wooded lands class covers the area with dense plantings: forests, scrubs and others. The minimum width of a wooded area shall be 15 m and a minimum length of 40 m. Group of trees, small forest or scrub with the surface less than 1000 m2 represent the class Natural Object. In the area of double-storied stand scrubs are included into the forest when their surface is less than 2000 m2"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Poland?" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_91 a skos:Concept ;
    dct:source "http://www.europe.apnet.com/inscight/12031996/forest1.htm"^^xsd:anyURI,
        "http://www.harcourt.com/dictionary/def/4/1/0/7/4107300.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A large area of land that is covered by trees and associated undergrowth, either growing wild or managed for the purpose of timber production. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_910 a skos:Concept ;
    dct:creator "Portuga" ;
    dct:date "2010"^^xsd:gYear ;
    dct:source "http://www.efi.int/files/attachments/publications/annex_1_to_efi_technical_report_88__2013.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "l Extent of land with an area ≥ 5 000 m2 and a width ≥ 20 m, with a degree of covered (defined as the ratio between the area of horizontal projection of the crown and the total area of the plot) ≥ 10% which reveal the presence of trees that forest for their characteristics or form of exploitation has reached or will reach, arboreal (height than 5 m) regardless of the stage which is the time of observation. Autoridade Florestal National (AFN) and Ministerio da Agricoltura do Desenvolvimento Rural e das Pesca, 2010"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Portuga 2010" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_911 a skos:Concept ;
    dct:date "1994"^^xsd:gYear ;
    dct:spatial "Portugal" ;
    skos:broadMatch ex:Forest ;
    skos:definition "According to minimum tree densities which vary from species to species (as low as 90/ha for cork oak, up to 840 for most conifers) with conifer heights from 1.5-5m hand broadleaf heights from 2-5m; or where the projected area of crowns of trees more than 5m height covers more than 15% of the ground areas. This rather complicated definition is necessary to define when grant payments are applicable and is necessary because Portugal has a long agroforestry tradition. (decree 199/94) From: Gerry Lawson <gjl@ite.ac.uk"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Portugal 1994" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_913 a skos:Concept ;
    dct:date "2010"^^xsd:gYear ;
    dct:source "http://www.efi.int/files/attachments/publications/annex_1_to_efi_technical_report_88__2013.pdf"^^xsd:anyURI ;
    dct:spatial "Portugal" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Extent of land with an area ≥ 5 000 m2 and a width ≥ 20 m, with a degree of covered (defined as the ratio between the area of horizontal projection of the crown and the total area of the plot) ≥ 10% which reveal the presence of trees that forest for their characteristics or form of exploitation has reached or will reach, arboreal (height than 5 m) regardless of the stage which is the time of observation. Autoridade Florestal National (AFN) and Ministerio da Agricoltura do Desenvolvimento Rural e das Pesca, 2010"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Portugal 2010" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_914 a skos:Concept ;
    dct:date "1996"^^xsd:gYear ;
    dct:source "http://www.fao.org/docrep/w7170E/w7170e0f.htm"^^xsd:anyURI ;
    dct:spatial "Oman" ;
    skos:broadMatch ex:Forest ;
    skos:definition "The total forest vegetation mentioned in the Forest Management Plans, both state-owned or private property, constitute the national forest area. Under the Forestry Code/1996 a forest area is defined as an area larger than 0.25 ha and covered with forest trees; the current forestry code refers to forest vegetation not included in the national forest area as forested pastures, forest windbreaks, forested low production areas, forests for watershed protection, community forest parks, dendrologic collections, forest tree alignments and the alpine vegetation with Pinus mugo"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Romania 1996" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_915 a skos:Concept ;
    dct:date "2000"^^xsd:gYear ;
    dct:source "http://www.fris.sk/Phare/Projects/ManagementOfForestInEurope/PDF/annex2.pdf"^^xsd:anyURI ;
    dct:spatial "Oman" ;
    skos:broadMatch ex:Forest ;
    skos:definition "land covered by forest vegetation with an area of more than 0.25 ha. For FRA 2000 - Source: UN/ECE 2000 p 85 and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Romania 2000" ;
    skos:prefLabel "- Forest"@no ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_916 a skos:Concept ;
    dct:date "2011"^^xsd:gYear ;
    dct:source "http://www.efi.int/files/attachments/publications/annex_1_to_efi_technical_report_88__2013.pdf"^^xsd:anyURI ;
    dct:spatial "Oman" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest is a land covered 0.5 ha, 10% crown cover and 5 m height. SILVA RNP, 2011"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Romania 2011" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_917 a skos:Concept ;
    dct:source "http://www.unece.org/fileadmin/DAM/timber/fra/pdf/chp1_tot.pdf"^^xsd:anyURI ;
    dct:spatial "Oman" ;
    skos:broadMatch ex:Forest ;
    skos:definition "According to the definition given in our “Forest Code”, forest is considered land covered by forest vegetation with an area of more than 0.25 ha. In order to approximate the TBFRA definition of the forest, the item “Forest” includes lands needed for culture (nurseries, orchards...), for production (game food...), for administration (forest roads, fire breaks...) and temporarily excluded from the “forest fund”. These are separately recorded in our statistics and in addition to forest area make “forest fund"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Romania" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_918 a skos:Concept ;
    dct:spatial "Oman" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Dense group of trees, interdependent one to another and to the other plants, animals and environmental conditions, creating a complex and unitary community, able to fulfill social and economic functions. Sorin Sfirlogea <sorinsf@rosilva.ro National Forests Administration"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Romania" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_919 a skos:Concept ;
    dct:spatial "Oman" ;
    skos:broadMatch ex:Forest ;
    skos:definition "This term includes not only surfaces covered by forest vegetation, but also nurseries, administrative surfaces (around the forest ranges offices, a.o.) glades (blanks) (M. Ilie, Bucuresti, Romania"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Romania" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_92 a skos:Concept ;
    dct:source "http://entomology.cornell.edu/cals/entomology/extension/outreach/upload/Daley_TeacherResource_Forest.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A large area of trees clumped together is called a forest"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_920 a skos:Concept ;
    dct:date "1998"^^xsd:gYear ;
    dct:spatial "Russian Federation" ;
    skos:broadMatch ex:Forest ;
    skos:definition "A population of forest plants changed in the exterior form and an internal structure under influence of effect against each other, on occupied soil and atmosphere. (G.F. Morozov- archfounder of scientific forestry in Russia). In practice of forestry forest consider as tree stands with a polnota more than 0,3. If polnota less than 0,3 - stand calls as light forest or open woodland. Main difference of a forest from \"not forests \" - the existence of mutual influence between all elementary component of a forest. [From: \" Russian Forest Encyclopedia\" \"Igor Yakovlev\" yakovlev@mari-el.ru Date: Sat, 6 Jun 1998 21:16:59 +0400]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Russian Federation 1998" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_921 a skos:Concept ;
    dct:date "1998"^^xsd:gYear ;
    dct:spatial "Russian Federation" ;
    skos:broadMatch ex:Forest ;
    skos:definition "One of main types of vegetation consist of an aggregate of trees, shrub, grassy etc. plants (mosses, lichens), including animals and microorganisms biologically interconnected in the development and influencing against each other and an environment. [From: \" Russian Forest Encyclopedia\" \"Igor Yakovlev\" yakovlev@mari-el.ru Date: Sat, 6 Jun 1998 21:16:59 +0400]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Russian Federation 1998" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_922 a skos:Concept ;
    dct:date "2003"^^xsd:gYear ;
    dct:source "http://www.fs.fed.us/research/sustain/2003SustainabilityReport/documents/SustainableForests.pdf"^^xsd:anyURI ;
    dct:spatial "Russian Federation" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Minimum area = 0.5 ha, minimum tree crown cover =30%, minimum tree height = Varies"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Russian Federation 2003" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_923 a skos:Concept ;
    dct:spatial "Russian Federation" ;
    skos:broadMatch ex:Forest ;
    skos:definition "An element of the geographical landscape composed of the totality (the aggregate) of arboreal (woody), bushy (shrubbery), herbaceous plants, animals and microorganisms, which are biologically interdependent in their developments and influencing each other, as well as external environment (GOST 18486-73, Russia"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Russian Federation" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_924 a skos:Concept ;
    dct:date "2006"^^xsd:gYear ;
    dct:source "http://www.itc.nl/library/papers_2006/general/westinga_for.pdf"^^xsd:anyURI ;
    dct:spatial "Rwanda" ;
    skos:broadMatch ex:Forest ;
    skos:definition "In the humid region forest are areas larger than 0.5 ha with tree cover more than 20 % and trees are > 7m. In the dry region (Akagera) this is > 5m. Young forest plantation and coppices are only found in the humid area. Young forest plantation have trees less than 7 m and cover from 10- 40 % or trees more than 7 meter and cover from 10- 20 %. Bush is found in the larger humid natural forest. Tree cover is by definition less than 20 % and in practice mostly less than 10% and shrub cover more than 20 % and high forbs and grasses"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Rwanda 2006" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_925 a skos:Concept ;
    dct:date "2010"^^xsd:gYear ;
    dct:source "http://www.agit.at/php_files/myagit/papers/2010/8163.pdf"^^xsd:anyURI ;
    dct:spatial "Rwanda" ;
    skos:broadMatch ex:Forest ;
    skos:definition "A land with 0.5 ha or more covered with trees higher than 7 meters and a canopy cover of more than 10%, or tree stands which have the potential to reach these thresholds in situ"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Rwanda 2010" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_926 a skos:Concept ;
    dct:date "2010"^^xsd:gYear ;
    dct:source "http://rnra.rw/uploads/media/Forestry_Sector_Strategic_Plan.pdf"^^xsd:anyURI ;
    dct:spatial "Rwanda" ;
    skos:broadMatch ex:Forest ;
    skos:definition "An ecosystem dominated by trees (defined as perennial woody plants taller than 5 meters at maturity), where the tree crown cover (or equivalent stocking level) exceeds 10% of the ground surface and the area is larger than 0.5ha"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Rwanda 2010" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_927 a skos:Concept ;
    dct:date "2012"^^xsd:gYear ;
    dct:source "http://www.gsdi.org/gsdiconf/gsdi14/papers/29.pdf"^^xsd:anyURI ;
    dct:spatial "Rwanda" ;
    skos:broadMatch ex:Forest ;
    skos:definition "A group of trees higher than 7 m and a canopy cover of more than 10 %, or trees able to reach these thresholds in situ on a land of about 0.25 ha or more"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Rwanda 2012" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_928 a skos:Concept ;
    dct:creator "Slovak Republic" ;
    dct:date "2011"^^xsd:gYear ;
    dct:source "http://www.efi.int/files/attachments/publications/annex_1_to_efi_technical_report_88__2013.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A forest is defined as land with tree crown cover of more than 10%, an area of more than 0.5 ha and an average width of more than 20 m. Trees should be able to reach a minimum height of 5 m at maturity in situ. FOREST EUROPE, UNECE AND FAO, 2011. Ministry of Agriculture of the Slovak Republic, 2009"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Slovak Republic 2011" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_929 a skos:Concept ;
    dct:creator "Slovak Republilc" ;
    dct:date "2009"^^xsd:gYear ;
    dct:source "http://www.efi.int/files/attachments/publications/annex_1_to_efi_technical_report_88__2013.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "National definition: Forest is land spanning more than 0.3 ha with trees taller than 5 m and a canopy cover of more than 20%, or trees able to reach these thresholds in situ. Ministry of Agriculture of the Slovak Republic, 2009"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Slovak Republilc 2009" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_93 a skos:Concept ;
    dct:creator "10 degrees C" ;
    dct:source "http://www.zmt-bremen.de/files/Downlods/marine_glossary.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A large area thickly covered with trees. Forests grow in different conditions, although large stands of trees need temperatures above about 50 degrees F in the warmest months and an annual precipitation over 8 inches (20 cm). Forests are distinguished by their main species of trees and plants, density, and soil type"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "10 degrees C" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_930 a skos:Concept ;
    dct:date "1993"^^xsd:gYear ;
    dct:source "http://www.iufro.org/download/file/5574/4510/61300-jundola01_pdf/"^^xsd:anyURI ;
    dct:spatial "Slovenia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Under the 1993 Forest Act, a forest is an area of land covered with forest trees in the form of a stand or with other forest growth, which ensures any forest function (economic, ecological and social"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Slovenia 1993" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_931 a skos:Concept ;
    dct:date "1994"^^xsd:gYear ;
    dct:source "http://unfccc.int/files/national_reports/initial_reports_under_the_kyoto_protocol/application/msword/initial_report-slovenia.docSlovenian"^^xsd:anyURI ;
    dct:spatial "Slovenia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Cover Min. Area (ha) = 0.05 Min. Crown Cover (%) = Min. Tree Height (m) = Min. Strip Width (m) = ns Excludes individual trees- riverine and windbelt trees- plantations- etc. Forest act (1994) -Forest means land overgrown with forest trees in the form of stands or other forest plants which provides any of the functions of a forest. Forest according to this Act also includes overgrown plots of land defined as forest in the spatial element of the forest management plan"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Slovenia 1994" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_932 a skos:Concept ;
    dct:date "1998"^^xsd:gYear ;
    dct:spatial "Slovenia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "A plot of land overgrown with forest trees in the form of stands or other forest growths which provide any of the functions of a forest. Forests according to this law also include overgrown plots of land defined as forest in the spatial element of the forest management plan. The following are not forest within the meaning of this law: individual forest trees, groups of forest trees up to an area of five hectares, non-autochthonous riverine and windbelt trees, avenues, parks, plantations of forest trees, pens for rearing game, and pastures overgrown with forest trees if used for pasturing, irrespective of how they are described in the land register. [From: Slovenian LAW ON FORESTS - Milan SINKO milan.sinko@UNI-LJ.SI via \"Maksym Polyakov\" <mpoliak@pcomp.usau.kiev.ua Date: Fri, 12 Jun 1998 16:11:17 +0300 (MSD)]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Slovenia 1998" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_933 a skos:Concept ;
    dct:date "2007"^^xsd:gYear ;
    dct:source "http://bookshop.europa.eu/is-bin/INTERSHOP.enfinity/WFS/EU-Bookshop-Site/en_GB/-/EUR/ViewPDFFile-OpenPDFFile?FileName=LBNA24300ENC_002.pdf&SKU=LBNA24300ENC_PDF"^^xsd:anyURI ;
    dct:spatial "Slovenia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "forest is land covered with forest trees in the form of stands with minimal tree height 5 m and with minimal area of 0.25 ha"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Slovenia 2007" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_935 a skos:Concept ;
    dct:date "2009"^^xsd:gYear ;
    dct:source "http://www.efi.int/files/attachments/publications/annex_1_to_efi_technical_report_88__2013.pdf"^^xsd:anyURI ;
    dct:spatial "Slovenia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "The national forest inventory defines forest as: (a) A plot of land overgrown with forest trees in the form of stands, which can reach a height of at least 5 m and sized to at least 0.25 ha (b) A plot of agricultural land in transition to forest land sized to at least 0.25 ha that has not been used for agriculture for the last 20 years and is overgrown with forest trees which can reach a height of at least 5 m and their crown cover should be at least 75% (c) Riverside forest corridors and windbreaks sized to at least 0.25 ha, if their widths are at least one tree-height. Kusar et al. in Tomppo et al. 2009. P. 439-440"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Slovenia 2009" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_936 a skos:Concept ;
    dct:date "2013"^^xsd:gYear ;
    dct:source "http://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:32013D0529"^^xsd:anyURI ;
    dct:spatial "Slovenia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Area (ha) 0.25; Tree crown cover (%) 30; Tree height (m) 2"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Slovenia 2013" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_937 a skos:Concept ;
    dct:source "http://www.fris.sk/Phare/Projects/ManagementOfForestInEurope/PDF/annex2.pdf"^^xsd:anyURI ;
    dct:spatial "Slovenia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "A land overgrown with forest trees - stands or other plants - which provides any of the functions of forests. Includes: land defined as forests in the forest management plan, and forest infrastructure not allocated into a separate lot. Excludes: individual trees and groups of forest trees smaller than 0.05 ha, non-native riverain and windbelt trees, avenues, parks, plantations of forest trees, pens for rearing game, pastures overgrown with forest trees. Definition applies also to forest trees outside forests insofar as they are specifically defined"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Slovenia" ;
    skos:prefLabel "Forest"@no ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_938 a skos:Concept ;
    dct:date "1999"^^xsd:gYear ;
    dct:spatial "Solomon Islands" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Any area of land predominantly covered by trees, and includes areas planted with trees except when such planting is carried out for agricultural purposes. [LEX-FAOC018884] SOLOMON ISLANDS: Forests Act (No. 3 of 1999). Date of text: 24 September 1999"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Solomon Islands 1999" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_939 a skos:Concept ;
    dct:spatial "Mali" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Min. av. height 5-10 m. Canopy closure 20%. Source: ECE-FAO Partnership Programme: Kenya Workshop on Forestry Statistics. Appendix 6"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Somalia" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_94 a skos:Concept ;
    dct:source "http://www.3datlas.com/list_gl.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A large area thickly covered with trees"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_940 a skos:Concept ;
    dct:date "1996"^^xsd:gYear ;
    dct:spatial "South Africa" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Tree canopy cover >70%. A multi-strata community with interlocking canopies, composed of canopy, subcanopy, shrub and herb layers. Excludes planted forests. Thompson. 1996? www.sac.co.za/geoinfo/ field_guide.htm"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "South Africa 1996" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_941 a skos:Concept ;
    dct:date "1998"^^xsd:gYear ;
    dct:source "http://www.oceandocs.net/bitstream/1834/560/1/case%20study.pdf"^^xsd:anyURI ;
    dct:spatial "South Africa" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest is defined as more than two trees whose canopies touch. 1998 Forest Act"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "South Africa 1998" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_942 a skos:Concept ;
    dct:date "1998"^^xsd:gYear ;
    dct:source "http://www.ext.grida.no/soesa/nsoer/resource/wetland/inventory_classif.htm#classes"^^xsd:anyURI ;
    dct:spatial "South Africa" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forested (wetland) A class is characterised by woody vegetation that is taller than 6 m. These habitats normally possess an overstorey of trees, an understorey of young trees or shrubs, and a herbaceous layer. South African National Wetland Inventory . Proposed wetland classification system for South Africa . J. Dini, G. Cowan & P. Goodman. FIRST DRAFT. August 1998"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "South Africa 1998" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_943 a skos:Concept ;
    dct:date "1999"^^xsd:gYear ;
    dct:source "http://www.environmental-auditing.org/LinkClick.aspx?fileticket=fbx%2FbAIVeFU%3D&tabid=128&mid=568"^^xsd:anyURI ;
    dct:spatial "South Africa" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest is a continuous stand of trees at least 10m tall, with their crowns interlocking. It is generally multi-layered vegetation unit dominated by trees (largely evergreen or semi-deciduous) whose combined strata have overlapping crowns (i.e. crown cover is > 75 percent). (Bailey, et.al., 1999"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "South Africa 1999" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_944 a skos:Concept ;
    dct:date "2002"^^xsd:gYear ;
    dct:source "http://www.fao.org/docrep/005/y4001e/Y4001E06a.htm"^^xsd:anyURI ;
    dct:spatial "South Africa" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Indigenous forest is defined as \"a generally multilayered vegetation unit dominated by trees (largely evergreen or semi-deciduous) whose combined strata have overlapping crowns (i.e. the crown cover is greater than or equal to 75 percent), and where graminoids in the herbaceous stratum (if present) are generally rare\""@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "South Africa 2002" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_945 a skos:Concept ;
    dct:spatial "South Africa" ;
    skos:broadMatch ex:Forest ;
    skos:definition "“Forest” means any ecosystem containing trees on forest land or any component of such an ecosystem, and includes land, water, air, woody vegetation and living organisms; www.dwaf.gov.za/Forestry/Forestry%20Policy/October%202001%20draft%20Protocol.doc"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "South Africa" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_946 a skos:Concept ;
    dct:source "http://www.polity.org.za/govdocs/green_papers/forest1.html#t1.1"^^xsd:anyURI ;
    dct:spatial "South Africa" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Closed canopy with three or more tree layers; many species and age classes; typically 5 to 20 m tall. Fires penetrate only rarely. Note: This definition of Forest appearst to exclude Plantations, Woodlands, and Wooded Grasslands"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "South Africa" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_947 a skos:Concept ;
    dct:spatial "South Africa" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Multi-layered vegetation of trees with a cover of greater than 75%. Fire does not normally pass through forest. From: Graeme Wild <GraemeW@za.sappi.com"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "South Africa" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_948 a skos:Concept ;
    dct:creator "South" ;
    dct:source "http://www.globalforestwatch.org/map/7/6.84/30.48/ALL/grayscale/loss,forestgain?begin=2001-01-01&end=2014-12-31&threshold=15"^^xsd:anyURI ;
    dct:spatial "Sudan" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Global Forest Watch South Sudan Product using 15% canopy cover"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "South Sudan" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_949 a skos:Concept ;
    dct:creator "South" ;
    dct:date "2009"^^xsd:gYear ;
    dct:spatial "Sudan" ;
    skos:broadMatch ex:Forest ;
    skos:definition "“Forest” mean any land containing a vegetation association dominated by trees of any size, whether exploitable or not, capable of producing wood or other products, potentially capable of influencing climate, exercising an influence on the soil, water regime, and providing habitat for wildlife, and includes woodlands; (CAMP Task Team, 2013"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "South Sudan 2009" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_95 a skos:Concept ;
    dct:source "http://www.linguistics.ruhr-uni-bochum.de:8099/cgi-bin/search.sh?tmpl=tmpls&itmpl=tmpls&form=forest"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A large area where trees grow close together"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_950 a skos:Concept ;
    dct:date "1997"^^xsd:gYear ;
    dct:spatial "Spain" ;
    skos:broadMatch ex:Forest ;
    skos:definition "A territory or ecosystem predominately with tree species and a cover closure = 10 %, also includes open forest over cultivated or pasture land where the crown closure is = 20 %. (European Communities 1997b - p. 927"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Spain 1997" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_951 a skos:Concept ;
    dct:date "2008"^^xsd:gYear ;
    dct:source "http://www.efi.int/files/attachments/publications/annex_1_to_efi_technical_report_88__2013.pdf"^^xsd:anyURI ;
    dct:spatial "Spain" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest surface is considered the land populated by forest tree species and whose dominant canopy cover (FCC) is more than 10%. It consists of: (i) woodland - land with trees whose FCC> = 20%; (ii) sparse woodland - 10% = <FCC <20%. It also includes land with scrub or grassland species dominant plant natural expression, but a FCC of between 10% and 20%. Ministerio de Medio Ambiente y Medio Rural y Marino, 2008"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Spain 2008" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_954 a skos:Concept ;
    dct:creator "St. Lucia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Any area of land covered in trees usually of various ages, mixed or single species as in forest plantations. (Source: Michael Andrew, chiefforest@maffe.org"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "St. Lucia" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_955 a skos:Concept ;
    dct:date "1970"^^xsd:gYear ;
    dct:source "http://postconflict.unep.ch/publications/sudan/09_forests.pdf"^^xsd:anyURI ;
    dct:spatial "Sudan" ;
    skos:broadMatch ex:Forest ;
    skos:definition "forests and woodlands as ‘any area of vegetation dominated by trees of any size’"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Sudan 1970" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_956 a skos:Concept ;
    dct:spatial "Sudan" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Min. av. height 10 m. Canopy closure 40 %. Source: ECE-FAO Partnership Programme: Kenya Workshop on Forestry Statistics. Appendix 6"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Sudan" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_957 a skos:Concept ;
    dct:creator "Swazi Nation" ;
    dct:date "1910"^^xsd:gYear ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"private forest\" means a forest, plantation or tree situate on land not owned by the Government, or on Swazi nation land; www.sntc.org.sz/documents/ForestPreservationAct.do"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Swazi Nation -1910" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_958 a skos:Concept ;
    dct:creator "Swaziland" ;
    dct:date "1994"^^xsd:gYear ;
    dct:source "https://scholar.sun.ac.za/bitstream/handle/10019.1/1174/Dlamini.pdf?sequence=1"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest – a vegetation type dominated by trees, which may be pristine rainforest, scrub woodland; Palm savanna or plantation (Wong 2000). According to FAO (1994) Forests are ecosystems with a minimlum of 10% cover of trees or bamboos"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Swaziland 1994" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_959 a skos:Concept ;
    dct:date "2000"^^xsd:gYear ;
    dct:spatial "Sweden" ;
    skos:broadMatch ex:Forest ;
    skos:definition "All land with a tree crown cover of more than 20 percent plus have the land with a tree crown cover ranging from 1 percent to 20 percent, and area more than 0.25 ha. For FRA 2000 - Source: UN/ECE 2000 p 87"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Sweden 2000" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_96 a skos:Concept ;
    dct:source "http://nhd.heinle.com/nhd-bin/searchNHD.pl"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A large area with many trees"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_961 a skos:Concept ;
    dct:date "2009"^^xsd:gYear ;
    dct:source "http://www.efi.int/files/attachments/publications/annex_1_to_efi_technical_report_88__2013.pdf"^^xsd:anyURI ;
    dct:spatial "Sweden" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Types of land under the Forestry Act Determined for the traditional types of land in productive forest, bog, mountain pine forests and other land. Forest land: Land bearing forest or without measures to increase production has the potential to bear forest with a height of 5 m and with a crown cover of at least 10%. Sveriges Lantbruksuniversitet (SLU), 2009"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Sweden 2009" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_963 a skos:Concept ;
    dct:date "1997"^^xsd:gYear ;
    dct:spatial "Switzerland" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Focuses on growing stock and applies to measurable criteria - width of forest area, crown closure and top height. Width of growing stock with canopy closure = 100% is at least 25 m and with crown closure = 20% at least 50 m. Canopy closure between 20 % and 100 % depending on width of growing stock. Minimum top height 3 m (exceptions afforestation, young growth, mountain alder, mountain pine) (European Communities 1997b - p. 1067"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Switzerland 1997" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_964 a skos:Concept ;
    dct:date "2006"^^xsd:gYear ;
    dct:source "http://www.efi.int/files/attachments/publications/annex_1_to_efi_technical_report_88__2013.pdf"^^xsd:anyURI ;
    dct:spatial "Switzerland" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest is land covered by trees with a minimum height of 3 m and the minimum width of the tree stand is 50 m. In addition, the tree crowns have to cover at least 20% of the area. Swiss Federal Research Institute (WSL) and Swiss Forest Monitoring, 2006"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Switzerland 2006" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_965 a skos:Concept ;
    dct:source "http://www.fao.org/legal/legstud/frmdocrep/41_AK476E.pdf"^^xsd:anyURI ;
    dct:spatial "Switzerland" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Any land area covered with forest trees or bushes"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Switzerland" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_966 a skos:Concept ;
    dct:creator "Taiwan, ROC" ;
    skos:broadMatch ex:Forest ;
    skos:definition "A plant association predominantly of trees and other woody vegetation ( Bamboo etc. ) in forest land. In Taiwan, the national forests are administrated by Taiwan Forestry Bureau, now subordinated to Council of Agriculture (COA). Source: \"&ordf;L&deg;È&sect;&frac12;service\" service@dns.forest.gov.tw"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Taiwan, ROC" ;
    skos:prefLabel "Forest"@no ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_967 a skos:Concept ;
    dct:date "1998"^^xsd:gYear ;
    dct:source "http://www.grida.no/prog/cee/enrin/htmls/tadjik/soe/forest/forest1.htm"^^xsd:anyURI ;
    dct:spatial "Tajikistan" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Ecosystems, which besides trees include soils, waters, and the multitude of associated animals, plants and micro-organisms. Source: State of the Environment Tajikistan 98 - Forest"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Tajikistan 1998" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_968 a skos:Concept ;
    dct:date "2010"^^xsd:gYear ;
    dct:source "http://naturalresources-centralasia.org/assets/files/Forestry%20sector%20analysis%20of%20the%20republic%20of%20Tajikistan%20eng.pdf"^^xsd:anyURI ;
    dct:spatial "Tajikistan" ;
    skos:broadMatch ex:Forest ;
    skos:definition "forests - an ecosystem with a minimum of 10 percent crown cover of forest trees/or bamboos generally associated with wild flora, fauna, natural regeneration and natural soil conditions that is not subject to agricultural practices. Forestry Code of Tajikistan"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Tajikistan 2010" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_969 a skos:Concept ;
    dct:creator "Tanzania" ;
    dct:date "1998"^^xsd:gYear ;
    dct:source "http://www.unep-wcmc.org/forest/restoration/docs/TanzaniaFLR.PDF"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "All land bearing a vegetative association dominated by trees of any size, exploitable or not, and capable of producing wood or other products of exerting influence on the climate or water regime or providing shelter to livestock and wildlife. From: Tanzania Forest policy, Roger Malimbwi, Faculty of Forestry <forestry@sua.ac.tz and (MNRT 1998a"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Tanzania 1998" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_97 a skos:Concept ;
    dct:source "http://scstsenvis.nic.in/envis/SDNPnewsletter.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A large tract of land covered with the different types of plant forms like shrubs, herbs and trees"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_970 a skos:Concept ;
    dct:creator "Tanzania" ;
    dct:date "2002"^^xsd:gYear ;
    dct:source "http://www.bunge.go.tz/Polis/PAMS/Docs/14-2002.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "''forest'' means an area of land with at least 10% tree crown cover, naturally grown or planted and or 50% or more shrub and tree regeneration cover and includes all forest reserves of whatever kind declared or gazetted under this Act and all plantations"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Tanzania 2002" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_971 a skos:Concept ;
    dct:creator "Tanzania" ;
    dct:date "2002"^^xsd:gYear ;
    dct:source "http://books.google.com/books?id=KDcRI1Nj9n0C&pg=PA32&lpg=PA32&dq=having10+percent+tree+cover+or+50+percent+shrub+or+tree+regeneration&source=bl&ots=KcKcFGiIKo&sig=zK4quavMBqFqG0EoOq65imubhq8&hl=en&sa=X&ei=DNo4T8S2Fqb00gGxipGwAg&ved=0CCUQ6AEwAA#v=onepage&q=having10%20percent%20tree%20cover%20or%2050%20percent%20shrub%20or%20tree%20regeneration&f=false"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land having10 percent tree cover or 50 percent shrub or tree regeneration cover, to be designated as a national forest reserve"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Tanzania 2002" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_972 a skos:Concept ;
    dct:creator "Tanzania" ;
    dct:date "2002"^^xsd:gYear ;
    dct:source "http://www.climate-standards.org/projects/files/tanzania/ufp_mfp_combined_validation_VCS_PDD-1.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Under the Forest Act/Law, forests are defined as “an area of land with at least 10% tree crown cover, naturally grown or planted and or 50% or more shrub and tree regeneration cover and includes all forest reserves of whatever kind declared or gazetted under the forest act and all plantations”"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Tanzania 2002" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_973 a skos:Concept ;
    dct:creator "Tanzania ?" ;
    dct:date "2007"^^xsd:gYear ;
    dct:source "https://cdm.unfccc.int/DNA/DNA/allCountriesARInfos.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Cover = 30%; Area = 1 ha; Tree height = 2 m"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Tanzania 2007?" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_974 a skos:Concept ;
    dct:creator "Tanzania" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Closed Forest) Trees 8 m and canopy closure 60%. No figures given for open forest. Source: ECE-FAO Partnership Programme: Kenya Workshop on Forestry Statistics. Appendix 6"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Tanzania" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_975 a skos:Concept ;
    dct:creator "Tanzania" ;
    skos:broadMatch ex:Forest ;
    skos:definition "An area of land covered with trees, grass, and other vegetation but dominated by trees. From: Tanzania Forest policy, Roger Malimbwi, Faculty of Forestry <forestry@sua.ac.tz"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Tanzania" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_976 a skos:Concept ;
    dct:date "2001"^^xsd:gYear ;
    dct:source "http://www.landcoalition.org/sites/default/files/legacy/legacypdf/08_gtz_land_tenure_systems.pdf"^^xsd:anyURI ;
    dct:spatial "Thailand" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Closed forest. Forest in which the stand density is greater than 20 percent of the area and tree crowns approach general contact with one another. Open forest. Forest in which the tree canopy layer is discontinuous but covers at least 10 percent of the area and in which the grass layer is continuous"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Thailand 2001" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_977 a skos:Concept ;
    dct:date "1988"^^xsd:gYear ;
    dct:spatial "Tunisia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "On entend par forêt, toute formation végétale d'origine naturelle ou artificielle composée d'une ou plusieurs espèces forestières d'arbes, d'arbustes ou de broussailles à l'état put ou en mélange.LEX-FAOC002805. TUNISIA: Loi n&ordm; 20 portant Code Forestier. Date of text: 13 April 1988"@fr ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Tunisia 1988" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_978 a skos:Concept ;
    dct:creator "Turkey" ;
    dct:date "1937"^^xsd:gYear ;
    dct:source "http://www.fao.org/forestry/16407-0c0665eddd86a68c9fbbe87cdde52501c.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "The first Forest Code defined forests as “areas covered by a collection of trees and shrubs grown either naturally or cultivated by humans, and producing woody materials or any kind of forest yield”. This definition excluded steppes, city parks, thorny areas, and areas of less than 5 ha that were not adjacent to natural forest boundaries and were owned by private entities"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Turkey 1937" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_979 a skos:Concept ;
    dct:creator "Turkey" ;
    dct:date "1950"^^xsd:gYear ;
    dct:source "http://turkeyforest.com/"^^xsd:anyURI,
        "http://turkeyforest.com/files/forest_report_18.02.2011_with_font_14_&_navigation_--property_rights_in_turkish_forests_-_final_version.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "AMMENDMENT 5653 was passed in 1950 (see APPENDIX_2). This law changed clauses 1 and 3 (among others) of Forest law 3116 redefying Legal Forests as follows : \"A collection of trees or bushes occurring naturally or planted by people\" with the exception of the following : \" All types of prickly plants, Trees in parks and graveyards, Trees not found in natural Forests such as poplar, eucalyptus,willow and acasia,Clumps of trees and bushes covering less than 3 hectars on private land more than 3 km from government Forest. All types of maquis. \". Giraud, Brian. 2011. Property rights in Turkish forests. 106 p. or"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Turkey 1950" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_98 a skos:Concept ;
    dct:source "http://www.lpb.org/programs/forestseries/pforser_glossary.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A large tract of land covered with trees and underbrush"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_980 a skos:Concept ;
    dct:creator "Turkey" ;
    dct:date "1956"^^xsd:gYear ;
    dct:source "http://web.ogm.gov.tr/languages/English/dokumanlar/dgf6831law.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "The groups of trees and small trees and their fields are in the scope of forest. Bit” sedgies; the fields containing steppe plants; all kinkds of prickly plants; parks; trees and groups of trees in city backyards and places in the territory of counties and villages, the places existing I private areas and cultivated trees and small trees"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Turkey 1956" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_981 a skos:Concept ;
    dct:creator "Turkey" ;
    dct:date "1987"^^xsd:gYear ;
    dct:source "http://www.elo.org/UserFiles/File/GR_GIRAUD.doc"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "THE CURRENT FORESTRY LAW 6831 of 1956 (see APPENDIX_4). In 1956 the present Forestry law was introduced replacing law 3116 and offering its own (similar) Forest definitions and Forestry policies. Legal Forests were again redefined as \"naturally occurring or planted collections of trees or shrubs together with the land they occupy.\" Exceptions were again listed as follows: \" Reed beds; Steppes; Land containing all types of prickly plants; parks (amendment 2896 clause 1 of 23/9/1983) tree and shrub covered areas in city cemeteries and in old cemeteries located inside municipality and Village limits; Private land containing trees and shrubs which do not grow naturally in surrounding Forests (amendment no 3373 clause 1 of 22/5/1987). Private registered land within Forest land or ajacent to Forest land, any private land outside Forest areas used as agricultural land containing random or orderly arranged trees or clumps of any species of tree or shrub.; (amendment no 3373 clause 1 of 22/5/1987). Private land less than 3 hectars in area located outside Forest areas containing any kind of tree or shrub. Private land containing or scheduled to be planted with (according to the suitability of the region) any kind of fruit bearing tree or shrub, including stone (nut bearing) pine and (acorn bearing) oak, (amendment no 2896 clause 1 of 23/9/1983). Private land containing grafted and ungrafted olive trees, land containing wild olive trees that has been separated from government Forest by special law provided that the improvement and ownership conditions have been met and land containing wild and grafted nut trees, mastic trees and … trees as specified by law 77 of 9//1956. Land covered by maquis and heather and land that does not have conservation characteristics. \""@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Turkey 1987" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_982 a skos:Concept ;
    dct:creator "Turkey" ;
    dct:date "1987"^^xsd:gYear ;
    dct:source "http://faolex.fao.org/docs/texts/tur20346.doc"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Tree and woodland communities, which are grown by human efforts, are regarded as Forest, together with their lands; Privately owned lands containing trees and woodland species, which do not grow naturally in the neighbouring forest or any kind of trees or woodlands on privately owned land and smaller than three hectares are not considered as forest"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Turkey 1987" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_983 a skos:Concept ;
    dct:creator "Turkey" ;
    dct:date "1988"^^xsd:gYear ;
    dct:source "http://turkeyforest.com/"^^xsd:anyURI,
        "http://turkeyforest.com/files/forest_report_18.02.2011_with_font_14_&_navigation_--property_rights_in_turkish_forests_-_final_version.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Naturally occurring or planted collections of trees or shrubs together with the land they occupy shall be called forests. …The word forest …refers to both the forest cover and the underlying real estate. Giraud, Brian. 2011. Property rights in Turkish forests. 106 p. or"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Turkey 1988" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_984 a skos:Concept ;
    dct:creator "Turkey" ;
    dct:date "2000"^^xsd:gYear ;
    skos:broadMatch ex:Forest ;
    skos:definition "All tree and tree formations communities together with their land are forest. Except for land covered with steppe vegetation, marshes and wetlands covered with buses, city park areas, cemeteries, private lands with tree cover which is not grown in surrounding forests naturally, land out of forest borders with an area of less than 3 ha. UN/ECE 2000 p 89"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Turkey 2000" ;
    skos:prefLabel "- Forest"@no ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_985 a skos:Concept ;
    dct:creator "Turkey" ;
    dct:date "2003"^^xsd:gYear ;
    dct:source "http://turkeyforest.com/"^^xsd:anyURI,
        "http://turkeyforest.com/files/forest_report_18.02.2011_with_font_14_&_navigation_--property_rights_in_turkish_forests_-_final_version.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Naturally occurring or planted collection of trees or shrubs together with the land they occupy. Exceptions are listed as follows: Reedbeds; Steppes; Land containing all types of prickly plants; Parks; Tree and shrub covered areas in city cemeteries and in old cemeteries located inside municipality and village limits; Private land containing trees and shrubs which do not grow naturally in surrounding forests; Land with Title Deeds within or adjacent to Forest Boundaries or if outside Forest Boundaries, privately owned land with any kind of ownership document, used as agricultural land and containing random or orderly arranged trees or clumps of any tree or shrub; Private land less than 3 hectars in area located outside forest areas containing any kind of tree or shrub; Private land with Title Deeds within or adjacent to Forest Boundaries and Private Land with any kind of ownership document outside Forest Boundaries containing or scheduled to be planted withy (according to the suitability of the region) any kind of fruit bearing tree or shrub, including stone (nut bearing) pine and acorn bearing) oak; Private lands containing grafted and ungrafted olive trees, land containing wild olive trees that has been separated from government forest by special law provided that the improvement and ownership conditions have been met and land containing wild and grafted nut trees, mastic trees and…trees as specified by law 77 of 9/1956; Land covered by maquis and heather and land that does not have conservation characteristics. Giraud, Brian. 2011. Property rights in Turkish forests. 106 p. or"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Turkey 2003" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_986 a skos:Concept ;
    dct:creator "Turkey" ;
    dct:date "2004"^^xsd:gYear ;
    dct:source "http://www.sayistay.gov.tr/english_tca/Performance/ProtectionOfForests.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "“Groups of trees and small trees growing naturally or grown by people are considered forest together with the land where they stand” and also includes exceptions of this definition within the rest of the article. (Turkish Article 1 of the Forest Law no. 6831). Karabeyli, Levent et al. 2004. Protection of forests. Turkish Court of Accounts. Performance Audit Report. 78 p"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Turkey 2004" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_987 a skos:Concept ;
    dct:creator "Turkey" ;
    dct:date "2004"^^xsd:gYear ;
    dct:source "http://www.sayistay.gov.tr/english_tca/Performance/ProtectionOfForests.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Article 1 of the Forest Law no. 6831 defines the forests as “Groups of trees and small trees growing naturally or grown by people are considered forest together with the land where they stand” and also includes exceptions of this definition within the rest of the article"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Turkey 2004" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_988 a skos:Concept ;
    dct:creator "Turkey" ;
    dct:date "2009"^^xsd:gYear ;
    dct:source "http://web.ogm.gov.tr/languages/English/dokumanlar/Publications/stateofforests.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A forest ecosystem is a natural unit consisting of all plants of which the main element is forest trees, animals and micro-organisms (biotic factors) in an area functioning together with all of the non-living physical (abiotic factors) factors of the environment. …The forest area in terms of crown density is classified into two main groups. Forest area with the crown density of 11-100 percent is defined as productive forest area constituting about 50 percent of the country’s forest area while the area with the crown density of 1-10 percent, the remaining about 50 percent named as degraded forest area. GDF. 2009. State of Turkey's Forests. Republic of Turkey. Ministry of Environment and Forestry. General Directorate of Forestry. Forest Administration and Planning Department. 28 p"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Turkey 2009" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_989 a skos:Concept ;
    dct:creator "Turkey" ;
    dct:date "2010"^^xsd:gYear ;
    dct:source "http://web.ogm.gov.tr/diger/forestandclimate/Dokumanlar/reports/ProposalforTurkey"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land spanning more than 0.5 hectares with trees higher than 5 meters and a canopy cover of more than 10 percent, or trees able to reach these thresholds in situ. It does not include land that is predominantly under agricultural or urban land use. FRA and LULUCF. ’sPost-2012NegotiatiForestry.pdf"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Turkey 2010" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_99 a skos:Concept ;
    dct:creator "Helms" ;
    dct:date "2002"^^xsd:gYear ;
    skos:broadMatch ex:Forest ;
    skos:definition "A large tract of land covered with trees: more exactly, a tract of land, more or less extensive, covered more or less densely with trees of useful character, viewed from the standpoint of economic use and development. SAF 1916"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Helms 2002" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_990 a skos:Concept ;
    dct:creator "Turkey" ;
    dct:date "2010"^^xsd:gYear ;
    dct:source "http://scialert.net/qredirect.php?doi=ijar.2007.22.32&linkid=pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "The forest area of Turkey is classified into two main groups on the basis of crown coverage. Forest area with a crown coverage of 11-100 % is defined as productive forest area and covers about 50 % of the country’s forest area. Forest area with crown coverage of 1-10 % is considered as degraded forest area which covers the remaining 50 % of Turkish forest lands. Tolunay, Ahmet et al. 2007. Definition and Classification of Traditional Agroforestry Practices in the West Mediterranean Region of Turkey. International Journal of Agricultural Research, 2: 22-32"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Turkey 2010" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_991 a skos:Concept ;
    dct:creator "Turkey" ;
    dct:date "2011"^^xsd:gYear ;
    dct:source "http://www.efi.int/files/attachments/publications/annex_1_to_efi_technical_report_88__2013.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A forest is defined as land with tree crown cover of more than 10%, an area of more than 0.5 ha and an average width of more than 20 m. Trees should be able to reach a minimum height of 5 m at maturity in situ. FOREST EUROPE, UNECE AND FAO, 2011"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Turkey 2011" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_992 a skos:Concept ;
    dct:creator "Turkey" ;
    dct:date "2013"^^xsd:gYear ;
    dct:source "http://web.ogm.gov.tr/Dkmanlar/istatistikler/Ormancilik-Istatistikleri_2011.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "The ecosystem with the forest trees which are able to reach a minimum height of 5 mt at maturity in suitalble sites. Forest land: The the area of land with forest trees by hectares"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Turkey 2013" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_993 a skos:Concept ;
    dct:date "2003"^^xsd:gYear ;
    dct:source "http://www.nemaug.org/regulations/forestry_tree_planting_act.pdf"^^xsd:anyURI ;
    dct:spatial "Uganda" ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"forest\" means an area of land containing a vegetation association that is predominantly composed of trees of any size, and includes - (a) a forest classified under this Act; (b) a natural forest, woodland or plantation; (c) the forest produce in a forest; and (d) the forest ecosystem; \"forest ecosystem\" means any natural or semi-natural formation of vegetation whose dominant element is trees, with closed or partially closed canopy, together with the biotic and abiotic environment; The National Forestry and Tree Planting Act, 8/2003"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Uganda 2003" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_994 a skos:Concept ;
    dct:date "2008"^^xsd:gYear ;
    dct:source "http://www.envalert.org/docs/Inventoryofcriticalissuesinforestry.pdf"^^xsd:anyURI ;
    dct:spatial "Uganda" ;
    skos:broadMatch ex:Forest ;
    skos:definition "An area of at least one hectare of land with a minimum tree canopy cover of 30% and a minimum tree potential height of 5 metres (Adapted from UNFCCC, 2001"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Uganda 2008" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_995 a skos:Concept ;
    dct:date "2017"^^xsd:gYear ;
    dct:source "http://www.fao.org/3/a-i7849e.pdf"^^xsd:anyURI ;
    dct:spatial "Uganda" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Woodland. “Wooded areas where trees and shrubs are predominant. There are wet and dry types. The wet type occurs as a zone along wetlands (riverine forest) and the dry type is found on grass-covered upland areas. To qualify as woodland the average height of the trees must exceed 4 m.” Woodland can be categorized as closed or open woodland according to its canopy cover. Closed woodland has a canopy cover > 40 percent and open woodland has a canopy cover of 10–40 percent"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Uganda 2017" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_996 a skos:Concept ;
    dct:spatial "Uganda" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Tropical high forest. Min. canopy closure 40%. Source: ECE-FAO Partnership Programme: Kenya Workshop on Forestry Statistics. Appendix 6"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Uganda" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_997 a skos:Concept ;
    dct:date "1994"^^xsd:gYear ;
    dct:spatial "Ukraine" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Combination of land, vegetation dominated by trees and shrubs, animals, microorganisms and other natural components interconnected in their development and influencing each other and the environment.'' [From: ``The Forest Code of Ukraine'' Kiev, 1994, 56p. \"Maksym Polyakov\" mpoliak@pcomp.usau.kiev.ua Date: Thu, 11 Jun 1998 12:06:37 +0300 (MSD)]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Ukraine 1994" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_998 a skos:Concept ;
    dct:date "2006"^^xsd:gYear ;
    dct:source "http://www.efi.int/files/attachments/publications/annex_1_to_efi_technical_report_88__2013.pdfagricultural"^^xsd:anyURI ;
    dct:spatial "Ukraine" ;
    skos:broadMatch ex:Forest ;
    skos:definition "In Ukraine's forest are forest areas, including those protective plantings linear type, area of not less than 0.1 ha. In Ukraine the forest area does not include: green spaces within settlements (parks, gardens, squares, boulevards, etc.) that are not included in the prescribed manner to the forest; individual trees and groups of trees, shrubs on land, homestead, cottage and garden areas. Supreme Council of Ukraine, 2006"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Ukraine 2006" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_999 a skos:Concept ;
    dct:date "2000"^^xsd:gYear ;
    dct:spatial "United Kingdom" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest 20 % and 0.25 ha. For FRA 2000 - Source: UN/ECE 2000 p 90"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "United Kingdom 2000" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:ForestedLand_1 a skos:Concept ;
    dct:creator "OECD" ;
    dct:source "http://stats.oecd.org/glossary/detail.asp?ID=6459"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land with tree crown cover (or equivalent stocking level) of more than 10 per cent and an area of more than 0.5 hectares. The trees should be able to reach a minimum height of 5 metres at maturity in situ"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "OECD" ;
    skos:prefLabel "Forested land"@en ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forested_1 a skos:Concept ;
    dct:creator "USA-STATE-New" ;
    dct:source "http://www.state.nj.us/dep/landuse/mglossary.html#f"^^xsd:anyURI ;
    dct:spatial "Jersey" ;
    skos:broadMatch ex:Forest ;
    skos:definition "that tree species with an average height greater than 20 feet are the predominant vegetation present"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-New Jersey" ;
    skos:prefLabel "Forested"@no ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forestland_1 a skos:Concept ;
    dct:spatial "Northern Mariana Islands" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Natural or managed area covered with diverse tree species reserved for dual purposes benefiting mankind, wildlife and ecosystem as a whole. Source: Estanislao Villagomez stanvill@gtepacifica.net Division of Agriculture"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Northern Mariana Islands" ;
    skos:prefLabel "Forestland"@no ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forestland_2 a skos:Concept ;
    dct:creator "Yugoslavia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "a section of land on which forest is cultivated. \"Srdjan BOJOVIC\" <bojos@ptt.yu"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Yugoslavia" ;
    skos:prefLabel "Forestland"@no ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forestland_3 a skos:Concept ;
    dct:creator "USA-STATE-Louisiana" ;
    dct:source "http://text.lsuagcenter.com/en/environment/forestry/commercial_forestry/Glossary+of+Forestry+Terms.htm#F"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Tract of land with trees and woody plants generally covering the landscape"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Louisiana" ;
    skos:prefLabel "Forestland"@no ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forestland_4 a skos:Concept ;
    dct:creator "USA-STATE-Arkansas" ;
    dct:date "1995"^^xsd:gYear ;
    skos:broadMatch ex:Forest ;
    skos:definition "an area at least 1 acre in size that is at least 10 percent stocked with trees, or formerly having such tree cover and not currently developed for nonforest uses. Forest Inventory and Analysis definition - Forest Statistics for Arkansas Counties - 1995 Jim Grant jim.grant@mail.state.ar.us - no official definitions in Arkansas law"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Arkansas 1995" ;
    skos:prefLabel "Forestland"@no ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forestland_5 a skos:Concept ;
    dct:creator "USA-STATE-Kentucky" ;
    skos:broadMatch ex:Forest ;
    skos:definition "land at least 10 percent stocked by forest trees of any size, including land that formerly had such cover and that will be naturally or artificially regenerated. The State of Kentucky does not have the terms Forest, Forestland, or Tree officially defined in State Statute or Regulation. The Division of Forestry utilizes the Society of American Forester's definitions for these terms as listed in John A. Helms' The Dictionary of Forestry. Steve.Kull@mail.state.ky.us"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Kentucky" ;
    skos:prefLabel "Forestland"@no ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forestland_6 a skos:Concept ;
    dct:creator "USA-STATE-North Carolina" ;
    dct:date "1990"^^xsd:gYear ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land at least 16.7 percent stocked by forest trees of any size, or formerly having had such tree cover, and not currently developed for nonforest use. Source: Forest Statistics for North Carolina, 1990. Resource Bulletin SE-120, by Tony G. Johnson. USDA-Forest Service, Southeastern Forest"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-North Carolina 1990" ;
    skos:prefLabel "Forestland"@no ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forestland_7 a skos:Concept ;
    dct:creator "USA-STATE-Mississippi" ;
    dct:date "2008"^^xsd:gYear ;
    dct:source "http://msucares.com/pubs/publications/p1250.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land which is currently producing (or, in some cases, capable of producing) a forest"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Mississippi 2008" ;
    skos:prefLabel "Forestland"@no ;
    skos:scopeNote "Ecological"@en,
        "State"@en .

ex:Forestry_1 a skos:Concept ;
    dct:creator "Central Europe" ;
    dct:source "http://www.fao.org/ag/agl/agll/landuse/clsys/Europecenral.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Compact forest complexes covering 75-80% of the area"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Central Europe" ;
    skos:prefLabel "Forestry"@en ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:ForestsLands_1 a skos:Concept ;
    dct:date "1993"^^xsd:gYear ;
    dct:source "http://faolex.fao.org/docs/texts/taj19369.doc"^^xsd:anyURI ;
    dct:spatial "Tajikistan" ;
    skos:broadMatch ex:Forest ;
    skos:definition "covered with forests, non-closed forest cultures, forest-nurseries, plantations, thinning, burning, felling and clearings; Non-forests - pashni, hay making, pastures, waters, gardens and vineyards, roads and through cuts, farmsteads, bogs, sands and glaciers. Forest Code of the Republic of Tajikistan"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Tajikistan 1993" ;
    skos:prefLabel "Forests lands"@en ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:ForestsOfAllKinds_1 a skos:Concept ;
    dct:source "http://www.polity.org.za/govdocs/white_papers/forestry.html"^^xsd:anyURI ;
    dct:spatial "South Africa" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Government policy in South Africa is formulated to include \"forests of all kinds\", that is, the indigenous forests, where trees grow with their crowns virtually intertwined, natural woodlands, where tree cover may be as little as 10%, plantation, and community forests"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "South Africa" ;
    skos:prefLabel "- forests of all kinds"@en ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:ForestsUpland_2 a skos:Concept ;
    dct:creator "USA-STATE-Florida" ;
    dct:date "1999"^^xsd:gYear ;
    dct:source "http://www.dot.state.fl.us/surveyingandmapping/Manuals/fluccmanual.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forests (Upland) - This category of land cover is reserved for those upland areas which support a tree canopy closure of ten (10) percent or more. The Upland Forests include both the xeric (drysite) and mesic (moderately moist site) forest communities. Wetland, or hydric, forest communities fall under the broad wetland category. Also included in the Upland Forest category are areas in which timber harvesting has occurred but which exhibit no evidence of being developed for other intended uses (clear-cuts in an area in which rotation forest management is practiced is a prime example of such a case"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Florida 1999" ;
    skos:prefLabel "Forests Upland"@en ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forests_1 a skos:Concept ;
    dct:creator "UN" ;
    dct:date "1996"^^xsd:gYear ;
    skos:broadMatch ex:Forest ;
    skos:definition "whether natural, modified or planted - are biotic communities characterized by a predominance of woody vegetation. They are found in all climatic zones (boreal, temperate, tropical and mountainous) and may take the form of closed canopy forests or open canopy woodlands. They comprise all the components of forest ecosystems and their natural resources. Forest lands may be covered by forests or degraded - that is, currently devoid of trees or not maintained in a sustainable manner (UNITED NATIONS 1996"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN 1996" ;
    skos:prefLabel "Forests"@en ;
    skos:scopeNote "International"@en,
        "Land use"@en .

ex:FromAFireManagementPerspective_1 a skos:Concept ;
    dct:creator "USA-STATE-South Carolina" ;
    dct:source "http://www.state.sc.us/forest/lawpro.htm#20"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Lands shall be construed as \"forest land\" which have enough forest growth, standing or down, or have sufficient inflammable debris or, outside of corporate limits, to constitute, in the judgement of the State Commission of Forestry, a fire menace to itself or adjoining lands"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-South Carolina" ;
    skos:prefLabel "From a fire management perspective"@en ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

