    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_157 a skos:Concept ;
    dct:source "http://www.lpb.org/programs/forest/glossary.html#d"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The removal of trees and often the plants associated with them"@en ;
