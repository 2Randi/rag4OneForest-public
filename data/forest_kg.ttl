        "unknown"@en .

ex:Afforestation_100 a skos:Concept ;
    dct:creator "USA-FED-DA-FS" ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "Establishment of forest crops by artificial methods, such as planting or sowing on land where trees have never grown. [Source: Timber Harvesting and Engineering Glossary, USFS]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DA-FS" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_18 a skos:Concept ;
    dct:creator "EU" ;
    dct:source "http://europa.eu.int/comm/dg08/forests/en/en4_6.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "The establishment of a more or less contiguous tree cover, normally by planting, in areas which have previously been without trees"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "EU" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_25 a skos:Concept ;
    dct:creator "IPCC" ;
    dct:date "2003"^^xsd:gYear ;
    dct:source "http://www.junkscience.com/draft_AR4/GLOSSARY_SOD_TSU_FINAL.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "Planting of new forests on lands that historically have not contained forests. For a discussion of the term →forest and related terms such as →afforestation, →reforestation, and →deforestation: see the IPCC Report on Land Use, Land-Use Change and Forestry (IPCC, 2000). See also the Report on Definitions and Methodological Options to Inventory Emissions from Direct Human-induced Degradation of Forests and Devegetation of Other Vegetation Types (IPCC, 2003) (Source: Second Order Draft Glossary IPCC WGI Fourth Assessment Report"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "IPCC - 2003" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_26 a skos:Concept ;
    dct:creator "IPCC" ;
    dct:date "1997"^^xsd:gYear ;
    dct:source "http://www.grida.no/climate/ipcc/regional/327.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "Forest stands established artificially on lands that previously have not supported forests for more than 50 years"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "IPCC -1997" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_43 a skos:Concept ;
    dct:creator "UN-EP" ;
    dct:date "2003"^^xsd:gYear ;
    dct:source "http://digitalcommons.unl.edu/cgi/viewcontent.cgi?article=1030&context=usdafsfacpub"^^xsd:anyURI ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "Planting of new forests on lands that historically have not contained forests"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-EP 2003" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_44 a skos:Concept ;
    dct:creator "UNFCCC" ;
    dct:date "2001"^^xsd:gYear ;
    dct:source "http://www.unfccc.int/resource/docs/cop6secpart/l11r01.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "“Afforestation” is the direct human-induced conversion of land that has not been forested for a period of at least 50 years to forested land through planting, seeding and/or the human-induced promotion of natural seed sources"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UNFCCC 2001" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_45 a skos:Concept ;
    dct:creator "UN-FRA" ;
    dct:date "2000"^^xsd:gYear ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "Artificial establishment of forest on lands which previously did not carry forest within living memory. (UN-ECE/FAO 1997 and FAO 1998"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FRA 2000" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_47 a skos:Concept ;
    dct:creator "USA-FED-CIA" ;
    dct:source "https://www.cia.gov/library/publications/the-world-factbook/docs/notesanddefs.html#2032"^^xsd:anyURI ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "converting a bare or agricultural space by planting trees and plants; reforestation involves replanting trees on areas that have been cut or destroyed by fire"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-CIA" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_50 a skos:Concept ;
    dct:creator "World Bank" ;
    dct:date "2000"^^xsd:gYear ;
    dct:source "http://www.holz.uni-goettingen.de/ek/woodsat/pdf/worldbankforestry.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "Also reafforestation) Establishment of a tree crop in an area from which it has always or long been absent"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "World Bank 2000" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_69 a skos:Concept ;
    dct:creator "IPCC" ;
    dct:date "1996"^^xsd:gYear ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "Planting of new forests on lands which, historically, have not contained forests. These newly created forests are included in the category Changes in Forest and Other Woody Biomass Stocks in the Land Use Change and Forestry module of the emissions inventory calculations"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "IPCC 1996" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_96 a skos:Concept ;
    dct:creator "EU" ;
    dct:date "2013"^^xsd:gYear ;
    dct:source "http://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:32013D0529"^^xsd:anyURI ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "‘afforestation’ means the direct human-induced conversion of land that has not been forest for a period of at least 50 years to forest through planting, seeding and/or the human-induced promotion of natural seed sources, where the conversion has taken place after 31 December 1989"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "EU 2013" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_98 a skos:Concept ;
    dct:creator "UN-FAO" ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "The establishment of a tree crop on an area from which it has always or very long been absent. Where such establishment fails and is repeated, the latter may properly be termed reafforestation (FAO 1997"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:Afforestation_99 a skos:Concept ;
    dct:creator "UN-FAO" ;
    dct:date "2001"^^xsd:gYear ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "Afforestation is the conversion from other land uses into forest, or the increase of the canopy cover to above the 10% threshold. Explanatory note (extract): Afforestation is the reverse of deforestation and includes areas that are actively converted from other land uses into forest through silvicultural measures. Afforestation also includes natural transitions into forest, for example on abandoned agricultural land or in burnt-over areas that have not been classified as forest during the barren period. As for deforestation, the conversion should be long-term, that is areas where the transition into forest is expected to last less than ten years, for example due to recurring fires, should not be classified as afforestation areas. Food and Agriculture Organization of the United Nations (FAO 2000b"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO 2001" ;
    skos:prefLabel "AFFORESTATION"@tl .

ex:AvailableOtherForestLand_1 a skos:Concept ;
    dct:creator "USA-FED-DA-FS" ;
    dct:date "1997"^^xsd:gYear ;
    skos:definition "forest land incapable of growing 20 cubic feet per acre per year (mean annual increment at culmination in fully stocked, natural stands) of industrial wood because of adverse conditions such as sterile soils, dry climate, poor drainage, subalpine sites, steepness, or rockiness. (Waddell and Bassett 1997"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DA-FS 1997" ;
    skos:prefLabel "Available other forest land"@en .

