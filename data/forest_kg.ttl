ex:Deforestation_94 a skos:Concept ;
    dct:source "http://www.epa.gov/ceisweb1/ceishome/atlas/ohiolandchange/ohiolandchangeglossary.html"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The act of removing forests from an area in favor of another land cover type, often agriculture or urban. In many areas forests are cut down to obtain lumber"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_95 a skos:Concept ;
    dct:source "http://www.merriam-webster.com/dictionary/deforestation"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The act or result of cutting down or burning all the trees in an area"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_96 a skos:Concept ;
    dct:source "http://www.m-w.com/cgi-bin/dictionary?book=Dictionary&va=deforestation"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The action or process of clearing of forests. The state of having been cleared of forest. [Source: WWWebster Dictionary]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_97 a skos:Concept ;
    dct:source "http://www.aloha.net/~ani/glossary.html"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The burning and bulldozing of trees for the purpose of lumber, agriculture, or ranching"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_98 a skos:Concept ;
    dct:source "http://www.ask.com/question/what-is-deforestation"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The burning and logging of trees in the forest. It kills animals and destroys habitats"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_99 a skos:Concept ;
    dct:creator "Wardle et al" ;
    dct:date "2003"^^xsd:gYear ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The change from forest cover into some other land cover formation without the planned revival of forests by natural or artificial reforestation"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Wardle et al. 2003" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:DeforestedArea_1 a skos:Concept ;
    dct:source "http://www.nscb.gov.ph/ru12/DEFINE/DEF-ENV.HTM"^^xsd:anyURI ;
    dct:spatial "Philippines" ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "the area which has been denuded but has not been reforested as of the end of the reference year"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Philippines" ;
    skos:prefLabel "Deforested Area"@en .

ex:DegradedForest_1 a skos:Concept ;
    dct:source "https://edcintl.cr.usgs.gov/downloads/sciweb1/shared/wafrica/downloads/documents/Landscapes_of_West_Africa_Atlas_low_resolution_en.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Degradation ;
    skos:definition "Dense, evergreen broadleaf forest with closed or partially closed canopy whose integrity has been degraded by logging or other forms of exploitation. Degraded forest can also be immature forest, or forest in various stages of regrowth after disturbance. Trees 10 to 30 m tall"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "Degraded forest"@da .

ex:DegradedForest_2 a skos:Concept ;
    dct:source "http://blog.worldagroforestry.org/index.php/2013/10/03/unpacking-the-evidence-on-firewood-and-charcoal-in-africa/"^^xsd:anyURI ;
    skos:broadMatch ex:Degradation ;
    skos:definition "ecosystem from which live trees have been harvested for wood can regenerate, but the sustainability of this type of selective removal of trees depends on the speed of ecosystem recovery against that of harvesting,” she explained. “But when trees are cut completely and the land is converted to other uses, that is deforestation, which causes permanent changes to the ecology.”"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "Degraded forest"@da .

ex:ForestSpecies_1 a skos:Concept ;
    dct:date "2011"^^xsd:gYear ;
    dct:source "http://www.maf.govt.nz/portals/0/documents/forestry/forestry-ets/2011-ETS-look-up-tables-guide.pdf"^^xsd:anyURI ;
    dct:spatial "New Zealand" ;
    skos:broadMatch ex:Tree ;
    skos:definition "A tree species capable of reaching at least five metres in height at maturity in the place that it is located, but does not include tree species grown or managed primarily for the production of fruit and nut crops. For the purposes of the Forestry ETS, any woody vegetation (and including tree ferns) capable of reaching 5 metres in the place it is growing is considered to be a “tree”"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "New Zealand 2011" ;
    skos:prefLabel "Forest species"@en .

ex:Forest_1 a skos:Concept ;
    dct:creator "silva" ;
    dct:source "http://www.ashdownforest.org/html/conservation.html"^^xsd:anyURI,
        "http://www.bartleby.com/61/69/F0256900.html"^^xsd:anyURI,
        "http://www.europarl.eu.int/workingpapers/forest/eurfo124_en.htm"^^xsd:anyURI,
        "http://www.wychwoodproject.org/templates/history.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "ETYMOLOGY: Middle English, from Old French, from Medieval Latin forestis , outside (forest), from Latin for s, outside. . In several European languages, the root for(s) today still means outsider -(e.g. foreigner). . The word “forest” in Medieval England came to mean land outside cultivation and belonging by default to the Crown. There is no direct reference to trees or woodland. . The term \"forest\" was a legal and did not mean that the whole area was wooded. “The word foresta appears for the first time in the laws of the Longobards and the capitularies of Charlemagne, referring not to woodlands in general but only to the royal game preserves. The obscure Latin verb forestare meant 'to keep out, to place off limits, to exclude.' In effect, during the Merovingian period in which the word foresta entered the lexicon, kings had taken it upon themselves to place public bans on vast tracts of woodlands in order to insure the survival of their wildlife, which in turn would insure the survival of a fundamental royal ritual--the hunt"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "silva" ;
    skos:prefLabel "FOREST/FOREST LAND"@de .

ex:Forest_2 a skos:Concept ;
    dct:creator "1598" ;
    dct:source "http://books.google.com/books?id=jhZsJc4z5RkC&pg=PA657&lpg=PA657&dq=hawaii+forestland&source=web&ots=YlCTj-qUZR&sig=PtkyXu4oaaWBg-3k45z2nub3mDs#PPA645,M1"^^xsd:anyURI,
        "http://www.ecobooks.com/forests.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Manwood in Lawes of the Forest describes a forest as “a certain territory of woody grounds, fruitful pastures, privileged for wild beasts and fowls of forest, chase and warren, to rest and abide in the safe protection of the king, for his princely delight and pleasures.” (Encyclopedia Britannia 1910. p. 645. ) A 'forest,' then, was originally a juridical term referring to land that had been placed off limits by a royal decree. Once a region had been 'afforested,' or declared a forest, it could not be cultivated, exploited, or encroached upon. It lay outside the public domain, reserved for the king's pleasure and recreation. In England it also lay outside the common juridical sphere. Offenders were not punishable by the common law but rather by a set of very specific 'forest laws.' The royal forests lay 'outside' in another sense as well, for the space enclosed by the walls of a royal garden was sometimes called silva, or wood. Forestis silva meant the unenclosed woods 'outside' the walls.\"”"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "1598" ;
    skos:prefLabel "FOREST/FOREST LAND"@de .

ex:Forest_3 a skos:Concept ;
    skos:broadMatch ex:Forest ;
    skos:definition "Table 1 lists terms for forest, forestland and tree in a multitude of languages from around the world"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de .

ex:Forest_4 a skos:Concept ;
    dct:source "http://forum.wordreference.com/showthread.php?t=186539"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "“A jungle is tropical and untrammeled. A forest is temperate and little touched by humans. Woods are forests that have been worked by humans.”"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de .

ex:Forest_5 a skos:Concept ;
    dct:creator "descendant of escaped African slaves" ;
    dct:source "http://www.wrm.org.uy/bulletin/174/viewpoint.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "For Claudentina, a quilombola woman in her 60s from the community of Angelim in Sapê do Norte, in the Brazilian state of Espíritu Santo, the forest is “a place where people used to go to find fruits and seeds, vines, wood, plants, roots; to hunt and fish. It was also a place to practice our faith.”"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "descendant of escaped African slaves" ;
    skos:prefLabel "FOREST/FOREST LAND"@de .

ex:Forest_6 a skos:Concept ;
    dct:creator "From: Smith_Brad/wo@fs.fed.us" ;
    dct:source "http://www.ncasi-nerc.org/projects/evmp/vcst/"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "We found over 1,700 definitions. Thresholds for tree cover vary from 0% to 80%. [Note: John Dwyer has done some work which shows that average forest cover in urban USA is about 33% ]. A crosswalk of various forest classification systems may be found at . We can group forest definitions according to their source - those found in general dictionaries and glossaries, definitions from the International Community, National definitions, and state, provincial or local definitions. We can further group these into 4 categories - those that are declared or administrative units, those that mean a land cover, those that mean a land use and a miscellaneous category"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "From: Smith_Brad/wo@fs.fed.us" ;
    skos:prefLabel "FOREST/FOREST LAND"@de .

ex:Forest_7 a skos:Concept ;
    dct:creator "1" ;
    dct:source "http://ruralsystemguide.com/Appendices/GlossF.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A community dominated by dense, extensive tree cover. (2) An area managed for producing timber and other products, or maintained under woody vegetation for such indirect benefits as protection of watersheds or recreation. (3) An area within an administrative boundary of a forest agency, whether having trees or not.(4) Land primarily devoted to trees"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "1" ;
    skos:prefLabel "Forest"@no .

ex:Forest_8 a skos:Concept ;
    dct:source "https://howlingpixel.com/wiki/Outline_of_forestry"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "defined as either a geographic area or delineated by the general composition of individuals"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "Forest"@no .

ex:ForestryArabic_1 a skos:Concept ;
    dct:spatial "Morocco" ;
    skos:definition "Forestry (Arabic : ‘Ilm Al Ghabat, French : Foresterie/Sciences forestière, Spanish : Ciencias de bosques) - Field of all the different discilines related to forestry aspects, such as reproduction, cultivation, caring, protection, development, etc. Mohammed Ellatifi, m.ellatifi@ellatifi.8m.com"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Morocco" ;
    skos:prefLabel "Forestry Arabic"@en .

ex:ForestryArabic_2 a skos:Concept ;
    dct:spatial "Yemen" ;
    skos:definition "Forestry (Arabic : ‘Ilm Al Ghabat, French : Foresterie/Sciences forestière, Spanish : Ciencias de bosques) - Field of all the different discilines related to forestry aspects, such as reproduction, cultivation, caring, protection, development, etc. Mohammed Ellatifi, m.ellatifi@ellatifi.8m.com"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Yemen" ;
    skos:prefLabel "Forestry Arabic"@en .

ex:LandClassification_1 a skos:Concept ;
    dct:source "http://www-markinfo.slu.se/eng/soildes/ago/agodef.html"^^xsd:anyURI ;
    skos:definition "is based on the status of the land at the time of inventory, ignoring the possibilities for production increasing measures. Expected changes in land use must also be ignored unless they have already taken place"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "Land classification"@en .

ex:LandConversion_1 a skos:Concept ;
    dct:creator "Washington Department of Ecology," ;
    dct:date "1992"^^xsd:gYear ;
    dct:source "http://www.p2pays.org/ref%5C04%5C03686/ch4-8.html"^^xsd:anyURI ;
    skos:definition "A change in land use, function, or purpose"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Washington Department of Ecology, 1992" ;
    skos:prefLabel "Land conversion"@en .

ex:LandCoverChange_1 a skos:Concept ;
    dct:creator "conversion" ;
    dct:source "http://www.aag.org/hdgc/www/intro/glossary/glossary.html"^^xsd:anyURI ;
    skos:broadMatch ex:LandCover ;
    skos:definition "a change from one class of land cover to another , such as from grassland to cropland, or a change of condition within a land cover category (modification), such as the thinning of a forest"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "conversion" ;
    skos:prefLabel "Land-cover change"@en .

ex:LandCoverClassification_1 a skos:Concept ;
    dct:creator "Kalensky et al" ;
    dct:date "2002"^^xsd:gYear ;
    skos:broadMatch ex:LandCover ;
    skos:definition "A process of stratification and systematic grouping of land cover into multi-level, mutually exclusive classes according to selected criteria. It is independent of map scale, data source and geographic area"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Kalensky et al. 2002" ;
    skos:prefLabel "Land cover classification"@en .

ex:LandCoverMapLegend_1 a skos:Concept ;
    dct:creator "forest map, forest change map, agricultural land map, land degradation map, etc" ;
    skos:broadMatch ex:LandCover ;
    skos:definition "A subset of land cover classes compatible with the map scale, map type and map accuracy requirements. Furthermore, the map legend is specific to a geographic area of the map. (Kalensky et al. 2002"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "forest map, forest change map, agricultural land map, land degradation map, etc." ;
    skos:prefLabel "Land cover map legend"@nl .

ex:LandUseChange_3 a skos:Concept ;
    dct:source "http://www.aag.org/hdgc/www/intro/glossary/glossary.html"^^xsd:anyURI ;
    skos:broadMatch ex:LandUse ;
    skos:definition "shift to a different land use or an intensification of an existing one"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "Land-use change"@en .

ex:Land_5 a skos:Concept ;
    dct:creator "including shallow lakes, rivers, marshes and swamps" ;
    dct:source "http://www.ecs.co.sz/seap/env_articles_policy_pliwgr_intro.htm"^^xsd:anyURI ;
    skos:definition "A delineable area of the earth's terrestrial surface, encompassing all attributes of the biosphere immediately above or below this surface, including those of the near-surface climate, the soil and terrain forms, the surface hydrology , the near-surface sedimentary layers and associated groundwater reserve, the plant and animal populations, the human settlement pattern and physical results of past and present human activity (terracing, water storage or drainage structures, roads, buildings, etc.). and www.pamagic.org/DataStds/Current/DataStandards_LandUse_05-22-02.pdf"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "including shallow lakes, rivers, marshes and swamps" ;
    skos:prefLabel "Land"@de .

ex:Land_6 a skos:Concept ;
    dct:source "http://www.css.cornell.edu/landeval/glossary.htm"^^xsd:anyURI ;
    skos:definition "An area of the earth's surface, the characteristics of which embrace all reasonably stable, or predictably cyclic, attributes of the biosphere vertically above and below this area, including those of the atmosphere, the soil and underlying geology, the hydrology, the plant and animal populations, and the results of past and present human activity, to the extent that these attributes exert a significant influence on present and future uses of the land by humans. www.itc.nl/~rossiter/teach/glossary.html and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "Land"@de .

ex:Land_7 a skos:Concept ;
    dct:creator "Mücher et al" ;
    dct:date "1993"^^xsd:gYear ;
    skos:definition "The physical environment, including climate, relief, soils, hydrology and vegetation, to the extent that these influence potential for land use"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Mücher et al 1993" ;
    skos:prefLabel "Land"@de .

ex:Landcover_1 a skos:Concept ;
    dct:creator "– Tasmania" ;
    dct:date "2003"^^xsd:gYear ;
    dct:source "http://soer.justice.tas.gov.au/2003/lan/2/issue/38/ataglance.php"^^xsd:anyURI ;
    dct:spatial "Australia" ;
    skos:broadMatch ex:LandCover ;
    skos:definition "Land cover refers to the physical state of the land surface and includes vegetation, soil, rock, water and man-made structures. It represents the cumulative consequence of human influence and ecological processes over many thousands of years"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Australia – Tasmania 2003" ;
    skos:prefLabel "LAND COVER"@fr .

ex:Landcover_14 a skos:Concept ;
    dct:source "http://envfor.nic.in/nfc/s-git.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:LandCover ;
    skos:definition "Broad land use classes interpreted from satellite data. The land cover classes used in this report are dense forest, open forest, scrub and nonforest"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "LAND COVER"@fr .

ex:Landcover_15 a skos:Concept ;
    dct:source "http://ma.caudillweb.com/proxy/Document.782.aspx"^^xsd:anyURI ;
    skos:broadMatch ex:LandCover ;
    skos:definition "Land cover - The physical coverage of land, usually expressed in terms of vegetation cover or lack of it. Related to, but not synonymous with, land use"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "LAND COVER"@fr .

ex:Landcover_16 a skos:Concept ;
    dct:source "http://ceos.cnes.fr:8100/cdrom-00b/ceos1/science/glossary/glossl.htm"^^xsd:anyURI ;
    skos:broadMatch ex:LandCover ;
    skos:definition "Land cover generally refers to actual ground cover, eg, vegetation, crops, urban areas and open water. It also includes associations of the Earth's surface and its cover, such as forests, which are composites of various covers. The term reef zone is often used in reef mapping in place of land cover"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "LAND COVER"@fr .

ex:Landcover_17 a skos:Concept ;
    dct:creator "Turner et al. , 20" ;
    dct:date "1995"^^xsd:gYear ;
    dct:source "http://www.rri.wvu.edu/WebBook/Briassoulis/contents.htm"^^xsd:anyURI ;
    skos:broadMatch ex:LandCover ;
    skos:definition "Land cover is the biophysical state of the earth’s surface and immediate subsurface\" . In other words, land cover \"describes the physical state of the land surface: as in cropland, mountains, or forests\" (Meyer 1995, 25 cited in Moser 1996, 247). Meyer and Turner (1994) add: \"it embraces, for example, the quantity and type of surface vegetation, water, and earth materials (Meyer and Turner 1994, 5). Moser (1996) notes that: \"The term originally referred to the type of vegetation that covered the land surface, but has broadened subsequently to include human structures, such as buildings or pavement, and other aspects of the physical environment, such as soils, biodiversity, and surfaces and groundwater\" (Moser 1996, 247"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Turner et al. 1995, 20" ;
    skos:prefLabel "LAND COVER"@fr .

ex:Landcover_18 a skos:Concept ;
    dct:creator "Jensen" ;
    dct:date "2005"^^xsd:gYear ;
    dct:source "http://www.utsa.edu/lrsg/teaching/es6973/project/jayar1.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:LandCover ;
    skos:definition "Land Cover is the type of material present on the landscape. Materials such as water, different types of vegetation, soil, and man-made materials like asphalt"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Jensen 2005" ;
    skos:prefLabel "LAND COVER"@fr .

ex:Landcover_19 a skos:Concept ;
    dct:source "http://www.cara.psu.edu/tools/glossary.asp"^^xsd:anyURI ;
    skos:broadMatch ex:LandCover ;
    skos:definition "Refers to the properties of a portion of the surface of the earth. For example, we can describe an area as covered in grassland, forests, or desert"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "LAND COVER"@fr .

ex:Landcover_2 a skos:Concept ;
    dct:date "2001"^^xsd:gYear ;
    dct:source "http://www.environment.gov.au/soe/2001/land/glossary.html"^^xsd:anyURI ;
    dct:spatial "Australia" ;
    skos:broadMatch ex:LandCover ;
    skos:definition "The physical state of the land surface, including vegetation, soil, rock and human made structures, but specifically used in relation to vegetational changes, to describe the proportion of land covered by vegetation"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Australia 2001" ;
    skos:prefLabel "LAND COVER"@fr .

ex:Landcover_20 a skos:Concept ;
    dct:creator "one or more different land uses" ;
    skos:broadMatch ex:LandCover ;
    skos:definition "That which overlays or currently covers the ground, especially vegetation, permanent snow and ice fields, water bodies, or structures. Barren land is also considered a ‘land cover’ although technically it is lack of cover. The term land cover can be thought of as applying to the setting in which action takes place (USDA Forest Service 1989"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "one or more different land uses" ;
    skos:prefLabel "LAND COVER"@fr .

ex:Landcover_21 a skos:Concept ;
    dct:source "http://ww2.iai.int/eblw1.htm"^^xsd:anyURI ;
    skos:broadMatch ex:LandCover ;
    skos:definition "The actual distribution of vegetation, water, desert, ice, and other physical features of the land, including those created by human activities"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "LAND COVER"@fr .

ex:Landcover_22 a skos:Concept ;
    dct:source "http://www.idg.suny.edu/HO%20submit%20SensitiveSens%2012%2017Porro.htm"^^xsd:anyURI ;
    skos:broadMatch ex:LandCover ;
    skos:definition "The biophysical state of the earth’s surface and immediate subsurface"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "LAND COVER"@fr .

ex:Landcover_23 a skos:Concept ;
    dct:creator "Cihlar and Jansen" ;
    dct:date "2001"^^xsd:gYear ;
    skos:broadMatch ex:LandCover ;
    skos:definition "The composition of the features of the earth's surface"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Cihlar and Jansen 2001" ;
    skos:prefLabel "LAND COVER"@fr .

ex:Landcover_24 a skos:Concept ;
    dct:creator "e.g., closed forests, open forests, or grasslands" ;
    skos:broadMatch ex:LandCover ;
    skos:definition "The ecological state and physical appearance of the land surface (Turner and Meyer 1994"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "e.g., closed forests, open forests, or grasslands" ;
    skos:prefLabel "LAND COVER"@fr .

ex:Landcover_25 a skos:Concept ;
    dct:source "http://www.csc.noaa.gov/crs/lca/faq_data.html#LULC"^^xsd:anyURI ;
    skos:broadMatch ex:LandCover ;
    skos:definition "The natural landscape recorded as surface components: forest, water, wetlands, urban, etc. Land cover can be documented by analyzing spectral signatures of satellite and aerial imagery"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "LAND COVER"@fr .

ex:Landcover_26 a skos:Concept ;
    dct:creator "bio" ;
    skos:broadMatch ex:LandCover ;
    skos:definition "The observed physical cover on the earth's surface. Also aspects describing land itself rather than land cover have been included (e.g. bare areas, waterbodies, etc.) because in practice the scientific community is used to describe those aspects under the term land cover (Di Gregorio and Jansen 1997, 1998, Jansen and Di Gregorio 1998, Choudhury and Jansen 1998"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "bio" ;
    skos:prefLabel "LAND COVER"@fr .

ex:Landcover_27 a skos:Concept ;
    dct:creator "bio" ;
    dct:source "http://www.glcn-lccs.org/index.php?name=Content&pa=showpage&pid=2"^^xsd:anyURI ;
    skos:broadMatch ex:LandCover ;
    skos:definition "The observed physical cover on the earth’s surface. In the strict sense, land cover is confined to vegetation and man-made features; bare rock or bare soils are describing land itself rather than land cover and it is also disputable whether water surfaces can be considered real land cover. However, in practice, the scientific community usually describes those aspects within the term land cover"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "bio" ;
    skos:prefLabel "LAND COVER"@fr .

ex:Landcover_28 a skos:Concept ;
    dct:source "http://www.bib.fsagx.ac.be/coste21/glossary.html"^^xsd:anyURI,
        "http://www.ipcc.ch/pub/SPM_SRLULUCF.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:LandCover ;
    skos:definition "The observed physical and biological cover of the Earth's land as vegetation or man-made features. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "LAND COVER"@fr .

ex:Landcover_29 a skos:Concept ;
    dct:source "http://www.greenfacts.org/glossary/jkl/land-cover.htm"^^xsd:anyURI ;
    skos:broadMatch ex:LandCover ;
    skos:definition "The physical coverage of land, usually expressed in terms of vegetation cover or lack of it. Related to, but not synonymous with, land use"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "LAND COVER"@fr .

ex:Landcover_30 a skos:Concept ;
    dct:source "http://www.aag.org/hdgc/www/intro/glossary/glossary.html"^^xsd:anyURI ;
    skos:broadMatch ex:LandCover ;
    skos:definition "The physical state of the land, including the quantity and type of surface vegetation, water, and earth materials"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "LAND COVER"@fr .

ex:Landcover_31 a skos:Concept ;
    dct:source "http://hosting.soonet.ca/eliris/remotesensing/bl130lec6.html"^^xsd:anyURI ;
    skos:broadMatch ex:LandCover ;
    skos:definition "The surface cover whether vegetation, water, bare soil, urban development or other. Identifying, delineating and mapping land cover is important for global monitoring studies, resource management, and planning activities"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "LAND COVER"@fr .

ex:Landcover_32 a skos:Concept ;
    dct:creator "Kalensky et al" ;
    dct:date "2002"^^xsd:gYear ;
    skos:broadMatch ex:LandCover ;
    skos:definition "The type of surface layer of the specific land area, including vegetation, barren land, open water bodies and artificial surfaces, that can be observed in the field and recorded by aerial or satellite remote sensing"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Kalensky et al. 2002" ;
    skos:prefLabel "LAND COVER"@fr .

ex:Landcover_33 a skos:Concept ;
    dct:creator "natural or planted" ;
    skos:broadMatch ex:LandCover ;
    skos:definition "The vegetation or man made constructions (buildings, etc.) which occur on the earth surface. Water, ice, bare rock, sand and similar surfaces also count as land cover. www.pamagic.org/DataStds/Current/DataStandards_LandUse_05-22-02.pdf"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "natural or planted" ;
    skos:prefLabel "LAND COVER"@fr .

ex:Landcover_34 a skos:Concept ;
    dct:creator "Burley," ;
    dct:date "1961"^^xsd:gYear ;
    skos:broadMatch ex:LandCover ;
    skos:definition "The vegetational and artificial constructions covering the land surface . It thus includes cultural (buildings, artifacts, fields), vegetational (grass, shrubs, trees) and other (water, burned objects and areas, soil , lithology) features on the Earth's surface. (Mücher et al 1993"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Burley, 1961" ;
    skos:prefLabel "LAND COVER"@fr .

ex:Landcover_35 a skos:Concept ;
    dct:source "http://srmwww.gov.bc.ca/risc/pubs/landuse/corporatelanduse/corporatelanduse-03.htm#a"^^xsd:anyURI ;
    skos:broadMatch ex:LandCover ;
    skos:definition "The vegetative, natural or artificial construction covering the land surface"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "LAND COVER"@fr .

ex:Landcover_36 a skos:Concept ;
    dct:source "http://surf.tstc.edu/~rcozby/GPS/ap_terms.htm#L"^^xsd:anyURI ;
    skos:broadMatch ex:LandCover ;
    skos:definition "Usually used to denote the nature of the Earth's surface in areas where the natural environment is dominant"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "LAND COVER"@fr .

ex:Landcover_4 a skos:Concept ;
    dct:creator "ICRAF" ;
    dct:date "2017"^^xsd:gYear ;
    dct:source "http://dx.doi.org/10.5716/WP16079.PDF"^^xsd:anyURI ;
    skos:broadMatch ex:LandCover ;
    skos:definition "Physical material at the surface of the earth, e.g. vegetation or open water, as observable from remote sensing"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "ICRAF - 2017" ;
    skos:prefLabel "LAND COVER"@fr .

ex:Landcover_5 a skos:Concept ;
    dct:creator "OECD" ;
    dct:source "http://stats.oecd.org/glossary/detail.asp?ID=6489"^^xsd:anyURI ;
    skos:broadMatch ex:LandCover ;
    skos:definition "Land cover reflects the (bio) physical dimension of the earth’s surface and corresponds in some regard to the notion of ecosystems. Typical examples for land cover categories are built-up areas, grassland, forests or rivers and lakes"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "OECD" ;
    skos:prefLabel "LAND COVER"@fr .

ex:Landuse_12 a skos:Concept ;
    dct:creator "USA-DOT-FHWA" ;
    dct:source "http://www.fhwa.dot.gov/planning/glossary/glossary_listing.cfm?TitleStart=L"^^xsd:anyURI ;
    skos:broadMatch ex:LandUse ;
    skos:definition "Refers to the manner in which portions of land or the structures on them are used, i.e. commercial, residential, retail, industrial, etc"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-DOT-FHWA" ;
    skos:prefLabel "LAND USE"@de .

ex:Landuse_13 a skos:Concept ;
    dct:creator "USA-EIA" ;
    dct:source "http://www.eia.gov/tools/glossary/index.cfm?id=L"^^xsd:anyURI ;
    skos:broadMatch ex:LandUse ;
    skos:definition "The ultimate uses to be permitted for currently contaminated lands, waters, and structures at each Department of Energy installation. Land-use decisions will strongly influence the cost of environmental management"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-EIA" ;
    skos:prefLabel "LAND USE"@de .

ex:Landuse_19 a skos:Concept ;
    dct:source "http://ohia.com/ohia/roadshows/sky/glossary.htm"^^xsd:anyURI ;
    skos:broadMatch ex:LandUse ;
    skos:definition "A particular manner of using land, such as for residences or recreation"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "LAND USE"@de .

ex:Landuse_20 a skos:Concept ;
    dct:creator "de Bie" ;
    dct:date "2000"^^xsd:gYear ;
    skos:broadMatch ex:LandUse ;
    skos:definition "A series of operations on land, carried out by humans, with the intention to obtain products and/or benefits through using land resources. www.pamagic.org/DataStds/Current/DataStandards_LandUse_05-22-02.pdf and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "de Bie 2000" ;
    skos:prefLabel "LAND USE"@de .

ex:Landuse_21 a skos:Concept ;
    dct:source "http://www.enviroliteracy.org/landuse.html"^^xsd:anyURI ;
    skos:broadMatch ex:LandUse ;
    skos:definition "A term used to describe the various ways in which human beings make use of the land and its resources, including farming, mining, building, or grazing sheep and cattle"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "LAND USE"@de .

ex:Landuse_22 a skos:Concept ;
    dct:source "http://www.glenelg-hopkins.vic.gov.au/catchmentprofile/glossary.asp"^^xsd:anyURI ;
    skos:broadMatch ex:LandUse ;
    skos:definition "Current or intended statutory use or tenure of land"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "LAND USE"@de .

ex:Landuse_23 a skos:Concept ;
    dct:source "http://www.naturegrid.org.uk/eco-exp/glossary.html#land"^^xsd:anyURI ;
    skos:broadMatch ex:LandUse ;
    skos:definition "How land is used. It might be for:· buildings, such as a housing estate, · industrial purposes, such as factories,· leisure, such as a sports centre,· agriculture, such as an orchard"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "LAND USE"@de .

ex:Landuse_24 a skos:Concept ;
    dct:creator "e.g., urban, rural, agricultural, range, forest" ;
    dct:source "http://www.nmlites.org/standards/socialstudies/glossary.html"^^xsd:anyURI ;
    skos:broadMatch ex:LandUse ;
    skos:definition "How people use the Earth's surface ; often subdivided into specific uses (e.g., retail, low-density housing, industrial"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "e.g., urban, rural, agricultural, range, forest" ;
    skos:prefLabel "LAND USE"@de .

ex:Landuse_25 a skos:Concept ;
    dct:source "http://www.wocat.org/ftp/ISCOmap.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:LandUse ;
    skos:definition "Human activities which are directly related to land, making use of its resources or having an impact upon it"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "LAND USE"@de .

ex:Landuse_26 a skos:Concept ;
    dct:source "http://www.idg.suny.edu/HO%20submit%20SensitiveSens%2012%2017Porro.htm"^^xsd:anyURI ;
    skos:broadMatch ex:LandUse ;
    skos:definition "Involves both the manner in which the biophysical attributes of the land are manipulated and the intent underlying that manipulation”"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "LAND USE"@de .

ex:Landuse_27 a skos:Concept ;
    dct:source "http://srmwww.gov.bc.ca/risc/pubs/landuse/corporatelanduse/corporatelanduse-03.htm#a"^^xsd:anyURI ;
    skos:broadMatch ex:LandUse ;
    skos:definition "Land \"use\" is defined in terms of a specific combination of land activity and land cover"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "LAND USE"@de .

ex:Landuse_28 a skos:Concept ;
    dct:creator "Turner et al. , 20" ;
    dct:date "1995"^^xsd:gYear ;
    dct:source "http://www.rri.wvu.edu/WebBook/Briassoulis/contents.htm"^^xsd:anyURI ;
    skos:broadMatch ex:LandUse ;
    skos:definition "Land use involves both the manner in which the biophysical attributes of the land are manipulated and the intent underlying that manipulation – the purpose for which the land is used\" . In a similar vein, Meyer (1995) states that \"land use is the way in which, and the purpose for which, human beings employ the land and its resources (Meyer 1995, 25 cited in Moser 1996, 247). Briefly, land use \"denotes the human employment of land\" (Turner and Meyer 1994, 5). Skole (1994) expands further and states that \"Land use itself is the human employment of a land-cover type, the means by which human activity appropriates the results of net primary production (NPP) as determined by a complex of socio-economic factors\" (Skole 1994, 438). Finally, FAO (1995) states that \"land use concerns the function or purpose for which the land is used by the local human population and can be defined as the human activities which are directly related to land, making use of its resources or having an impact on them\" (FAO 1995, 21"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Turner et al. 1995, 20" ;
    skos:prefLabel "LAND USE"@de .

ex:Landuse_29 a skos:Concept ;
    dct:source "http://www.glcn-lccs.org/index.php?name=Content&pa=showpage&pid=2"^^xsd:anyURI ;
    skos:broadMatch ex:LandUse ;
    skos:definition "Land use is characterized by the arrangements, activities and inputs people undertake in a certain land cover type to produce, change or maintain it. The definition of land use establishes a direct link between land cover and the actions of people in their environment"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "LAND USE"@de .

ex:Landuse_30 a skos:Concept ;
    dct:creator "Jensen" ;
    dct:date "2005"^^xsd:gYear ;
    dct:source "http://www.utsa.edu/lrsg/teaching/es6973/project/jayar1.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:LandUse ;
    skos:definition "Land Use refers to what people do on the land surface, such as agriculture, commercial and residential development, and transportation"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Jensen 2005" ;
    skos:prefLabel "LAND USE"@de .

ex:Landuse_31 a skos:Concept ;
    dct:source "http://www.nscb.gov.ph/ru12/DEFINE/DEF-ENV.HTM"^^xsd:anyURI ;
    skos:broadMatch ex:LandUse ;
    skos:definition "Man's activities on land of which settlements, forestry, agriculture, mining, grazing and water use are the most predominant"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "LAND USE"@de .

ex:Landuse_32 a skos:Concept ;
    dct:creator "Anderson et al" ;
    dct:date "1976"^^xsd:gYear ;
    skos:broadMatch ex:LandUse ;
    skos:definition "Man's activities on land which are directly related to land"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Anderson et al. 1976" ;
    skos:prefLabel "LAND USE"@de .

ex:Landuse_33 a skos:Concept ;
    dct:source "http://www.cara.psu.edu/tools/glossary.asp"^^xsd:anyURI ;
    skos:broadMatch ex:LandUse ;
    skos:definition "Refers to how land is utilized by humans, as in agricultural land use, urban development, or mining"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "LAND USE"@de .

ex:Landuse_34 a skos:Concept ;
    dct:source "http://www.raqc.org/more/define.htm#L"^^xsd:anyURI ;
    skos:broadMatch ex:LandUse ;
    skos:definition "Refers to the manner in which portions of land or the structures on them are used, e.g., commercial, residential, retail, industrial, etc"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "LAND USE"@de .

ex:Landuse_35 a skos:Concept ;
    dct:creator "or land occasionally cut for hay" ;
    dct:source "http://dnr.state.il.us/mines/lrd/guides/farm6.htm"^^xsd:anyURI ;
    skos:broadMatch ex:LandUse ;
    skos:definition "Specific use or management-related activity, rather than the vegetation or cover of the land. The categories of and use are cropland, developed water resource, fish and wildlife habitat, forestry, industrial/commercial, pastureland , recreation, residential, and undeveloped land"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "or land occasionally cut for hay" ;
    skos:prefLabel "LAND USE"@de .

ex:Landuse_36 a skos:Concept ;
    dct:source "http://cfpm.org/caves/CAVESWiki/Glossary"^^xsd:anyURI ;
    skos:broadMatch ex:LandUse ;
    skos:definition "The activity land is used for"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "LAND USE"@de .

ex:Landuse_37 a skos:Concept ;
    dct:creator "Di Gregorio and Jansen , , Jansen and Di Gregorio" ;
    dct:date "1997"^^xsd:gYear ;
    skos:broadMatch ex:LandUse ;
    skos:definition "The arrangements, activities and inputs people undertake in a certain land cover type to produce, change or maintain it . A given land use may take place on one, or more than one, piece of land and several land uses may occur on the same piece of land. Definition of land use in this way provides a basis for precise and quantitative economic and environmental impact analysis and permits precise distinctions between land uses, if required. Lands may be devoid of forest cover, but may be used for forestry purposes. Similarly, lands may have tree cover, but not used for forestry use – i.e. \"urban forests.\""@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Di Gregorio and Jansen 1997, 1998, Jansen and Di Gregorio 1998" ;
    skos:prefLabel "LAND USE"@de .

ex:Landuse_38 a skos:Concept ;
    dct:source "http://ceos.cnes.fr:8100/cdrom-00b/ceos1/science/glossary/glossl.htm"^^xsd:anyURI ;
    skos:broadMatch ex:LandUse ;
    skos:definition "The current use of an area of land. This term is different to, but often confused with, land cover"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "LAND USE"@de .

ex:Landuse_39 a skos:Concept ;
    dct:creator "the actual use of land and related structures and modifications to the landscape" ;
    dct:source "http://srmwww.gov.bc.ca/risc/pubs/landuse/corporatelanduse/corporatelanduse-03.htm#a"^^xsd:anyURI ;
    skos:broadMatch ex:LandUse ;
    skos:definition "The description of human enterprises on the land and water, and may have the following components: activities ; use-related land cover (where cover implies a use or is important to interpreting patterns or impacts of use); declared interests in the land (where use decisions may be affected by such interests); legal entities (legal boundaries, tenures, and regulations that affect use"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "the actual use of land and related structures and modifications to the landscape" ;
    skos:prefLabel "LAND USE"@de .

ex:Landuse_40 a skos:Concept ;
    dct:source "http://srmwww.gov.bc.ca/risc/pubs/landuse/corporatelanduse/corporatelanduse-03.htm#a"^^xsd:anyURI ;
    skos:broadMatch ex:LandUse ;
    skos:definition "The description of the human cultural activities on the land and water"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "LAND USE"@de .

ex:Landuse_41 a skos:Concept ;
    dct:creator "agro" ;
    skos:broadMatch ex:LandUse ;
    skos:definition "The direct interaction/manipulation with/of the ecosystem by man (Mücher et al 1993"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "agro-" ;
    skos:prefLabel "LAND USE"@de .

ex:Landuse_42 a skos:Concept ;
    dct:source "http://www.csc.noaa.gov/crs/lca/faq_data.html#LULC"^^xsd:anyURI ;
    skos:broadMatch ex:LandUse ;
    skos:definition "The documentation of human uses of the landscape: residential, commercial, agricultural, etc. Land use can be inferred but not explicitly derived from satellite and aerial imagery. There is no spectral basis for land use determination in satellite imagery"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "LAND USE"@de .

ex:Landuse_43 a skos:Concept ;
    dct:creator "HUDCC" ;
    dct:source "http://www.nscb.gov.ph/peenra/Publications/Compendium/glossary.PDF"^^xsd:anyURI ;
    skos:broadMatch ex:LandUse ;
    skos:definition "The employment of a site or holding so as to derive revenue or other benefits from it; the delineation by a governing authority of the utilization of the land within a particular jurisdiction so as to promote the most advantageous development of the community such as industrial, residential, commercial, recreational and other uses under a plan"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "HUDCC" ;
    skos:prefLabel "LAND USE"@de .

ex:Landuse_44 a skos:Concept ;
    dct:source "http://anmf.web1000.com/BIBLIOGRAPHY%20ON%20AFRICA%20MOUNTAINS.html"^^xsd:anyURI ;
    skos:broadMatch ex:LandUse ;
    skos:definition "The function for which the land is rendered in the attempt to satisfy some human wants"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "LAND USE"@de .

ex:Landuse_45 a skos:Concept ;
    dct:creator "Thompson" ;
    dct:date "1996"^^xsd:gYear ;
    skos:broadMatch ex:LandUse ;
    skos:definition "The human activity that is associated with a specific land unit, in terms of utilization, impacts or management practices"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Thompson 1996" ;
    skos:prefLabel "LAND USE"@de .

ex:Landuse_46 a skos:Concept ;
    dct:source "http://www.aag.org/hdgc/www/intro/glossary/glossary.html"^^xsd:anyURI ;
    skos:broadMatch ex:LandUse ;
    skos:definition "The human employment of land; includes settlements, cultivation, pasture, rangeland, and recreation, among others"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "LAND USE"@de .

ex:Landuse_47 a skos:Concept ;
    dct:creator "Meyer and Turner" ;
    dct:date "1992"^^xsd:gYear ;
    skos:broadMatch ex:LandUse ;
    skos:definition "The human employment of the land"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Meyer and Turner 1992" ;
    skos:prefLabel "LAND USE"@de .

ex:Landuse_48 a skos:Concept ;
    dct:creator "such as irrigated agriculture or recreation" ;
    dct:source "http://ma.caudillweb.com/proxy/Document.782.aspx"^^xsd:anyURI,
        "http://www.greenfacts.org/glossary/jkl/land-use.htm"^^xsd:anyURI ;
    skos:broadMatch ex:LandUse ;
    skos:definition "The human use of a piece of land for a certain purpose . Influenced by, but not synonymous with, land cover. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "such as irrigated agriculture or recreation" ;
    skos:prefLabel "LAND USE"@de .

ex:Landuse_49 a skos:Concept ;
    dct:creator "Turner, et al" ;
    dct:date "1995"^^xsd:gYear ;
    skos:broadMatch ex:LandUse ;
    skos:definition "The intent and management strategy placed on a land cover type"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Turner, et al. 1995" ;
    skos:prefLabel "LAND USE"@de .

ex:Landuse_5 a skos:Concept ;
    dct:creator "ICRAF" ;
    dct:date "2017"^^xsd:gYear ;
    dct:source "http://dx.doi.org/10.5716/WP16079.PDF"^^xsd:anyURI ;
    skos:broadMatch ex:LandUse ;
    skos:definition "Management and modification of land cover for specific (human) purposes, such as agriculture, forestry, industrial or urban uses"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "ICRAF - 2017" ;
    skos:prefLabel "LAND USE"@de .

ex:Landuse_50 a skos:Concept ;
    dct:source "http://surf.tstc.edu/~rcozby/GPS/ap_terms.htm#L"^^xsd:anyURI ;
    skos:broadMatch ex:LandUse ;
    skos:definition "The nature of the Earth's surface in areas where the human imprint upon land is dominant"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "LAND USE"@de .

ex:Landuse_52 a skos:Concept ;
    dct:creator "Kalnensky et al" ;
    dct:date "2002"^^xsd:gYear ;
    skos:broadMatch ex:LandUse ;
    skos:definition "The purpose for which a specific land area is used by people; the socio-economic function of such an area"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Kalnensky et al. 2002" ;
    skos:prefLabel "LAND USE"@de .

ex:Landuse_53 a skos:Concept ;
    dct:source "http://hosting.soonet.ca/eliris/remotesensing/bl130lec6.html"^^xsd:anyURI ;
    skos:broadMatch ex:LandUse ;
    skos:definition "The purpose the land serves, for example, recreation, wildlife habitat, or agriculture, urban development, and mostly areas impacted by human activity. Knowledge of land use helps us to develop strategies to balance conservation, conflicting uses, and developmental pressures. Some of the issues which are of concern include the removal or disturbance of productive land, urban encroachment, and depletion of forests"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "LAND USE"@de .

ex:Landuse_54 a skos:Concept ;
    dct:creator "e.g., protected areas, forestry for timber products, plantations, row-crop agriculture, pastures, or human settlements" ;
    skos:broadMatch ex:LandUse ;
    skos:definition "The purpose to which land is put by humans (Turner and Meyer 1994). Change in land use may or may not cause a significant change in land cover. For example, change from selectively harvested forest to protected forest will not cause much discernible cover change in the short term, but change to cultivated land will cause a large change in cover"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "e.g., protected areas, forestry for timber products, plantations, row-crop agriculture, pastures, or human settlements" ;
    skos:prefLabel "LAND USE"@de .

ex:Landuse_55 a skos:Concept ;
    dct:creator "Cihlar and Jansen" ;
    dct:date "2001"^^xsd:gYear ;
    skos:broadMatch ex:LandUse ;
    skos:definition "The type of human activity taking place at or near the earth's surface"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Cihlar and Jansen 2001" ;
    skos:prefLabel "LAND USE"@de .

ex:Landuse_56 a skos:Concept ;
    dct:source "http://en.mimi.hu/environment/land_use.html"^^xsd:anyURI ;
    skos:broadMatch ex:LandUse ;
    skos:definition "The way in which land is used, especially in farming and city planning"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "LAND USE"@de .

ex:Landuse_57 a skos:Concept ;
    dct:creator "Meyer" ;
    dct:date "1995"^^xsd:gYear ;
    skos:broadMatch ex:LandUse ;
    skos:definition "The way in which, and the purposes for which, humans employ the land and its resources"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Meyer 1995" ;
    skos:prefLabel "LAND USE"@de .

ex:Landuse_58 a skos:Concept ;
    dct:creator "agriculture, residences, industries, etc" ;
    dct:source "http://www.abag.ca.gov/bayarea/sfep/reports/soe/soegloss.htm"^^xsd:anyURI ;
    skos:broadMatch ex:LandUse ;
    skos:definition "The way land is developed and used in terms of the kinds of activities allowed and the size of buildings and structures permitted"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "agriculture, residences, industries, etc." ;
    skos:prefLabel "LAND USE"@de .

ex:Landuse_59 a skos:Concept ;
    dct:creator "e.g., agriculture, residential areas, industrial areas" ;
    dct:source "http://www.planning.arizona.edu/projects/proj_azcity_glossary.doc"^^xsd:anyURI ;
    skos:broadMatch ex:LandUse ;
    skos:definition "The way land is developed and used in terms of the kinds of anthropogenic activities that occur"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "e.g., agriculture, residential areas, industrial areas" ;
    skos:prefLabel "LAND USE"@de .

ex:Landuse_9 a skos:Concept ;
    dct:creator "OECD" ;
    dct:source "http://stats.oecd.org/glossary/detail.asp?ID=6493"^^xsd:anyURI ;
    skos:broadMatch ex:LandUse ;
    skos:definition "Land use is based on the functional dimension of land for different human purposes or economic activities. Typical categories for land use are dwellings, industrial use, transport, recreational use or nature protection areas"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "OECD" ;
    skos:prefLabel "LAND USE"@de .

ex:LocalArabicTerm_1 a skos:Concept ;
    dct:spatial "Yemen" ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "Local Arabic term : Tashjeer or Tahreej) Artificial creation (by man) of a forest on an land. Mohammed Ellatifi, m.ellatifi@ellatifi.8m.com"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Yemen" ;
    skos:prefLabel "- Local Arabic term"@ca .

ex:NativeTree_1 a skos:Concept ;
    dct:source "http://www.u-net.com/trees/p4.htm"^^xsd:anyURI ;
    dct:spatial "United Kingdom" ;
    skos:broadMatch ex:Tree ;
    skos:definition "Those trees that colonised the British Isles after the last ice age and before they were cut off from the rest of Europe by the rising sea levels. Includes the island of Ireland as well as Britain"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "United Kingdom" ;
    skos:prefLabel "Native Tree"@en .

ex:Nativeforest_1 a skos:Concept ;
    skos:broadMatch ex:NativeForest ;
    skos:definition "See: Lund, H. Gyde. 2016 revised. Definitions of old growth, pristine, climax, ancient forests, degradation, desertification, forest fragmentation, and similar terms. [Online publication], Gainesville, VA: Forest Information Services. Misc. pagination. DOI: 10.13140/RG.2.1.2963.7361"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "NATIVE FOREST"@en .

ex:NaturalRegeneration_1 a skos:Concept ;
    dct:source "http://www.forestry.gov.uk/standard.html"^^xsd:anyURI,
        "http://www.forestry.gov.uk/standard.pdf"^^xsd:anyURI ;
    dct:spatial "United Kingdom" ;
    skos:broadMatch ex:Regeneration ;
    skos:definition "Plants growing on a site as a result of natural seed fall or suckering. The term is also used to describe the silvicultural practices used to encourage natural seeding and successful growth of the seedlings. [Source: THE UK FORESTRY STANDARD. The Government's Approach to Sustainable Forestry, EDINBURGH: FORESTRY COMMISSION, 1998 and From: \"Maksym Polyakov\" <mpoliak@pcomp.usau.kiev.ua Date: Tue, 23 Jun 1998 21:04:18 +0300 (MSD)]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "United Kingdom" ;
    skos:prefLabel "Natural Regeneration"@de .

ex:Naturalforest_1 a skos:Concept ;
    skos:broadMatch ex:NaturalForest ;
    skos:definition "See: Lund, H. Gyde. 2016 revised. Definitions of old growth, pristine, climax, ancient forests, degradation, desertification, forest fragmentation, and similar terms. [Online publication], Gainesville, VA: Forest Information Services. Misc. pagination. DOI: 10.13140/RG.2.1.2963.7361"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "NATURAL FOREST"@no .

ex:Neubewaldung_1 a skos:Concept ;
    dct:spatial "Austria" ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "A land use change from different uses to forests. Both natural regeneration and artificial planting count as afforestation. (Austrian Forestry Act (Federal Legal Gazette no. 440/1975, as amended Federal Legal Gazette 231/1977, 142/1978 and 576/1987) From: Weiss Peter weissp@ubavie.gv.at"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Austria" ;
    skos:prefLabel "Neubewaldung"@de .

ex:NonForestEcosystem_1 a skos:Concept ;
    dct:source "http://legacy.ca.gov/pub_docs/CCRISP_ResourceAssessmentMethodologyCaseStudies.pdf"^^xsd:anyURI,
        "http://www.eman-rese.ca/eman/ecotools/protocols/terrestrial/vegetation/glossary.html"^^xsd:anyURI ;
    skos:broadMatch ex:NonForest ;
    skos:definition "Grasslands, shrublands, chaparral, wetlands, deserts, etc., where trees are not the dominant life form, although they may be present as scattered individuals or in patches. See forest ecosystem. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "Non-forest ecosystem"@en .

ex:Nonforest_1 a skos:Concept ;
    dct:source "http://www.cbd.int/doc/world/fj/fj-nr-04-en.pdf"^^xsd:anyURI ;
    dct:spatial "Fiji" ;
    skos:broadMatch ex:NonForest ;
    skos:definition "Non-forest: .is defined as areas covered by settlements, urban areas, and grass and shrub vegetation visible as such in the satellite images"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Fiji" ;
    skos:prefLabel "Non-Forest"@en .

ex:Nonforest_2 a skos:Concept ;
    dct:creator "Russia" ;
    dct:date "1995"^^xsd:gYear ;
    dct:source "http://www.fire.uni-freiburg.de/iffn/iffn_24/iffn24.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:NonForest ;
    skos:definition "Non-forest lands include lands that are part of the forestry system (land occupied by cutlines between forest compartments or blocks, roads, arable lands, and other lands), as well as other lands located within the borders of the Forest Fund (lands occupied by bogs, rocky places, or other lands unsuitable for use"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Russia 1995" ;
    skos:prefLabel "Non-Forest"@en .

ex:Nonforest_3 a skos:Concept ;
    dct:source "http://www.r5.fs.fed.us/sixrivers/publications/feis/appedix/g.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:NonForest ;
    skos:definition "Lands that are incapable of having 10 percent or more of the area occupied by forest trees, or lands developed for other uses"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "Non-Forest"@en .

ex:Nonforest_4 a skos:Concept ;
    dct:source "http://srmwww.gov.bc.ca/tib/reports/glossary/glossary.htm#n.htm"^^xsd:anyURI ;
    skos:broadMatch ex:NonForest ;
    skos:definition "Non-forest - Land not primarily intended for growing or supporting forest. Includes alpine, rock, slide, non-productive burn, non-productive brush, swamp or muskeg, cultivated, cleared, urban, open range, wild hay meadow, clay bank, gravel bar, and other categories"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "Non-Forest"@en .

ex:Nonforest_5 a skos:Concept ;
    dct:source "http://www.babineefmpp.com/glossary/N.html"^^xsd:anyURI,
        "http://www.swp.bc.ca/myw/html/21_Glossary.htm"^^xsd:anyURI ;
    skos:broadMatch ex:NonForest ;
    skos:definition "Non-forest land - Land not primarily intended for growing or supporting a forest. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "Non-Forest"@en .

