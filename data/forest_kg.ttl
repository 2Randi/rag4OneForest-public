ex:Bosque_1 a skos:Concept ;
    dct:spatial "Nicaragua" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Draft -Ecosistema con un mínimo de un 25% de copas de árboles y/o bambú y palmáceas, asociadas generalmente a una fauna silvestre y condiciones de suelos naturales. www.nicarao.org.ni/ja (see Borrador de la ley, CAPITULO II DEFINICIONES) Harrie harnic@ibw.com.ni"@es ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Nicaragua" ;
    skos:prefLabel "Bosque"@fr ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

