ex:Forest_1266 a skos:Concept ;
    dct:date "2006"^^xsd:gYear ;
    dct:source "http://www.fire.uni-freiburg.de/GlobalNetworks/BalticRegion/ForestCode-3rdReading-061108-eng.pdf"^^xsd:anyURI ;
    dct:spatial "Russian Federation" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Статья 5. Понятие леса - Использование, охрана, защита, воспроизводство лесов осуществляются исходя из понятия о лесе как об экологической системе или как о природном ресурсе. Article 5. Definition of forest Utilization, protection, conservation and reforestation are carried out based on understanding forests as an ecological system or a natural resource. From Yelena Gordeeva, 3 June 2015. yelena.gordeeva@uhasselt.be See also"@ru ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Russian Federation 2006" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "National"@en .

ex:Forest_1267 a skos:Concept ;
    dct:source "http://www.fao.org/legal/prs-ol/lpo%2084.pdf"^^xsd:anyURI ;
    dct:spatial "South Africa" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Under the Forest Act, not only does the definition of forest include all biological organisms, it also includes the desire to “do anything in a state forest for which a licence is required” (which could apply to hunting) (sec. 29"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "South Africa " ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "National"@en .

