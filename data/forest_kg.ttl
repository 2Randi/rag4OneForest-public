ex:ForForestCoverAssessments_1 a skos:Concept ;
    dct:date "1997"^^xsd:gYear ;
    dct:spatial "India" ;
    skos:broadMatch ex:Forest ;
    skos:definition "all lands with a tree canopy density of more than 10 percent though they may not be statutorily notified as forest. Thus the forest cover assessments would leave out barren \"forest\" areas but include plantations done outside forest reserves. T P Singh tpsingh@teri.res.in and Forest Survey of India. 1997. The state of Forest Report (Ministry of Environment and Forests. Dehra Dun, India"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "India 1997" ;
    skos:prefLabel "For forest cover assessments"@en ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:ForGypsyMothSpraying_1 a skos:Concept ;
    dct:creator "USA-STATE-Virginia" ;
    dct:source "http://gypsymoth.ento.vt.edu/vagm/VDACS_CostShare02.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Any spray block proposed for treatment under this program must contain an area that meets the following definition of susceptible forest. A susceptible forest is a wooded area where the trees are 25 feet or more in height and 50% or more of the surface area, when viewed from above, is covered by the tree crowns of moderately or highly susceptible hardwood tree species. Any block that does not contain a forested area as defined will not be accepted for treatment under this program. Residential or other qualified properties with only scattered ornamental trees and shrubs or only a few large shade trees are not acceptable. However, residential or other qualified properties, even if they do not contain trees directly around them, are acceptable if they are less than 200 feet from a susceptible forest"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Virginia" ;
    skos:prefLabel "For Gypsy Moth Spraying"@en ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:ForestAndOtherWoodedLand_1 a skos:Concept ;
    dct:creator "UN-SD" ;
    dct:date "2001"^^xsd:gYear ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land with tree crown cover (or equivalent stocking level) of more than 10 per cent and area of more than 0.5 hectares and land either with a crown cover (or equivalent stocking level) of 5-10 per cent of trees able to reach a height of 5 metres at maturity in situ; or a crown cover (or equivalent stocking level) of more than 10 per cent of trees not able to reach a height of 5 metres at maturity in situ (e.g. dwarf or stunted trees); or with shrub or bush cover of more than 10 per cent. www.un.org/Depts/unsd/enviro/q2001land.pdf. United Nations Statistics Division"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-SD 2001" ;
    skos:prefLabel "Forest and other wooded land"@en ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:ForestAndWoodland_1 a skos:Concept ;
    dct:creator "Islamic Countries" ;
    dct:source "http://www.sesrtcic.org/SUBFILES/SUBJDEF.HTM"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest (and woodland) - Areas covered by natural or planted trees and areas that are cleared but planned to be reforested. Source: - for 56 Islamic Countries"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Islamic Countries" ;
    skos:prefLabel "Forest and woodland"@en ;
    skos:scopeNote "International"@en,
        "Land use"@en .

ex:ForestAndWoodyVegetation_1 a skos:Concept ;
    dct:source "http://www.fao.org/forestry/fo/country/index.jsp?lang_id=1&geo_id=114"^^xsd:anyURI ;
    dct:spatial "Kiribati" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Intensive agroforestry practices system based on coconut breadfruit, bananas, pandanus and native figs. The system tends to represent natural forest since the trees occur spontaneously. It includes coastal vegetation, inland forest and wetlands"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Kiribati" ;
    skos:prefLabel "Forest and woody vegetation"@en ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:ForestArabic_1 a skos:Concept ;
    dct:spatial "Morocco" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest (Arabic : Ghabah, French : Foret, Spanish : Bosque, Berber : ‘Ari) - Piece of land covered a vegetation in which trees(not only fruit trees) are predominant(over 50%), and with at least 3 ha of continuously forested area, and with a tree crown cover equal or superior to 20%. Mohammed Ellatifi, m.ellatifi@ellatifi.8m.com"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Morocco" ;
    skos:prefLabel "Forest Arabic"@ca ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

