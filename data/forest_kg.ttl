ex:Woodland_82 a skos:Concept ;
    skos:broadMatch ex:Woodland ;
    skos:definition "20% to 49% trees. Source: Amreican Forests via Fleishman, Sandra. 2003. Why were the trees cut down? The Washington Post. Section F1,8-9. 28 June. Note: area with less than 20% trees are termed “Developed Acreage.”"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_83 a skos:Concept ;
    dct:source "http://www.woodlandowner.org.uk/glossary.htm#W"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "A biological community dominated by trees and other woody plants"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_84 a skos:Concept ;
    dct:source "http://members.aol.com/artgumbus/glossary.html"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "A cultural period of the Eastern North American Aborigine Indians dating from 3,000 - 1,300 B.P. Usually, the presence of pottery differentiates the Woodland culture from the Archaic culture which preceded it"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_85 a skos:Concept ;
    dct:source "http://www.mhhe.com/biosci/pae/glossary/glossaryw.mhtml"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "A forest where tree crowns cover less than 20 percent of the ground; also called open canopy"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_86 a skos:Concept ;
    dct:source "http://www.sfrc.ufl.edu/Extension/ssfor11.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "A forest with low tree densities, often defined as less than 20% to 30% crown cover when trees are mature"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_87 a skos:Concept ;
    dct:source "http://www.for.nau.edu/courses/for250/Definitions/Definitions.html"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "A landscape where the dominant vegetation is composed of tree species that are generally not capable of producing commercial tree growth"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_88 a skos:Concept ;
    dct:creator "up to 30% of the land surface covered by the crowns" ;
    dct:source "http://www.forestry.sa.gov.au/pdf/glossary.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "A native plant community dominated by trees with relatively open spacing , often with a dense understorey"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "up to 30% of the land surface covered by the crowns" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_89 a skos:Concept ;
    dct:source "http://www.midcoast.com/~wpl/mvlt/nri/glossary.html"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "A natural community of widely spaced and often stunted trees that occurs on knolls and hill tops where soils are excessively well-drained and bedrock outcrops are abundant"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_9 a skos:Concept ;
    dct:source "http://www.statcan.ca/english/agcensus2006/glossary.htm#gt36"^^xsd:anyURI ;
    dct:spatial "Canada" ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Non-workable land such as woodlots, sugarbushes, tree windbreaks, and bush that is not used for grazing"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Canada" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_90 a skos:Concept ;
    dct:source "http://www.ifdn.com/teacher/glossary.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "A piece of land on which trees are cultivated"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_91 a skos:Concept ;
    dct:creator "usually species of eucalypts" ;
    dct:source "http://155.187.10.12/glossary/fl-nsw.html"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "A plant community dominated by short-boled trees that are separated from each other and with grasses and other herbs forming a more or less continuous ground cover between them"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "usually species of eucalypts" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_92 a skos:Concept ;
    dct:source "http://www.thamesriver.on.ca/ONHS/final_report/Glossary.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "A plant community dominated by trees with over 35% canopy cover"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_93 a skos:Concept ;
    dct:creator "cf. Savanna, 1.1.4.2.7" ;
    dct:source "https://onlinelibrary.wiley.com/doi/pdf/10.1111/j.1365-2494.2010.00780.x"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "A plant community in which, in contrast to a typical forest, the trees are often small, characteristically short-boled relative to their crown depth and forming only an open canopy with the intervening area being occupied by shorter vegetation, commonly grass"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "cf. Savanna, 1.1.4.2.7" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_94 a skos:Concept ;
    dct:source "http://www.fnr.purdue.edu/inwood/glossary.html"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "A small forest"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_95 a skos:Concept ;
    dct:source "http://www.kalro.org:8080/repository/bitstream/0/5057/1/REPRINT%20COLLECTION%2063%20Split%2035.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "A stand of trees, up to 18 m in height, with an open or continuous but not thickly interlaced canopy, sometimes with shrubs interspersed, and a canopy cover of more than 20%. Grasses and herbs dominate the ground cover; epiphytic ferns are rare. Often subject to periodic burning. Woodland thicket )-defined as for bushland thicket-may also be recognized"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_96 a skos:Concept ;
    dct:source "http://www.michigandnr.com/publications/pdfs/huntingwildlifehabitat/Landowners_Guide/Introduction/Glossary.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "A tract of forest"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_97 a skos:Concept ;
    dct:source "http://mojavedesert.net/glossary/forest.html"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "A vegetation community that includes widely spaced large trees. The tree crowns are typically more spreading in form than those of forest trees and do not form a closed canopy. Grass, heath, or scrub may develop between the trees"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_98 a skos:Concept ;
    dct:creator "Timberlake, Nobanda & Mapaure, ; Pratt, Greenway & Gwynne," ;
    dct:date "1993"^^xsd:gYear ;
    skos:broadMatch ex:Woodland ;
    skos:definition "A woodland is a stand of trees up to 18m high with a canopy cover of 20-80%. Ground layer is dominated by grasses . (Isaac Mapaure. Researchgate. 23 Jan 2014).g"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Timberlake, Nobanda & Mapaure, 1993; Pratt, Greenway & Gwynne, 1966" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_99 a skos:Concept ;
    dct:source "http://www.rmrs.nau.edu/publications/rm_gtr_295/glossary.html"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "An area or biotic community dominated by widely-spaced trees of short stature growing on warm, dry sites. In the Southwest, common woodland species are oak, pinyon, and juniper; these woodlands usually occur below 8,000 feet elevation"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:WoodlandsAreDefinedToHave_1 a skos:Concept ;
    dct:creator "Tanzania" ;
    dct:source "http://www.fao.org/ag/agl/agll/landuse/clsys/Usambara.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "10 - 40 % crown cover (Iversen 1991) and dominant height less than 10 meters. Source: Kari Hyytiaeinen, Land Use Classification and Mapping for the East Usambara Mountains, Usambara Catchment Forest Project, Technical Paper No. 12, Department of International Development Co-optation, Finland, Metsaehallitus - Forest and Park Service, 1995"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Tanzania" ;
    skos:prefLabel "Woodlands are defined to have"@en .

ex:WoodlandsOpen_1 a skos:Concept ;
    dct:source "http://content.alterra.wur.nl/Internet/webdocs/ilri-publicaties/publicaties/Pub36/Proceeding%20of%20the%20workshop%20leeg-h3.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Woodlands, open with less than 20% tree cover, often as small forest remnants scattered over the hill ranges; the domination is important: it indicates that these terrains, regardless of their administrative status, are used as grazing lands, and that their production potential for animal husbandry is more important than for timber production"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "Woodlands open"@nl .

ex:Woodlands_1 a skos:Concept ;
    dct:source "http://www.polity.org.za/govdocs/green_papers/forest1.html#t1.1"^^xsd:anyURI ;
    dct:spatial "South Africa" ;
    skos:broadMatch ex:Woodland ;
    skos:definition "40-99% canopy cover, usually a tree layer, shrub layer and grass layer, typically 6m or more tall; regular fires"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "South Africa" ;
    skos:prefLabel "Woodlands"@en .

ex:Woodlands_3 a skos:Concept ;
    dct:source "http://www.scopenvironment.org/downloadpubs/scope56/Chapter04.html"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "have 50-100% tree canopy cover by trees, and a sometimes sparse, but always significant gramineous layer; Savannas have 10-50% cover by woody plants, and in the unexploited state, a well-developed grass layer"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "Woodlands"@en .

ex:Woodlands_4 a skos:Concept ;
    dct:creator "generally forming 25-60% cover" ;
    dct:source "https://wrangle.org/biome/woodland-savanna"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "and savannas are considered open stands of trees with crowns not usually touching . Canopy tree cover may be less than 25% in cases where it exceeds shrub, herb, and nonvascular cover, respectively"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "generally forming 25-60% cover" ;
    skos:prefLabel "Woodlands"@en .

ex:Woodlot_1 a skos:Concept ;
    dct:source "http://www.nap.edu/openbook.php?record_id=1985&page=674"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "A restricted area of woodland, usually privately maintained as a source of fuel, posts, and lumber"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "Woodlot"@pl .

ex:Woodlot_2 a skos:Concept ;
    dct:source "http://www.fnr.purdue.edu/inwood/glossary.html"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "A small forest"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "Woodlot"@pl .

ex:WoodsCopses_1 a skos:Concept ;
    dct:source "http://www.fsc-uk.demon.co.uk/Appendices.html"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Woods, Copses, Shelterbelts - predominately tree covered land in smaller units. Paraphrased from"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "Woods Copses"@en .

ex:Woods_1 a skos:Concept ;
    dct:creator "USA-STATE-TEXAS" ;
    dct:source "http://www.texasep.org/html/wld/wld_4hab.html"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Woody plants mostly nine to 30 feet tall with closed crowns or nearly so (71 to 100 percent canopy cover); midstory usually lacking"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-TEXAS" ;
    skos:prefLabel "Woods"@af .

ex:WoodyLand_1 a skos:Concept ;
    dct:creator "Dobson, et al" ;
    dct:date "1995"^^xsd:gYear ;
    dct:source "http://www.dos.state.ny.us/cstl/Final_Draft_HTML/Tech_Report_HTM/Land_Cover/Appendices1_LC.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "\"The Woody land class includes any species with an aerial stem that persists for more than one season. The class is divided into three subclasses: 1.41-Deciduous, 1`.42-Evergreen, and 1.43-Mixed.\" . Each of these classes in turn are divided into Forest and Scrub/Shrub components based on a 20 foot height criterion"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Dobson, et al. 1995" ;
    skos:prefLabel "Woody land"@en .

ex:WoodyLand_2 a skos:Concept ;
    dct:source "http://www.hgac.cog.tx.us/resources/wq/crp/lcmethod_rev3.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "includes non-agricultural trees and shrubs. The category alleviates the problem of separating various sizes of trees and shrubs using satellite remote sensor data but allows a height-based separation if high-resolution aerial photography are available. The class may be partitioned into three subclasses: Deciduous, Evergreen, and Mixed. These three subclasses generally can be discriminated with satellite remote sensing systems"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "Woody Land"@en .

ex:WoodyVegetation_1 a skos:Concept ;
    dct:source "http://www.asiaforestnetwork.org/pub/pub29.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "formations with scattered trees, generally with less than 40% crown cover. Also known as open forests"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "Woody vegetation"@en .

