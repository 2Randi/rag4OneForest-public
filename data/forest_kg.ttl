    dct:date "2008"^^xsd:gYear ;
    dct:source "http://www.for.gov.bc.ca/hfd/library/documents/glossary/Glossary.pdf"^^xsd:anyURI ;
    dct:spatial "Canada" ;
    skos:broadMatch ex:Forest ;
    skos:definition "“A complex community of plants and animals in which trees are the most conspicuous members and where the tree crown density—the amount of compactness of foliage in the tree tops—is greater than 10 percent” (64):Section F quote BC 2008"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Canada-BC 2008" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

