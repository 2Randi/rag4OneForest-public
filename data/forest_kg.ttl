ex:Forest_1247 a skos:Concept ;
    dct:date "2009"^^xsd:gYear ;
    dct:source "http://www.efi.int/files/attachments/publications/annex_1_to_efi_technical_report_88__2013.pdf"^^xsd:anyURI ;
    dct:spatial "Finland" ;
    skos:broadMatch ex:Forest ;
    skos:definition "The second definition is the national definition of forest that in Finland is the same as in the two other Nordic countries, Sweden and Norway: forest is defined as a land capable of producing an annual increment of volume growing stock of at least 1 m3/ha per year over the rotation under the most favorable tree species composition, and not used for any other purpose than forestry or forestry related purposes. METLA (Finnish Forest Research Institute), 2009"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Finland 2009" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "National"@en .

ex:Forest_1248 a skos:Concept ;
    dct:date "1979"^^xsd:gYear ;
    dct:source "http://www.oikotechnics.org/greek_legislation.html"^^xsd:anyURI ;
    dct:spatial "Greece" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Greek Constitution, article 24, “As forest or forest ecosystem is meant the organic whole of wild plants with ligneous trunk on the requisite land surface, which, together with the co-existing flora and fauna, form throughout their mutual interdependence and interactions, a certain biological community (forest biological community) and a certain natural environment (forest environment). Wooded tract exists when in the aforementioned whole the wild ligneous vegetation, high or bushy, is sparse.”"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Greece 1979" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "National"@en .

ex:Forest_1249 a skos:Concept ;
    dct:date "2005"^^xsd:gYear ;
    dct:source "http://www.oikotechnics.org/greek_legislation.html"^^xsd:anyURI ;
    dct:spatial "Greece" ;
    skos:broadMatch ex:Forest ;
    skos:definition "According to the existing Greek Constitution, article 24, “As forest or forest ecosystem is meant the organic whole of wild plants with ligneous trunk on the requisite land surface, which, together with the co-existing flora and fauna, form throughout their mutual interdependence and interactions, a certain biological community (forest biological community) and a certain natural environment (forest environment). Wooded tract exists when in the aforementioned whole the wild ligneous vegetation, high or bushy, is sparse.” Greek Forest Protection and Forest Development Legislation 2005"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Greece 2005" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "National"@en .

ex:Forest_125 a skos:Concept ;
    dct:source "http://envfor.nic.in/nfc/s-git.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "All lands, more than one hectare in area, with a tree canopy density of more than 10 percent. Such lands may not be statutorily notified as forest area"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_1250 a skos:Concept ;
    dct:source "http://www.unccd.int/cop/reports/lac/national/2000/grenada-eng.pdf"^^xsd:anyURI ;
    dct:spatial "Grenada" ;
    skos:broadMatch ex:Forest ;
    skos:definition "‘Forest’ is understood to include all forest ecosystems (from coastal scrub and mangroves through to cloud forests) and non-agricultural trees, as well as the goods and services that they provide. (Grenada’ means ‘Grenada, Carriacou and Petit Martinique"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Grenada" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "National"@en .

ex:Forest_1251 a skos:Concept ;
    dct:date "2000"^^xsd:gYear ;
    dct:source "http://www.fire.uni-freiburg.de/iffn/country/id/id_25.htm"^^xsd:anyURI ;
    dct:spatial "Indonesia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"Forest means a unit of ecosystem….comprising biological resources, dominated by trees in their natural forms and environment….\". Indonesia"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Indonesia 2000" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "National"@en .

ex:Forest_1252 a skos:Concept ;
    dct:date "2009"^^xsd:gYear ;
    dct:source "https://www.elaw.org/system/files/REDD_PERMENHUT_P-30-2009_BILINGUAL.pdf"^^xsd:anyURI ;
    dct:spatial "Indonesia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest means a unity of ecosystem in the form of land consisting of biological resources dominated by trees in their natural form and environment, in which one and another are inseparable"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Indonesia 2009" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "National"@en .

ex:Forest_1253 a skos:Concept ;
    dct:date "1998"^^xsd:gYear ;
    dct:source "http://www.nwpg.gov.za/esds/links/Act84%20-%20National%20Forests%20.htm"^^xsd:anyURI ;
    dct:spatial "Ireland" ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"forest\" includes-- a natural forest, a woodland and a plantation; the forest produce in it; and the ecosystems which it makes up"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Ireland 1998" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
