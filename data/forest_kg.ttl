ex:Forest_247 a skos:Concept ;
    dct:date "1996"^^xsd:gYear ;
    skos:broadMatch ex:Forest ;
    skos:definition "Scholes & Hall define them as having complete tree canopy cover and three or more overlapping vegetation strata. The ground layer is NOT dominated by grasses but by other non-gramineceous herbs and shrubs. There are also open and closed forests, moist/rain and dry forests"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "1996" ;
