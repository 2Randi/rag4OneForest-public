    dct:source "http://www.dpiw.tas.gov.au/inter.nsf/Attachments/LJEM-6K32GF/$FILE/Glossary,%20Appendices,%20Index.pdf"^^xsd:anyURI ;
    dct:spatial "Australia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Vegetation with trees more than 5 m high and more than 50% solid canopy cover"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Australia-Tasmania" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_1317 a skos:Concept ;
    dct:creator "Tasmania" ;
    dct:source "http://www.workplacetransformations.com/Forestry%20Scam%20Erica%206-426.htm"^^xsd:anyURI ;
    dct:spatial "Australia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"Forest\" or \"forest\" means an area of land carrying a Forest Community, or a plantation of one or more tree species established for timber production"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Australia-Tasmania" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_1318 a skos:Concept ;
    dct:creator "Tasmania" ;
    dct:source "http://www.rfa.gov.au/rfa/tas/raa/envher/volumes1-4/gloss.html"^^xsd:anyURI ;
    dct:spatial "Australia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "forest in the context of this regional forest agreement, is an area, incorporating all living and non-living components, that is dominated by trees having usually a single stem and a mature or potential mature stand height exceeding 8 metres, and with existing or potential projective cover of overstorey strata about equal to or greater than 5 per cent"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Australia-Tasmania" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
