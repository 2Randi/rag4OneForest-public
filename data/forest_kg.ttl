ex:AnAreaOfLand_1 a skos:Concept ;
    dct:creator "UN-EP/CBD" ;
    dct:date "2001"^^xsd:gYear ;
    dct:source "http://www.worldgrowth.org/assets/file/WG%20Forestry_Development_Final%20Report.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "that is more than 0.5 hectares in size; which has a tree canopy cover of more than 10 per cent; and which is not primarily under agriculture or other specific non-forest land use. It includes young forest or regions in which tree growth is climatically suppressed, only if the trees have the potential to: reach a height of five metres in situ; and meet the requirement in respect of canopy cover"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-EP/CBD 2001" ;
    skos:prefLabel "An area of land"@en ;
    skos:scopeNote "International"@en,
        "Land use"@en .

ex:AndWoodland_1 a skos:Concept ;
    dct:creator "UN-FAO" ;
    dct:date "1995"^^xsd:gYear ;
    skos:broadMatch ex:Forest ;
    skos:definition "Includes woodlot or timber tracts, natural or planted, constituting part of the holding which have or will have value as wood, timber, or other forest products or for protection. Forest tree nurseries should be included in this category. Rows, belts and small clumps of trees, bamboo and other woody vegetation should be included.... Proposed definition for the World Census for Agriculture 2000. (FAO 1995"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO 1995" ;
    skos:prefLabel "and woodland"@en ;
    skos:scopeNote "International"@en,
        "Land use"@en .

ex:AndWoodlands_1 a skos:Concept ;
    dct:creator "UN-FAO" ;
    dct:date "2007"^^xsd:gYear ;
    dct:source "http://faostat.fao.org/site/379/default.aspx"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land under natural or planted stands of trees, whether productive or not. This category includes land from which forests have been cleared but that will be reforested in the foreseeable future, but it excludes woodland or forest used only for recreation purposes"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO 2007" ;
    skos:prefLabel "and Woodlands"@en ;
    skos:scopeNote "International"@en,
        "Land use"@en .

