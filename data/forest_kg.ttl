ex:Forest_1035 a skos:Concept ;
    dct:spatial "Vanuatu" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Tree canopy is greater than 10 m in height. Crowns are touching or overlapping. Ground layer not visible on airphotos. Source: Bellamy, J.A. Vanuatu Resource Information System. VANRIS Handbook. Via Adam Gerrand"@en ;
