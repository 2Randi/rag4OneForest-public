ex:Deforestation_158 a skos:Concept ;
    dct:source "http://www.harcourtcollege.com/geography/regionalatlas/glossary.html"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The removal of trees by people or their livestock"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_159 a skos:Concept ;
    dct:source "http://www-pub.naz.edu:9000/~jborsos9/deforestation.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The removal of trees from a forested area that can be the result of Mother Nature, e.g. forest fires, or of human nature"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_16 a skos:Concept ;
    dct:creator "ICRAF" ;
    dct:date "2017"^^xsd:gYear ;
    dct:source "http://dx.doi.org/10.5716/WP16079.PDF"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Change from a forested to a non-forested state, which depending on forest definition, relates to both institutional and tree cover dimensions"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "ICRAF- 2017" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_160 a skos:Concept ;
    dct:source "https://www.coris.noaa.gov/glossary/#/search/main"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The removal of trees from a habitat dominated by forest"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_161 a skos:Concept ;
    dct:source "http://www.life123.com/home-garden/green-living/energy-consumption/what-is-deforestation.shtml?fcsource=dell"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The removal of trees from forests by humans"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_162 a skos:Concept ;
    dct:source "http://www.notredame.ac.jp/cgi-bin/wn?cmd=wn&word=deforestation"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The removal of trees"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_163 a skos:Concept ;
    dct:source "http://www.minntrees.org/asp/default.asp?PageID=59"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The removal of trees without replacing them with young trees"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_164 a skos:Concept ;
    dct:source "http://info.live58.org/why-should-i-care-about-deforestation/"^^xsd:anyURI,
        "http://www.notredame.ac.jp/cgi-bin/wn?deforestation"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The state of being clear of trees. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_165 a skos:Concept ;
    dct:source "http://www.africanculturalcenter.org/10_0glossary.html"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The state of having been cleared of forests"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_166 a skos:Concept ;
    dct:source "http://answers.ask.com/Science/Other/what_is_deforestation"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The term used for when people completely remove trees and vegetation from a large forested area. Think of it like shaving, except instead of hairs, it's trees. Once an area is deforested, there's nothing left except dirt"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_167 a skos:Concept ;
    dct:source "http://www.geocities.com/RainForest/Andes/7292/Terms.html"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "To clear away the trees or forests from"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_168 a skos:Concept ;
    dct:source "http://www.mso.anu.edu.au/~ralph/OPTED/v003/wb1913_d.html"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "To clear of forests; to disforest"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_169 a skos:Concept ;
    dct:source "http://www.dictionary.com/cgi-bin/dict.pl?term=deforestation"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "To cut down and clear away the trees or forests from"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_17 a skos:Concept ;
    dct:date "2009"^^xsd:gYear ;
    dct:source "http://redd.unfccc.int/files/national_frel_for_redd__in_indonesia_2015.pdf"^^xsd:anyURI,
        "https://www.elaw.org/system/files/REDD_PERMENHUT_P-30-2009_BILINGUAL.pdf"^^xsd:anyURI ;
    dct:spatial "Indonesia" ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Minister of Forestry No. 30/2009 that stated deforestation as the permanent alteration from forested area into a non-forested area as a result of human activities (MoFor, 2009). and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Indonesia 2009" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_170 a skos:Concept ;
    dct:source "http://nhd.heinle.com/nhd-bin/searchNHD.pl"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "To remove the trees from an area as by fire, flood, logging, etc"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_171 a skos:Concept ;
    dct:source "http://www.chias.org/www/edu/cse/owpglo.html"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "To strip or deprive of trees and forest; the loss of our forest"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_172 a skos:Concept ;
    dct:source "http://kids.ran.org/kidscorner/rainforests/wordup.html"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "When a living forest is destroyed due to things such as logging, cattle ranching, or oil drilling"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_173 a skos:Concept ;
    dct:source "http://www.gisdevelopment.net/application/gii/planning/giipl0015a.htm"^^xsd:anyURI ;
    dct:spatial "Brazil" ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The conversion of areas of primary forest physiognomy by anthropogenic activities, for the development of agriculture and cattle raising, detected by orbital platforms. Gross deforestation indicates that areas in process of secondary succession or forest recovery are not subtracted in the calculation of the extent and the rate. The above definition does not include areas of forest affected by selective logging activities or wild fires, which are object of specific reports by INPE"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Brazil" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_175 a skos:Concept ;
    dct:spatial "Italy" ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "A loss of forest area because of change of land use to agricultural lands, barren lands, buildings, roads, pipelines, etc. Burned forest areas are not considered deforested. ISTAT (1950-1997). Statistiche Forestali. Annuari 1-47. Istituto Nazionale di Statistica. Rome. Lorenzo Ciccarese ciccarese@anpa.it"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Italy" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_176 a skos:Concept ;
    dct:spatial "Malaysia" ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The conversion of forest or forest land to permanent non-forestry uses such as for agricultural crops, infrastructural and industrial development, settlements etc. From: hcthang@forestry.gov.my (Thang Hooi Chiew), Forestry Department Peninsular Malaysia"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Malaysia" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_179 a skos:Concept ;
    dct:source "http://ches.ing.ula.ve/GAIA/gis/maps/CaseStudies/explain/caseT.exp"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "A complete change in land use from forest to agriculture - including shifting cultivation and pasture - or urban use"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_18 a skos:Concept ;
    dct:date "2015"^^xsd:gYear ;
    dct:source "http://redd.unfccc.int/files/national_frel_for_redd__in_indonesia_2015.pdf"^^xsd:anyURI ;
    dct:spatial "Indonesia" ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "In this submission, deforestation was defined as a conversion of natural forest cover into other land-cover categories that has only occurred one time in particular areas. The practical definition emphasises on land cover instead of land use. Consequently it is different from the definition of deforestation by FAO, which employed terminology of land use"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Indonesia 2015" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_180 a skos:Concept ;
    dct:source "http://fiesta.bren.ucsb.edu/~idgec/publications/reports/forest.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "A complete transformation in land use from forest to agricultural and urban uses, such as those brought upon by shifting cultivation, agroforestry and pasture. Excluded in the process is the large scale clear-cutting of plantations adopted by commercial tree growers"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_181 a skos:Concept ;
    dct:creator "Setiadi , modified" ;
    dct:date "1996"^^xsd:gYear ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "A process of land-use change from forest to other uses, because of population pressure, shifting cultivation, agricultural development, transmigration, forest fires, or unsupervised and poor logging practices, climatic and human-induced disturbancies . Lorenzo Ciccarese ciccarese@anpa.it"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Setiadi 1996, modified" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_182 a skos:Concept ;
    dct:source "http://www.fs.fed.us/institute/cifor/cifor_260.html"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Area of forest permanently converted to non-forest land use, e.g., urbanization and Semi-permanent or temporary loss or gain of forest ecosystems, e.g., grasslands and agriculture"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_183 a skos:Concept ;
    dct:creator "Schlamadinger" ;
    dct:date "1998"^^xsd:gYear ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Conversion of forest land to other land use"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Schlamadinger 1998" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_185 a skos:Concept ;
    dct:creator "i.e., cropland, pasture, dams" ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Converting forest land to other vegetation or uses . www.wws.princeton.edu/cgi-bin/byteserv.prl/~ota/disk1/1992/9217/921713.PDF"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "i.e., cropland, pasture, dams" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_186 a skos:Concept ;
    dct:source "http://www.auburn.edu/~hurlbkl/definition.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Forest conversion to other uses, leaving out logged areas to regenerate"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_187 a skos:Concept ;
    dct:source "http://www.peopleandplanet.net/section.php?section=1&topic=8&PHPSESSID=1a9faae006a4efebfebe57431f0ca5ac"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The conversion of forest lands to alternative uses such as cropland or human settlement"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_188 a skos:Concept ;
    dct:source "http://www.nafi.com.au/k12/ourforests/glossary.html"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The permanent clearing of forest areas, preventing regrowth e.g. clearing land for agriculture"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_189 a skos:Concept ;
    dct:source "http://www.fieldtripearth.org/qa_article.xml?id=28"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The permanent conversion of forests to pasture, farmland, or urban landscape"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_190 a skos:Concept ;
    dct:source "http://edugreen.teri.res.in/explore/glossary.htm#d"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The practice or process that result in the long-term change in land-use to non-forest uses"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_191 a skos:Concept ;
    dct:source "http://www.undp.org/gef/workshop/glossary.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The process of degradation or loss of forests by shifting use of the forest to agriculture—including shifting cultivation and pasture—urban use, and timber harvesting, thus reducing the forests contribution to preserving biodiversity, water retention, soil and climate preservation, and other environmental services"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_192 a skos:Concept ;
    dct:source "http://www.pfmt.org/glossary/d.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The unintentional or intentional conversion of land use from forest to nonforest. Associated with nonrenewable timber harvesting practises in ecologically sensitive areas, such a tropical reinforests"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_193 a skos:Concept ;
    dct:source "http://earthobservatory.nasa.gov:81/Library/glossary.php3?mode=alpha&seg=d"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Those practices or processes that result in the change of forested lands to non-forest uses"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_194 a skos:Concept ;
    dct:source "http://www.doc.mmu.ac.uk/aric/diction.html"^^xsd:anyURI,
        "http://www.epa.gov/globalwarming/publications/outreach/general/glossary.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Those practices or processes that result in the conversion of forested lands for non-forest uses. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_195 a skos:Concept ;
    dct:creator "BC" ;
    dct:source "http://www.for.gov.bc.ca/pab/publctns/glossary/glossary.htm"^^xsd:anyURI ;
    dct:spatial "Canada" ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Clearing an area of forest on a non-temporary basis for another use. Clearcutting (even with stump removal), if shortly followed by reforestation for forestry purposes, is not deforesting. [Source: Glossary of Forestry Terms, Province of British Columbia, Ministry of Forests, via Igor A. Yakovlev]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Canada - BC" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_196 a skos:Concept ;
    dct:creator "Sask" ;
    dct:source "http://nfdp.ccfm.org/silviterm/silvi_e/silvitermatode.htm#D"^^xsd:anyURI ;
    dct:spatial "Canada" ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "[deboisement (n.m.)] Permanent removal of forest cover and withdrawal of land from forest use, whether deliberately or circumstantially. [Source: Silvicultural Terms in Canada - Second Edition 1995 From: Mark Johnston <johnston@larix.derm.gov.sk.ca Date: Tue, 16 Jun 1998 17:44:48 -0600]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Canada - Sask." ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_197 a skos:Concept ;
    dct:creator "NR" ;
    dct:source "https://www.nrcan.gc.ca/forests/inventory/13419"^^xsd:anyURI ;
    dct:spatial "Canada" ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Deforestation is the permanent removal of forest cover from an area, and the conversion of the previously forested land to other uses"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Canada NR" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_198 a skos:Concept ;
    dct:source "http://nrcan.gc.ca/cfs/proj/ppiab/sof/sof.html"^^xsd:anyURI ;
    dct:spatial "Canada" ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Clearing an area of forest for another long-term use"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Canada" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_199 a skos:Concept ;
    dct:spatial "Cyprus" ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Deforestation: the removal of a forest stand from an area where the land is put to a nonforest use. A.K. Christou \"Forestry Department - Research and Publicity Sector\" publicity@cytanet.com.cy"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Cyprus" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_2 a skos:Concept ;
    dct:creator "to be distinguished from ‘deforest’, q.v" ;
    dct:source "http://info.sjc.ox.ac.uk/forests/glossary.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Disafforest - Free forest land from the operation of forest law (P 205); remove an area of land from the constraints of forest law (R 166); release land from forest law (L 237"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "to be distinguished from ‘deforest’, q.v." ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_20 a skos:Concept ;
    dct:date "2005"^^xsd:gYear ;
    dct:source "http://formin.finland.fi/public/download.aspx?ID=15959&GUID=%7B88EFD0B8-9F47-4528-A24F-66DDE0CFE370%7D"^^xsd:anyURI ;
    dct:spatial "Kenya" ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Deforestation means the negative reduction of forest cover from the original status"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Kenya 2005" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_200 a skos:Concept ;
    dct:spatial "India" ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Removal of forest cover from a forest land. It excludes clearfelling. [Source: Glossary of Technical Terms, Forest Research Institute, India. From: \"Vivek K. Varma\" <v.varma@landfood.unimelb.edu.au Date: Fri, 17 Jul 1998 02:28:29 -0400 (EDT)]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "India" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_201 a skos:Concept ;
    dct:date "2002"^^xsd:gYear ;
    dct:source "http://www.globalforestwatch.org/common/indonesia/sof.indonesia.english.low.pdf"^^xsd:anyURI ;
    dct:spatial "Indonesia" ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The permanent removal of forest cover and conversion of the land to other uses. According to the land use definition used by FAO and accepted by most governments, forest land that has been harvested, even clear-cut, is not regarded as deforested because, in principle, trees may regrow or be replanted. Deforestation is recorded only when the land is permanently converted to nonforest use. However, the remote sensing imagery used in this report to determine land cover (the presence or absence of forest) over time does not make such a distinction and clear-cut land has been recorded as nonforest or deforested land"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Indonesia - 2002" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_202 a skos:Concept ;
    dct:spatial "Lithuania" ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Clearing of an area with the purpose to change forest land to other land use category. Source: A. Kuliesis, Director of Lithuanain Forest Inventory and Management Institute Email: Sekrtetore sek@mp.is.lt"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Lithuania" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_203 a skos:Concept ;
    dct:creator "INEGI y SEMARNAP" ;
    dct:spatial "Mexico" ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Proceso de cambio de uso del suelo de forestal a otro uso (INEGI y SEMARNAP 1999"@es ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Mexico -INEGI y SEMARNAP" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_204 a skos:Concept ;
    dct:spatial "Pakistan" ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "To remove the tree crop from a piece of land without the intention of reforesting. Definition adopted from the British Commonwealth Forest Terminology Part-I, 1953. Source: Mumtaz Ahmad, Section Forest Officer, Pakistan Min. of Environment, Local Government, and Rural Development"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Pakistan" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_205 a skos:Concept ;
    dct:creator "Papua New" ;
    dct:spatial "Guinea" ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The removal of trees from forestland and subsequent conversion of land-use from forestry to other such as agriculture. Vitus Ambia, Papua New Guinea Forest Authority"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Papua New Guinea" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_206 a skos:Concept ;
    dct:creator "Tanzania" ;
    dct:source "http://www.unep-wcmc.org/forest/restoration/docs/TanzaniaFLR.PDF"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Normally refers to clearing of a forest or woodland cover and replacing it with other land uses i.e. converting forest land to agriculture farms or settlement areas"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Tanzania" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_207 a skos:Concept ;
    dct:creator "UN" ;
    dct:source "http://www.nscb.gov.ph/peenra/Publications/Compendium/glossary.PDF"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Clearing of tree formations and their replacement by non-forest land uses. (UN Glossary of Environment Statistics"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_21 a skos:Concept ;
    dct:date "2014"^^xsd:gYear ;
    dct:source "http://redd.unfccc.int/files/frel_mexico_modified.pdf"^^xsd:anyURI ;
    dct:spatial "Mexico" ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The General Law for the Sustainable Development of Forests indicates that deforestation refers to \"the process of reducing the capacity of ecosystems to provide environmental services and to produce goods.\" In the context climate change mitigation in Mexico, forests are considered a regulator of the carbon cycle"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Mexico 2014" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_216 a skos:Concept ;
    dct:creator "USA –STATE- Maryland" ;
    dct:source "http://www.wrm.org.uy/actors/WB/1994policy.html"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The clearing of forests and the conversion of land to nonforest uses"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA –STATE- Maryland" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_217 a skos:Concept ;
    dct:creator "USA-Congress-OTA" ;
    dct:date "1984"^^xsd:gYear ;
    dct:source "http://govinfo.library.unt.edu/ota/Ota_4/DATA/1984/8426.PDF"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The conversion of forests to land uses that have a tree cover of less than 10 percent"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-Congress-OTA 1984" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_218 a skos:Concept ;
    dct:creator "WAF" ;
    dct:date "2004"^^xsd:gYear ;
    dct:source "http://www.worldagroforestry.org/sea/Publications/files/book/BK0073-04.PDF"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The conversion of forest land to non-forest land"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "WAF 2004" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_219 a skos:Concept ;
    dct:creator "Herrera et al. n.d" ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Cambio de uso del suelo que impica la desaparicion de las selva o el bosque"@es ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Herrera et al. n.d." ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_22 a skos:Concept ;
    dct:spatial "Nepal" ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "deforestation = reduction of stocking due to overcutting for fuelwood, timber, and fodder (from Master plan for the forestry sector Nepal, main report, 1988). Krishna H Gautam <khg13@student.canterbury.ac.nz"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Nepal" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_220 a skos:Concept ;
    dct:creator "Repetto and Gillis" ;
    dct:date "1998"^^xsd:gYear ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Change in forest land use from forestry to other purposes, such that it no longer functions as a forest ecosystem"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Repetto and Gillis 1998" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_221 a skos:Concept ;
    dct:source "http://www.fnfp.gc.ca/rep99/gloss-e.htm"^^xsd:anyURI,
        "http://www.nrcan-rncan.gc.ca/cfs-scf/science/prodserv/glossary_e.html#22"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Clearing an area of forest for another long-term use. Déboisement"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_222 a skos:Concept ;
    dct:source "http://www.for.gov.bc.ca/pab/publctns/glossary/glossary.txt"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Clearing an area of forest on a non-temporary basis for another use"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_223 a skos:Concept ;
    dct:creator "even with stump removal" ;
    dct:source "http://typhoon.sdsu.edu/nasa_lcluc/forest.html"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Clearing an area of forest on a non-temporary basis for another use. Clearcutting , if shortly followed by reforestation for forestry purposes, is not deforesting"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "even with stump removal" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_224 a skos:Concept ;
    dct:creator "Ecoforestry" ;
    dct:date "1997"^^xsd:gYear ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Clearing an area permanently for another use, such as agriculture or road building"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Ecoforestry 1997" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_225 a skos:Concept ;
    dct:creator "Bruening n.d" ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Clearing of forest from large tracts of land which consequently remains unforested either as barren land or as agricultural crop"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Bruening n.d." ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_226 a skos:Concept ;
    dct:creator "PEENRA website" ;
    dct:source "http://unfcccbali.org/unfccc/component/option,com_glossary/Itemid,100/func,display/letter,D/catid,31/page,1/"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Clearing of tree formations and their replacement by non forest land use"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "PEENRA website" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_227 a skos:Concept ;
    dct:source "http://www.schools.wafa.org.au/terms.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Clearing trees for timber, fuel, farmland or for new settlements from a piece of land without the intention of reforesting"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_228 a skos:Concept ;
    dct:creator "natural forest, modified forest, or planted forest" ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Conversion of any forest to non-forest conditions (cropland, pasture, or urban land) (IUCN, UNEP, WWF 1991"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "natural forest, modified forest, or planted forest" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_229 a skos:Concept ;
    dct:creator "Hard" ;
    dct:source "http://www.wisegeek.com/what-is-hard-deforestation.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Deforestation occurs when forested lands are clearcut and then compromised so that the trees cannot grow back"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Hard" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_23 a skos:Concept ;
    dct:spatial "Northern Mariana Islands" ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "A science and are of harvesting or act of destroying a forestland to meet a particular objective. Source: Estanislao Villagomez stanvill@gtepacifica.net Division of Agriculture"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Northern Mariana Islands" ;
    skos:prefLabel "Deforestation"@da .

ex:Deforestation_230 a skos:Concept ;
    dct:creator "Wasteful" ;
    dct:source "http://www.sprl.umich.edu/GCL/notes2/Deforestation.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Deforestation – occurs when forests yielding high values of goods and services are clearcut and replaced with land uses that yield lower returns"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Wasteful" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_231 a skos:Concept ;
    dct:source "http://wiki.answers.com/Q/What_is_deforestation?altQ=What_is_deforrestation#slide=1"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Deforestation happens when human beings turn forested land into non-forested land due to our activities. It is not a good thing for wildlife because it takes away much of their natural habitat"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_232 a skos:Concept ;
    dct:source "http://www.globalchange.umich.edu/globalchange2/current/lectures/deforest/deforest.html"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Deforestation implies the long-term or permanent loss of forest cover and its transformation into another land use"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_233 a skos:Concept ;
    dct:source "http://abushald.blogspot.com/2008/11/why-is-deforestation-important.html"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Deforestation is when forests, rain forests or a group of trees in the same area are living with animals and many different types of plants, are being chopped of, or mostly burnt for the land use"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_234 a skos:Concept ;
    dct:source "http://eschooltoday.com/forests/what-is-deforestation.html"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Deforestation is when humans remove or clear large areas of forest lands and related ecosystems for non-forest use. These include clearing for farming purposes, ranching and urban use. In these cases, trees are never re-planted"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_235 a skos:Concept ;
    dct:source "http://www.meritnation.com/ask-answer/question/what-is-deforestation/forest-society-and-colonialism/6273919"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Deforestation is when humans remove or clear large areas of forest lands for non-forest use. These include clearing for farming purposes, ranching and urban use. Inthese cases, trees are never re-planted"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_236 a skos:Concept ;
    dct:creator "Food and Agriculture Organization of the U.N" ;
    dct:source "http://www.mongabay.com/08define.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Deforestation refers to the loss of forest cover; land that is permanently converted from forest to agricultural land, golf courses, cattle pasture, homes, lakes, or desert. The FAO defines tropical deforestation as \"change of forest with depletion of tree crown cover to less than 10%.\" Depletion of forest to tree crown cover greater than 10% (say from 100% to 12%) is considered forest degradation. Logging most often falls under the category of forest degradation and thus is not included in deforestation statistics. Therefore forest degradation rates are considerably higher than deforestation rates. For example, according to satellite surveys Indonesia has considerable forest coverage, but millions of hectares are highly degraded by logging and no longer contain their full diversity or original structure"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Food and Agriculture Organization of the U.N." ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_237 a skos:Concept ;
    dct:source "http://en.wikipedia.org/wiki/Deforestation"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Deforestation, clearance or clearing is the removal of a forest or stand of trees where the land is thereafter converted to a non-forest use.[1] Examples of deforestation include conversion of forestland to farms, ranches, or urban use"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_238 a skos:Concept ;
    dct:source "http://www.northern.edu/natsource/BIRDS/Conser1.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Destruction of forested habitats for conversion to other uses"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_239 a skos:Concept ;
    dct:creator "Varela" ;
    dct:date "1998"^^xsd:gYear ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Eliminacion total de la vegetacion y su reemplazo por usos no forestales de la tierra"@es ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Varela 1998" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_24 a skos:Concept ;
    dct:spatial "Pakistan" ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "To remove, kill or destroy all or most of the trees of a forest so that reproduction is impossible except by artificial means. Definition adopted from the British Commonwealth Forest Terminology Part-I, 1953. Source: Mumtaz Ahmad, Section Forest Officer, Pakistan Min. of Environment, Local Government, and Rural Development"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Pakistan" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_240 a skos:Concept ;
    dct:source "http://loki.stockton.edu/~epsteinc/deforest.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Forests are removed and the land changed to another kind of land use"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_241 a skos:Concept ;
    dct:creator "esp. pasture" ;
    dct:source "http://hcd.ucdavis.edu/classes/iad10/enviro.html"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Large scale cutting of forest; replacement with other plant cover"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "esp. pasture" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_243 a skos:Concept ;
    dct:creator "Anon. a" ;
    dct:date "1995"^^xsd:gYear ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Para la delimitacion y cuantificacion de la deforestacion, la ha definido como la remocion temporal o permanente de la cubierta vegetal natural para dedicar otro uso no forestal"@es ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Anon. 1995a" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_244 a skos:Concept ;
    dct:source "http://nfdp.ccfm.org/silviterm/silvi_e/silvitermatode.htm#D"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Permanent removal of forest cover and withdrawal of land from forest use, whether deliberately or circumstantially"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_245 a skos:Concept ;
    dct:creator "Herrera" ;
    dct:date "1998"^^xsd:gYear ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Se considera el cambio de uso del suelo de foresta a no forestal en un periodo determinado. Tambien puede expresarse como la elimiacion completa de areas arbolada a usos del suelo no forestales"@es ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Herrera 1998" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_246 a skos:Concept ;
    dct:source "http://www.oxfam.org.uk/coolplanet/glossary.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The clearance of all the trees and undergrowth in a forest to make land usable for farming"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_247 a skos:Concept ;
    dct:creator "shifting cultivation, permanent agriculture and ranching" ;
    dct:source "http://www.sprl.umich.edu/GCL/wri/forest/deforest.html"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The clearing of forest lands for all forms of agricultural uses and for other land uses such as settlements, other infrastructure and mining. In tropical countries, this entails clearing that reduces tree crown cover to less than 10 percent. As defined here, deforestation does not include other alterations, such as selective logging (unless the forest cover is permanently reduced to less than 10 percent), that can substantially affect forests, forest soil, wildlife and its habitat, and the global carbon cycle"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "shifting cultivation, permanent agriculture and ranching" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_248 a skos:Concept ;
    dct:source "https://www.uni-hohenheim.de/i490a/teaching/M4901-430/ws_03_04/reading_materials/New_Neef_Schwarzmeier_Studie.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The clearing of forests and the conversion of land to non-forest uses such as cropland or human settlement"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_249 a skos:Concept ;
    dct:source "http://www.wrm.org.uy/actors/WB/1991policy3.html"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The clearing of forests and the conversion of land to nonforest uses"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_25 a skos:Concept ;
    dct:source "http://www.nscb.gov.ph/ru12/DEFINE/DEF-ENV.HTM"^^xsd:anyURI ;
    dct:spatial "Philippines" ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The destruction of forest trees in such a manner as to leave practically little or no chance at all of normal recovery for a forest. Some of the factors responsible for the destruction of forest products include: illegal loggers, illegal forestry product gatherers, timber smugglers, kaingeros, squatters, forest incendiaries, miners, atmospheric agents, biological agents"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Philippines" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_250 a skos:Concept ;
    dct:creator "reforesting" ;
    dct:source "http://www.businessdictionary.com/definition/deforestation.html"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The clearing of virgin forests, or intentional destruction or removal of trees and other vegetation for agricultural, commercial, housing, or firewood use without replanting and without allowing time for the forest to regenerate itself. Deforestation is one of the major factors contributing to the greenhouse effect and desertification"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "reforesting" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_251 a skos:Concept ;
    dct:source "http://www.globalchange.umich.edu/globalchange2/current/lectures/deforest/deforest.html"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The conversion of forest to another land use"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_252 a skos:Concept ;
    dct:source "http://www.globalchange.umich.edu/globalchange2/current/lectures/deforest/deforest.html"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The conversion of forest to another land use or the long-term reduction of the tree canopy cover below a 10 percent threshold. Deforestation implies the long-term or permanent loss of forest cover and its transformation into another land use"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_253 a skos:Concept ;
    dct:source "http://www.climateservices.com/glossary.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The conversion of forested to non-forested land. Deforestation can involve the cutting and burning of trees to provide land for agricultural purposes or clearing for residential and industrial uses"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_254 a skos:Concept ;
    dct:creator "reafforestation" ;
    dct:source "http://ukdb.web.aol.com/hutchinson/encyclopedia/50/M0020550.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The destruction of forest for timber, fuel, charcoal burning, and clearing for agriculture and extractive industries, such as mining, without planting new trees to replace those lost or working on a cycle that allows the natural forest to regenerate"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "reafforestation" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_255 a skos:Concept ;
    dct:source "http://www.quiknet.com/~mathman/csus/Site_Map/Glossary/glossary.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The destruction of forests, typically to clear land for agriculture or ranching or to provide fuel and timber"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_256 a skos:Concept ;
    dct:date "2008"^^xsd:gYear ;
    dct:source "http://www.greenpeace.org/raw/content/usa/turning-up-the-heat-global-w.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The direct, human-induced conversion of forested land to non-forested land"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "2008" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_257 a skos:Concept ;
    dct:source "http://www.conserve-energy-future.com/causes-effects-solutions-of-deforestation.php"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The felling and clearing of forest cover or tree plantations in order to accommodate agricultural, industrial or urban use. It involves permanent end of forest cover to make that land available for residential, commercial or industrial purpose"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_258 a skos:Concept ;
    dct:date "2000"^^xsd:gYear ;
    dct:source "http://forestry.oxfordjournals.org/content/77/1/9.full.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The felling of trees without subsequent replanting or regeneration, i.e. the conversion of previously forested land to agricultural, urban or other land uses, which do not have a substantial tree canopy cover (<10 per cent, according to the definition in FAO"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "2000" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_259 a skos:Concept ;
    dct:creator "AGRO" ;
    dct:source "http://www.canadian-forests.com/fsc-glossary.html"^^xsd:anyURI,
        "http://www.web.net/~fscca/standard.htm#anchor88641"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The long-term removal of trees from forested site to permit other site uses. and . Cutting of trees followed by regeneration is not deforestation. syn: forest clearing disturbance, conversion, or wasteful destruction of forest lands. (Dunster and Dunster 1996"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "AGRO" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_26 a skos:Concept ;
    dct:spatial "Oman" ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The act of removing the forest vegetation from forest lands, without changing the land destination (considering the administrative point of view). Sorin Sfirlogea <sorinsf@rosilva.ro National Forests Administration"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Romania" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_260 a skos:Concept ;
    dct:source "http://greenliving.lovetoknow.com/What_is_Deforestation"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The net loss of forests. A \"net loss\" of forests occurs when more forest cover is removed than is replaced, leaving the landscape substantially altered"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_261 a skos:Concept ;
    dct:source "http://www.nafi.com.au/k12/ourforests/glossary.html"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The permanent clearing of forest areas, preventing regrowth e.g. clearing land for agriculture"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_262 a skos:Concept ;
    dct:source "http://www.socialwatch.org/indicators/Glossary.htm#Deforestation"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The permanent clearing of forest lands for shifting cultivation, permanent agriculture or settlements; it does not include other alterations such as selective logging"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_263 a skos:Concept ;
    dct:source "http://www.auburn.edu/~hurlbkl/definition.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The permanent destruction of forests and woodlands; it occurs as the forests are converted for agricultural uses"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_264 a skos:Concept ;
    dct:source "http://www.livescience.com/27692-deforestation.html"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The permanent destruction of forests in order to make the land available for other uses"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_265 a skos:Concept ;
    dct:creator "Keller," ;
    dct:date "1994"^^xsd:gYear ;
    dct:source "http://www.scar.toronto.edu/~97fauche/termassignment.html#"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The permanent destruction of indigenous forest and woodland. Deforestation thus refers to clearing of original forests, and it includes a range of processes, from a selective removal of valuable timber species to clear cutting followed by burning and creation of pasture and agricultural fields . What is deforestation, the state of deforestation. Keller, M. (1994) Controls on Soil-Atmosphere fluxes of nitrous oxide and methane: effects of tropical deforestation. In Climate-Biosphere Interactions Ed. Zepp, R.G. John Wiley and sons, Georgia"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Keller, 1994" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_266 a skos:Concept ;
    dct:source "http://www.globaled.org/issues/152/a.html"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The permanent destruction of indigenous forests and woodlands"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_267 a skos:Concept ;
    dct:source "http://www.botany.uwc.ac.za/envfacts/facts/deforestation.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The permanent destruction of indigenous forests and woodlands. The term does not include the removal of industrial forests such as plantations of gums or pines"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_268 a skos:Concept ;
    dct:source "http://www.gn.apc.org/LivingEarth/RainforestDB/glossary.a-e.html#climax_forest"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The permanent removal of forest and undergrowth"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_269 a skos:Concept ;
    dct:creator "Achard et al" ;
    dct:date "1998"^^xsd:gYear ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The process of land cover transformation from forest to non-forest"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Achard et al. 1998" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_27 a skos:Concept ;
    dct:creator "South" ;
    dct:date "2009"^^xsd:gYear ;
    dct:spatial "Sudan" ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "“Deforestation” means reduction of forest cover from the original status"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "South Sudan 2009" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_270 a skos:Concept ;
    dct:source "https://www.princeton.edu/~achaney/tmve/wiki100k/docs/Deforestation.html"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The removal of a forest or stand of trees where the land is thereafter converted to a nonforest use.[1] Examples of deforestation include conversion of forestland to agriculture or urban use. The term deforestation is often misused to describe any activity where all trees in an area are removed. However in temperate mesic climates, the removal of all trees in an area—in conformance with sustainable forestry practices—is correctly described as regeneration harvest.[2] In temperate mesic climates, natural regeneration of forest stands often will not occur in the absence of disturbance, whether natural or anthropogenic.[3] Furthermore, biodiversity after regeneration harvest often mimics that found after natural disturbance, including biodiversity loss after naturally occurring rainforest destruction.[4][5]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_271 a skos:Concept ;
    dct:creator "Helms" ;
    dct:date "1998"^^xsd:gYear ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The removal of a forest stand where the land is put to a non-forest use"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Helms 1998" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_272 a skos:Concept ;
    dct:source "http://www.buzzle.com/articles/causes-and-effects-of-deforestation.html"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The removal of forest or trees from a land and converting it for nonforest use"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_273 a skos:Concept ;
    dct:source "http://www.minntrees.org/facts/ff17.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The removal of trees without replacing them with young trees"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_274 a skos:Concept ;
    dct:creator "Grainger" ;
    dct:date "1993"^^xsd:gYear ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The temporary or permanent clearance of forest for agriculture or other purposes"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Grainger 1993" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_275 a skos:Concept ;
    dct:source "http://www.globalchange.umich.edu/globalchange2/current/lectures/deforest/deforest.html"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The transformation of forested lands by human actions"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_276 a skos:Concept ;
    dct:creator "regardless of the commercial or aesthetic value of the trees" ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The willful and permanent transition in vegetative cover from that which is clearly \"forest\" to that which is clearly devoted to other uses - with trees seen as undesirable invaders. On this definition, the clear cutting of portions of a forest with the intention of allowing regeneration of trees does not qualify as deforestation - even though all the trees are removed at a certain time (Daniel W. Bromley, Deforestation: Institutional Causes And Solutions, in World Forests, Society and Environment, Volume I. In press"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "regardless of the commercial or aesthetic value of the trees" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_277 a skos:Concept ;
    dct:creator "e.g. volcanic eruption, landslides" ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "To clear an area, other than purely temporarily, of forest. 1) While man is the main deforester, natural agencies may also contribute. (2) Clear cutting (even with stump removal), if shortly followed by reforestation is not deforesting. (Ford-Robertson 1971"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "e.g. volcanic eruption, landslides" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_278 a skos:Concept ;
    dct:source "http://wiki.answers.com/Q/What_is_deforestation_and_deforestation#slide=2"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Trees being cut down and not being replanted"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_279 a skos:Concept ;
    dct:source "http://www.shsu.edu/~chemistry/Glossary/de.html#D"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Type of \"forestry practice\" which involves the permanent removal of forests and their undergrowth so that the land can serve another purpose"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_28 a skos:Concept ;
    dct:creator "St. Lucia" ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The cutting down of forest or destruction of forests. (Source: Michael Andrew, chiefforest@maffe.org"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "St. Lucia" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_280 a skos:Concept ;
    dct:source "http://www.uncc.edu/~chamato/glossary.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Annual Deforestation - Annual loss of forest land; reflects land degradation"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_281 a skos:Concept ;
    dct:source "http://www-pub.naz.edu:9000/~jwitten2/about2.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Deforestation occurs in a number of ways, both natural and unnatural"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_282 a skos:Concept ;
    dct:source "http://www.auburn.edu/~hurlbkl/definition.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Induced land degradation in developing countries that is a direct result of land tenure systems that facilitate property-right acquisition in idle lands"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_283 a skos:Concept ;
    dct:source "http://www.globalchange.org/glossall/glossd-f.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Loss of forest"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_284 a skos:Concept ;
    dct:source "http://www.britell.com/misc/lex.html"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Simply means to \"divest of forests\""@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_285 a skos:Concept ;
    dct:date "2008"^^xsd:gYear ;
    dct:source "http://www.greenpeace.org/raw/content/usa/turning-up-the-heat-global-w.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The direct, human-induced conversion of forested land to non-forested land"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "2008" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_286 a skos:Concept ;
    dct:source "http://ellerbruch.nmu.edu/classes/cs255f03/cs255students/jedens/P12/deforestation.ppt"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Deforestation is the inevitable result of the current social and economic policies being carried out in the name of development"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_29 a skos:Concept ;
    dct:creator "Taiwan, ROC" ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The behavior and activity of destroy forest, included forest fire, disease, insect pest, illegal cutting and illegal cultivation. Source: \"&ordf;L&deg;È&sect;&frac12;service\" service@dns.forest.gov.tw"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Taiwan, ROC" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_3 a skos:Concept ;
    dct:source "http://www.hants.gov.uk/newforest/bibliog.html"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Disafforestation – to remove land from the authority of the Verderers"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_30 a skos:Concept ;
    dct:spatial "Uganda" ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "When the biomass abstracted is higher than the natural growth. The Environmental Act (1995). Paolo Viskanic viskanic@imul.com"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Uganda" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_31 a skos:Concept ;
    dct:creator "UN-DP" ;
    dct:date "1999"^^xsd:gYear ;
    dct:source "http://www.profor.info/pdf/InnovatForesFinanc.pdf"^^xsd:anyURI,
        "http://www.un.org.vn/undp/projects/profor/pdffiles/trexler.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The conversion of forested to non-forested land. Deforestation can involve the cutting and burning of trees to provide land for agricultural purposes or clearing for residential and industrial uses. .and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-DP 1999" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_4 a skos:Concept ;
    dct:creator "– NSW-EPA" ;
    dct:date "1995"^^xsd:gYear ;
    dct:source "http://unfcccbali.org/unfccc/component/option,com_glossary/Itemid,100/func,display/letter,D/catid,31/page,1/"^^xsd:anyURI ;
    dct:spatial "Australia" ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The removal of forest and undergrowth (NSW-EPA, 1995"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Australia – NSW-EPA 1995" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_40 a skos:Concept ;
    dct:creator "UN-HCR" ;
    dct:date "2005"^^xsd:gYear ;
    dct:source "http://postconflict.unep.ch/liberia/displacement/documents/UNHCR_IUCN_Forest_Management_Refugee_Returnee_Situations.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The depletion of tree crown cover to less than 10 per cent. UNHCR 2005"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-HCR 2005" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_41 a skos:Concept ;
    dct:creator "USA-EIA" ;
    dct:source "http://www.eia.gov/tools/glossary/index.cfm?id=D"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The net removal of trees from forested land"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-EIA" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_44 a skos:Concept ;
    dct:creator "Venezuela" ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "DEFORESTACION: eliminar por métodos mecánicos la vegetación alta y mediana para erradicarla totalmente (1); tala de un bosque con el propósito de habilitar la tiera,para uso agrícola o ganadero y/o aprovechar la madera para la construcción o propósitos industriales. Reglamento de la Ley Forestal de Suelos y Aguas (1977). Areas Naturales Protegidas de Venezuela. Series Aspectos Conceptuales y Metodológicos, DGSPOA/ACM/01, feb 1992. Via Profauna@marnr.gov.ve"@es ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Venezuela" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_46 a skos:Concept ;
    dct:creator "Palo" ;
    dct:date "1999"^^xsd:gYear ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "A change from forest cover into some other land cover formations, without the revival of forests by natural or artificial reforestation within a human planning horizon"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Palo 1999" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_47 a skos:Concept ;
    dct:source "http://www.sprl.umich.edu/GCL/notes2/Deforestation.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "A complete and permanent removal of all forest cover"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_48 a skos:Concept ;
    dct:source "http://science.howstuffworks.com/environmental/conservation/issues/what-is-deforestation.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "A fancy word that means exactly what you probably think it means: the destruction of forested lands"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_49 a skos:Concept ;
    dct:source "http://cbmjournal.springeropen.com/articles/10.1186/s13021-016-0054-9"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "A long term loss of canopy cover and area, notably a conversion to another non-forest use, which been monitored effectively over time at multiple scales effectively for tropical forests using remote sensing technologies"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_5 a skos:Concept ;
    dct:creator "Bolivia" ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "DEFORESTADO: Desprovisto de bosque, por haber talado. Source: Luis Castello faopaf@caoba.entelnet.bo Adjunto sírvase encontrar la versión no oficial y premilinar del Glosario Forestal elaborado por el Proyecto de Apoyo a la Coordinación e Implementación del Plan de Acción Forestal para Bolivia"@es ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Bolivia" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_50 a skos:Concept ;
    dct:creator "Bosques y Selvas" ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "A reduccion de areas arbolades (Herrera 1999"@es ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Bosques y Selvas" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_51 a skos:Concept ;
    dct:creator "this definition relates to the definition of forests as ecosystems with a minimum 10% cover of trees" ;
    dct:source "http://www.spcforests.org/Library/usestatus/usestatus.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Changes of land use which lead to a depletion of tree crown to less than 10% . (FAO, 1990"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "this definition relates to the definition of forests as ecosystems with a minimum 10% cover of trees" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_52 a skos:Concept ;
    dct:source "http://www.oldhamagenda21.demon.co.uk/Plan/Glossary.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Chopping down the natural forest of an area …"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_53 a skos:Concept ;
    dct:source "http://www.devon.gov.uk/agenda21/glossary.html#terminology"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Clearing land and trees"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_54 a skos:Concept ;
    dct:source "http://www.ran.org/kids_action/glossary.html"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Clearing land of trees by cutting or burning"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_55 a skos:Concept ;
    dct:source "http://www.schools.wafa.org.au/terms.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Clearing trees for timber, fuel, farmland or for new settlements from a piece of land without the intention of reforesting"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_56 a skos:Concept ;
    dct:source "http://www.gardenweb.com/glossary/deforestation"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Clearing trees from a woodland, often done to promote food for wildlife as well as to provide timber"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_57 a skos:Concept ;
    dct:source "http://www.isabelperez.com/select/forest.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Cutting down trees is called deforestation"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_58 a skos:Concept ;
    dct:creator "Soft" ;
    dct:source "http://www.wisegeek.com/what-is-hard-deforestation.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Deforestation happens when trees are cleared, but they later grow back"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Soft" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_59 a skos:Concept ;
    dct:creator "Tropical" ;
    dct:source "http://www.trfic.msu.edu/data_portal/Landsat7doc/defor_fact.html"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Deforestation - The clearing of tropical forests across the Earth"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Tropical" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_6 a skos:Concept ;
    dct:spatial "Bulgaria" ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "destruction of the forests on certain area under the influence of natural disasters, uncontrolled or planned (final cuttings) human activities. This term is not defined in the forestry law. Forest Research Institute forestin@bulnet.bg"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Bulgaria" ;
    skos:prefLabel "Deforestation"@da .

ex:Deforestation_60 a skos:Concept ;
    dct:source "http://www.globaled.org/issues/152/a.html"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Deforestation includes the destruction of forests…as well as woodlands…. The term deforestation does not apply to the removal of trees from plantations or industrial forests"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_61 a skos:Concept ;
    dct:source "http://www.globaled.org/issues/152/a.html"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Deforestation involves the permanent destruction of indigenous forests and woodlands"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_62 a skos:Concept ;
    dct:source "http://curiosity.discovery.com/question/deforestation-biggest-threat-biodiversity"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Deforestation is just what it sounds like: the destruction of large areas of forest lands or rainforests"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_63 a skos:Concept ;
    dct:source "http://wiki.answers.com/Q/What_is_deforestation?altQ=What_is_deforrestation#slide=1"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Deforestation is people cutting down whole forests of trees, and making it even less likely for humans to survive"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_64 a skos:Concept ;
    dct:source "http://www.s-cool.co.uk/a-level/biology/ecological-concepts/revise-it/human-effects-on-the-environment"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Deforestation is the rapid destruction of woodland. Although it can occur due to natural catastrophe it is most commonly caused by human intervention"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_65 a skos:Concept ;
    dct:source "http://eschooltoday.com/forests/what-is-deforestation.html"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Deforestation is when humans remove or clear large areas of forest lands for non-forest use. These include clearing for farming purposes, ranching and urban use. In these cases, trees are never re-planted"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_66 a skos:Concept ;
    dct:source "http://answers.ask.com/Science/Other/what_is_deforestation"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Deforestation is when trees are cut down or cleared out. Deforestation is becoming a large problem in rain forest areas, because the trees that are cut down for use aren't being replaced"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_67 a skos:Concept ;
    dct:creator "396 UN CSD" ;
    dct:source "http://www.hq.nasa.gov/iwgsdi/ISS_SDI_Land_Use.html"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Deforestation Rate - Area of forest harvested per year for lumber"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "396 UN CSD" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_68 a skos:Concept ;
    dct:creator "or allocation" ;
    dct:source "http://www.unredd.net/index.php?option=com_docman&task=doc_download&gid=7437&Itemid=53"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Deforestation: this involves a decrease in the area covered by forest. However, it cannot be so defined without adding a reference to its use . In point of fact, there exist certain forms of forest utilization - and priority objectives of forest management - that clear temporarily the forest cover while guaranteeing its maintenance. This is the case of clearcutting of areas where forest will regenerate itself or be regenerated, or of the final cut in an even-aged forest sylvicultural treatment once natural regeneration has been assured. In other words, there is no deforestation if there is a guarantee of continuity in maintaining the forest cover"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "or allocation" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_69 a skos:Concept ;
    dct:creator "reafforestation" ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Destruction of forest for timber, fuel, charcoal burning, and clearing for agriculture and extractive industries such as mining without planting new trees to replace those lost or working on a cycle that allows natural forest to regenerate (Lindley and Moore 1998"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "reafforestation" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_7 a skos:Concept ;
    dct:source "http://carbon.cfs.nrcan.gc.ca/definitions_e.html"^^xsd:anyURI ;
    dct:spatial "Canada" ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The conversion of forested land to nonforested land as a direct result of human activities"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Canada" ;
    skos:prefLabel "Deforestation"@da .

ex:Deforestation_70 a skos:Concept ;
    dct:source "http://www.climnet.org/CAN_2008_sep_LCA_REDD.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Direct, human-induced conversion of natural forest to non-forest land or plantation. The canopy cover threshold, demarcating the transition from native forest to non-forest land, should be defined for specific forest ecosystems"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_71 a skos:Concept ;
    dct:source "http://www.notredame.ac.jp/cgi-bin/wn?deforestation"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Disforestation -- the removal of trees"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_72 a skos:Concept ;
    dct:source "http://p5uni.ii.pw.edu.pl/infterra/"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Forest cover destruction Source: Infoterra Thesaurus"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_73 a skos:Concept ;
    dct:source "http://www.oznet.ksu.edu/library/MISC2/SB661.PDF"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Forest loss; typically defined as a forest losing 40 percent or more of the trees"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_74 a skos:Concept ;
    dct:source "http://wings.ucdavis.edu/Book/Atmosphere/beginner/deforestation-01.html"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Happens when people cut down forests or when trees are burned"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_75 a skos:Concept ;
    dct:source "http://www.wrm.org.uy/oldsite/deforestation/Africa/Gambia.html"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "In simple terms, can be the gradual reduction of the stocking of the vegetation cover resulting from human activities"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_76 a skos:Concept ;
