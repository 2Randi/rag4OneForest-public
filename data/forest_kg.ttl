        "unknown"@en .

ex:Reforestation_105 a skos:Concept ;
    dct:creator "UN-EP" ;
    dct:date "2003"^^xsd:gYear ;
    dct:source "http://digitalcommons.unl.edu/cgi/viewcontent.cgi?article=1030&context=usdafsfacpub"^^xsd:anyURI ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "Planting of forests on lands that have previously contained forests but that have been converted to some other use"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-EP 2003" ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_108 a skos:Concept ;
    dct:creator "IPCC" ;
    dct:date "1996"^^xsd:gYear ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "Planting of forests on lands which have, historically, previously contained forests but which have been converted to some other use. Replanted forests are included in the category, Changes in Forest and Other Woody Biomass Stocks, in the LUCF module of the emissions inventory calculations"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "IPCC 1996" ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_16 a skos:Concept ;
    dct:creator "EU" ;
    dct:date "2013"^^xsd:gYear ;
    dct:source "http://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:32013D0529"^^xsd:anyURI ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "‘reforestation’ means any direct human-induced conversion of land that is not forest to forest through planting, seeding and/or the human-induced promotion of natural seed sources, which is confined to land that was forest but ceased to be forest before 1 January 1990, and which has been reconverted to forest in the period after 31 December 1989"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "EU 2013" ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_17 a skos:Concept ;
    dct:creator "EU" ;
    dct:source "http://europa.eu.int/comm/dg08/forests/en/en4_6.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "The restoration of tree cover, to areas from which trees have recently been removed, by planting, encouragement of natural regeneration, or a combination of these methods"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "EU" ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_22 a skos:Concept ;
    dct:creator "IPCC" ;
    dct:date "1997"^^xsd:gYear ;
    dct:source "http://www.grida.no/climate/ipcc/regional/327.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "Forest stands established artificially on lands that have supported forests within the last 50 years"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "IPCC - 1997" ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_37 a skos:Concept ;
    dct:creator "UN-FAO" ;
    dct:date "1997"^^xsd:gYear ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "Establishment of a tree crop on forest land (FAO 1997"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO 1997" ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_38 a skos:Concept ;
    dct:creator "UN-FAO" ;
    dct:date "2001"^^xsd:gYear ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "The re-establishment of forest formations after a temporary condition with less than 10% canopy cover due to human-induced or natural perturbations. Explanatory note (extract): The definition of forest clearly states that forests under regeneration are considered as forests even if the canopy cover is temporarily below 10 per cent. Many forest management regimes include clearcutting followed by regeneration, and several natural processes, notably forest fires and windfalls, may lead to a temporary situation with less than 10 per cent canopy cover. In these cases, the area is considered as forest, provided that the re-establishment (i.e., reforestation) to above 10 per cent canopy cover takes place within the relatively near future. Food and Agriculture Organization of the United Nations (FAO 2000b"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO 2001" ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_39 a skos:Concept ;
    dct:creator "UN-FAO" ;
    dct:date "2005"^^xsd:gYear ;
    dct:source "http://unfccc.int/files/methods_and_science/lulucf/application/pdf/060830_killmann.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "Establishment of forest plantations on temporarily unstocked lands that are considered as forests"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO 2005" ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_40 a skos:Concept ;
    dct:creator "UN-FAO" ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "The establishment of forest, naturally or artificially, on an area previously in forest cover (FAO - IUFRO). From: Graeme Wild GraemeW@za.sappi.com"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO" ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_41 a skos:Concept ;
    dct:creator "UNFCCC" ;
    dct:date "2001"^^xsd:gYear ;
    dct:source "http://www.unfccc.int/resource/docs/cop6secpart/l11r01.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "“Reforestation” is the direct human-induced conversion of non-forested land to forested land through planting, seeding and/or the human-induced promotion of natural seed sources, on land that was forested but that has been converted to non-forested land. For the first commitment period, reforestation activities will be limited to reforestation occurring on those lands that did not contain forest on 31 December 1989"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UNFCCC 2001" ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_42 a skos:Concept ;
    dct:creator "UN-FRA" ;
    dct:date "2000"^^xsd:gYear ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "Artificial establishment of forest on lands which carried forest before. (UN-ECE/FAO 1997 and FAO 1998"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FRA 2000" ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_46 a skos:Concept ;
    dct:creator "USA-FED-DA-FS" ;
    dct:source "http://www.fs.fed.us/land/emterms.html"^^xsd:anyURI ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "The restocking of an area with forest trees, by either natural or artificial means, such as planting"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DA-FS" ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_50 a skos:Concept ;
    dct:creator "WCMC" ;
    dct:source "http://www.panda.org/downloads/forests/wcmcflrmapping.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "The managed reestablishment of forests on lands that once contained forests"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "WCMC" ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_51 a skos:Concept ;
    dct:creator "World Bank" ;
    dct:date "1999"^^xsd:gYear ;
    dct:source "http://www-wds.worldbank.org/servlet/WDSContentServer/WDSP/IB/1999/09/17/000178830_98101901520841/Rendered/INDEX/multi0page.txt"^^xsd:anyURI ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "The replacement of trees in cut-over forest areas"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "World Bank 1999" ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_52 a skos:Concept ;
    dct:creator "World Bank" ;
    dct:date "2000"^^xsd:gYear ;
    dct:source "http://www.holz.uni-goettingen.de/ek/woodsat/pdf/worldbankforestry.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "The replacement or establishment of a tree crop on forestland. . World Bank 2000"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "World Bank 2000" ;
    skos:prefLabel "REFORESTATION"@de .

ex:ReservedForestLand_1 a skos:Concept ;
    dct:creator "USA-FED-DA-FS" ;
    skos:definition "Forest lands that have statutory or administrative restrictions prohibiting the harvest of trees. Examples include land within the wilderness preservation system, research natural areas, National Parks and Monuments, and state parks. In National Forests, reserved forest lands are referred to collectively as \"withdrawn forest land\" (Powell 1993"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DA-FS" ;
    skos:prefLabel "Reserved Forest Land"@en .

ex:ReservedOtherForest_1 a skos:Concept ;
    dct:creator "USA-FED-DA-FS" ;
    skos:definition "Forest land incapable of growing 20 cubic feet per acre per year (mean annual increment at culmination in fully stocked, natural stands) of industrial wood that has been dedicated to noncommodity use through statute, ordinance, or administrative order. (Waddell and Bassett 1997"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DA-FS" ;
    skos:prefLabel "Reserved other forest"@en .

ex:ReservedTimberland_1 a skos:Concept ;
    dct:creator "USA-FED-DA-FS" ;
    skos:definition "Forest land capable of growing 20 cubic feet per acre per year (mean annual increment at culmination in fully stocked, natural stands) of industrial wood that has been dedicated to noncommodity use through statute, ordinance, or administrative order. Plots were not established in reserved areas; tree data therefore were not available to determine the mean annual increment (MAI) for these plots [sic]. Because of this, reserved forest land with an MAI of less than 20 cubic feet per acre per year may be classified as reserved timberland rather than reserved other forest land. (Waddell and Bassett 1997"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DA-FS" ;
    skos:prefLabel "Reserved timberland"@da .

