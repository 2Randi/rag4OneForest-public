    skos:definition "‘Forests’ have a closed canopy beneath which grasses do not grow. They are distinct from open-canopied woodlands that grow over a grass sward"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "IUCN and WCMC 1990" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
