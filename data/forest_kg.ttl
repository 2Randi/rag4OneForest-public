    dct:source "http://mrw.wallonie.be/cgi/dgrne/sibw/eunis.glo.pl?WORD=forest"^^xsd:anyURI ;
    dct:spatial "Belgium" ;
    skos:broadMatch ex:Forest ;
    skos:definition "A continuous tract over a large area where the dominant organisms are trees. Trees are of height >5m, tree crown cover of >10%, area >0.5ha and width >20m"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Belgium-Wallonie" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_132 a skos:Concept ;
    dct:source "http://ohia.com/ohia/roadshows/sky/glossary.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "An area of land covered largely with trees. Forests are vital parts of our global ecosystem supplying oxygen, habitat for wildlife, timber and recreation areas"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

