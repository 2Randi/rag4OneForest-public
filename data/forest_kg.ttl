ex:ProductiveReservedForestLand_1 a skos:Concept ;
    dct:creator "USA-FED-DA-FS" ;
    skos:definition "Forest land that would otherwise be classified as timberland, except that it is withdrawn from timber utilization by statute or administrative regulation. (Powell et al. 1993"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DA-FS" ;
    skos:prefLabel "Productive reserved forest land"@en .

ex:REUNational_1 a skos:Concept ;
