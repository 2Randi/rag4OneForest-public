ex:Forest_205 a skos:Concept ;
    dct:source "http://www.extension.iastate.edu/naturemapping/naturemapping_process/habitat_codes.html#forest"^^xsd:anyURI,
        "http://www.gap.uidaho.edu/handbook/LandCoverAssessment/Appendix5/default.htm"^^xsd:anyURI ;
