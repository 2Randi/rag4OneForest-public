ex:ForestSkogur_1 a skos:Concept ;
    dct:spatial "Iceland" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest (skogur) - Ecosystems where the dominant organisms are trees. The term includes all organisms, processes and physical components of these ecosystems. Includes scrubland where the dominant \"trees\" (usually the native birch, Betula pubescens) may only reach 1-2 m in height. Source: Latest draft of a new forestry act : Þröstur Eysteinsson throstur@simnet.is"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Iceland" ;
    skos:prefLabel "Forest skogur"@no ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:ForestWood_1 a skos:Concept ;
    dct:source "http://www.forestry.gov.uk/forestry/hcou-4ubj75"^^xsd:anyURI ;
    dct:spatial "United Kingdom" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest (Wood) - Generally speaking, a forest is a large wood or a collection of woods although the two terms are often interchangeable"@en ;
    skos:inScheme ex:ForestScheme ;
