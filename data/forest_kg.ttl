    skos:scopeNote "National"@en,
        "potential"@en .

ex:SYRNational_1 a skos:Concept ;
    dct:spatial "Syrian Arab Rep" ;
    skos:broadMatch ex:Forest ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "Syrian Arab Rep national criteria"@en ;
    skos:scopeNote "National"@en,
        "unknown"@en .

ex:TCDNational_1 a skos:Concept ;
    dct:spatial "Chad" ;
    skos:broadMatch ex:Forest ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "Chad national criteria"@en ;
    skos:scopeNote "National"@en,
        "unknown"@en .

ex:TKMNational_1 a skos:Concept ;
    dct:spatial "Turkmenistan" ;
    skos:broadMatch ex:Forest ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "Turkmenistan national criteria"@en ;
    skos:scopeNote "National"@en,
        "unknown"@en .

ex:Timberland_2 a skos:Concept ;
    dct:creator "USA-FED-DA-FS" ;
    skos:definition "Forest land that is producing or is capable of producing crops of industrial wood, and that is not withdrawn from timber utilization by statute or administrative regulation (Note: Areas qualifying as timberland are capable of producing more than 20 cubic feet per acre per year of industrial wood in natural stands. Currently inaccessible and inoperable areas are included.) (Powell et al. 1993). A subsequent report (Smith et al. 1994) provides the metric equivalent for timberland as 1.4 cubic meters per hectare per year"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DA-FS" ;
    skos:prefLabel "Timberland"@id .

ex:Tree_103 a skos:Concept ;
    dct:creator "UN FAO" ;
    dct:date "1998"^^xsd:gYear ;
    skos:broadMatch ex:Tree ;
    skos:definition "A woody perennial plant with a single well defined stem or, in the case of coppice, with several stems, carrying a more or less defined crown. Includes: a) bamboos, palms meeting the above criteria, b) trees as described above being at least 3 m tall, c) woody plants without a tree-like appearance but being more than 5 m tall (Choudhury and Jansen 1998"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN FAO 1998" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_104 a skos:Concept ;
    dct:creator "UN FAO" ;
    dct:date "1998"^^xsd:gYear ;
    skos:broadMatch ex:Tree ;
    skos:definition "A woody perennial plant with a single, well defined stem carrying a more-or-less-defined crown and being at least 3 m tall. Note: where a clear separation between trees and shrubs is too difficult to establish, a sub-condition of Height is applied: a woody plant higher than 5 m is classified as a Tree; a woody plant lower than 5 m is classified as a shrub. This general rule is subject to the following exception: a woody plant with the clear physiognomic aspect of tree can be classified as a Tree even if the height is less than 5 m, but more than 3 m (Di Gregorio and Jansen 1998"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN FAO 1998" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_105 a skos:Concept ;
    dct:creator "UN FAO  and" ;
    dct:date "2000"^^xsd:gYear ;
    dct:source "http://unfccc.int/files/methods_and_science/lulucf/application/pdf/060830_killmann.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "A woody perennial with a single main stem or, in the case of coppice with several stems, having a more or less definite crown. Includes: Bamboos, palms another woody plants meeting the above criterion (UN-ECE/FAO 1997 and FAO 1998). and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN FAO 2000 and 2005" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_110 a skos:Concept ;
    dct:creator "USA-FED-5WAY" ;
    dct:date "1985"^^xsd:gYear ;
    skos:broadMatch ex:Tree ;
    skos:definition "Tree. (III) A woody plant usually having one erect perennial stem at least 7.5 cm in diameter at breast height at maturity: a more or less definitely formed crown of foliage, and a height of at least 5 m at maturity (Land Use and Land Cover Common Terminology Work Group 1985"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-5WAY 1985" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_111 a skos:Concept ;
    dct:creator "USA-FED-Census 1870" ;
    dct:source "http://memory.loc.gov/cgi-bin/query/r?ammem/gmd:@field(NUMBER+@band(g3701gm+gct00008"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "Trees grow to 30 feet or higher"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-Census 1870" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_112 a skos:Concept ;
    dct:creator "USA-FED-DA-FS" ;
    dct:date "1979"^^xsd:gYear ;
    skos:broadMatch ex:Tree ;
    skos:definition "A woody plant having one erect perennial stem or trunk at least 3 inches (7.5 centimeters) in diameter at ‘breast height (4 1/2 feet or 1.3 meters), a more or less definitely formed crown of foliage, and a height of at least 13 feet (4meters) (LITTLE 1979"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DA-FS 1979" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_113 a skos:Concept ;
    dct:creator "USA-FED-DA-FS" ;
    dct:date "1989"^^xsd:gYear ;
    skos:broadMatch ex:Tree ;
    skos:definition "A woody plant usually having one or more perennial stem at least 3 inches d.b.h. at maturity, a more or less definitely formed crown of foliage, and a height of at least 16 feet at maturity (USDA Forest Service 1989"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DA-FS 1989" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_114 a skos:Concept ;
    dct:creator "USA-FED-DA-FS" ;
    dct:date "1999"^^xsd:gYear ;
    dct:source "http://www.gcrio.org/OnLnDoc/senate_epw990603.html"^^xsd:anyURI,
        "http://www.srsfia.usfs.msstate.edu/scripts/ew.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "A woody plant usually having one or more perennial stems, a more or less definitely formed crown of foliage, and a height of al least 12 feet at maturity. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DA-FS 1999" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_115 a skos:Concept ;
    dct:creator "USA-FED-DA-FS" ;
    dct:date "2006"^^xsd:gYear ;
    dct:source "http://fia.fs.fed.us/tools-data/docs/default.asp"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "A woody perennial plant, typically large, with a single well-defined stem carrying a more or less definite crown; sometimes defined as attaining a minimum diameter of 3 inches (7.6 cm) and a minimum height of 15 ft (4.6 m) at maturity. For FIA, any plant on the tree list in the current field manual is measured as a tree"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DA-FS 2006" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_116 a skos:Concept ;
    dct:creator "USA-FED-DA-NRCS" ;
    dct:date "1992"^^xsd:gYear ;
    dct:source "http://www.ftc.nrcs.usda.gov/doc/nri/72.html"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "Cover) An Earth Cover (Level 1) category with vegetative cover recognized as woody plants which usually have one perennial stem, a definitely formed crown of foliage, and a mature height of at least 4 meters. This category contains all trees, even those planted for the purposes of producing food and ornamentals, including Christmas trees. The second level categories of tree cover include fruit and nut trees, conifers, hardwoods, inter-mixed, and tropical species. [NRI-92]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DA-NRCS 1992" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_117 a skos:Concept ;
    dct:creator "USA-FED-DA-NRCS" ;
    dct:source "http://nsscnt.nssc.nrcs.usda.gov/nfm/apxframe.htm"^^xsd:anyURI,
        "http://www.statlab.iastate.edu/soils/nssh/622.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "For the purpose of developing ecological site descriptions, a woody-stemmed perennial plant, usually single stemmed, that can grow to 4 meters in height at maturity. and National Soil Survey Handbook"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DA-NRCS" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_118 a skos:Concept ;
    dct:creator "USA-FED-DA-SCS & FS" ;
    dct:date "1997"^^xsd:gYear ;
    skos:broadMatch ex:Tree ;
    skos:definition "Forest tree) A woody perennial plant having a single well developed main stem and usually more than 12 feet in height at maturity. (FS 1977"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DA-SCS & FS 1997" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_119 a skos:Concept ;
    dct:creator "USA-FED-DI-FWS" ;
    dct:source "http://www.nwi.fws.gov/contents.html#concept"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "A woody plant which at maturity is usually 6 m (20 feet) or more in height and generally has a single trunk, unbranched for 1 m or more above the ground, and a more or less definite crown; e.g., red maple (Acer rubrum), northern white cedar (Thuja occidentalis"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DI-FWS" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_120 a skos:Concept ;
    dct:creator "USA-FED-EPA" ;
    dct:date "2003"^^xsd:gYear ;
    dct:source "http://www.epa.gov/fedrgstr/EPA-IMPACT/2003/August/Day-11/i20345.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "A tall woody plant having comparatively great height and a single trunk from which an annual fruit or vegetable crop is produced for commercial purposes, such as maple tree for syrup, papaya tree, or orchard tree. Plantain and banana plants are also included. Trees used for pulp or timber are not considered trees under this part"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-EPA 2003" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_121 a skos:Concept ;
    dct:creator "USA-FED-FGDC" ;
    dct:date "1997"^^xsd:gYear ;
    dct:source "http://biology.usgs.gov/fgdc.veg/standards/appendix3.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "Woody plants that generally have a single main stem and have more or less definite crowns. In instances where life form cannot be determined, woody plants equal to or greater than 5 m in height will be considered trees. [Source: ]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-FGDC 1997" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_122 a skos:Concept ;
    dct:creator "USA-FED-FGDC  Draft" ;
    dct:date "2007"^^xsd:gYear ;
    dct:source "http://www.fgdc.gov/standards/projects/FGDC-standards-projects/vegetation/index_html"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "A woody plant that generally has a single main stem and a more or less definite crown. In instances where growth form cannot be determined, woody plants equal to or greater than 5 m in height at maturity shall be considered trees (adapted from FGDC 1997). Includes dwarf trees (Tart et al. 2005b) or “treelets” (Box 1981"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-FGDC 2007 Draft" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_123 a skos:Concept ;
    dct:creator "USA-FED-NOAA" ;
    dct:date "2003"^^xsd:gYear ;
    dct:source "http://www.csc.noaa.gov/crs/lca/tech_cls.html"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "Single-stemmed, woody vegetation unbranched 2 to 3 feet above the ground having a height greater than 6 meters (20 feet"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-NOAA 2003" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_152 a skos:Concept ;
    dct:creator "WCMC" ;
    dct:source "http://www.wcmc.org.uk/forest/data/cdrom2/text2.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "Mainly phanerophytes (single-trunked individuals, as most trees) and not chamaephytes (multi-stemmed individuals, as most shrubs"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "WCMC" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_243 a skos:Concept ;
    dct:creator "IPCC  GL FRA" ;
    dct:date "2006"^^xsd:gYear ;
    dct:source "http://unfccc.int/files/methods_and_science/lulucf/application/pdf/060830_killmann.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "Trees outside forests - Trees outside forests include all trees found outside forests and outside other wooded lands: - stands smaller than 0.5 ha; - tree cover in agricultural land, e.g. agroforestry systems, home gardens, orchards; - trees in urban environments; - along roads and scattered in the landscape"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "IPCC 2006 GL FRA 2005" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_257 a skos:Concept ;
    dct:creator "FAO" ;
    dct:date "2002"^^xsd:gYear ;
    dct:source "http://www.fao.org/DOCREP/005/Y2328E/y2328e00.htm#toc"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "Trees growing outside the forest and not belonging to the category of forests, forest lands, or other wooded land. According to this definition, Trees outside forests are located on \"other land\", such as agricultural land, built-up areas such as settlements and infrastructure, and bare land (dunes, former mining areas, etc.). (Bellefontaine, Ronald et al. 2002. Trees outside forests - Towards a better awareness. FAO Conservation Giude 35"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "FAO-2002" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_258 a skos:Concept ;
    dct:creator "FAO" ;
    dct:date "2003"^^xsd:gYear ;
    dct:source "http://www.fao.org/docrep/004/y1997e/y1997e00.htm"^^xsd:anyURI,
        "http://www.fao.org/docrep/006/ac840e/AC840E00.htm#TOC"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "Trees on land not defined as forest and other wooded land. Includes: trees on land that fulfils the requirements of forest and other wooded land except that the area is less than 0.5 ha; trees able to reach a height of at least 5 m at maturity in situ where the stocking level is below 5 percent; trees not able to reach a height of 5 m at maturity in situ where the stocking level is below 20 percent; scattered trees in permanent meadows and pastures; permanent tree crops such as fruit-trees and coconuts; trees in parks and gardens, around buildings and in lines along streets, roads, railways, rivers, streams and canals; trees in shelterbelts of less than 20 m width and 0.5 ha area (Rawat, J.K. et al. 2003. Training Manual on Inventory of Trees Outside Forests (TOF). FAO . FAO. 2001. Global forest resources assessment 2000. Main report. Food and Agriculture Organization of the United Nations, Rome"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "FAO-2003" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_3 a skos:Concept ;
    dct:creator "For reference, shrubs may be considered - a vegetation type where the dominant woody elements are shrubs which grow to a height of more than 50 cm and less than 5 metres on maturity. The height limits for trees and shrubs should be interpreted with flexibility http://europa.eu.int/comm/dg08/forests/en/en4_6.htm" ;
    dct:source "http://europa.eu.int/comm/dg08/forests/en/en4_6.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "As indicated above, many definitions of \"forest\" included the term \"tree.\" Therefore, we also need to understand what is considered a \"tree.\" Many of the above forest definitions included definitions of \"tree.\" Several have built-in height thresholds varying from 2-15 m. (For reference, shrubs may be considered - a vegetation type where the dominant woody elements are shrubs which grow to a height of more than 50 cm and less than 5 metres on maturity. The height limits for trees and shrubs should be interpreted with flexibility"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "For reference, shrubs may be considered - a vegetation type where the dominant woody elements are shrubs which grow to a height of more than 50 cm and less than 5 metres on maturity. The height limits for trees and shrubs should be interpreted with flexibility http://europa.eu.int/comm/dg08/forests/en/en4_6.htm" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_39 a skos:Concept ;
    dct:creator "European Environment Agency" ;
    dct:source "http://www.epa.gov/trs"^^xsd:anyURI ;
    skos:broadMatch ex:Tree ;
    skos:definition "Any large woody perennial plant with a distinct trunk giving rise to branches or leaves at some distance from the ground.(Source: CED) European Environment Agency (EEA), European Topic Centre on Catalogue of Data Sources (ETC/CDS) : General Multilingual Environmental Thesaurus Term Detail"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "European Environment Agency" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_78 a skos:Concept ;
    dct:creator "SAF" ;
    dct:date "1958"^^xsd:gYear ;
    skos:broadMatch ex:Tree ;
    skos:definition "A woody plant having one well defined stem and a more or less definitely formed crown, usually attaining a height of at least 8 feet. (SAF 1958"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "SAF 1958" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_79 a skos:Concept ;
    dct:creator "SAF" ;
    dct:date "1971"^^xsd:gYear ;
    skos:broadMatch ex:Tree ;
    skos:definition "A woody perennial plant, typically large and with a single well defined stem carrying a more or less definite crown. (FORD-ROBERTSON 1971"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "SAF 1971" ;
    skos:prefLabel "TREE"@vi .

ex:Tree_80 a skos:Concept ;
    dct:creator "SAF" ;
    dct:date "1998"^^xsd:gYear ;
    skos:broadMatch ex:Tree ;
    skos:definition "A woody perennial plant, typically large and with a well-defined stem or stems carrying a more or less definite crown --note sometimes defined as attaining a minimum diameter of 5 in (12.7 cm) and a minimum height of 15 ft (4.6 m) at maturity, with no branches within 3 ft (1 m) of the ground\". SAF (1998"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "SAF 1998" ;
    skos:prefLabel "TREE"@vi .

ex:TreesOutsideForests_1 a skos:Concept ;
    dct:creator "UN-FAO" ;
    dct:date "2004"^^xsd:gYear ;
    dct:source "http://www.fao.org/forestry/foris/webview/forestry2/index.jsp?siteId=4261&sitetreeId=13629&langId=1&geoId=0"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "all trees found outside forests and outside other wooded lands: stands smaller than 0.5 ha; tree cover in agricultural land, e.g. agroforestry systems, homegardens, orchards; trees in urban environments; along roads and scattered in the landscape"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO-2004" ;
    skos:prefLabel "Trees outside forests"@en .

ex:UZBNational_1 a skos:Concept ;
    dct:spatial "Uzbekistan" ;
    skos:broadMatch ex:Forest ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "Uzbekistan national criteria"@en ;
    skos:scopeNote "National"@en,
        "unknown"@en .

ex:VGBNational_1 a skos:Concept ;
    dct:spatial "British Virgin Islands" ;
    skos:broadMatch ex:Forest ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "British Virgin Islands national criteria"@en ;
    skos:scopeNote "National"@en,
        "unknown"@en .

ex:WESTERN_SANational_1 a skos:Concept ;
    dct:spatial "Western Samoa" ;
    skos:broadMatch ex:Forest ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "Western Samoa national criteria"@en ;
    skos:scopeNote "National"@en,
        "unknown"@en .

ex:WoodedArea_1 a skos:Concept ;
    dct:creator "EU" ;
    dct:source "http://ec.europa.eu/agriculture/envir/report/en/lex_en/report_en.htm"^^xsd:anyURI,
        "http://europa.eu.int/estatref/info/sdds/en/for/for_res.htm#toc"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "2000. - includes forest area and other types of wooded land. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "EU" ;
    skos:prefLabel "Wooded area"@en .

ex:WoodlandOrForest_2 a skos:Concept ;
    dct:creator "UN-FAO" ;
    dct:date "2005"^^xsd:gYear ;
    dct:source "http://www.fao.org/es/ess/census/12ch5.asp"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "This includes woodlot or timber tracts, natural or planted, constituting part of the holding which have or will have value as wood, timber, other forest products or for protection. Forest tree nurseries should be included in this category. Rows, belts and small clumps of trees, bamboo and other woody vegetation should be included in woodland and forest"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO-2005" ;
    skos:prefLabel "Woodland or forest"@en .

ex:Woodland_14 a skos:Concept ;
    dct:creator "EU" ;
    dct:source "http://europa.eu.int/comm/development/body/publications/forests/en/en4_6.htm"^^xsd:anyURI,
        "http://europa.eu.int/comm/dg08/forests/en/en4_6.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Open stand of trees up to approximately 18 metres in height in which tree crowns cover at least 30 per cent of the land area but are, for the most part, not overlapping and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "EU" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_15 a skos:Concept ;
    dct:creator "EU" ;
    dct:source "http://ec.europa.eu/agriculture/envir/report/en/lex_en/report_en.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Other wooded land are areas which have some characteristics of forests but which are not forests as defined above. They include open woodland and scrub, shrub and brushland"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "EU" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_16 a skos:Concept ;
    dct:creator "EU" ;
    dct:source "http://europa.eu.int/estatref/info/sdds/en/for/for_res.htm#toc"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "2000. Other wooded land is land which has some forestry characteristics but is not forest as defined above. It includes open woodland and scrub, shrub and brushland, whether or not used for pasture or range. It excludes land occupied by \"trees outside the forest.”"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "EU" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_27 a skos:Concept ;
    dct:creator "SAF" ;
    skos:broadMatch ex:Woodland ;
    skos:definition "1958) (Farm woodland) The wooded portion of a farm or ranch, or the wooded land operated in connection with a farm or ranch. In the Southwest. the piñion-juniper and chaparral forest types. In California, the open stand of oaks and occasionally digger pine in valleys and foothills, (SAF 1958"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "SAF" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_28 a skos:Concept ;
    dct:creator "SAF" ;
    skos:broadMatch ex:Woodland ;
    skos:definition "1971) Generally, a wooded area. More particularly, as in the tropics and western USA. plant communities in which trees, often small and characteristically short-holed relative to their depth of crown, are present but form only an open canopy, the intervening areas being occupied by lower vegetation, commonly grass, in contrast to a typical wood. (FORD-ROBERTSON 1971"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "SAF" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_41 a skos:Concept ;
    dct:creator "UN-EP" ;
    dct:source "http://www.unep.org/geo/geo4/report/Glossary.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Wooded land, which is not classified as forest, spanning more than 0.5 hectares, with trees higher than 5 metres and a canopy cover of 5-10 per cent, or trees able to reach these thresholds in situ, or with a combined cover of shrubs, bushes and trees above 10 per cent. It does not include areas used predominantly for agricultural or urban purposes"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-EP" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_45 a skos:Concept ;
    dct:creator "UN-FAO-," ;
    dct:date "2000"^^xsd:gYear ;
    dct:source "http://www.maweb.org/documents/document.290.aspx.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "‘‘Wodland’’ refers to the type of land cover characterized by trees and shrubs: ‘‘other wooded land.’’ Other wooded land, or OWL, is defined by FRA-2000 as land with a tree crown cover (or equivalent stocking level) of 5–10% of trees able to reach a height of 5 meters at maturity, a crown cover of more than 10% of trees not able to reach a height of 5 meters at maturity (such as dwarf or stunted trees), or shrub and bush cover of more than 10%. OWL excludes areas with the tree, shrub, or bush cover just specified but of less than 0.5 hectares and width of 20 meters, as well as land predominantly used for agricultural practices (FAO 2000, 2001c"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO-2000, 2001" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_46 a skos:Concept ;
    dct:creator "UN-FAO" ;
    dct:date "2005"^^xsd:gYear ;
    dct:source "http://www.fao.org/es/ess/census/PROGwca2010/chapter11_r7.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Other wooded land is land with: (i) crown cover of 5–10% for trees able to reach a height of 5 metres or more at maturity; or (ii) crown cover of more than 10% for trees not able to reach a height of 5 metres at maturity; or (iii) shrub or bush cover of more than 10%"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO-2005" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_47 a skos:Concept ;
    dct:creator "UN-FRA- Proposed" ;
    dct:date "2010"^^xsd:gYear ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Land with tree canopy cover of more than 5 percent and area of more than 0.5 hectares. Trees, defined by Ecoregion, should be able to reach a minimum height of 2m at maturity in situ. Generally, woodland trees will not excede 5m in height at maturity. Source: Brad Smith, USDA Forest Service, May 2002"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FRA-2010 Proposed" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_52 a skos:Concept ;
    dct:creator "USA-FED-CENSUS" ;
    dct:source "http://www.census.gov/prod/2/agr/92area/aca11.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "1992) Woodland, total. This category includes natural or planted woodlots or timber tracts, cutover and deforested land with young growth which has or will have value for wood products, land planted for Christmas tree production, and woodland pastured. Land covered by sagebrush or mesquite was to be reported as other pastureland and rangeland or other land"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-CENSUS" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_53 a skos:Concept ;
    dct:creator "USA-FED-CENSUS" ;
    dct:source "http://www.census.gov/prod/ac97/ac97a-11.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "1997) Woodland, total. This category includes natural or planted woodlots or timber tracts, cutover and deforested land with young growth which has or will have value for wood products, and woodland pastured. Land covered by sagebrush or mesquite was to be reported as other pastureland and rangeland or other land. Land planted for Christmas tree production was to be reported in cropland harvested, and land in tapped maple trees reported as woodland not pastured"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-CENSUS" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_54 a skos:Concept ;
    dct:creator "USA-FED-DA-FS" ;
    skos:broadMatch ex:Woodland ;
    skos:definition "1979) An area on which the dominant vegetation is broadleaf or deciduous trees. (FS 1979B"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DA-FS" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_55 a skos:Concept ;
    dct:creator "USA-FED-DA-FS" ;
    skos:broadMatch ex:Woodland ;
    skos:definition "1980) A plant community composed of trees at least 4 meters tail with crown not usually touching but with a foliar cover of over 25 percent but less than 61 percent at maturity. A herbaceous and/or scrub understory is usually present. (FS 1980"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DA-FS" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_56 a skos:Concept ;
    dct:creator "USA-FED-DA-FS-R8" ;
    skos:broadMatch ex:Woodland ;
    skos:definition "An open stand of trees with crowns not usually touching (generally forming a 25 to 60 percent cover). USDA Forest Service 1997"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DA-FS-R8" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_57 a skos:Concept ;
    dct:creator "USA-FED-DA-SCS" ;
    skos:broadMatch ex:Woodland ;
    skos:definition "1970) Land used primarily for the production of adapted wood crops and to provide tree cover for watershed protection, beautification, etc. Does not include farmstead and field windbreak plantings. (SCS 1970"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DA-SCS" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_58 a skos:Concept ;
    dct:creator "USA-FED-DC-NOAA" ;
    dct:source "http://www.csc.noaa.gov/crs/lca/proto2.html"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Woody Land class includes any species with an aerial stem that persists for more than one season. The Woody class is divided into three subclasses: 1.41 - Deciduous, 1.42 - Evergreen, and 1.43 - Mixed. . 1995"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DC-NOAA" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_59 a skos:Concept ;
    dct:creator "USA-FED-DI-BIA" ;
    dct:source "http://conbio.rice.edu/nae/docs/assessment.html"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Forestland with less than 5% crown cover by commercial timber species"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DI-BIA" ;
    skos:prefLabel "Woodland"@en .

ex:Woodland_60 a skos:Concept ;
    dct:creator "USA-FED-DI-BLM" ;
    dct:source "http://www.blm.gov/nhp/efoia/wo/fy03/im2003-035attach1.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Those lands with 5 percent or greater crown cover in tree species not typically used in commercially processed wood products, including such species as pinyon pine, juniper, white oak, live oak, and black spruce. Stocking can be measure by either crown density, stem density, or basal area. Include land that formerly had such tree cover and that will be managed to be naturally or artificially regenerated to tree cover"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DI-BLM" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_61 a skos:Concept ;
    dct:creator "USA-FED-DI-GS" ;
    dct:source "http://mcmcweb.er.usgs.gov/phil/gis.html"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Woodland, which is defined as \"forest land,\" includes deciduous, evergreen, and mixed forest land, and orchards. The woodland data layer identifies deforestation or reforestation resulting from urbanization or conservation. The woodland is compiled using criteria based on tint and spectral reflectance. The minimum mapping unit for woodland is 10 acres. The classification scheme adopted for woodland is a modification of the Anderson Level II classification system. All woodland areas are collected as polygons, compiled into one separate coverage, and assigned category 44"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DI-GS" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_62 a skos:Concept ;
    dct:creator "USA-FED-DI-GS" ;
    dct:source "https://edcintl.cr.usgs.gov/downloads/sciweb1/shared/wafrica/downloads/documents/Landscapes_of_West_Africa_Atlas_low_resolution_en.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Open formations of small to medium height trees; tree height over 10 m and tree cover generally between 50 and 75 percent; canopies are often contiguous, with open areas between trees; grass understory can be scattered to dense, often associated with other herbaceous plants"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DI-GS" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_63 a skos:Concept ;
    dct:creator "USA-FED-DI-OSM" ;
    dct:source "http://www.osmre.gov/mountaintop.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "\"Woodlands\" is defined in CSR 38-2-2.134 to mean commercial woodlands where the postmining land use would result in the development of a commercial product for which flat or gently rolling land is essential to facilitate the operation of mechanical harvesting equipment"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DI-OSM" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_64 a skos:Concept ;
    dct:creator "USA-FED-FGDC" ;
    dct:source "http://www.fgdc.gov/fgdc.html"^^xsd:anyURI,
        "http://www.forestguild.org/climate_change/Pinon-Juniper.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Woodland: Mature (late successional) height of trees > 5 metes and canopy cover +/> 10 % and =/< 25 %. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-FGDC" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodland_77 a skos:Concept ;
    dct:creator "WCMC" ;
    dct:source "http://www.panda.org/downloads/forests/wcmcflrmapping.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Woodland includes thicket and bushland but not shrubland"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "WCMC" ;
    skos:prefLabel "WOODS, WOODLAND, OTHER WOODED LANDS (OWL)"@de .

ex:Woodlands_2 a skos:Concept ;
    dct:creator "UN-FAO" ;
    dct:date "2017"^^xsd:gYear ;
    dct:source "http://www.fao.org/3/a-i7849e.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Wooded areas where trees and shrubs are predominant. There are wet and dry types. The wet type occurs as a zone along wetlands (riverine forest) and the dry type is found on grasscovered upland areas. To qualify as woodland the average height of the trees must exceed 4 m”. Woodlands can be distinguished into closed and open woodlands by their canopy cover. Closed woodlands have a canopy cover of > 40% whereas open woodlands have one of 10 to 40%"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO 2017" ;
    skos:prefLabel "Woodlands"@en .

