ex:Forest_1312 a skos:Concept ;
    dct:creator "Queensland" ;
    dct:source "http://www.nrm.qld.gov.au/slats/final9799.html"^^xsd:anyURI ;
    dct:spatial "Australia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "There are many definitions of what constitutes a forest or woody vegetation. A common definition used by foresters is 20 per cent crown cover which equates to approximately 12 per cent foliage projective cover (FPC) (NFI, 1998"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Australia-Queensland" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_1313 a skos:Concept ;
    dct:creator "South" ;
    dct:source "http://www.atlas.sa.gov.au/atlas1986/2ENVIRONMENT_RESOURCES/5VEGETATION.cfm"^^xsd:anyURI ;
    dct:spatial "Australia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest is mapped where trees form the tallest stratum and their projective foliage covers more than 30% of the ground"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Australia-South Australia" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_1314 a skos:Concept ;
    dct:creator "Tasmania" ;
