    skos:note "USA 2003" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_1009 a skos:Concept ;
    dct:creator "USA" ;
    skos:broadMatch ex:Forest ;
    skos:definition "A stand of trees where trees are no more than 60 feet apart. Based upon excavated roots of some mature trees and determined that a forest could not be a forest if the trees were more than about 20 meters apart. This definition assumed that the trees were mature. This was a definition for the USA. Source: \"J. Foster\" <borealis@mail.wellsgray.net from an article in Journal of Forestry"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_101 a skos:Concept ;
    dct:creator "Choudhury & Jansen  and Timberlake & van der Poel" ;
    dct:date "1998"^^xsd:gYear ;
    dct:source "http://www.iapad.org/publications/ppgis/landglossary.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A large tract of land with a fairly dense growth of trees. This differs in degree from woodland, which tends to refer more to open forests"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Choudhury & Jansen 1998 and Timberlake & van der Poel 1979" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

