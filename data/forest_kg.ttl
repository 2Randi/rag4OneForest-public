    dct:spatial "Kyrgyzstan" ;
    skos:broadMatch ex:Forest ;
    skos:definition "forest?) areas - - Areas both covered and not covered with the forest territories included into the National Forest Fund (stock). The main use of such lands is forest planting and growing. Source: Irina Yunusova irina@lesic.elcat.kg"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Kyrgyzstan" ;
    skos:prefLabel "forest areas"@en ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:ForestCover_2 a skos:Concept ;
    dct:creator "UN-SD" ;
    dct:source "http://esa.un.org/unsd/envmnt/gesform.asp?getitem=539"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "All the trees and other woody plants (underbrush) covering the ground in a forest. It includes (a) trees and all shrubs, (b) herbs and shrubs growing thereunder or in openings in the forest or brush fields, (c) litter or fallen leaves, branches, fallen trees and other vegetable material on the forest floor and (d) the rich humus of partially decayed vegetable matter at the surface and top layer of the soil. United Nations Statistical Division"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-SD" ;
    skos:prefLabel "Forest Cover"@no ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:ForestCover_3 a skos:Concept ;
    dct:source "http://moef.gov.in/nfc/s-git.pdf"^^xsd:anyURI ;
    dct:spatial "India" ;
    skos:broadMatch ex:Forest ;
    skos:definition "All lands, more than one hectare in area, with a tree canopy density of more than 10 percent. Such lands may not be statutorily notified as forest area"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "India" ;
    skos:prefLabel "Forest cover"@en ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:ForestIncludingWoodland_1 a skos:Concept ;
    dct:creator "Ontario" ;
    dct:date "1998"^^xsd:gYear ;
    dct:source "http://www.ontarionature.org/pdf/Significant_Woodlands_Guidelines(Draft%20Aug%202004).pdf"^^xsd:anyURI ;
    dct:spatial "Canada" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest (including woodland) - A treed community with at least 34% tree cover. (Ecological Land Classification for southern Ontario, O.M.N.R., 1998"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Canada-Ontario 1998" ;
    skos:prefLabel "Forest including woodland"@en ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:ForestLandForestDomainArabic_1 a skos:Concept ;
    dct:spatial "Morocco" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest land /Forest domain (Arabic : Ard ghabawyah/Milk ghabawee, French : Terrain forestier/Domaine forestier, Spanish : Terreno forestal) - Land covered with a forest, or land belonging to the State and put under the control of the forest Service, even if it does not any more trees on it (but did in the past). Mohammed Ellatifi, m.ellatifi@ellatifi.8m.com"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Morocco" ;
    skos:prefLabel "Forest land Forest domain Arabic"@en ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:ForestLandHa_1 a skos:Concept ;
    dct:date "2006"^^xsd:gYear ;
    dct:source "http://www.efi.int/files/attachments/publications/annex_1_to_efi_technical_report_88__2013.pdf"^^xsd:anyURI ;
    dct:spatial "Hungary" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest land (1000 ha) - With defined tree species, minimum block size 0.5 ha, -Crown cover min. 50% (30% if protection function). Area: all forest where the forest block is at least 0.5 ha (all area which has “forest” cadastral status, plus all area where forest is found) Definition: Forest should be consisted more than 50% of the tree species (listed in the Forest Act) and forest cover is more than 30%. Mezőgazdasági Szakigazgatási Hivatal (MGSZH), 2006"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Hungary 2006" ;
    skos:prefLabel "Forest land ha"@en ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:ForestLandMeans_1 a skos:Concept ;
    dct:creator "Western" ;
    dct:date "1967"^^xsd:gYear ;
    dct:source "http://www.thecommonwealth.org/Shared_ASP_Files/UploadedFiles/42862479-BC6A-481C-ADEB-50432C31A072_ForestsAct1967.pdf"^^xsd:anyURI ;
    dct:spatial "Samoa" ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"Forest land\" means, - (a) State forest land; or (b) Public or customary land which is subject to a licence or lease to the Minister or any other person for any purpose of forestry; or (c) Freehold land which is subject to a licence or lease to the Minister or any other person for any purpose of forestry, or in respect of which the Minister is a trustee under Part IX of this Act: Forests Act 1967 Laws of Western Samoa"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Western Samoa 1967" ;
    skos:prefLabel "Forest land means"@en ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:ForestLandMetsamaa_1 a skos:Concept ;
    dct:date "1999"^^xsd:gYear ;
    dct:spatial "Estonia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest land [metsamaa] - Land that is assigned for growing ligneous plants (by land survey or by land cadastre). Other lands that have importance for forestry can also be assigned into forest land if these are not suitable for other category. Current Estonian Forestry Act (valid until 01/01/99) From: \"Sulev Svilponis\" Sulev@ekm.envir.ee. Definitions are unofficial translations"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Estonia 1999" ;
    skos:prefLabel "Forest land metsamaa"@et ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:ForestLandMetsamaa_2 a skos:Concept ;
    dct:spatial "Estonia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest land [metsamaa] - Land which is used for forestry. Forest land can be divided: - land with forest (stands), - land without forest (not regenerated cut over areas, treeless, openings, burnt woodlands, perished stands) - young silvicultures which are not yet dense enough, - tree nurseries. Estonian Encyclopedia From: \"Sulev Svilponis\" Sulev@ekm.envir.ee. Definitions are unofficial translations"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Estonia" ;
    skos:prefLabel "Forest land metsamaa"@et ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:ForestLandSkoglendi_1 a skos:Concept ;
    dct:spatial "Iceland" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest land (skoglendi) - Land that is or will be, mostly or fully, covered by forest vegetation, natural or planted, forest or scrub*. *The Icelandic word \"kjarr\", which is translated as scrub, refers to low-growing and crooked birch and in some cases willows. Source: Latest draft of a new forestry act : Þröstur Eysteinsson <throstur@simnet.is"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Iceland" ;
    skos:prefLabel "Forest land skoglendi"@da ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:ForestLandTerrainForestier_1 a skos:Concept ;
    dct:source "http://www.pfc.cfs.nrcan.gc.ca/landscape/inventory/terms/haddon/glossary.html#F"^^xsd:anyURI ;
    dct:spatial "Canada" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest land: [terrain forestier] - Land primarily intended for growing, or currently supporting, forest. Includes land not now forested, e.g., clearcuts; northern lands that are forested but not intended for any use; and plantations"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Canada" ;
    skos:prefLabel "Forest land terrain forestier"@en ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:ForestLandUseCategory_1 a skos:Concept ;
    dct:creator "USA-STATE-Washington" ;
    dct:date "1998"^^xsd:gYear ;
    dct:source "http://www.efsec.wa.gov/oplarchive/DEIS/TOC/glossary.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest (land use category) - Includes public or private forest lands and tree farms, and may be designated for recreational uses. Forested Wetland - Any area of vegetated wetland where woody vegetation over 20 feet tall and dominated by trees (e.g., alder, cedar, hemlock, cottonwood, some willow species) comprises at least 30 percent areal cover"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Washington 1998" ;
    skos:prefLabel "Forest land use category"@en ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:ForestLand_1 a skos:Concept ;
    dct:spatial "Bulgaria" ;
    skos:broadMatch ex:Forest ;
    skos:definition "every territory outside the building boundaries of the settlements, determined by general or detailed building projects or by outside limiting polygons, planned mainly for forests and including tree stands, shrubs, lands for afforestation, non-productive lands, indicated in the United Cadastre. Forest Research Institute forestin@bulnet.bg"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Bulgaria" ;
    skos:prefLabel "Forest land"@fr ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:ForestLand_10 a skos:Concept ;
    dct:creator "Czech Republic" ;
    dct:source "http://www.fris.sk/Phare/Projects/ManagementOfForestInEurope/PDF/annex2.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land with forests stands & cleared areas under regeneration, unpaved forest roads with width <4m, paved forest roads, nurseries, plantations, small water areas, other areas & lands above the alpine limit of woody vegetation"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Czech Republic" ;
    skos:prefLabel "Forest land"@fr ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:ForestLand_11 a skos:Concept ;
    dct:source "http://www.fris.sk/Phare/Projects/ManagementOfForestInEurope/PDF/annex2.pdf"^^xsd:anyURI ;
    dct:spatial "Estonia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land which fulfils at least one of the following: 1) Trees are >1.3 m high, crown density is >30%; 2) Land is or it is intended to be managed to get timber and other forest products or where trees are conserved for use in other ways (nature conservation, environment protection, sanitary protection, recreation, hygiene and sport, research and studies, multiple use, hunting, state security); 3) Ability to produce timber in the long run of at least 1 m3 of bole timber per 1 ha a year. Increment on forest land with small productivity may be lower"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Estonia" ;
    skos:prefLabel "Forest land"@fr ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:ForestLand_12 a skos:Concept ;
    dct:source "http://www.fris.sk/Phare/Projects/ManagementOfForestInEurope/PDF/annex2.pdf"^^xsd:anyURI ;
    dct:spatial "Hungary" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Area of 0.15 ha or more covered with wood – including land with spontaneous afforestation, land temporarily utilized for other purposes - together with glades and fire strips located in it. Includes forest plantations (seed sowing, planting or coppice sprouting) of 0.15 ha or more. Includes: Forest lands smaller than the limit if surrounded by a real estate registered in a sector other than forestry; and Land directly serving forestry activities (listed explicitly in §9"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Hungary" ;
    skos:prefLabel "Forest land"@fr ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:ForestLand_13 a skos:Concept ;
    dct:spatial "Lithuania" ;
    skos:broadMatch ex:Forest ;
    skos:definition "areas of land, covered by forest (stands) and without forests (clear-cut, destructed areas, glades, nurseries, seed orchards, woody plants and special plantations for preparation of various raw materials). Forest land also includes forest roads, block lines, border lines, technological lines, antifire belts, timber yards, other areas for technological, recreational needs, game forage, also land nominated for afforestation. Source: A. Kuliesis, Director of Lithuanain Forest Inventory and Management Institute Email: Sekrtetore sek@mp.is.lt"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Lithuania" ;
    skos:prefLabel "Forest land"@fr ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:ForestLand_14 a skos:Concept ;
    dct:date "1949"^^xsd:gYear ;
    dct:spatial "New Zealand" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land on which forest is growing, land used for agroforestry, and land intended to be forested or used for agroforestry by the owner or occupier of the land. (from Forests Act 1949"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "New Zealand 1949" ;
    skos:prefLabel "Forest land"@fr ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:ForestLand_15 a skos:Concept ;
    dct:source "http://www.climatechange.govt.nz/glossary.html#f"^^xsd:anyURI ;
    dct:spatial "New Zealand" ;
    skos:broadMatch ex:Forest ;
    skos:definition "A minimum area of land of one hectare with tree crown cover (or equivalent stocking level) of more than 30 per cent with trees with the potential to reach a minimum height of five metres at maturity in situ. This category includes all land with woody vegetation consistent with thresholds used to define forest land in the national GHG inventory, sub-divided at the national level into managed and unmanaged and also by ecosystem type as specified in the IPCC Guidelines.6 It also includes systems with vegetation that currently falls below, but is expected to exceed, the threshold of the forest land category. Young natural stands and all plantations which have yet to reach a crown density of 30 percent or tree height of five metres are included under forest, as are areas normally forming part of the forest land area which are temporarily un-stocked as a result of human intervention such as harvesting or natural causes but which are expected to revert to forest (Kyoto Protocol definition). Tree cover less than 30 metres wide is excluded. Does not include shelter belt where the tree crown cover at maturity has, or is expected to have, an average width of less than 30 metres; or an area of land where the tree crown cover at maturity has, or is expected to have, an average width of less than 30 metres, unless the area is contiguous with other forest land"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "New Zealand" ;
    skos:prefLabel "Forest land"@fr ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:ForestLand_16 a skos:Concept ;
    dct:source "http://www.environment.govt.nz/footprint/glossary.html"^^xsd:anyURI ;
    dct:spatial "New Zealand" ;
    skos:broadMatch ex:Forest ;
    skos:definition "land used for the production of commercial forests"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "New Zealand" ;
    skos:prefLabel "Forest land"@fr ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:ForestLand_17 a skos:Concept ;
    dct:source "http://www.fris.sk/Phare/Projects/ManagementOfForestInEurope/PDF/annex2.pdf"^^xsd:anyURI ;
    dct:spatial "Oman" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land belonging to the national forest estate, and that intended for afforested to serve silvicultural, production and/or other needs"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Romania" ;
    skos:prefLabel "Forest land"@fr ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:ForestLand_18 a skos:Concept ;
    dct:creator "Taiwan, ROC" ;
    skos:broadMatch ex:Forest ;
    skos:definition "the land that is at least 0.5 hectare in size with at least 10% of the area covered with tree crowns or commercial bamboo, the forest belt beside road or river is at least 50 meters wide. The road, river, other water area or open lands in forest is less than 20 meters wide. The open land over than 0.5 hectare which is considered to reforestation or afforestation. Source: The Third Forest Resources and Land Use Inventory in Taiwan&uml; - \"&ordf;L&deg;È&sect;&frac12;service\" service@dns.forest.gov.tw"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Taiwan, ROC" ;
    skos:prefLabel "Forest land"@fr ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:ForestLand_19 a skos:Concept ;
    dct:creator "USA-STATE-Kansas" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land at least 10% stocked by forest trees of any size, or formerly having such tree cover, and not currently developed for non-forest use. Stocking is measured by comparing specified standards with basal area and /or number of trees, age or size and spacing. The minimum area classification for forest land is 1 acre. Roadside, streamside, and shelterbelt strips of timber must have a crown width of at least 120 feet to qualify as forest land. \"An Analysis of the Forest Resources of Kansas\", Leatherberry, Schmidt, Strickler & Aslin, USDA/FS NCRS NC-334. Robert L. Atchison ratchiso@oznet.ksu.edu"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Kansas" ;
    skos:prefLabel "Forest land"@fr ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:ForestLand_2 a skos:Concept ;
    dct:source "http://www.fris.sk/Phare/Projects/ManagementOfForestInEurope/PDF/annex2.pdf"^^xsd:anyURI ;
    dct:spatial "Bulgaria" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest territories include all forests, and also rocks, lakes, and pastures situated within forests"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Bulgaria" ;
    skos:prefLabel "Forest land"@fr ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:ForestLand_20 a skos:Concept ;
    dct:creator "USA-STATE-Virginia" ;
    dct:date "1997"^^xsd:gYear ;
    dct:source "http://www.dof.virginia.gov/edu/glossary.htm#F"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land at least 10 percent stocked by trees of any size or formerly having had such tree cover and not currently built-up or developed for agricultural use. Forestland may include Grassland, Shrubland, Treeland, Wetland, and/or Barren land. Examples of forest land use are grazing, recreation, and timber production. See Forest Land Class for further breakdowns. Virginia Fire Law defines forestland as 80 woody stems per acre"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Virginia 1997" ;
    skos:prefLabel "Forest Land"@fr ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:ForestLand_3 a skos:Concept ;
    dct:date "1911"^^xsd:gYear ;
    dct:spatial "Pakistan" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Any land which has been declared to be forest by notification under a Forest Act. Definition adopted from Glossary of Technical Terms for use in Indian Forestry - compiled by A.M.F. Caccia and revised by R.S. Troup, 1911. Source: Mumtaz Ahmad, Section Forest Officer, Pakistan Min. of Environment, Local Government, and Rural Development"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Pakistan 1911" ;
    skos:prefLabel "Forest land"@fr ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:ForestLand_4 a skos:Concept ;
    dct:source "http://www.fris.sk/Phare/Projects/ManagementOfForestInEurope/PDF/annex2.pdf"^^xsd:anyURI ;
    dct:spatial "Poland" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Definition of „Forests“ in the Forest Act includes: * Forest Stands * Other areas designated for forest production, nature reserves or part of National Park or listed in the nature conservation register * Forest infrastructure, and installations, including those for tourism"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Poland" ;
    skos:prefLabel "Forest land"@fr ;
    skos:scopeNote "Declared"@en,
        "National"@en .

ex:ForestLand_5 a skos:Concept ;
    dct:source "http://www.fris.sk/Phare/Projects/ManagementOfForestInEurope/PDF/annex2.pdf"^^xsd:anyURI ;
    dct:spatial "Albania" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Besides the forests according to the FAO definition, also areas where trees should not be able to reach a minimum height of 5 m at maturity and bare/rocky terrain, eroded and abandoned/refused lands are classified as the forest land"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Albania" ;
    skos:prefLabel "Forest land"@fr ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:ForestLand_6 a skos:Concept ;
    dct:creator "Papua New" ;
    dct:spatial "Guinea" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land that has forest growing on it, be it natural and or plantation forest and irrespective of its exploitative capability. In PNG over 80% of the land is customarily owned and the State can only plan and designate areas for forest exploitation and other use. The final decision as to whether or not the area is exploited rests with the customary land-owners. Vitus Ambia, Papua New Guinea Forest Authority"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Papua New Guinea" ;
    skos:prefLabel "Forest Land"@fr ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:ForestLand_7 a skos:Concept ;
    dct:spatial "Oman" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Surface of forest covered by forest vegetation, destined to fulfill social and/or economic function. Sorin Sfirlogea <sorinsf@rosilva.ro National Forests Administration"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Romania" ;
    skos:prefLabel "Forest land"@fr ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:ForestLand_8 a skos:Concept ;
    dct:spatial "Thailand" ;
    skos:broadMatch ex:Forest ;
    skos:definition "forest area derived from satellite imagery interpretation by the Royal Forest Department. Songkram Thammincha fforskt@ku.ac.th"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Thailand" ;
    skos:prefLabel "Forest land"@fr ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:ForestLand_9 a skos:Concept ;
    dct:source "http://www.pfc.cfs.nrcan.gc.ca/landscape/inventory/terms/363_ch2.pdf"^^xsd:anyURI ;
    dct:spatial "Canada" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land primarily intended for growing, or currently supporting forests. Includes temporarily nonforested lands such as clearcuts"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Canada" ;
    skos:prefLabel "Forest land"@fr ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:ForestMets_1 a skos:Concept ;
    dct:date "1998"^^xsd:gYear ;
    dct:source "http://www.envir.ee/metsaamet/english/acts/forestact.htm"^^xsd:anyURI ;
    dct:spatial "Estonia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest [mets] - growing site of ligneous plants which area is at least 0.5 ha and which corresponds to the following conditions: 1) height of growing trees is at least 1.3 m and density of crowns is at least 30%; 2) it is managed for timber and other forest products or there are ligneous plants preserved for use in ways which are described in the Forestry Act. Forests can be divided into productive forests (producing at least 1 cubic metre of stem timber as an average for long period) and unproductive forests (producing less than 1 cubic metre of stem timber as an average for long period. Estonian new Forestry Act From: \"Sulev Svilponis\" Sulev@ekm.envir.ee . Definitions are unofficial translations The Forest Act Passed on 9 December 1998, (RT* I 1998, 113/114, 1872),Entered into force on 9 January 1999"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Estonia 1998" ;
    skos:prefLabel "Forest mets"@no ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:ForestMets_2 a skos:Concept ;
    dct:spatial "Estonia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest [mets] - forest land with plant community. Trees, bushes and other plants are important part of forest. Forest fauna is part of forest ecosystem. Current Estonian Forestry Act (valid until 01/01/99) From: \"Sulev Svilponis\" Sulev@ekm.envir.ee. Definitions are unofficial translations"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Estonia" ;
    skos:prefLabel "Forest mets"@no ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:ForestMets_3 a skos:Concept ;
    dct:spatial "Estonia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest [mets] - Part of landscape and habitat which is formed when trees are growing together and where appear multifarious mutual influence and relations between trees and site conditions (relief, soil, microclimate). Collection of trees is called forest if the area, height and density are exceeding the limits when environmental conditions start to change qualitatively. Estonian Encyclopedia From: \"Sulev Svilponis\" Sulev@ekm.envir.ee . Definitions are unofficial translations"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Estonia" ;
    skos:prefLabel "Forest mets"@no ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:ForestPlantationOfTrees_1 a skos:Concept ;
    dct:spatial "Argentina" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest: Plantation of trees. - Bosque nativo: Native forest, Natural forest; Bosque cultivado: Plantation. (\"Mirta Rosa Larrieu\" milarr@sagyp.mecon.ar"@fr ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Argentina" ;
    skos:prefLabel "Forest Plantation of trees"@en ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

