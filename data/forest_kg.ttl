    skos:inScheme ex:ForestScheme ;
    skos:note "United Kingdom" ;
    skos:prefLabel "- OWL"@pt .

ex:ProductionForest_1 a skos:Concept ;
    dct:creator "– BC" ;
    dct:source "http://www.for.gov.bc.ca/PAB/PUBLCTNS/GLOSSARY/P.htm"^^xsd:anyURI ;
    dct:spatial "Canada" ;
    skos:definition "the forest used for production of various commodities, for example timber. [BC's official definition at ]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Canada – BC" ;
    skos:prefLabel "Production forest"@en .

ex:ProductiveForestLand_2 a skos:Concept ;
    dct:creator "– BC" ;
    dct:source "http://www.for.gov.bc.ca/PAB/PUBLCTNS/GLOSSARY/P.htm"^^xsd:anyURI ;
    dct:spatial "Canada" ;
    skos:definition "forest land that is capable of producing a merchantable stand within a defined period of time. [BC's official definition at ]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Canada – BC" ;
    skos:prefLabel "Productive forest land"@en .

ex:ProductiveWoodland_1 a skos:Concept ;
    dct:source "http://www.fao.org/ag/agl/agll/landuse/clsys/Canada2.htm"^^xsd:anyURI ;
    dct:spatial "Canada" ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Wooded land with trees having over 25% canopy cover and being over 20 feet in height approximately. Much cutover and burned over land is included"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Canada" ;
    skos:prefLabel "Productive woodland"@en .

ex:Puud_1 a skos:Concept ;
    dct:spatial "Estonia" ;
    skos:broadMatch ex:Tree ;
    skos:definition "[] - Long-lived higher plants with lignified stem. Estonian Encyclopedia From: \"Sulev Svilponis\" Sulev@ekm.envir.ee. Definitions are unofficial translations"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Estonia" ;
    skos:prefLabel "puud"@et .

ex:RealEstate_1 a skos:Concept ;
    dct:creator "USA-STATE-Virginia" ;
    skos:broadMatch ex:Tree ;
    skos:definition "TREE. A tree is single woody stem of a species presently or prospectively suitable for commercial industrial wood products. Standards for Classification of Real Estate As Devoted To Forest Use Under The Virginia Land Use Assessment Law Under the authority of 58.1-3229, et. seq. of the Code of Virginia \"Starr, James\" starrj@dof.state.va.us"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Virginia" ;
    skos:prefLabel "Real Estate"@ro .

ex:ReboisementNMSynReafforestation_1 a skos:Concept ;
    dct:creator "Sask" ;
    dct:spatial "Canada" ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "[reboisement (n.m.)] syn. reafforestation - Successful renewal of a forest crop by planting or direct seeding. [Source: Silvicultural Terms in Canada - Second Edition 1995 From: Mark Johnston <johnston@larix.derm.gov.sk.ca Date: Tue, 16 Jun 1998 17:44:48 -0600]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Canada - Sask." ;
    skos:prefLabel "reboisement n m syn reafforestation"@fr .

ex:ReforestaciN_1 a skos:Concept ;
    dct:spatial "Nicaragua" ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "Draft.La acción de poblar con especies arbóreas o arbustivas mediante plantación, regeneración manejada o siembra, un terreno que haya sido objeto de aprovechamiento previo o afectado por incendios o fenómenos naturales. www.nicarao.org.ni/ja (see Borrador de la ley, CAPITULO II DEFINICIONES) Harrie <harnic@ibw.com.ni>"@es ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Nicaragua" ;
    skos:prefLabel "Reforestación"@es .

ex:ReforestationArabic_1 a skos:Concept ;
    dct:spatial "Morocco" ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "Reforestation (Arabic : I’adat tashjeer/tahreej, French : Reboisement) - Artificial creation (by man) of a forest on an land which has been forested before, but on which the forest has disappeared, using seedlings, vegetative materials or seeds (sowing) Mohammed Ellatifi, m.ellatifi@ellatifi.8m.com"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Morocco" ;
    skos:prefLabel "Reforestation Arabic"@en .

ex:ReforestationArabic_2 a skos:Concept ;
    dct:spatial "Yemen" ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "Reforestation (Arabic : I’adat tashjeer/tahreej, French : Reboisement) - Artificial creation (by man) of a forest on an land which has been forested before, but on which the forest has disappeared, using seedlings, vegetative materials or seeds (sowing) Mohammed Ellatifi, m.ellatifi@ellatifi.8m.com"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Yemen" ;
    skos:prefLabel "Reforestation Arabic"@en .

ex:Reforestation_1 a skos:Concept ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "Reforestation is sorted by restoration of land cover and land cover and use. Several specified the planting of \"crops.\""@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_10 a skos:Concept ;
    dct:source "http://nrcan.gc.ca/cfs/proj/ppiab/sof/sof.html"^^xsd:anyURI ;
    dct:spatial "Canada" ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "The reestablishment of trees on denuded forest land by natural or artificial means, such as planting or seeding. State of Canada's Forests 1996-97"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Canada" ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_100 a skos:Concept ;
    dct:creator "Setiadi" ;
    dct:date "1996"^^xsd:gYear ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "When revegetation is established within the forest areas . Lorenzo Ciccarese ciccarese@anpa.it"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Setiadi 1996" ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_101 a skos:Concept ;
    dct:creator "Bolivia" ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "REFORESTACIÓN: Tala de un bosque con el propósito de crear tierra arable, para usos agrícolas o ganaderos y aprovechar la madera para la construcción o propósitos industriales. Este proceso elimina los árboles y el sotobosque, alterando todo el ecosistema, con la consecuente perdida de humus del suelo, con las consecuencias de escorrentia superficial por la baja infiltración, perdida de animales y plantas útiles al hombre, y la inestabilidad de las cuencas hidrográficas. A causa de la deforestación no solo se modifica el régimen hidrológico, sino se pueden dar cambios del microclima y extensos daños aguas abajo, por erosión hídrica de la cuenca, así como modificaciones substanciales en la sedimentación estuarina. Source: Luis Castello faopaf@caoba.entelnet.bo Adjunto sírvase encontrar la versión no oficial y premilinar del Glosario Forestal elaborado por el Proyecto de Apoyo a la Coordinación e Implementación del Plan de Acción Forestal para Bolivia"@es ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Bolivia" ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_102 a skos:Concept ;
    dct:spatial "India" ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "Bringing any deforested land under forest cover. [Source: Glossary of Technical Terms, Forest Research Institute, India. From: \"Vivek K. Varma\" <v.varma@landfood.unimelb.edu.au Date: Fri, 17 Jul 1998 02:28:29 -0400 (EDT)]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "India" ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_103 a skos:Concept ;
    dct:spatial "Latvia" ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "A complex of measures to afforest land (area) not covered by forest. Source: \"Maksym Polyakov\" <mpoliak@pcomp.nauu.kiev.ua"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Latvia" ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_104 a skos:Concept ;
    dct:spatial "Thailand" ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "The planting of forests on lands which have historically contained forests but which have since been converted to some other use. The report of Thailand's National Greenhouse Gas Inventory, 1990. \"Wilailak Pangtawaong\" wpangtaw@deqp.go.th"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Thailand" ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_106 a skos:Concept ;
    dct:creator "USA-STATE-Illinois" ;
    dct:source "http://dnr.state.il.us/legal/1537.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "\"Reforestation\" means the natural or artificial restocking with trees on forest land"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Illinois" ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_107 a skos:Concept ;
    dct:creator "or other number to be chosen" ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "Establishing forests on lands which have, historically, previously contained forests but which have been converted to some other use. This \"other use\" must have prevailed for at least 20 years, or, alternatively, the \"other use\" can be shorter if the land has been counted as \"deforested\" within a commitment period under the Kyoto Protocol (Schlamadinger 1998"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "or other number to be chosen" ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_109 a skos:Concept ;
    dct:source "http://epdweb.engr.wisc.edu/dmc/courses/hazards/BB02-apx1.html"^^xsd:anyURI ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "The establishment of a tree crop on forest land following deforestation"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_11 a skos:Concept ;
    dct:spatial "Chile" ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "La acción de poblar con especies arbóreas o arbustivas mediante plantación, regeneración manejada o siembra, un terreno que haya sido objeto de explotación extractiva (Cerda 1998"@es ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Chile" ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_110 a skos:Concept ;
    dct:source "http://www.harcourt.com/dictionary/def/8/5/7/2/8572900.html"^^xsd:anyURI ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "The reestablishment and development of a timber crop on forest land. Also, REAFFORESTATION"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_111 a skos:Concept ;
    dct:source "http://www.deltaenviro.org.za/resources/envirofacts/afforestation.html"^^xsd:anyURI ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "The restocking of existing forests and woodlands which have been depleted. Source"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_12 a skos:Concept ;
    dct:spatial "Colombia" ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "Es el establecimiento de árboles para formar bosques, realizado por el hombre. (Decreto 1791 de 1996. Ministerio del medio Ambiente.) \"Gerardo Lozano\" glozano@impsat.net.co and María del Pilar Pardo mpp@LatinMail.com"@es ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Colombia" ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_13 a skos:Concept ;
    dct:spatial "Cuba" ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "Reforestación: la acción de poblar con especies arbóreas áreas que hayan sido objeto de aprovechamiento previos o arrasadas por incendios y otras causas. Christoph Kleinn <ckleinn@catie.ac.cr"@es ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Cuba" ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_14 a skos:Concept ;
    dct:spatial "Cyprus" ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "Reforestation: the establishment of a forest cover in an area where there was a forest before but due to some reasons (fire, felling etc.) has been removed. A.K. Christou \"Forestry Department - Research and Publicity Sector\" publicity@cytanet.com.cy"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Cyprus" ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_15 a skos:Concept ;
    dct:spatial "Denmark" ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "Reforestation forests with a forest-obligation written in the cadastre must be reforested, if not deforestation takes place and that is forbidden without permission from the national forest-authorities. A forest obligation states that the area in principle shall be used for forests purposes forever (so-called 'good and sustainable forestry'). If the owner can give the forest authorities a very good reason - for instance the soil is not suited for forestry - he can have permission to raise the cadastre-note, but normally he shall find another agriculture land of a bigger size to plant with forest, for instance a double size. (From: PMP@sns.dk Date: Tue, 29 Sep 1998 09:31:59 +0100"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Denmark" ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_18 a skos:Concept ;
    dct:spatial "Fiji" ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "Areas where trees have been felled and replanted. Malakai Sevudredre, Conservator of Forests, F.9641/2. 01/06/2000"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Fiji" ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_19 a skos:Concept ;
    dct:spatial "Ghana" ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "When a degraded or removed forest land is restored to its original forest status. (Osei Kofi, Forestry Dept.- Letter 7 May 99"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Ghana" ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_2 a skos:Concept ;
    dct:creator "NSW" ;
    dct:source "http://www.forest.nsw.gov.au/education/glossary/default.asp#Ltr_W"^^xsd:anyURI ;
    dct:spatial "Australia" ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "Replanting of a forest on cleared or destroyed forest areas"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Australia-NSW" ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_20 a skos:Concept ;
    dct:creator "GM/UNCCD" ;
    dct:date "2008"^^xsd:gYear ;
    dct:source "http://www.global-mechanism.org/dynamic/documents/document_file/final2-viet-nam-climate-change-report---1july08.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "This process increases the capacity of the land to sequester carbon by replanting forest biomass in areas where forests have been previously harvested. Registration: The formal acceptance by the CDM Executive Board of a validated project as a CDM project activity"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "GM/UNCCD 2008" ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_21 a skos:Concept ;
    dct:date "2002"^^xsd:gYear ;
    dct:source "http://www.globalforestwatch.org/common/indonesia/sof.indonesia.english.low.pdf"^^xsd:anyURI ;
    dct:spatial "Indonesia" ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "The establishment by humans of forest cover on land that was formerly forested"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Indonesia - 2002" ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_23 a skos:Concept ;
    dct:date "1999"^^xsd:gYear ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "Kyrgyzstan - New Forest Code ) - The installation of forest plantations on areas previously covered by forest. Source: Irina Yunusova irina@lesic.elcat.kg"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "1999" ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_24 a skos:Concept ;
    dct:spatial "Kyrgyzstan" ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "An active (with human support) form of afforestation on the territories formerly covered with the forest (lands) Source: Irina Yunusova irina@lesic.elcat.kg"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Kyrgyzstan" ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_25 a skos:Concept ;
    dct:spatial "Kyrgyzstan" ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "from Russian it is likely to be translated as \"forest regeneration\") - The process of the creation of the forest generation under the forest cover, at the fellings and forest fires sites, and other areas formerly covered with the forest. Forest regeneration can be natural, artificial and mixed. Source: Irina Yunusova irina@lesic.elcat.kg"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Kyrgyzstan" ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_26 a skos:Concept ;
    dct:spatial "Lithuania" ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "The reestablishment of forest cover on forest land either naturally or artificially. Source: A. Kuliesis, Director of Lithuanain Forest Inventory and Management Institute Email: Sekrtetore sek@mp.is.lt"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Lithuania" ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_27 a skos:Concept ;
    dct:spatial "Malaysia" ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "The artificial establishment of forests by direct seeding or planting seedlings or cuttings on lands which previously (within the living memory or within 50 years) carry forests. From: hcthang@forestry.gov.my (Thang Hooi Chiew), Forestry Department Peninsular Malaysia"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Malaysia" ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_28 a skos:Concept ;
    dct:spatial "Northern Mariana Islands" ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "A science and art of establishing a multistorey species of trees beneficial to mankind, wildlife and ecosystem. Source: Estanislao Villagomez stanvill@gtepacifica.net Division of Agriculture"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Northern Mariana Islands" ;
    skos:prefLabel "Reforestation"@en .

ex:Reforestation_29 a skos:Concept ;
    dct:spatial "Pakistan" ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "To restock felled or otherwise cleared woodland. Definition adopted from the British Commonwealth Forest Terminology Part-I, 1953. Source: Mumtaz Ahmad, Section Forest Officer, Pakistan Min. of Environment, Local Government, and Rural Development"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Pakistan" ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_3 a skos:Concept ;
    dct:spatial "Austria" ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "Wiederbewaldung): Reforestation areas are temporarily unstocked areas caused by harvesting, wind breaks, natural disasters and so on. These areas have to be reforested artificially (usually within 3 years, under certain circumstances within maximal 8 years) or with methods of natural regeneration (usually within 8 years, under certain circumstances within maximal 11 years). In Austria reforestation has always been recognized as a part of forest management and has never been linked up to land use change. (Austrian Forestry Act (Federal Legal Gazette no. 440/1975, as amended Federal Legal Gazette 231/1977, 142/1978 and 576/1987) From: Weiss Peter weissp@ubavie.gv.at"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Austria" ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_30 a skos:Concept ;
    dct:spatial "Paraguay" ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "Reforestación: La acción de poblar con especies arbóreas mediante plantación, regeneración manejada o siembra, un terreno anteriormente boscoso que haya sido objeto de explotación extractiva. Ley N&deg; 536 - DE FOMENTO A LA FORESTACION Y REFORESTACION. Capítulo I. Artículo 2do. cdcdpnvs@venus.pla.net.py (Nombre Apellido"@es ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Paraguay" ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_31 a skos:Concept ;
    dct:source "http://www.nscb.gov.ph/ru12/DEFINE/DEF-ENV.HTM"^^xsd:anyURI ;
    dct:spatial "Philippines" ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "the act of planting trees on bare or open land which is used to be covered with forest growth"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Philippines" ;
    skos:prefLabel "Reforestation"@en .

ex:Reforestation_32 a skos:Concept ;
    dct:spatial "Oman" ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "The act of installation, through artificial methods, of the forest vegetation on lands where forest was recently removed. Sorin Sfirlogea <sorinsf@rosilva.ro National Forests Administration"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Romania" ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_33 a skos:Concept ;
    dct:spatial "Russian Federation" ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "Process of establishing of forest cultures on before forested areas. (Forest cultures (specific Russian term) - forest, which was created by seeding or planting). [From: \"Igor Yakovlev\" yakovlev@mari-el.ru Date: Wed, 10 Jun 1998 02:51:19 -0400 (EDT)]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Russian Federation" ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_34 a skos:Concept ;
    dct:creator "St. Lucia" ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "The planting of forest trees in an area where forest existed before (Source: Michael Andrew, chiefforest@maffe.org"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "St. Lucia" ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_35 a skos:Concept ;
    dct:creator "Taiwan, ROC" ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "To reforest in cut-over areas. Source: \"&ordf;L&deg;È&sect;&frac12;service\" service@dns.forest.gov.tw"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Taiwan, ROC" ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_36 a skos:Concept ;
    dct:creator "UN-DP" ;
    dct:date "1999"^^xsd:gYear ;
    dct:source "http://www.profor.info/pdf/InnovatForesFinanc.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "Generally refers to planting trees on land that has been cleared of forest within the relatively recent past. May or may not refer to planting trees on land that has just been harvested"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-DP 1999" ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_4 a skos:Concept ;
    dct:spatial "Brazil" ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "REFLORESTAMENTO always, no matter the previous land use was not a forest and it is the first time this land bears a forest. Currently, reforestation (REFLORESTAMENTO) is the general name of planted forests. From: Erich Schaitza <erich@cnpf.embrapa.br"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Brazil" ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_43 a skos:Concept ;
    dct:spatial "United Kingdom" ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "Re-establishment of a tree crop on forest land (British Commonwealth Terminology) (Ford-Robertson 1971"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "United Kingdom" ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_44 a skos:Concept ;
    dct:creator "USA –STATE- Maryland" ;
    dct:source "http://pilot.wash.lib.md.us/washco/forestcn.html"^^xsd:anyURI ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "The creation of a biological community dominated by trees and other woody plants containing at least 100 live trees per acre with at least 50 percent of those trees having the potential of attaining a 2-inch or greater diameter measured at 4.5 feet above the ground, within 7 years, according to procedures set forth in the Washington County Forest Conservation Technical Manual. The term also includes landscaping of areas under an approved landscaping plan establishing a forest at least 35 feet wide and covering 2500 square feet or more of area"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA –STATE- Maryland" ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_45 a skos:Concept ;
    dct:creator "USA-EIA" ;
    dct:source "http://www.eia.gov/tools/glossary/index.cfm?id=R"^^xsd:anyURI ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "Replanting of forests on lands that have recently been harvested or otherwise cleared of trees"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-EIA" ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_47 a skos:Concept ;
    dct:creator "USA-STATE-Oregon" ;
    dct:source "http://www.cof.orst.edu/cof/teach/for442/odfdefin.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "\"Natural reforestation\" means restocking a site with self-grown trees resulting from self-seeding or vegetative means"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Oregon" ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_48 a skos:Concept ;
    dct:creator "Venezuela" ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "REFORESTACION: cultivo de árboles, con fines económicos o con fines de protección en áreas donde ya habían existido vegetacón en épocas pasadas. Reglamento de la Ley Forestal de Suelos y Aguas (1977). Areas Naturales Protegidas de Venezuela. Series Aspectos Conceptuales y Metodológicos, DGSPOA/ACM/01, feb 1992. Via Profauna@marnr.gov.ve"@es ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Venezuela" ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_49 a skos:Concept ;
    dct:creator "WAF" ;
    dct:date "2004"^^xsd:gYear ;
    dct:source "http://www.worldagroforestry.org/sea/Publications/files/book/BK0073-04.PDF"^^xsd:anyURI ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "The establishment of forest on land previously under a forest land-use"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "WAF 2004" ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_5 a skos:Concept ;
    dct:spatial "Bulgaria" ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "there is no special definition for \"reforestation\". It is part of the afforestation activities. Forest Research Institute forestin@bulnet.bg"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Bulgaria" ;
    skos:prefLabel "Reforestation"@en .

ex:Reforestation_53 a skos:Concept ;
    dct:source "http://ifdn.com/teacher/glossary.htm#d"^^xsd:anyURI ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "A process by which a forest regrown"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_54 a skos:Concept ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "A sylvicultural system that consists in seeding or planting tree forest stock in a forest area after felling or when species are unreliable for natural regeneration. Lorenzo Ciccarese ciccarese@anpa.it"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_55 a skos:Concept ;
    dct:creator "planting, seeding" ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "Artificial or natural re-establishment of forest on previously forest or other wooded land. [Source: UN/ECE 1990, via Brita Pajari]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "planting, seeding" ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_56 a skos:Concept ;
    dct:source "http://www.gcrio.org/OnLnDoc/senate_epw990603.html"^^xsd:anyURI ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "Conversion of non-forest to forest on lands which had, historically, contained forests but which had been converted to some other use as of 1990"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_57 a skos:Concept ;
    dct:source "http://www.abforestprod.org/ARglossary.html"^^xsd:anyURI ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "Establishment of a replacement stand of trees after harvesting operations are complete, based on scientific silvicultural practices that may include natural seeding or suckering, mechanical seeding or planting of seedlings"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_58 a skos:Concept ;
    dct:source "http://www.grida.no/climate/ipcc/tectran/362.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "Forest stands established artificially on lands that have supported forests within the last 50 years"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_59 a skos:Concept ;
    dct:source "http://www.climateservices.com/glossary.htm"^^xsd:anyURI,
        "http://www.undp.org/seed/forest/pdf/InnovatForesFinanc.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "Generally refers to planting trees on land that has been cleared of forest within the relatively recent past. May or may not refer to planting trees on land that has just been harvested. . and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_6 a skos:Concept ;
    dct:creator "BC" ;
    dct:source "http://www.for.gov.bc.ca/pab/publctns/westland/gloss.htm"^^xsd:anyURI ;
    dct:spatial "Canada" ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "Regeneration (reforestation): The renewal of a tree crop either by natural means (seeded on-site from adjacent stands or deposited by wind, birds, or animals) or by planted seedlings or direct seeding"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Canada - BC" ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_60 a skos:Concept ;
    dct:source "http://www.oxfam.org.uk/coolplanet/glossary.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "Planting trees to replace forests which have been harvested or destroyed"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_61 a skos:Concept ;
    dct:source "http://fiesta.bren.ucsb.edu/~idgec/publications/reports/forest.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "Process of re-establishing forests on previously forested lands"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_62 a skos:Concept ;
    dct:creator "replanting" ;
    dct:source "http://www.notredame.ac.jp/cgi-bin/wn?reforestation"^^xsd:anyURI ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "Re-afforestation -- (the restoration of a forest that had been reduced by fire or cutting"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "replanting" ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_63 a skos:Concept ;
    dct:source "http://www.deltaenviro.org.za/resources/envirofacts/afforestation.html"^^xsd:anyURI ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "Reafforestation - is the restocking of existing forests and woodlands which have been depleted"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_64 a skos:Concept ;
    dct:source "http://education.vsnl.com/deep/"^^xsd:anyURI ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "Reafforestation - The planting of trees on land that was previously under the forest cover, but which has been depleted by habitat destruction or over-exploitation"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_65 a skos:Concept ;
    dct:source "http://msucares.com/pubs/pub1250.htm"^^xsd:anyURI,
        "http://www.ces.ncsu.edu/nreos/forest/woodland/won-26r.html"^^xsd:anyURI ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "Reestablishing a forest by planting or seeding an area from which forest vegetation has been removed. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_66 a skos:Concept ;
    dct:source "http://www.mrsc.org/environment/forest/glossary.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "Reestablishing a forest in an area where trees have been removed"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_67 a skos:Concept ;
    dct:creator "less than 10 years" ;
    dct:source "http://greenplanet.eolss.net/EolssLogn/mss/C10/E5-03/E5-03-01/E5-03-01-05/E5-03-01-05-TXT.aspx#Glossary"^^xsd:anyURI ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "Reestablishment of forest formation after a temporary period with less than 10% canopy cover due to human induced or natural perturbations"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "less than 10 years" ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_68 a skos:Concept ;
    dct:source "http://www.bugwood.caes.uga.edu/glossary/"^^xsd:anyURI ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "Replacing forests after felling"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_69 a skos:Concept ;
    dct:source "http://www.oznet.ksu.edu/library/MISC2/SB661.PDF"^^xsd:anyURI ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "Replacing forests"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_7 a skos:Concept ;
    dct:creator "BC" ;
    dct:source "http://www.for.gov.bc.ca/pab/publctns/glossary/glossary.htm"^^xsd:anyURI ;
    dct:spatial "Canada" ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "The natural or artificial restocking (i.e., planting, seeding) of an area with forest trees. Also called forest regeneration. [Source: Glossary of Forestry Terms, Province of British Columbia, Ministry of Forests, via Igor A. Yakovlev]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Canada - BC" ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_70 a skos:Concept ;
    dct:source "http://www.eia.doe.gov/oiaf/1605/ggrpt/glossary.html"^^xsd:anyURI ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "Replanting of forests on lands that have recently been harvested or otherwise cleared of trees"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_71 a skos:Concept ;
    dct:source "http://www.eia.doe.gov/oiaf/1605/vr95rpt/gloss.html"^^xsd:anyURI,
        "http://www.epa.gov/globalwarming/publications/outreach/general/glossary.pdf"^^xsd:anyURI,
        "http://www.theadvisorygroup.com/PDF2/publications/Carbon%20Sequestration%20Paper.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "Replanting of forests on lands that have recently been harvested. , and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_72 a skos:Concept ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "Restocking an area with forest trees. [Source: Timber Harvesting and Engineering Glossary, USFS]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_74 a skos:Concept ;
    dct:source "http://www.plant-a-tree-today.org/webcontrol/ShowPicture.asp?Status=ShowLibraryPDF&LiId=40"^^xsd:anyURI ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "Revegetation - Re-establishment of non-forest vegetation and restoration of degraded non-forested lands, such as overgrazed native grasslands or cultivated wetlands"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_75 a skos:Concept ;
    dct:source "http://www.nscb.gov.ph/ru12/DEFINE/DEF-ENV.HTM"^^xsd:anyURI ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "The act of planting trees on bare or open land which is used to be covered with forest growth"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_76 a skos:Concept ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "The act of renewing forest cover by planting seeds or young trees. [Source: WWWebster Dictionary]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_77 a skos:Concept ;
    dct:source "http://www.idahoforests.org/dict1.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "The act of replanting or reseeding a forest area to replace trees removed by harvest or destroyed by fire, wind or disease"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_78 a skos:Concept ;
    dct:source "http://www.ci.rockville.md.us/cityprojects/envguide/eggloss.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "The creation of a biological community dominated by trees and other woody plants containing at least 100 trees per acre, with at least 50 percent of those trees having the potential of attaining a 2-inch or greater dbh within seven years"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_79 a skos:Concept ;
    dct:source "http://www.plant-a-tree-today.org/webcontrol/ShowPicture.asp?Status=ShowLibraryPDF&LiId=40"^^xsd:anyURI ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "The direct human-induced conversion of non-forested land back to forested land. In the context of the Kyoto Protocol to the UNFCCC, reforestation can take place on land that was historically forested but as of December 31, 1989 was subject to another land-use"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_8 a skos:Concept ;
    dct:creator "Sask" ;
    dct:source "http://www.studyweb.com/Agriculture/"^^xsd:anyURI ;
    dct:spatial "Canada" ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "The natural or artificial restocking of an area with trees. [Source: Chapter F-19.1: An Act Respecting the Management of Forest Resources... new provincial legislation on forest management From: Mark Johnston <johnston@larix.derm.gov.sk.ca Date: Tue, 16 Jun 1998 17:44:48 -0600] also"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Canada - Sask." ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_80 a skos:Concept ;
    dct:source "http://greenplanet.eolss.net/EolssLogn/mss/C09/E4-27/E4-27-08/E4-27-08-04/E4-27-08-04-TXT.aspx#Glossary_"^^xsd:anyURI ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "The establishment of forest in an area where there was forest during the previous 50 years"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_81 a skos:Concept ;
    dct:creator "Brown et al" ;
    dct:date "1986"^^xsd:gYear ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "The establishment of plantations] to produce a forest product \"crop\" on lands that have supported forests within the last 50 years and where the original crop has been replaced with a different one"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Brown et al. 1986" ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_82 a skos:Concept ;
    dct:creator "Dunster and Dunster" ;
    dct:date "1996"^^xsd:gYear ;
    dct:source "http://www.sfrc.ufl.edu/Class/for3162c/silvterm.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "The natural or artificial restocking of an area with forest trees. . Typically, refers to planting"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Dunster and Dunster 1996" ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_83 a skos:Concept ;
    dct:source "http://www.lehigh.edu/~kaf3/books/reporting/glossary.html"^^xsd:anyURI ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "The natural or artificial restocking of an area with forest trees, most commonly used in reference to the artificial. The Art and Science of Sustainable Use. 1997"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_84 a skos:Concept ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "The natural or artificial restocking of an area with trees. www.superiornationalforest.org/july4thstorm1999/Appendix%20B.doc"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_85 a skos:Concept ;
    dct:source "http://www.woodrow.org/teachers/biology/institutes/1992/old_growth.html"^^xsd:anyURI ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "The planting of trees for re-establishment of a former forest"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_86 a skos:Concept ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "The planting of trees on land from which the forest has been removed. [Source: Water Words Dictionary]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_87 a skos:Concept ;
    dct:source "http://www.minntrees.org/facts/ff17.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "The planting of young trees in forests that have been affected by harvest, fire, disease, wind or other factors"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_88 a skos:Concept ;
    dct:source "http://www.rfa.gov.au/cra/vic/cenhigh/press/glossary.html"^^xsd:anyURI ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "The re-establishment of a stand of trees by planting or sowing with species native to the locality on previously cleared or poorly forested land"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_89 a skos:Concept ;
    dct:creator "by natural seeding, coppice, or root suckers" ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "The reestablishment of forest cover either naturally or artificially (by direct seeding or planting). Note - reforestation usually maintains the same forest type and is done promptly after the previous stand or forest was removed (Helms 1998"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "by natural seeding, coppice, or root suckers" ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_9 a skos:Concept ;
    dct:source "http://carbon.cfs.nrcan.gc.ca/definitions_e.html"^^xsd:anyURI ;
    dct:spatial "Canada" ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "The conversion of non-forested land to forested land through human activities, on land that was forested but that had been converted to non-forested land"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Canada" ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_90 a skos:Concept ;
    dct:source "http://assets.panda.org/downloads/lowermekongregionaloverview.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "The re-establishment of trees and understorey plants at a site previously occupied by forest cover"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_91 a skos:Concept ;
    dct:source "http://www.vanaturally.com/glossary.html"^^xsd:anyURI ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "The renewal of forest cover by natural regeneration or the planting of seeds or seedlings"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_92 a skos:Concept ;
    dct:source "http://ohia.com/ohia/roadshows/sky/glossary.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "The renewal of forest cover by seeding or planting"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_93 a skos:Concept ;
    dct:source "http://www.nap.edu/openbook.php?record_id=1985&page=671"^^xsd:anyURI,
        "http://www.wrm.org.uy/actors/WB/1991policy3.htm"^^xsd:anyURI,
        "https://www.uni-hohenheim.de/i490a/teaching/M4901-430/ws_03_04/reading_materials/New_Neef_Schwarzmeier_Studie.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "The replacement of trees in cut-over forest areas. , and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_94 a skos:Concept ;
    dct:source "http://buttecreekwatershed.org/ecr/new/glossary.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "The replanting of trees in an area that was previously forested"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_95 a skos:Concept ;
    dct:source "http://www.soton.ac.uk/~engenvir/glossary.html#D"^^xsd:anyURI ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "The replanting of trees in areas which have been cleared of woodland"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_96 a skos:Concept ;
    dct:source "http://solstice.crest.org/renewables/SJ/glossary/A.html#AFFORESTATION"^^xsd:anyURI ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "The replanting of trees on previously forested lands"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_97 a skos:Concept ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "The restocking of felled or otherwise cleared woodland. [Source: British Commonwealth Forest Terminology via Renate Prüller]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_98 a skos:Concept ;
    dct:source "http://greenplanet.eolss.net/EolssLogn/mss/C09/E4-27/E4-27-08/E4-27-08-05/E4-27-08-05-TXT.aspx#Glossary_"^^xsd:anyURI ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "To re-establish tree cover on a once-forested site"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "REFORESTATION"@de .

ex:Reforestation_99 a skos:Concept ;
    dct:source "http://www.timbertax.org/research/aghndbk/glossary.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "To reestablish trees on a harvested area by planting trees, setting tree seeds, seeding-in from adjacent trees, or sprouts from the stumps or roots of harvested trees"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "REFORESTATION"@de .

ex:Regeneration_1 a skos:Concept ;
    skos:broadMatch ex:Regeneration ;
    skos:definition "Regenreation is grouped by natural methods and by any method. All implied the restoration of land cover. Some specified the establishment of \"crops.\""@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "REGENERATION"@de .

ex:Regeneration_10 a skos:Concept ;
    dct:creator "noun" ;
    dct:source "http://www.rfa.gov.au/cra/vic/cenhigh/press/glossary.html"^^xsd:anyURI ;
    skos:broadMatch ex:Regeneration ;
    skos:definition "The young regrowth of forest plants following disturbance or the forest such as timber harvesting or fire"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "noun" ;
    skos:prefLabel "REGENERATION"@de .

ex:Regeneration_11 a skos:Concept ;
    dct:source "http://www.forestry.gov.uk/standard.html"^^xsd:anyURI,
        "http://www.forestry.gov.uk/standard.pdf"^^xsd:anyURI ;
    dct:spatial "United Kingdom" ;
    skos:broadMatch ex:Regeneration ;
    skos:definition "Renewal of woodland through sowing, planting, or natural regeneration. [Source: THE UK FORESTRY STANDARD. The Government's Approach to Sustainable Forestry, EDINBURGH: FORESTRY COMMISSION, 1998 and From: \"Maksym Polyakov\" <mpoliak@pcomp.usau.kiev.ua Date: Tue, 23 Jun 1998 21:04:18 +0300 (MSD)]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "United Kingdom" ;
    skos:prefLabel "REGENERATION"@de .

ex:Regeneration_12 a skos:Concept ;
    skos:broadMatch ex:Regeneration ;
    skos:definition "An act or the process of regenerating : the state of being regenerated [Source WWWebster 11 June 1998]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "REGENERATION"@de .

ex:Regeneration_13 a skos:Concept ;
    dct:creator "performed through seeding or planting" ;
    skos:broadMatch ex:Regeneration ;
    skos:definition "Establishment and early development of new tree seedlings. In managed forests, regeneration may be natural or artificial (WESTVACO"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "performed through seeding or planting." ;
    skos:prefLabel "REGENERATION"@de .

ex:Regeneration_14 a skos:Concept ;
    dct:creator "regrowth" ;
    dct:source "http://nrcan.gc.ca/cfs/proj/iepb/nfdp/regen/regen_e/s18.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Regeneration ;
    skos:definition "Renewal of a forest crop by natural, artificial or vegetative means. Also the new crop so obtained. The new crop is generally less than 1.3 m high"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "regrowth" ;
    skos:prefLabel "REGENERATION"@de .

ex:Regeneration_15 a skos:Concept ;
    dct:creator "17" ;
    dct:source "http://rredc.nrel.gov/biomass/forest/tim_glossary/t_glossary.html#F"^^xsd:anyURI ;
    skos:broadMatch ex:Regeneration ;
    skos:definition "Renewal of a tree crop, either by natural or artificial means. -Young tree crop"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "17" ;
    skos:prefLabel "REGENERATION"@de .

ex:Regeneration_16 a skos:Concept ;
    dct:creator "http://www.fs.fed.us/land/emterms.html" ;
    dct:source "http://www.fs.fed.us/land/emterms.html"^^xsd:anyURI ;
    skos:broadMatch ex:Regeneration ;
    skos:definition "The renewal of a tree crop by either natural or artificial means. The term is also used to refer to the young crop itself"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "http://www.fs.fed.us/land/emterms.html" ;
    skos:prefLabel "REGENERATION"@de .

ex:Regeneration_17 a skos:Concept ;
    dct:creator "seeded on-site from adjacent stands or deposited by wind, birds or animals" ;
    dct:source "http://www.interfor.com/glossary/glossary29.html"^^xsd:anyURI ;
    skos:broadMatch ex:Regeneration ;
    skos:definition "The renewal of a tree crop through either natural means or artificial means (by planting seedlings or direct seeding"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "seeded on-site from adjacent stands or deposited by wind, birds or animals" ;
    skos:prefLabel "REGENERATION"@de .

ex:Regeneration_2 a skos:Concept ;
    dct:creator "Natural" ;
    skos:broadMatch ex:Regeneration ;
    skos:definition "Areas that become forested through the ordinary process of forest succession (e.g. occupation of abandoned farm lands or lands laid bare by recent glaciation). Also where forest is being regenerated to the same or similar species as removed from the site. Brinkley 1997"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Natural" ;
    skos:prefLabel "REGENERATION"@de .

ex:Regeneration_3 a skos:Concept ;
    dct:creator "Natural" ;
    skos:broadMatch ex:Regeneration ;
    skos:definition "Regrowth of forest vegetation, in the absence of planting or direct seeding, following any of many kinds of disturbances that were lethal to forest vegetation (e.g. landslide, fire, pest damage, wind, logging, clearing for agriculture) previously growing on the site. Stanley 1998"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Natural" ;
    skos:prefLabel "REGENERATION"@de .

ex:Regeneration_4 a skos:Concept ;
    dct:creator "without special seeding or planting" ;
    skos:broadMatch ex:Regeneration ;
    skos:definition "All types of natural recovering of forest vegetation on forest lands , the natural one (seeds or coppice) or with the help of men by means of different types of forest activities such as scarification, stripes or gap cuttings, etc. (Yakovlev 1998"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "without special seeding or planting" ;
    skos:prefLabel "REGENERATION"@de .

ex:Regeneration_5 a skos:Concept ;
    dct:creator "in word-by-word translation" ;
    skos:broadMatch ex:Regeneration ;
    skos:definition "Process of formation of new generation of forest by natural way (Yakovlev 1998"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "in word-by-word translation" ;
    skos:prefLabel "REGENERATION"@de .

ex:Regeneration_6 a skos:Concept ;
    dct:creator "Sask" ;
    dct:spatial "Canada" ;
    skos:broadMatch ex:Regeneration ;
    skos:definition "Renewal of a forest stand (i.e. establishment of new young trees) by natural or artificial means. [Source: the Saskatchewan Long-term Integrated Forest Resource Management Plan March 1995 From: Mark Johnston <johnston@larix.derm.gov.sk.ca Date: Tue, 16 Jun 1998 17:44:48 -0600]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Canada - Sask." ;
    skos:prefLabel "REGENERATION"@de .

ex:Regeneration_7 a skos:Concept ;
    dct:source "http://nrcan.gc.ca/cfs/proj/ppiab/sof/sof.html"^^xsd:anyURI ;
    dct:spatial "Canada" ;
    skos:broadMatch ex:Regeneration ;
    skos:definition "The continuous renewal of a forest stand. Natural regeneration occurs gradually with seeds from adjacent stands or with seeds brought in by wind, birds, or animals. Artificial regeneration involves direct seeding or planting"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Canada" ;
    skos:prefLabel "REGENERATION"@de .

ex:Regeneration_8 a skos:Concept ;
    dct:creator "Czech Republic" ;
    skos:broadMatch ex:Regeneration ;
    skos:definition "A set of measures resulting in the development of a new generation of forest stand. [Source: Act on Forests and Amendments to Some Acts (the Forest Act) dated 3 November 1995. Ministry of Agriculture of the Czech Republic. Prague, 1996. 58 pp. From: \"Maksym Polyakov\" <mpoliak@pcomp.usau.kiev.ua Date: Mon, 15 Jun 1998 11:32:47 +0300 (MSD)]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Czech Republic" ;
    skos:prefLabel "REGENERATION"@de .

ex:Regeneration_9 a skos:Concept ;
    dct:spatial "Japan" ;
    skos:broadMatch ex:Regeneration ;
    skos:definition "Forest stands established following harvesting artificially or naturally. Definition of Glossary of Agriculture, Forestry and Fishery Statistics, Agriculture and Forestry Statistics Association. From: Masahiro Amano <masahiro@ss.ffpri.affrc.go.jp"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Japan" ;
    skos:prefLabel "REGENERATION"@de .

ex:RicostituzioneBoschiva_1 a skos:Concept ;
    dct:spatial "Italy" ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "A forest activity aimed to restore or improve the forest tree and shrub cover through seeding, planting and 'regeneration coppicing' (in Italian riceppatura, which is a coppicing method for regenerating stumps, for example, after fire). (ISTAT) 'Rimboschimento' (reforestation), also for ex-novo planting in bare lands.From: Vittorio Tosi ISAFA Biometria isafa.biofor@tqs.it and Lorenzo Ciccarese ciccarese@anpa.it"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Italy" ;
    skos:prefLabel "ricostituzione boschiva"@it .

ex:Rimboschimento_1 a skos:Concept ;
    dct:spatial "Italy" ;
    skos:broadMatch ex:Afforestation ;
    skos:definition "Outplanting forest stock on areas previously managed for other uses (agricultural lands, barren lands, etc.) (ISTAT). 'Imboschimento'(afforestation) is used very seldom. From: Vittorio Tosi ISAFA Biometria <isafa.biofor@tqs.it and Lorenzo Ciccarese ciccarese@anpa.it ISTAT (1950-1997). Statistiche Forestali. Annuari 1-47. Istituto Nazionale di Statistica. Rome"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Italy" ;
    skos:prefLabel "rimboschimento"@it .

ex:Rvore_1 a skos:Concept ;
    dct:creator "Cape Verde" ;
    dct:date "1998"^^xsd:gYear ;
    skos:broadMatch ex:Tree ;
    skos:definition "As árvores, os arbustos e as formações herbáceas, com excepção das cultivadas ou destinadas a fins agrícolas; LEX-FAOC013213. CAPE VERDE: Forestry Act (No. 48/V/98"@pt ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Cape Verde 1998" ;
    skos:prefLabel "Árvore"@sk .

