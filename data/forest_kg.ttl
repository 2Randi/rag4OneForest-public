ex:Forest_1036 a skos:Concept ;
    dct:creator "Venezuela" ;
    dct:date "1977"^^xsd:gYear ;
    skos:broadMatch ex:Forest ;
    skos:definition "AREAS BOSCOSAS: son espacios naturales compuestos por uno o más ecosistemas forestales que por sus característicaas ecológicas y masa arbórea predominante densa, son aptas para la producción permanente de bienes forestales (maderables y no maderables) y de servicios ambientales y sociales, cuyo manejo sustentable permita mantener los ciclos ecológicos y, por ende, la cubierta forestal. Reglamento de la Ley Forestal de Suelos y Aguas (1977). Areas Naturales Protegidas de Venezuela. Series Aspectos Conceptuales y Metodológicos, DGSPOA/ACM/01, feb 1992. Via Profauna@marnr.gov.ve"@es ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Venezuela 1977" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_1037 a skos:Concept ;
    dct:creator "Venezuela" ;
    dct:date "1977"^^xsd:gYear ;
    skos:broadMatch ex:Forest ;
    skos:definition "BOSQUE: Comunidad vegetal dominada por elementos típicamente arbóreos, que forman por lo menos un estrato de copas (dosel)más o menos contínuo, generalmente de 5 m de altura (2); espacio natural conformado por árboles, arbustos, hierbas,bacterias, hongos, protozoarios, artrópodos, otros invertebrados de todos los tamaños, clases y descripciones, vertebrados, oxígeno, dióxido de carbono, agua, minerales y materia orgánica muerta, que en su totalidad constituyen el ecosistema forestal. Reglamento de la Ley Forestal de Suelos y Aguas (1977). Areas Naturales Protegidas de Venezuela. Series Aspectos Conceptuales y Metodológicos, DGSPOA/ACM/01, feb 1992. Via Profauna@marnr.gov.ve"@es ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Venezuela 1977" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_1038 a skos:Concept ;
    dct:creator "Venezuela" ;
    dct:source "http://www.fao.org/forestry/fo/country/index.jsp?lang_id=1&geo_id=214"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Incluye bosques (formas arbóreas) de al menos 5 metros de altura"@es ;
