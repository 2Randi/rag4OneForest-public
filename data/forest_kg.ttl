    skos:broadMatch ex:Forest ;
    skos:definition "Use Min. Area (ha) = 0.1 Min. Crown Cover (%) = 15 Min. Tree Height (m) = 2 Min. Strip Width (m) = ns - Sasaki & Putz 2009"@en,
        "defines a forest as an area of land greater than 0.1 hectare, with more than 15% canopy cover and a minimum tree height of 2 metres"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Ghana 2006 KP",
        "Ghana 2009 KP" ;
    skos:prefLabel "Ghana UNFCCC"@en ;
    skos:scopeNote "National"@en,
        "potential"@en .

ex:HRVUnfccc_1 a skos:Concept ;
    ex:minAreaHa 0.1 ;
    ex:minCrownCoverPct 10.0 ;
    ex:minTreeHeightM 2.0 ;
    dct:creator "KP" ;
    dct:date "2008"^^xsd:gYear ;
    dct:source "http://books.google.com/books?id=iU6ctBak3-gC&pg=PA132&lpg=PA132&dq=Croatia++Forest++definition+define+%22forest+is%22+law&source=bl&ots=yvf2xQpJPr&sig=mQUVqbZLIEa6C88qGsh1mYS9UDY&hl=en&sa=X&ei=SoI6T_26K4Tg0QGAmoHFCw&ved=0CCMQ6AEwAA#v=onepage&q=Croatia%20%20Forest%20%20definition%20define%20%22forest%20is%22%20law&f=false"^^xsd:anyURI,
        "http://unfccc.int/files/meetings/ad_hoc_working_groups/kp/application/pdf/awgkp_croatia_2011.pdf"^^xsd:anyURI,
        "http://unfccc.int/files/national_reports/initial_reports_under_the_kyoto_protocol/application/pdf/27-08-08_initial_report_croatia.pdf"^^xsd:anyURI ;
    dct:spatial "Croatia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Min. Area (ha) = 0.1 Min. Crown Cover (%) = 10 Min. Tree Height (m) = 2 Min. Strip Width (m) = ns and"@en,
        "forest is land spanning more than 0.1 hectares with trees higher than 2 meters and canopy cover more than 10 percent, or trees able to reach these thresholds in situ"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Croatia 2008 KP",
        "Croatia KP" ;
    skos:prefLabel "Croatia UNFCCC"@en ;
    skos:scopeNote "National"@en,
        "declared"@en .

ex:IRLUnfccc_1 a skos:Concept ;
    ex:minAreaHa 0.1 ;
    ex:minCrownCoverPct 20.0 ;
    ex:minTreeHeightM 5.0 ;
    dct:creator "KP" ;
    dct:date "2006"^^xsd:gYear ;
    dct:source "http://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:32013D0529"^^xsd:anyURI,
        "http://unfccc.int/files/national_reports/initial_reports_under_the_kyoto_protocol/application/x-zip-compressed/fin_ir_report_22dec.zip"^^xsd:anyURI ;
    dct:spatial "Ireland" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Use Min. Area (ha) = 0.1 Min. Crown Cover (%) = 20 Min. Tree Height (m) = 5 Min. Strip Width (m) = ns . (2006).Young natural stands and all plantations that have yet to reach a crown density of 20 percent or a tree height of 5 metres are included under forest. Areas normally forming part of the forest area that are temporarily un-stocked as a result of human intervention, such as harvesting or natural causes such as wind-throw, but which are expected to revert to forest are also included"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Ireland 2006 KP" ;
    skos:prefLabel "Ireland UNFCCC"@en ;
    skos:scopeNote "Young natural stands and all plantations that have yet to reach a crown density of 20 percent or a tree height of 5 metres are included under forest. Areas normally forming part of the forest area that are temporarily un-stocked as a result of human intervention, such as harvesting or natural causes such as wind-throw, but which are expected to revert to forest are also included.",
        "National"@en,
        "use"@en .

