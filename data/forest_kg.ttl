    skos:note "Russia Khabarovsk Krai 1999" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "National"@en .

ex:Forest_1265 a skos:Concept ;
    dct:bibliographicCitation "Ref. Forest Code of the Russian Federation, adopted by the State Duma of the Russian Federation 22 January 1997, page 3, Moscow, 1997" ;
    dct:creator "Ecological" ;
    dct:date "1997"^^xsd:gYear ;
    dct:spatial "Russian Federation" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest is the aggregate of forest vegetation, land, fauna and other components of the natural environment that are of great ecological, economic and social importance"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Russian Federation 1997 Ecological" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
