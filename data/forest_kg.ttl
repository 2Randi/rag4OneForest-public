ex:Forest_191 a skos:Concept ;
    dct:creator "1" ;
    dct:source "http://www.fw.vt.edu/zedaker/3364/ecolterms.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "FOREST COVER: All trees and other plants occupying the ground in a forest, i.e. including any ground cover. NOTE: Is the silviculturist's crop viewed from the ecologist's angle. (2) All woody growth occupying the ground in a forest, as distinct from the ground cover NOTE: Is the silviculturist's forest crop viewed from the ecologist's angle. (3) A category of forest site, including all the interchangeable phases of vegetation that it supports, defined mainly by the general nature of the ground cover. NOTE: As originally developed by Cajander for Finland"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "1" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_192 a skos:Concept ;
    dct:source "http://www.clayoquot.org/glossary.htm#F"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest cover: forest stands or cover types consisting of a plant community made up of trees and other woody vegetation, growing more or less closely together"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_193 a skos:Concept ;
    dct:source "http://www.mckone.org/tfrrung.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest includes woodland and other similar vegetation formations"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_194 a skos:Concept ;
    dct:source "http://192.83.171.71/newcrons/navig/en/theme8/milieu/10fo/notmeth.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest land comprises the actual forests areas dominated by trees or shrubs capable of producing wood or other forest products. Minimum surface area is: 0,5 ha. Areas should be covered by forest trees for at least 20% measured as the vertical projection from the trees for a mature stand. Unstocked forest land includes areas which are not themselves productive but necessary for production"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_195 a skos:Concept ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest land currently stocked with trees. Encyclopedia Britannia 1970"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_196 a skos:Concept ;
    dct:source "http://www.geog.umd.edu/tropical/per80v141README"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest refers to primarily closed canopy humid tropical forest, and includes cloud forest"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_197 a skos:Concept ;
    dct:creator "perennial woody plants taller than five meters at maturity" ;
    dct:source "http://ma.caudillweb.com/proxy/Document.782.aspx"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest systems: Systems in which trees are the predominant life forms. Statistics reported in this assessment are based on areas that are dominated by trees , where the tree crown cover exceeds 10%, and where the area is more than 0.5 hectares. ‘‘Open forests’’ have a canopy cover between 10% and 40%, and ‘‘closed forests’’ a canopy cover of more than 40%. ‘‘Fragmented forests’’ refer to mosaics of forest patches and non-forest land"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "perennial woody plants taller than five meters at maturity" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_198 a skos:Concept ;
    dct:creator "leaf/branch" ;
    dct:source "http://www.esd.ornl.gov/projects/qen/veg.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "FOREST VEGETATION; more than 60% canopy cover above a level 8m off the ground A suggestion for an improved vegetation scheme for local and global mapping and monitoring. Jonathan M. Adams Submitted to Environmental Management, January 1998"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "leaf/branch" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_199 a skos:Concept ;
    dct:creator "land that is covered with trees and shrubs" ;
    dct:source "http://www.notredame.ac.jp/cgi-bin/wn?forest"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest, woodland, timberland, timber"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "land that is covered with trees and shrubs" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_20 a skos:Concept ;
    dct:source "http://www.molluscsoftasmania.net/Portfolio/Grove_1998_NatureConservationSourcebookForForestryProfessionals.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest Reserve - A government land designation the purpose of which is to retain that land as forest or other natural vegetation, or to encourage its conversion to forest"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "General"@en .

ex:Forest_200 a skos:Concept ;
    dct:creator "according to the U.S. National Vegetation Classification system" ;
    dct:source "http://www.museum.state.il.us/muslink/forest/htmls/intro_def.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forests consist of trees with overlapping crowns forming 60% to 100% cover. Woodlands are more open, with 25% to 60% cover"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "according to the U.S. National Vegetation Classification system" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_201 a skos:Concept ;
    dct:creator "more accurately called woods" ;
    dct:source "http://www.iea.org.uk/books/envindicators.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forests are areas covered in dense tree growth"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "more accurately called woods" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_202 a skos:Concept ;
    dct:source "http://www.conservation.org/osiris/Documents/DNPI%20Green%20Review%20on%20REDD+.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forests are described as non-annual plants reaching a height of minimum 5 m and with a crown cover of more than 30 percent of a defined area, normally one hectare"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_203 a skos:Concept ;
    dct:source "http://www.fs.fed.us/research/publications/forest_production_for_tropical_america/appendix_d.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forests differ from woodlands in that they have continuous canopies, gaps between the tree crowns and the ground, and juvenile trees"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_204 a skos:Concept ;
    dct:creator "woodland" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Fôret Claire - Woody plants > 8 m ht., 70-90% canopy cover. Yangambi Classification 1956. (Fournier 1991"@en ;
