ex:Deforestation_123 a skos:Concept ;
    dct:creator "FAO," ;
    dct:date "1995"^^xsd:gYear ;
    dct:source "http://www.spcforests.org/Library/usestatus/usestatus.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The disruption of the forest ecosystem by changes in land use that deplete tree crown cover to less than 10 percent of the land area . By this definition, very productive agricultural land with less than 10 percent tree crown cover is considered deforested. On the other hand, logging or any form of removal of 90 percent of the trees leaving only 10 percent of the tree crown cover would not be considered deforestation but would be considered as degradation if it results in damage to the land"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "FAO, 1995" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_174 a skos:Concept ;
    dct:creator "EU" ;
    dct:date "2013"^^xsd:gYear ;
    dct:source "http://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:32013D0529"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "‘deforestation’ means the direct human-induced conversion of forest to land that is not forest, where the conversion has taken place after 31 December 1989"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "EU 2013" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_177 a skos:Concept ;
    dct:creator "UN-FAO" ;
    dct:source "http://faov02.fao.org:70/0gopher_root%3a[fao.fra]def_uk.txt"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The change of land use from forest to other land-use. [Source: from (concepts, definitions and methodology of the FAO Forest Resources Assessment 1990) via Bernhard Schlamadinger]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_178 a skos:Concept ;
    dct:creator "UN-FAO" ;
    dct:date "2001"^^xsd:gYear ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Deforestation is the conversion of forest to another land use or the long-term reduction of tree canopy cover below the 10% threshold. Explanatory note (extract): Deforestation implies the long-term or permanent loss of forest cover. Such a loss can only be caused and maintained through a continued man-induced or natural perturbation. Deforestation includes, for example, areas of forest converted to agriculture (including agroforestry), pasture, water reservoirs and urban areas. The term specifically excludes areas where the trees have been removed, due, for example, to harvesting or logging, and where the forest is expected to regenerate naturally or with the aid of silvicultural measures within the short term. Food and Agriculture Organization of the United Nations (FAO 2000b"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO 2001" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_184 a skos:Concept ;
    dct:creator "IPCC c" ;
    dct:date "1996"^^xsd:gYear ;
    dct:source "http://www.greenhouse.gov.au/ncas/files/strategic/glossary.html"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Conversion of forests to another land use, frequently accompanied by burning"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "IPCC 1996c" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_19 a skos:Concept ;
    dct:creator "IPCC" ;
    dct:date "2003"^^xsd:gYear ;
    dct:source "http://www.junkscience.com/draft_AR4/GLOSSARY_SOD_TSU_FINAL.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Conversion of forest to non-forest. For a discussion of the term →forest and related terms such as →afforestation, →reforestation, and deforestation: see the IPCC Report on Land Use, Land-Use Change and Forestry (IPCC, 2000). See also the Report on Definitions and Methodological Options to Inventory Emissions from Direct Human-induced Degradation of Forests and Devegetation of Other Vegetation Types (IPCC, 2003). (Source: Second Order Draft Glossary IPCC WGI Fourth Assessment Report"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "IPCC - 2003" ;
    skos:prefLabel "Deforestation"@da .

ex:Deforestation_208 a skos:Concept ;
    dct:creator "UN-EP" ;
    dct:date "2003"^^xsd:gYear ;
    dct:source "http://digitalcommons.unl.edu/cgi/viewcontent.cgi?article=1030&context=usdafsfacpub"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Conversion of forest to non-forest"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-EP 2003" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_209 a skos:Concept ;
    dct:creator "UN-FAO" ;
    dct:date "2000"^^xsd:gYear ;
    dct:source "http://www.fao.org/DOCREP/X7273E/x7273e05.htm#P0_0"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "A permanent conversion to other uses"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO 2000" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_210 a skos:Concept ;
    dct:creator "UN-FAO" ;
    dct:date "2000"^^xsd:gYear ;
    dct:source "http://unfcccbali.org/unfccc/component/option,com_glossary/Itemid,100/func,display/letter,D/catid,31/page,1/"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The conversion of forest to another land use or the long-term reduction of tree canopy cover below the 10% threshold (FAO, 2000"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO 2000" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_211 a skos:Concept ;
    dct:creator "UN-FAO" ;
    dct:date "2001"^^xsd:gYear ;
    dct:source "http://www.fao.org/docrep/003/y0900e/y0900e11.htm#P1_7"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The conversion of forest to another land use or the long-term reduction of the tree canopy cover below the minimum 10 percent threshold (see the UN-FAO 2001 definition of forest and the following explanatory note). Explanatory note: Deforestation implies the long-term or permanent loss of forest cover and implies transformation into another land use. Such a loss can only be caused and maintained by a continued human-induced or natural perturbation. Deforestation includes areas of forest converted to agriculture, pasture, water reservoirs and urban areas. The term specifically excludes areas where the trees have been removed as a result of harvesting or logging and where the forest is expected to regenerate naturally or with the aid of silvicultural measures. Unless logging is followed by the clearing of the remaining logged-over forest for the introduction of alternative land uses, or the clearings are maintained through continued disturbance, forests commonly regenerate, although often to a different, secondary condition. In areas of shifting agriculture, forest, forest fallow and agricultural lands appear in a dynamic pattern where deforestation and the return of forest occur frequently in small patches. To simplify reporting of such areas, the net change over a larger area is typically used. Deforestation also includes areas where, for example, the impact of disturbance, overutilization or changing environmental conditions affects the forest to an extent that it cannot sustain a tree cover above the 10 percent threshold. and . ftp://ftp.fao.org/docrep/fao/009/j9345e/j9345e00.pdf"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO 2001" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_212 a skos:Concept ;
    dct:creator "UN-FAO" ;
    dct:date "2004"^^xsd:gYear ;
    dct:source "http://www.fao.org/forestry/foris/webview/forestry2/index.jsp?siteId=4261&sitetreeId=13629&langId=1&geoId=0"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The conversion of forest to another land use or the long-term reduction of the tree canopy cover below the minimum 10 percent threshold. Explanatory notes: 1. Deforestation implies the long-term or permanent loss of forest cover and implies transformation into another land use. Such a loss can only be caused and maintained by a continued human-induced or natural perturbation. 2. Deforestation includes areas of forest converted to agriculture, pasture, water reservoirs and urban areas. 3. The term specifically excludes areas where the trees have been removed as a result of harvesting or logging, and where the forest is expected to regenerate naturally or with the aid of silvicultural measures. Unless logging is followed by the clearing of the remaining logged-over forest for the introduction of alternative land uses, or the maintenance of the clearings through continued disturbance, forests commonly regenerate, although often to a different, secondary condition. In areas of shifting agriculture, forest, forest fallow and agricultural lands appear in a dynamic pattern where deforestation and the return of forest occur frequently in small patches. To simplify reporting of such areas, the net change over a larger area is typically used. 4. Deforestation also includes areas where, for example, the impact of disturbance, overutilization or changing environmental conditions affects the forest to an extent that it cannot sustain a tree cover above the 10 percent threshold"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO 2004" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_213 a skos:Concept ;
    dct:creator "UN-FAO" ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "To clear an area, other than purely temporarily, of forest. Clear cutting (even with stump removal), if shortly followed by reforestation, is not deforesting. From: Graeme Wild <GraemeW@za.sappi.com"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_214 a skos:Concept ;
    dct:creator "UN-FCCC" ;
    dct:date "2001"^^xsd:gYear ;
    dct:source "http://unfcccbali.org/unfccc/component/option,com_glossary/Itemid,100/func,display/letter,D/catid,31/page,1/"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The direct human-induced conversion of forested land to non-forested land. (UNFCCC, 2001"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FCCC 2001" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_215 a skos:Concept ;
    dct:creator "UN-FCCC" ;
    dct:source "http://unfcccbali.org/unfccc/component/option,com_glossary/Itemid,100/func,display/letter,D/catid,31/page,1/"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The removal of forest stands by cutting and burning to provide land for agricultural purposes, residential or industrial building sites, roads, etc., or by harvesting the trees for building materials or fuel"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FCCC" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_287 a skos:Concept ;
    dct:creator "IPCC" ;
    dct:date "2003"^^xsd:gYear ;
    dct:source "http://www.junkscience.com/draft_AR4/GLOSSARY_SOD_TSU_FINAL.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Reforestation ;
    skos:definition "Conversion of forest to non-forest. For a discussion of the term →forest and related terms such as →afforestation, →reforestation, and deforestation: see the IPCC Report on Land Use, Land-Use Change and Forestry (IPCC, 2000). See also the Report on Definitions and Methodological Options to Inventory Emissions from Direct Human-induced Degradation of Forests and Devegetation of Other Vegetation Types (IPCC, 2003). (Source: Second Order Draft Glossary IPCC WGI Fourth Assessment Report"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "IPCC - 2003" ;
    skos:prefLabel "Deforestation"@da .

ex:Deforestation_32 a skos:Concept ;
    dct:creator "UN-EP" ;
    dct:source "http://www.nyo.unep.org/action/ap1.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The felling of trees, usually for commercial purposes"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-EP" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_33 a skos:Concept ;
    dct:creator "UN-FAO" ;
    dct:date "1998"^^xsd:gYear ;
    dct:source "http://unfcccbali.org/unfccc/component/option,com_glossary/Itemid,100/func,display/letter,D/catid,31/page,1/"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Refers to change of land cover with depletion of tree crown cover to less than 10%. Changes within the forest class (e.g. from closed to open forest) which negatively affect the stand or site and, in particular, lower the production capacity, are termed forest degradation"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO 1998" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_34 a skos:Concept ;
    dct:creator "UN-FAO" ;
    dct:source "http://europa.eu.int/comm/development/forests/en/en4_6.htm"^^xsd:anyURI,
        "http://faov02.fao.org:70/0gopher_root%3a[fao.fra]def_uk.txt"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "and (EU) The depletion of forest crown cover to less than 10%. [Source: from (concepts, definitions and methodology of the FAO Forest Resources Assessment 1990) via Bernhard Schlamadinger]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_35 a skos:Concept ;
    dct:creator "UN-FAO" ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Developed countries: Change of forest with depletion of tree crown cover to less than 20 percent (FAO 1997"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_36 a skos:Concept ;
    dct:creator "UN-FAO" ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Developing countries: Change of forest with depletion of tree crown cover to less than 10 percent (FAO 1997"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_37 a skos:Concept ;
    dct:creator "UN-FCCC" ;
    dct:date "2001"^^xsd:gYear ;
    dct:source "http://www.unfccc.int/resource/docs/cop6secpart/l11r01.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "the direct human-induced conversion of forested land to nonforested land. Decision 11/CP.7 ftp://ftp.fao.org/docrep/fao/009/j9345e/j9345e00.pdf and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FCCC 2001" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_38 a skos:Concept ;
    dct:creator "UN-FCCC" ;
    dct:date "2006"^^xsd:gYear ;
    dct:source "http://www.iop.org/EJ/article/1748-9326/3/2/025011/erl8_2_025011.pdf?request-id=dc893ad1-7028-4e4a-a91d-c44bc540a975"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "A ‘measurable sustained decrease in crown cover’ below a 10–30% threshold"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FCCC 2006" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_39 a skos:Concept ;
    dct:creator "UN-FRA" ;
    dct:date "2000"^^xsd:gYear ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Refers to change of land cover with depletion of tree crown cover to less than 10 percent. Changes within the forest class (e.g. from closed to open forest) which negatively affect the stand or site and, in particular, lower the production capacity, are termed forest degradation. (UN-ECE/FAO 1997 and FAO 1998"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FRA 2000" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_42 a skos:Concept ;
    dct:creator "USA-FED-CIA" ;
    dct:source "https://www.cia.gov/cia/publications/factbook/docs/notesanddefs.html#2032"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Tthe destruction of vast areas of forest (e.g., unsustainable forestry practices, agricultural and range land clearing, and the over exploitation of wood products for use as fuel) without planting new growth"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-CIA" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_43 a skos:Concept ;
    dct:creator "USA-FED-EPA" ;
    dct:source "http://homeguides.sfgate.com/deforestation-effects-global-scale-78864.html"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Deforestation is the \"permanent removal of standing forests"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-EPA" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_45 a skos:Concept ;
    dct:creator "World Bank" ;
    dct:date "2000"^^xsd:gYear ;
    dct:source "http://www.holz.uni-goettingen.de/ek/woodsat/pdf/worldbankforestry.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Change of forest with depletion of tree crown cover to less than 10 percent. The clearing of forests and the conversion of land to non-forest uses"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "World Bank 2000" ;
    skos:prefLabel "DEFORESTATION"@de .

