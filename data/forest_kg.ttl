    dct:source "http://ewg.gecp.virginia.edu/ewg_forest_us/general/glossary.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "This category includes productive forest land and open woodland with naturally and artificially grown forest , and shrubs. Minimum volume density is the main characteristic of these lands, it should be 0.4 and higher for young forest and shrubs, and 0.3 and higher - in all other stands. Minimum Mapping Unit of 0.5 ha"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "forest plantation" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

