    dct:spatial "Australia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"forest\" means an area containing trees; Forest Practices Act 1985 - Sect 3"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Australia-Tasmania 1985" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_1315 a skos:Concept ;
    dct:creator "Tasmania" ;
    dct:source "http://www.delm.tas.gov.au/pluc/glossy.html"^^xsd:anyURI ;
    dct:spatial "Australia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "An area, incorporating all living and non-living components, that is dominated by trees having usually a single stem and a mature or potentially mature stand height exceeding 5 metres, and with existing or potential projective cover of overstorey strata about equal to or greater than 30 per cent"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Australia-Tasmania" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

