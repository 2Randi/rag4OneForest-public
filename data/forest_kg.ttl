ex:Forest_133 a skos:Concept ;
    dct:creator "or more" ;
    skos:broadMatch ex:Forest ;
    skos:definition "An area of tree-covered land typically consisting of hundreds or thousands of individual stands comprising trees of similar species composition, age-structure and management regime (Apps and Price 1996"@en ;
