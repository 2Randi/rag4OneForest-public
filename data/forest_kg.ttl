ex:LandCoverChange_2 a skos:Concept ;
    dct:creator "USA-FED-UDSI-USGS" ;
    dct:source "http://biology.usgs.gov/s+t/SNT/noframe/lu106.htm"^^xsd:anyURI ;
    skos:broadMatch ex:LandCover ;
    skos:definition "describes differences in the area occupied by cover types through time"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-UDSI-USGS" ;
    skos:prefLabel "Land cover change"@en .

ex:LandCoverUse_1 a skos:Concept ;
    dct:creator "USA-FED-DA and Census Bureau" ;
    dct:source "http://www.allcountries.org/uscensus/383_land_cover_use_by_state.html"^^xsd:anyURI ;
    skos:definition "Land Cover/use . A term that includes categories of land cover and categories of land use. Land cover is the vegetation or other kind of material that covers the land surface. Land use is the purpose of human activity on the land; it is usually, but not always, related to land cover. The NRI uses the term \"land cover/use\" to identify the categories that account for all the surface area in the United States [BS-1982, NRI-92] ftp://ftp-fc.sc.egov.usda.gov/NCGC/products/nri/2004range/chapter6.pdf and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DA and Census Bureau" ;
    skos:prefLabel "Land Cover use"@en .

ex:LandUseChange_1 a skos:Concept ;
    dct:creator "UN-EP" ;
    dct:date "2000"^^xsd:gYear ;
    dct:source "http://www.grida.no/climate/ipcc_tar/wg1/518.htm"^^xsd:anyURI ;
    skos:broadMatch ex:LandUse ;
    skos:definition "A change in the use or management of land by humans, which may lead to a change in land cover. Land cover and land-use change may have an impact on the albedo, evapotrans-piration, sources and sinks of greenhouse gases, or other properties of the climate system and may thus have an impact on climate, locally or globally. See also: the IPCC Report on Land Use, Land-Use Change, and Forestry (IPCC, 2000"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-EP 2000" ;
    skos:prefLabel "Land-use change"@en .

ex:LandUseChange_2 a skos:Concept ;
    dct:creator "USA-FED-Climate Change Science Program" ;
    dct:date "2003"^^xsd:gYear ;
    dct:source "http://www.climatescience.gov/Library/stratplan2003/final/annexd.htm#L"^^xsd:anyURI ;
    skos:broadMatch ex:LandUse ;
    skos:definition "A change in the use or management of land by humans, which may lead to a change in land cover. Land cover and land-use change may have an impact on the albedo, evapotranspiration, sources, and sinks of greenhouse gases, or other properties of the climate system, and may thus have an impact on climate, locally or globally"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-Climate Change Science Program 2003" ;
    skos:prefLabel "Land-use change"@en .

ex:Land_1 a skos:Concept ;
    dct:creator "European Environment Agency" ;
    dct:source "http://glossary.eea.europa.eu/EEAGlossary/L/land"^^xsd:anyURI ;
    skos:definition "Land - The terrestrial bio-productive system that comprises soil vegetation, other biota, and the ecological and hydrological processes that operate within the system"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "European Environment Agency" ;
    skos:prefLabel "Land"@de .

ex:Land_2 a skos:Concept ;
    dct:creator "UN-FA0" ;
    dct:date "2004"^^xsd:gYear ;
    dct:source "http://www.fao.org/nr/lada/index.php?option=com_docman&task=doc_download&gid=15&Itemid=157"^^xsd:anyURI ;
    skos:definition "A delineable area encompassing all attributes of the biosphere immediately above or below the earth surface, including the soil, terrain, surface hydrology, the near-surface climate, sediments and associated groundwater reserve, the biological resource, as well as the human settlements pattern and infrastructure resulting from human activity. Ponce Hernandez and Koohafkan (FAO, 2004"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FA0 2004" ;
    skos:prefLabel "Land"@de .

ex:Land_3 a skos:Concept ;
    dct:creator "UN-FAO  and" ;
    dct:date "1995"^^xsd:gYear ;
    dct:source "http://www.fao.org/nr/lada/index.php?option=com_docman&task=doc_download&gid=15&Itemid=157"^^xsd:anyURI,
        "http://www.rri.wvu.edu/WebBook/Briassoulis/contents.htm"^^xsd:anyURI ;
    skos:definition "A delineable area of the earth’s terrestrial surface, encompassing all attributes of the biosphere immediately above or below this surface, including those of the near-surface climate, the soil and terrain forms, the surface hydrology (including shallow lakes, rivers, marshes, and swamps), the near-surface sedimentary layers and associated groundwater reserve, the plant and animal populations, the human settlement pattern and physical results of past and present human activity (terracing, water storage or drainage structures, roads, buildings, etc.). (FAO 1995, 6). (W. Sombroek, Land resources evaluation and the role of land-related indicators, FAO Land and Water Bulletin 5, 1997"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO 1995 and 1997" ;
    skos:prefLabel "Land"@de .

ex:Land_4 a skos:Concept ;
    dct:creator "USA-FED-U.S. Bureau of the Census" ;
    dct:source "http://ifdc.nres.uiuc.edu/publications/pdf/forestresources02/pg81-86.pdf"^^xsd:anyURI ;
    skos:definition "Dry land and land temporarily or partly covered by water such as marshes, swamps, and river flood plains (omitting tidal flats below mean high tide); streams, slough, estuaries, and canals less than one eight of a statute mile wide; and lakes, reservoirs, and ponds less than 40 acres in area"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-U.S. Bureau of the Census" ;
    skos:prefLabel "Land"@de .

ex:Landcover_10 a skos:Concept ;
    dct:creator "USA-FED-NASA" ;
    dct:source "http://eobglossary.gsfc.nasa.gov/Library/glossary.php3?mode=alpha&seg=l&segend=n"^^xsd:anyURI ;
    skos:broadMatch ex:LandCover ;
    skos:definition "The characteristics of a land surface as determined by its spectral signature (the unique way in which a given type of land cover reflects and absorbs light"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-NASA" ;
    skos:prefLabel "LAND COVER"@fr .

ex:Landcover_11 a skos:Concept ;
    dct:creator "USA-FED-DA" ;
    skos:broadMatch ex:LandCover ;
    skos:definition "The vegetation or other kind of material that covers the land surface. ftp://ftp-fc.sc.egov.usda.gov/NCGC/products/nri/2004range/chapter6.pdf"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DA" ;
    skos:prefLabel "LAND COVER"@fr .

ex:Landcover_12 a skos:Concept ;
    dct:creator "USA-FED-DA-NRCS" ;
    dct:source "http://199.156.157.191/nri/blcu.htm"^^xsd:anyURI,
        "http://www.wv.nrcs.usda.gov/nri/blcu.htm"^^xsd:anyURI ;
    skos:broadMatch ex:LandCover ;
    skos:definition "The vegetation or other kind of material that covers the land surface. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DA-NRCS" ;
    skos:prefLabel "LAND COVER"@fr .

ex:Landcover_13 a skos:Concept ;
    dct:creator "USA-FED-DI-USGS" ;
    dct:source "http://biology.usgs.gov/s+t/SNT/noframe/lu106.htm"^^xsd:anyURI ;
    skos:broadMatch ex:LandCover ;
    skos:definition "The habitat or vegetation type present, such as forest, agriculture, and grassland"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DI-USGS" ;
    skos:prefLabel "LAND COVER"@fr .

ex:Landcover_3 a skos:Concept ;
    dct:creator "European Environment Agency" ;
    dct:source "http://ec.europa.eu/agriculture/publi/landscape/gloss.htm"^^xsd:anyURI,
        "http://glossary.eea.europa.eu/EEAGlossary/L/land_cover"^^xsd:anyURI ;
    skos:broadMatch ex:LandCover ;
    skos:definition "Land cover corresponds to a (bio)physical description of the earth's surface. It is that which overlays or currently covers the ground. This description enables various biophysical categories to be distinguished - basically, areas of vegetation (trees, bushes, fields, lawns), bare soil, hard surfaces (rocks, buildings) and wet areas and bodies of water (watercourses, wetlands). and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "European Environment Agency" ;
    skos:prefLabel "LAND COVER"@fr .

ex:Landcover_6 a skos:Concept ;
    dct:creator "UN-EP" ;
    dct:source "http://www.eapap.unep.org/lc/cd/html/training/module1.html"^^xsd:anyURI ;
    skos:broadMatch ex:LandCover ;
    skos:definition "The physical attributes of the land that can be seen readily as opposed to the land use which describes a pattern of human activities undertaken within a social and economic context"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-EP" ;
    skos:prefLabel "LAND COVER"@fr .

ex:Landcover_7 a skos:Concept ;
    dct:creator "UN-EP/EAP.AP" ;
    dct:source "http://www.rrcap.unep.org/lc/cd/html/training/module1.html"^^xsd:anyURI ;
    skos:broadMatch ex:LandCover ;
    skos:definition "Land cover can simply be defined as \"the physical attributes of the land that can be seen readily as opposed to the land use which describes a pattern of human activities undertaken within a social and economic context\""@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-EP/EAP.AP" ;
    skos:prefLabel "LAND COVER"@fr .

ex:Landcover_8 a skos:Concept ;
    dct:creator "USA-FED-Climate Change Science Program" ;
    dct:date "2003"^^xsd:gYear ;
    dct:source "http://www.climatescience.gov/Library/stratplan2003/final/annexd.htm#L"^^xsd:anyURI ;
    skos:broadMatch ex:LandCover ;
    skos:definition "The vegetation and artificial built-up materials covering the land surface. This includes areas of vegetation (forests, shrublands, crops, deserts, lawns), bare soil, developed surfaces (paved land, buildings), and wet areas and bodies of water (watercourses, wetlands"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-Climate Change Science Program 2003" ;
    skos:prefLabel "LAND COVER"@fr .

ex:Landcover_9 a skos:Concept ;
    dct:creator "USA-FED-EPA" ;
    dct:date "2006"^^xsd:gYear ;
    dct:source "http://www.epa.gov/indicate/roe/html/roeAppDf.htm#f"^^xsd:anyURI,
        "http://www.epa.gov/indicators/roe/html/roeGlossL.htm"^^xsd:anyURI,
        "http://www.epa.gov/urban/glossary.htm"^^xsd:anyURI ;
    skos:broadMatch ex:LandCover ;
    skos:definition "The ecological status and physical structure of vegetation on the land surface. What can be seen on the landscape - essentially the vegetation and other physical characteristics. Land cover is often mapped using remotely sensed data as cover types can be delineated based on appearance or their spectral reflectance. 2006. , , and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-EPA 2006" ;
    skos:prefLabel "LAND COVER"@fr .

ex:Landuse_1 a skos:Concept ;
    dct:creator "European Environment Agency" ;
    dct:source "http://ec.europa.eu/agriculture/publi/landscape/gloss.htm"^^xsd:anyURI,
        "http://glossary.eea.europa.eu/EEAGlossary/L/land_use"^^xsd:anyURI ;
    skos:broadMatch ex:LandUse ;
    skos:definition "Land use corresponds to the socio-economic description (functional dimension) of areas: areas used for residential, industrial or commercial purposes, for farming or forestry, for recreational or conservation purposes, etc. Links with land cover are possible; it may be possible to infer land use from land cover and conversely. But situations are often complicated and the link is not so evident. Contrary to land cover, land use is difficult to 'observe'. For example, it is often difficult to decide if grasslands are used or not for agricultural purposes. Distinctions between land use and land cover and their definition have impacts on the development of classification systems, data collection and information systems in general. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "European Environment Agency" ;
    skos:prefLabel "LAND USE"@de .

ex:Landuse_10 a skos:Concept ;
    dct:creator "UN-EP" ;
    dct:source "http://www.grida.no/climate/ipcc_tar/wg1/518.htm"^^xsd:anyURI ;
    skos:broadMatch ex:LandUse ;
    skos:definition "The total of arrangements, activities and inputs undertaken in a certain land cover type (a set of human actions). The social and economic purposes for which land is managed (e.g., grazing, timber extraction, and conservation"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-EP" ;
    skos:prefLabel "LAND USE"@de .

ex:Landuse_11 a skos:Concept ;
    dct:creator "UN-FAO" ;
    dct:date "2005"^^xsd:gYear ;
    dct:source "http://www.fao.org/es/ess/census/PROGwca2010/glossary_r7.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:LandUse ;
    skos:definition "Land use: classification of land according to the activity undertaken on the land (paragraphs 11.20–11.39"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO-2005" ;
    skos:prefLabel "LAND USE"@de .

ex:Landuse_14 a skos:Concept ;
    dct:creator "USA-FED-Climate Change Science Program" ;
    dct:source "http://www.climatescience.gov/Library/stratplan2003/final/annexd.htm#L"^^xsd:anyURI ;
    skos:broadMatch ex:LandUse ;
    skos:definition "The total of arrangements, activities, and inputs undertaken in a certain land cover type (a set of human actions). The social and economic purposes for which land is managed (e.g., grazing, timber extraction, and conservation). U"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-Climate Change Science Program" ;
    skos:prefLabel "LAND USE"@de .

ex:Landuse_15 a skos:Concept ;
    dct:creator "USA-FED-EPA" ;
    dct:date "2006"^^xsd:gYear ;
    dct:source "http://www.epa.gov/urban/glossary.htm"^^xsd:anyURI ;
    skos:broadMatch ex:LandUse ;
    skos:definition "The degree to which the land reflects human activities (e.g., residential and industrial development, roads, mining, timber harvesting, agriculture, grazing, etc.). Land use describes how a piece of land is managed or used by humans. Land use is generally locally regulated in the U.S. based on zoning and other regulations. Land use mapping differs from land cover mapping in that it is not always obvious what the land use is from visual inspection. 2006"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-EPA 2006" ;
    skos:prefLabel "LAND USE"@de .

ex:Landuse_16 a skos:Concept ;
    dct:creator "USA-FED-EPA" ;
    dct:source "http://www.epa.gov/indicate/roe/html/roeAppDf.htm#f"^^xsd:anyURI,
        "http://www.epa.gov/indicators/roe/html/roeGlossL.htm"^^xsd:anyURI ;
    skos:broadMatch ex:LandUse ;
    skos:definition "Describes how a piece of land is managed or used by humans. The degree to which the land reflects human activities (e.g., residential and industrial development, roads, mining, timber harvesting, agriculture, grazing, etc.). and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-EPA" ;
    skos:prefLabel "LAND USE"@de .

ex:Landuse_17 a skos:Concept ;
    dct:creator "USA-FED-DA" ;
    dct:date "1982"^^xsd:gYear ;
    skos:broadMatch ex:LandUse ;
    skos:definition "The purpose of human activity on the land; it is usually, but not always, related to land cover. The NRI uses the term \"land cover/use\" to identify the categories that account for all the surface area in the United States [BS-1982, NRI-92] ftp://ftp-fc.sc.egov.usda.gov/NCGC/products/nri/2004range/chapter6.pdf"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DA 1982" ;
    skos:prefLabel "LAND USE"@de .

ex:Landuse_18 a skos:Concept ;
    dct:creator "USA-FED-DI-NRCS" ;
    dct:source "http://199.156.157.191/nri/blcu.htm"^^xsd:anyURI,
        "http://www.wv.nrcs.usda.gov/nri/blcu.htm"^^xsd:anyURI ;
    skos:broadMatch ex:LandUse ;
    skos:definition "The purpose of human activity on the land; it is usually, but not always, related to land cover. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DI-NRCS" ;
    skos:prefLabel "LAND USE"@de .

ex:Landuse_2 a skos:Concept ;
    dct:creator "European Environment Agency" ;
    dct:source "http://europa.eu.int/comm/agriculture/publi/landscape/gloss.htm"^^xsd:anyURI ;
    skos:broadMatch ex:LandUse ;
    skos:definition "The socio-economic description (functional dimension) of areas: areas used for residential, industrial or commercial purposes, for farming or forestry, for recreational or conservation purposes, etc. Links with land cover are possible; it may be possible to infer land use from land cover and conversely. But situations are often complicated and the link is not so evident. Contrary to land cover, land use is difficult to \"observe\". For example, it is often difficult to decide if grasslands are used or not for agricultural purposes. Distinctions between land use and land cover and their definition have impacts on the development of classification systems, data collection and information systems in general"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "European Environment Agency" ;
    skos:prefLabel "LAND USE"@de .

ex:Landuse_3 a skos:Concept ;
    dct:creator "European Union" ;
    dct:source "http://epaedia.eea.europa.eu/glossary.php?letter=L&gid=92#viewterm"^^xsd:anyURI ;
    skos:broadMatch ex:LandUse ;
    skos:definition "Corresponds to the socio-economic description (functional dimension) of areas: areas used for residential, industrial or commercial purposes, for farming or forestry, for recreational or conservation purposes, etc. Links with land cover are possible; it may be possible to infer land use from land cover and conversely. But situations are often complicated and the link is not so evident. Contrary to land cover, land use is difficult to 'observe'. For example, it is often difficult to decide if grasslands are used or not for agricultural purposes. Distinctions between land use and land cover and their definition have impacts on the development of classification systems, data collection and information systems in general"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "European Union" ;
    skos:prefLabel "LAND USE"@de .

ex:Landuse_4 a skos:Concept ;
    dct:creator "European Union" ;
    dct:source "http://circa.europa.eu/irc/dsis/coded/info/data/coded/en/gl009961.htm"^^xsd:anyURI ;
    skos:broadMatch ex:LandUse ;
    skos:definition "For land use, various approaches are proposed into the literature. Two main \"schools\" may be distinguished. Land use in terms of functional dimension corresponds to the description of areas in terms of their socio-economic purpose: areas used for residential, industrial or commercial purposes, for farming or forestry, for recreational or conservation purposes, etc. Links with land cover are possible; it may be possible to infer land use from land cover and conversely. But situations are often complicated and the link is not so evident. Another approach, termed sequential, has been particularly developed for agricultural purposes. The definition is a series of operations on land, carried out by humans, with the intention to obtain products and/or benefits through using land resources. For example a sequence of operations such as ploughing, seeding, weeding, fertilising and harvesting (MÜCHER et al. 1993). Contrary to land cover, land use is difficult to \"observe\". For example, it is often difficult to decide if grasslands are used or not for agricultural purposes. The information coming from the source of observation may not be sufficient and may require additional information. In the case of agricultural use, farmers may bring information, for example if cattle are present or not, if they are grazing. It is also possible to use characteristics on the spot indicating the presence or absence of cattle. For the FUNCTIONAL approach, inference from land cover may be helpful. For the SEQUENTIAL approach, a more exhaustive recording of various attributes will be needed, for example a multi-temporal approach. In the following, land use will be understood as FUNCTIONAL"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "European Union" ;
    skos:prefLabel "LAND USE"@de .

ex:Landuse_51 a skos:Concept ;
    dct:creator "USDA Forest Service" ;
    dct:date "1989"^^xsd:gYear ;
    skos:broadMatch ex:LandUse ;
    skos:definition "The predominant purpose for which an area is employed"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USDA Forest Service 1989" ;
    skos:prefLabel "LAND USE"@de .

ex:Landuse_6 a skos:Concept ;
    dct:creator "IPCC" ;
    dct:date "2003"^^xsd:gYear ;
    dct:source "http://www.junkscience.com/draft_AR4/GLOSSARY_SOD_TSU_FINAL.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:LandUse ;
    skos:definition "The total of arrangements, activities and inputs undertaken (a set of human actions) in a certain land cover type. The term “land use” is also used in the sense of the social and economic purposes for which land is managed (e.g., grazing, timber extraction, and conservation). (Source: Second Order Draft Glossary IPCC WGI Fourth Assessment Rept"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "IPCC - 2003" ;
    skos:prefLabel "LAND USE"@de .

ex:Landuse_7 a skos:Concept ;
    dct:creator "IPCC" ;
    dct:source "http://www.bib.fsagx.ac.be/coste21/glossary.html"^^xsd:anyURI,
        "http://www.ipcc.ch/pub/SPM_SRLULUCF.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:LandUse ;
    skos:definition "The social and economic purposes for which land is managed (e.g., grazing, timber extraction, conservation). and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "IPCC" ;
    skos:prefLabel "LAND USE"@de .

ex:Landuse_8 a skos:Concept ;
