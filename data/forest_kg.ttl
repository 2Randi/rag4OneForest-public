ex:NonforestLand_1 a skos:Concept ;
    dct:creator "USA-FED-DA-FS" ;
    skos:definition "Land that has never supported forests or formerly was forested and currently is developed for nonforest uses. Included are lands used for agricultural crops, Christmas tree farms, improved pasture, residential areas, city parks, constructed roads, operating railroads and their right-of-way clearings, powerline and pipeline clearings, streams more than 30 feet wide, and 1- to 40-acre areas of water classified by the Bureau of the Census, U.S. Department of Commerce, as land. If intermingled in forest areas, unimproved roads and other nonforest strips must be more than 120 feet wide, and clearings or other areas must be 1 acre or larger to qualify as nonforest land. (Waddell and Bassett 1997"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DA-FS" ;
    skos:prefLabel "Nonforest land"@no .

ex:NonforestLand_2 a skos:Concept ;
    dct:creator "USA-FED-DA-FS" ;
    skos:definition "Land that has never supported forests, and lands formerly forested where use of timber management is precluded by development for other uses. (Note: This includes area used for crops, improved pasture, residential areas, city parks, improved roads of any width and adjoining clearings, powerline clearings of any width, and 1- to 4.5-acre areas of water classified by the Bureau of the Census as land. If intermingled in forest areas, unimproved roads and nonforest strips must be more than 120 feet wide, and clearings, etc., more than 1 acre, to qualify as nonforest land. (Powell et al. 1993"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DA-FS" ;
    skos:prefLabel "Nonforest land"@no .

ex:OMNNational_1 a skos:Concept ;
    dct:spatial "Oman" ;
    skos:broadMatch ex:Forest ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "Oman national criteria"@en ;
    skos:scopeNote "National"@en,
        "unknown"@en .

ex:OtherForestLand_1 a skos:Concept ;
    dct:creator "USA-FED-DA-FS" ;
    skos:definition "Forest land other than timberland and productive reserved forest land. It includes available and reserved forest land, which is incapable of producing annually 20 cubic feet per acre of industrial wood under natural conditions, because of adverse site conditions, such as sterile soils, dry climate, poor drainage, high elevation, steepness, or rockiness. Urban forest land is also included. (Powell et al. 1993"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DA-FS" ;
    skos:prefLabel "Other forest land"@en .

ex:OtherLand_1 a skos:Concept ;
    dct:creator "FAO," ;
    dct:date "2015"^^xsd:gYear ;
    skos:broadMatch ex:NonForest ;
    skos:definition "Land considered as \"Other land\", that is predominantly agricultural or urban lands use and has patches of tree cover that span more than 0.5 hectares with a canopy cover of more than 10 percent of trees able to reach a height of 5 meters at maturity. It includes both forest and non-forest tree species"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "FAO, 2015" ;
    skos:prefLabel "Other Land"@en .

ex:OtherWoodedLand_1 a skos:Concept ;
    dct:creator "UN-FAO-," ;
    dct:date "2004"^^xsd:gYear ;
    dct:source "http://www.fao.org/docrep/017/ap862e/ap862e00.pdf"^^xsd:anyURI,
        "http://www.fao.org/forestry/foris/webview/forestry2/index.jsp?siteId=4261&sitetreeId=13629&langId=1&geoId=0"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Land not classified as Forest, spanning more than 0.5 hectares; with trees higher than 5 meters and a canopy cover of 5-10 percent, or trees able to reach these thresholds in situ; or with a combined cover of shrubs, bushes and trees above 10 percent. It does not include land that is predominantly under agricultural or urban land use. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO-2004, 2013" ;
    skos:prefLabel "Other wooded land"@en .

ex:OtherWoodedLand_2 a skos:Concept ;
    dct:creator "UN-FAO" ;
    dct:date "2010"^^xsd:gYear ;
    dct:source "http://www.fao.org/forestry/foris/pdf/fra/2010/north-and-central-america/united-states-virgin-islands-2010-224.doc"^^xsd:anyURI ;
    skos:broadMatch ex:Woodland ;
    skos:definition "Land not classified as “Forest”, spanning more than 0.5 hectares; with trees higher than 5 meters and a canopy cover of 5-10 percent, or trees able to reach these thresholds in situ; or with a combined cover of shrubs, bushes and trees above 10 percent. It does not include land that is predominantly under agricultural or urban land use. FRA 2010"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO-2010" ;
    skos:prefLabel "Other wooded land"@en .

