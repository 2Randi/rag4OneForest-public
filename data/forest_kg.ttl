    skos:broadMatch ex:LandUse ;
    skos:definition "The total of arrangements, activities, and inputs undertaken in a certain land cover type (a set of human actions). and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "IPCC" ;
    skos:prefLabel "LAND USE"@de .

