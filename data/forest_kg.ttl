    skos:definition "Forest land incapable of producing 20 cubic feet per acre per year of industrial wood under natural conditions, because of adverse site conditions. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-STATE-Virginia" ;
    skos:prefLabel "- Woodland"@en .

