    dct:date "1905"^^xsd:gYear ;
    dct:source "http://ir.library.oregonstate.edu/xmlui/bitstream/handle/1957/6265/terms%20used%20in%20forestry%20%5Bocr%5D.pdf?sequence=1"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "An area whose principal crop is trees. A forest includes both the forest cover and the soil beneath it. A forest judged by the character of the stand may be timberland or woodland. These constitute the two great classes of forest, between which it is possible to draw a practical but not an absolute distinction. Timberland may be broadly defined as that class of forest which contains in commercial quantities trees of sufficient size and of the required kind to furnish saw logs, pulp wood, ties, poles, or wood for similar uses. Woodland may be broadly defined as forest which contains trees fit for firewood or fencing, but none or very few trees which are suitable for the uses enumerated above. A timber tract is a body of timberland, usually of large area. A woodlot is a forest of small area in which the wood is used mainly for fuel, fencing, and other farm purposes"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DA Bureau of Forestry 1905" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_1015 a skos:Concept ;
    dct:creator "USA-FED-DA-NRCS" ;
    dct:source "http://nsscnt.nssc.nrcs.usda.gov/nfm/apxframe.htm"^^xsd:anyURI,
        "http://www.statlab.iastate.edu/soils/nssh/622.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "For the purpose of developing ecological site descriptions, a spatially defined site where the historic climax plant community was dominated by a 25% overstory canopy of trees, as determined by crown perimeter-vertical projection. and National Soil Survey Handbook"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DA-NRCS" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_1016 a skos:Concept ;
    dct:creator "USA-FED-DA-SCS" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Lands with at least 25 percent tree canopy cover or lands at least 16.7 stocked by forest trees of any size. Source: USDA- Soil Conserv. Serv. 1977. INTERA -FS/S'CS Agreement-Inventory, Appraisal, and Assessment Responsibilities. Memo dated 1/17/77. Note: this was an attempt to resolve differences in definitions between the USFS and the Soil Conservation Service - now NRCS. See also Lund, et. al. 1981"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DA-SCS" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_1017 a skos:Concept ;
    dct:creator "USA-FED-DC-NOAA ?" ;
    dct:date "2007"^^xsd:gYear ;
    dct:source "http://www.csc.noaa.gov/crs/lca/tech_cls.html#9"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Areas dominated by trees generally greater than 5 meters tall and greater than 20 percent of total vegetation cover. and www.csc.noaa.gov/crs/lca/ccap.html"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DC-NOAA 2007?" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_1018 a skos:Concept ;
    dct:creator "USA-FED-DC-NOAA-Coastal Services Center" ;
    dct:source "http://www.csc.noaa.gov/crs/lca/oldscheme.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Includes areas dominated by single-stemmed, woody vegetation unbranched 2 to 3 feet above the ground having a height greater than 6 meters (20 feet) (2004"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DC-NOAA-Coastal Services Center" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_1019 a skos:Concept ;
    dct:creator "USA-FED-DI-BLM" ;
    dct:date "2011"^^xsd:gYear ;
    dct:source "http://www.blm.gov/pgdata/etc/medialib/blm/co/programs/land_use_planning/rmp/white_river/documents/rmpa-2.Par.82091.File.dat/07_WRFO_RMPA-EIS_Chapter%206_Aug2012.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest. Contains tree species commonly harvested as a timber resource including ponderosa pine, lodgepole pine, Douglas-fir, spruce/fir mix, and aspen"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DI-BLM 2011" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_1020 a skos:Concept ;
    dct:creator "USA-FED-DI-FWS" ;
    dct:source "http://www.nwi.fws.gov/riparian.htm#DEFINITIONS"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Woody vegetation greater than 6 meters in height"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DI-FWS" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_1021 a skos:Concept ;
    dct:creator "USA-FED-DI-FWS" ;
    dct:date "2004"^^xsd:gYear ;
    dct:source "https://www.fws.gov/northeast/planning/ESV/PDF/(18)%20%20%20GLOSSARY.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land dominated by trees. For the purposes of the impacts analysis in this document, all forested land was assumed to have the potential to be occasionally harvested, and forested land owned by timber companies was assumed to be harvested on a more intensive, regular schedule"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DI-FWS 2004" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_1022 a skos:Concept ;
    dct:creator "USA-FED-DI-GS-NLCD" ;
    dct:date "1992"^^xsd:gYear ;
    dct:source "http://landcover.usgs.gov/classes.php#upland"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forested Upland - Areas characterized by tree cover (natural or semi-natural woody vegetation, generally greater than 6 meters tall); tree canopy accounts for 25-100 percent of the cover NLCD 92"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DI-GS-NLCD 1992" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_1023 a skos:Concept ;
    dct:creator "USA-FED-DI-NBS/NPS" ;
    dct:date "1994"^^xsd:gYear ;
    skos:broadMatch ex:Forest ;
    skos:definition "Areas with tree 5 m in height or more and with crowns interlocking (60-100% crown cover). (TNC-NBS/NPS. 1994"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DI-NBS/NPS 1994" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_1024 a skos:Concept ;
    dct:creator "USA-FED-DI-NPS" ;
    dct:date "2009"^^xsd:gYear ;
    dct:source "http://science.nature.nps.gov/im/units/netn/inventory/docs/Inventory%20Reports/Land_Cover_Change_FINAL_20091203.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Areas dominated by trees. Wang, Y. Q.; Nugranad-Marzilli, J. 2009. Land cover change in Northeast Temperate Network parks 1973-2002. Natural Resource Technical Report NPS/NETN/NRTR — 2009/238. National Park Service, Fort Collins, Colorado"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DI-NPS 2009" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_1025 a skos:Concept ;
    dct:creator "USA-FED-DS-AID" ;
    dct:date "2008"^^xsd:gYear ;
    dct:source "http://www.usaid.gov/locations/latin_america_caribbean/environment/docs/section_118/Jamaica_2008_FAA_118_and_119_FINAL.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A forest is best defined as an ecosystem or assemblage of ecosystems dominated by trees and other woody vegetation. Forests (according to the U.S. National Vegetation Classification system) consist of trees with overlapping crowns forming 60% to 100% cover. Woodlands are more open, with 25% to 60% cover"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DS-AID 2008" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_1026 a skos:Concept ;
    dct:creator "USA-FED-EPA" ;
    dct:date "2001"^^xsd:gYear ;
    dct:source "http://a257.g.akamaitech.net/7/257/2422/14mar20010800/edocket.access.gpo.gov/cfr_2002/julqtr/pdf/40cfr171.2.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "The term forest means a concentration of trees and related vegetation in non-urban areas sparsely inhabited by and infrequently used by humans; characterized by natural terrain and drainage patterns"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-EPA 2001" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_1027 a skos:Concept ;
    dct:creator "USA-FED-EPA" ;
    dct:source "http://www.epa.gov/indicate/roe/html/roeAppDf.htm#f"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Lands at least 10 percent covered by trees of any size, at least one acre in extent. This includes areas in which trees are intermingled with other cover, such as chaparral and pinyon, juniper areas in the Southwest, and both naturally regenerating forests and areas planted for future harvest (plantations or tree farms"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-EPA" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_1028 a skos:Concept ;
    dct:creator "USA-FED-EPA" ;
    dct:source "http://oaspub.epa.gov/trs/trs_proc_qry.alphabet?p_term_nm=F"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Plant communities which exist along floodplains or on the eastern side of rivers where they were protected from fires. They are dominated by trees that are intolerant of fire and can grow in poorly drained soils, although bur oak trees can be a part of this community. In Northeastern Illinois, the word \"forest\" is often used interchangeably with \"woodland\" or \"woods,\" as in the \"Big Woods.\" EPA/Great Lakes National Program Office : Natural Landscaping for Public Officials: Glossary Term Detail"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-EPA" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_1029 a skos:Concept ;
    dct:creator "USA-FED-EPA" ;
    dct:source "http://www.epa.gov/nerlesd1/land-sci/table1.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Vegetative communities comprised principally of trees potentially over 10m in height and typically characterized by closed or multi-layered canopies"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-EPA" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_1030 a skos:Concept ;
    dct:creator "USA-FED-FGDC" ;
    dct:source "http://www.fgdc.gov/fgdc.html"^^xsd:anyURI,
        "http://www.forestguild.org/climate_change/Pinon-Juniper.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Mature (late successional) height of trees > 5 m (16.5 ft.) and canopy cover =/>25%. FGDC. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-FGDC" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_1031 a skos:Concept ;
    dct:creator "USA-FED-NASA" ;
    dct:source "http://vathena.arc.nasa.gov/curric/land/wetland/gloss.html"^^xsd:anyURI,
        "http://www.dictionary.com/cgi-bin/dict.pl?term=forest"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A dense growth of trees, plants, and underbrush covering a large area. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-NASA" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Forest_1189 a skos:Concept ;
    dct:creator "USA-FED-5-Agency" ;
    dct:date "1982"^^xsd:gYear ;
    dct:source "http://home.comcast.net/~gyde/5-agency_paper-2.doc"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land at least ten percent stocked by trees of any size or formerly having had such tree cover and not currently built-up or developed for agricultural use. Forest land may include Grassland, Shrubland, Treeland, Wetland and/or Barren land. Examples of forest land use arc grazing, recreation and timber production. (Note we are not recommending that “ten percent stocked” be used to determine dominance in the classification categories.) (Land Use and Land Cover Common Terminology Work Group 1985"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-5-Agency1982" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1190 a skos:Concept ;
    dct:creator "USA-FED-Census Bureau" ;
    dct:date "2006"^^xsd:gYear ;
    dct:source "http://www.allcountries.org/uscensus/383_land_cover_use_by_state.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A Land cover/use category that is at least 10 percent stocked by single-stemmed woody species of any size that will be at least 4 meters (13 feet) tall at maturity. Also included is land bearing evidence of natural regeneration of tree cover (cut over forest or abandoned farmland) and not currently developed for nonforest use. Ten percent stocked, when viewed from a vertical direction, equates to an areal canopy cover of leaves and branches of 25 percent or greater. The minimum area for classification as forestland is 1 acre, and the area must be at least 100 feet wide"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-Census Bureau 2006" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1191 a skos:Concept ;
    dct:creator "USA-FED-Congressional Research Service and House of Representatives" ;
    dct:date "1992"^^xsd:gYear ;
    dct:source "http://agriculture.house.gov/glossary/forestland.htm"^^xsd:anyURI,
        "http://www.cnie.org/nle/AgGlossary/letter-f.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A classification of land use in the Natural Resources Inventory (NRI). It includes areas where trees cover at least 10% of the land and must be at least an acre in size. Forestland was found on 395 million acres, almost 30% of all private lands, in the 1992 NRI. Congressional Research Service Report for Congress Agriculture: A Glossary of Terms, Programs, and Laws and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-Congressional Research Service and House of Representatives 1992" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1192 a skos:Concept ;
    dct:creator "USA-FED-DA" ;
    dct:date "2003"^^xsd:gYear ;
    dct:source "http://www.cbd.int/doc/world/us/us-nr-vfe-en.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land with a specified minimum tree crown cover and generally more than the specified minimum area, including land that formerly had such tree cover and that will be naturally or artificially regenerated. The trees should generally be able to reach a minimum specified tree height at maturity in situ. It may consist either of closed forest formations in which trees of various stories and undergrowth cover a high proportion of the ground, or of open forest formations with a continuous vegetation cover in which tree crown cover exceeds the minimum percent. Young natural stands and all plantations established for forestry purposes, which have yet to reach the minimum crown density or tree height, are included under forest, as are areas normally forming part of the forest area that is temporarily unstocked as a result of human intervention or natural causes, but which are expected to revert to forest. Limiting measures for qualification as forest land vary by country. Current minimum area, cover, and tree height needed to be classified as forest by country"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DA 2003" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1193 a skos:Concept ;
    dct:creator "USA-FED-DA-ERS" ;
    dct:date "2003"^^xsd:gYear ;
    dct:source "http://www.ers.usda.gov/data/majorlanduses/glossary.htm#grassland"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest land, as defined by the U.S. Forest Service, includes land at least 10 percent of which is stocked by trees of any size, or land formerly having had such tree cover that will be naturally or artificially regenerated. Forest land includes transition zones, such as areas between heavily forested and nonforested lands that are at least 10 percent stocked with forest trees and forest areas adjacent to urban and built-up lands. The total includes pinyon-juniper and chaparral areas in the West and afforested areas"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DA-ERS 2003" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1194 a skos:Concept ;
    dct:creator "USA-FED-DA-ERS" ;
    dct:date "2003"^^xsd:gYear ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest-use land (total forest land exclusive of forested areas in parks and other special uses), 642 million acres (ERS 2003"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DA-ERS 2003" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1195 a skos:Concept ;
    dct:creator "USA-FED-DA-FS" ;
    dct:date "1972"^^xsd:gYear ;
    dct:source "http://home.comcast.net/~gyde/5-agency_paper-2.doc"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land at least 10 percent stocked by forest trees of any size or formerly having had such tree cover, and not currently developed for nonforest use. (Note: Stocking is measured by comparison of basal area and/or number of trees, by age or size and spacing with specified standards. The minimum area for classification forest land is 1 acre. Roadside, streamside. and shelterbelt strips of timber must have a crown width of at least 120 feet wide to qualify as forest land. Unimproved roads and trails, streams, or other bodies of water or clearings in forest areas shall be classed as forest if less than 120 feet in width.) (FS 1972"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DA-FS 1972" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1196 a skos:Concept ;
    dct:creator "USA-FED-DA-FS" ;
    dct:date "1993"^^xsd:gYear ;
    dct:source "http://www.ers.usda.gov/data/majorlanduses/glossary.htm#forest"^^xsd:anyURI,
        "http://www.fs.fed.us/land/sustain_dev/sd/criter2.htm"^^xsd:anyURI,
        "http://www.srsfia.usfs.msstate.edu/wo/review.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land at least 10 percent stocked by forest trees of any size, including land that formerly had such tree cover and that will be naturally or artificially regenerated. Forest land includes transition zones, such as areas between heavily forested and nonforested lands that are at least 10 percent stocked with forest trees and forested areas adjacent to urban or built-up lands. Also included are pinyon juniper and chaparral areas in the West and afforested areas. The minimum area for classification of forest is 1 acre. Roadside, streamside, and shelterbelt strips of timber must have a crown width of at least 120 feet to qualify as forest land. Unimproved roads and trails, streams, and clearings in forest areas are classified as forest if less than 120 feet wide. (Powell et al. 1993) , , and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DA-FS 1993" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1197 a skos:Concept ;
    dct:creator "USA-FED-DA-FS" ;
    dct:date "1997"^^xsd:gYear ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land at least 10 percent stocked with live trees, or land that had this minimum tree stocking in the past and is not currently developed for nonforest use. The minimum area recognized is 1 acre. (Waddell and Bassett 1997"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DA-FS 1997" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1198 a skos:Concept ;
    dct:creator "USA-FED-DA-FS" ;
    dct:date "2001"^^xsd:gYear ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land that is at least 10 percent stocked by forest trees of any size, or land formerly having such tree cover, and is not currently developed for a nonforest use. The minimum area for classification as forest land is one acre. Roadside, stream-side, and shelterbelt strips of timber must have a crown width at least 120 feet wide to qualify as forest land. Unimproved roads and trails, streams and other bodies of water, or natural clearings in forested areas shall be classified as forest, if less than 120 feet in width or an acre in size. Grazed woodlands, reverting fields, and pastures that are not actively maintained are included if the above qualifications are satisfied. (Also see definitions of nonforest land, idle farmland and improved/maintained pasture.) Forest land is divided into timberland, reserved timberland and woodland. SRS FIA Southern Research Station Field Guide; Version 1.5; January 8, 2001, Updated March 23, 2001; Based upon FIA National Core Field Guide, Version 1.5, January, 2001 and FIA National Manual v1.4"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DA-FS 2001" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1199 a skos:Concept ;
    dct:creator "USA-FED-DA-FS" ;
    dct:date "2004"^^xsd:gYear ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest land -\"(a) the condition is at least 10-percent stocked by trees . . . of any size or has been at least 10-percent stocked in the past. Additionally, the condition is not subject to nonforest use(s) that prevent normal tree regeneration and succession such as regular mowing, intensive pruning, or recreation activities; or \"(b) in several western woodland species . . . where stocking cannot be determined, and the condition has at least 5 percent crown cover by trees of any size, or has had at least 5 percent cover in the past. Additionally, the condition is not subject to nonforest use that prevents normal regeneration and succession such as regular mowing, chaining, or recreation activities.\" Further, the condition generally must be at least 36.6 m (120 ft.) wide and 0.40 ha (1.0 ac.) in area to qualify as forest land (Perry et al 2005 and USDA Forest Service, 2004"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DA-FS 2004" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1200 a skos:Concept ;
    dct:creator "USA-FED-DA-FS" ;
    dct:date "2006"^^xsd:gYear ;
    dct:source "http://socrates.lv-hrc.nevada.edu/fia/ab/issues/pending/glossary/Glossary_5_30_06.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land that is at least 10 percent stocked by forest trees of any size, or land formerly having such tree cover, and not currently developed for a nonforest use. The minimum area for classification as forest land is one acre. Roadside, stream-side, and shelterbelt strips of timber must be at least 120 feet wide to qualify as forest land. Unimproved roads and trails, streams and other bodies of water, or natural clearings in forested areas are classified as forest, if less than 120 feet in width or one acre in size. Grazed woodlands, reverting fields, and pastures that are not actively maintained are included if the above qualifications are satisfied. Forest land includes three sub-categories: timberland, reserved forest land, and other forest land"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DA-FS 2006" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1201 a skos:Concept ;
    dct:creator "USA-FED-DA-FS" ;
    dct:date "2007"^^xsd:gYear ;
    dct:source "http://www.fs.fed.us/nrs/pubs/gtr/gtr_wo78.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "forest land—Land at least 120 feet wide and 1 acre in size with at least 10 percent cover (or equivalent stocking) by live trees of any size, including land that formerly had such tree cover and that will be naturally or artificially regenerated. Forest land includes transition zones, such as areas between forest and nonforest lands that have at least 10 percent cover (or equivalent stocking) with live trees and forest areas adjacent to urban and built-up lands. Roadside, streamside, and shelterbelt strips of trees must have a crown width of at least 120 feet and continuous length of at least 363 feet to qualify as forest land. Unimproved roads and trails, streams, and clearings in forest areas are classified as forest if they are less than 120 feet wide or an acre in size. Tree-covered areas in agricultural production settings, such as fruit orchards, or tree-covered areas in urban settings, such as city parks, are not considered forest land. NOTE: This definition does not apply to the data for western Texas, western Oklahoma, and interior Alaska, which, to date, have not had field verification of reported (Smith et al. 2009"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DA-FS 2007" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1202 a skos:Concept ;
    dct:creator "USA-FED-DA-FS" ;
    dct:source "http://www.srsfia.usfs.msstate.edu/scripts/ew.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land currently growing forest trees of any size with a total stocking value of at least 16.7 (10 base 100 in the West), or lands formerly forested, currently capable of becoming forest land, and not currently developed for nonforest uses. These lands must be a minimum of 1 acre in area. Roadside, streamside, and shelterbelt strips of timber must have a crown width of at least 120 feet to qualify as forest land. Unimproved roads, trails, streams, and clearings within forest areas are classified as forest land if they are less than 120 feet wide. Recently clearcut areas that are currently nonstocked are classed as forest land unless they are being used for a nonforest use such as agriculture. Forest land is divided into two categories (timberland and other forest land), and both of these categories may be further classified as reserved if harvesting of trees is prohibited by statutory or administrative restrictions"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DA-FS" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1203 a skos:Concept ;
    dct:creator "USA-FED-DA-FSA" ;
    dct:date "2003"^^xsd:gYear ;
    dct:source "http://www.fsa.usda.gov/dafp/cepd/epb/pdf/ECP_Final_PEIS_0303/15_Glossary.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A land cover/land use category that is at least 10 percent stocked by singlestemmed woody species of any size that will be at least 13 feet tall at maturity. Also included, for the NRI, is land bearing evidence of natural regeneration of tree cover and not currently developed for nonforest use"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DA-FSA 2003" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1204 a skos:Concept ;
    dct:creator "USA-FED-DA-NRCS" ;
    dct:date "1992"^^xsd:gYear ;
    dct:source "http://www.ftc.nrcs.usda.gov/doc/nri/72.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A Land Cover/Use that is at least 10 percent stocked by single stemmed forest trees of any size which will be at least 4 meters (13 feet) tall at maturity. When viewed vertically, canopy cover is 25 percent or greater. Also included are areas bearing evidence of natural regeneration of tree cover (cutover forest or abandoned farmland) and not currently developed for nonforest use. For classification as forest land, an area must be at least one acre and 100 feet wide. [NRI-92] Forest land, grazed. Forest land that is being grazed by livestock and managed using range management principles and practices adapted to the forest ecosystem. [NCPM]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DA-NRCS 1992" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1205 a skos:Concept ;
    dct:creator "USA-FED-DA-NRCS" ;
    dct:date "2000"^^xsd:gYear ;
    dct:source "http://soils.usda.gov/technical/handbook/contents/part622.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A site type of “forestland” is assigned and described where a 25% overstory canopy of trees, as determined by crown perimeter-vertical projection, dominated this historic vegetation"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DA-NRCS 2000" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1206 a skos:Concept ;
    dct:creator "USA-FED-DA-NRCS  &" ;
    dct:date "2002"^^xsd:gYear ;
    skos:broadMatch ex:Forest ;
    skos:definition "A land cover/use category that is at least 10 percent stocked by single-stemmed woody species of any size that will be at least 4 meters (13 feet) tall at maturity. Also included is land bearing evidence of natural regeneration of tree cover (cutover forest or abandoned farmland) and not currently developed for non-forest use. Ten percent stocked, when viewed from a vertical direction is a canopy cover of leaves and branches of 25 percent or greater. The minirnum area is 0.40 ha (1.0 ac) and.width is 30.5 m (100 ft.) '(Perry et al 2005 and Natural Resources Conservation Service, 2002, ftp://ftp-fc.sc.egov.usda.gov/NCGC/products/nri/2004range/appendixd.pdf"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DA-NRCS 2002 & 2004" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1207 a skos:Concept ;
    dct:creator "USA-FED-DA-NRCS" ;
    dct:source "http://www.nh.nrcs.usda.gov/NRI/Publications/NRIglossary.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A Land cover/use category that is at least 10 percent stocked by single –stemmed woody species of any size that will be at least 4 meters (13 feet) tall at maturity. Also included is land bearing evidence of natural regeneration of tree cover (cut over forest or abandoned farmland) and not currently developed for nonforest use. Ten percent stocked, when viewed from a vertical direction, equates to an areal canopy cover of leaves and branches of 25 percent or greater. The minimum area for classification as forest land is 1 acre, and the area must be at least 100 feet wide"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DA-NRCS" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1208 a skos:Concept ;
    dct:creator "USA-FED-DA-NRCS" ;
    dct:source "http://www.ftc.nrcs.usda.gov/doc/npph/glossary/56.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land use designation for land on which the primary vegetation is forest (climax, natural, or introduced plant community) and use is primarily for production of wood products National Planning Procedures Handbook (NPPH) Glossary"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DA-NRCS" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1209 a skos:Concept ;
    dct:creator "USA-FED-DA-SCS" ;
    dct:date "1980"^^xsd:gYear ;
    dct:source "http://home.comcast.net/~gyde/5-agency_paper-2.doc"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land at least 10 percent stocked by forest trees of any size, or formerly having had such tree cover, and not currently developed for nonforest use. The minimum area is 1 acre and must be at least 100 feet wide. (Ten percent tree canopy cover is used to separate forest land from rangeland in the transition vegetation types.) (SCS 1980"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DA-SCS 1980" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1210 a skos:Concept ;
    dct:creator "USA-FED-DA-SCS" ;
    dct:date "1982"^^xsd:gYear ;
    dct:source "http://208.55.71.155/cae/foe2/report/foeglos.html"^^xsd:anyURI,
        "http://farm.fic.niu.edu/foe2/report/foeglos.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land at least 10 percent stocked by forest trees of any size, or formerly having had such tree cover and not currently developed for non-forest use. The minimum area for classification of forestland is one acre and must be at least 100 feet wide. Forestland is distinguished from rangeland in transition vegetation types if the tree canopy cover exceeds 10 percent. Forestlands include cut over areas temporarily unstocked as well as young stands and plantations established for forestry purposes which do not yet have 10 percent crown cover. [source: USDA-SCS 1982 NRI] and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DA-SCS 1982" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1211 a skos:Concept ;
    dct:creator "USA-FED-DD-AF" ;
    dct:date "1994"^^xsd:gYear ;
    dct:source "http://www.afrpa.hq.af.mil/handbook/basis/guidance/afi/af327064.htm#Att1"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land on which forest trees of various sizes constitute at least 10 percent of the area. This category includes open land that is capable of supporting trees and is planned for forest regeneration and management"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DD-AF 1994" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1212 a skos:Concept ;
    dct:creator "USA-FED-DI-BIA" ;
    dct:source "http://thorpe.ou.edu/codes/grandronde/ch620.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land for which a primary use is the growing and harvesting of forest tree species. Source: THE CONFEDERATED TRIBES OF THE GRAND RONDE COMMUNITY OF OREGON FOREST PRACTICES ORDINANCE TRIBAL CODE &sect; 6.20"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DI-BIA" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1213 a skos:Concept ;
    dct:creator "USA-FED-DI-BLM" ;
    dct:date "1971"^^xsd:gYear ;
    skos:broadMatch ex:Forest ;
    skos:definition "Productive forest land) Any forested land capable of being both at least 16.7% stocked and capable of producing 20 cubic feet per acre per year of merchantable wood. (Lund 1974"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DI-BLM 1971" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1214 a skos:Concept ;
    dct:creator "USA-FED-DI-BLM" ;
    dct:date "1973"^^xsd:gYear ;
    dct:source "http://home.comcast.net/~gyde/5-agency_paper-2.doc"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land which is, or has been, at least 16.7 percent stocked by forest trees (10 percent of normal yield values), and not currently developed for nonforest use. This included land currently developed for nonforest use, such as urban or thickly settled residential or resort areas, city parks, orchards, improved roads, or pastureland improved by such measures as seeding or irrigation. (BLM 1973"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DI-BLM 1973" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1215 a skos:Concept ;
    dct:creator "USA-FED-DI-BLM" ;
    dct:date "1998"^^xsd:gYear ;
    dct:source "http://www.blm.gov/narsc/blmannual/annual98/stewardship.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Lands capable of growing trees for harvest, land at least ten percent stocked with trees of any species and size, or lands that were stocked, have been harvested, and will be replanted. Source: Stewardship Assets"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DI-BLM 1998" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1216 a skos:Concept ;
    dct:creator "USA-FED-DI-BLM" ;
    dct:date "2003"^^xsd:gYear ;
    dct:source "http://www.pinedalermp.com/documents/PinedaleGlossaryJanuaryMSA.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land that is now, or is capable of becoming, at least 10 percent stocked with forest trees, and that has been developed for nontimber use. Pinedale Resource Management Plan"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DI-BLM 2003" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1217 a skos:Concept ;
    dct:creator "USA-FED-DI-BLM" ;
    dct:date "2003"^^xsd:gYear ;
    dct:source "http://www.blm.gov/nhp/efoia/wo/fy03/im2003-035attach1.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Those lands with 10 percent or greater stocking (or the potential to in tree species which are typically used in commercially processed wood products (lumber, plywood, paper, etc.), such as ponderosa pine, lodgepole pine, Douglas-fir, white spruce, white fir, grandfir, hemlock, and aspen. Stocking can be measure by either crown density, stem density, or basal area. Include land that formerly had such tree cover and that will be managed to be naturally or artificially regenerated with tree cover"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DI-BLM 2003" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1218 a skos:Concept ;
    dct:creator "USA-FED-DI-BLM" ;
    dct:source "http://web.ead.anl.gov/rmpweb/application/rmp_browse.cfm?rmpid=28&idref=27602"^^xsd:anyURI,
        "http://www.or.blm.gov/Medford/medford/glossary.html"^^xsd:anyURI,
        "http://www.or.blm.gov/coosbay/rmp/glossary.html"^^xsd:anyURI,
        "http://www.streamnet.org/ff/Glossary/glossaryforest.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land that is now, or is capable of becoming, at least l0 percent stocked with forest trees and that has not been developed for nontimber use. Source: Coos Bay Record of Decision - , .(Streamnet online) , and Medford Record of Decision and Resource Management Plan"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DI-BLM" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1219 a skos:Concept ;
    dct:creator "USA-FED-DI-GS" ;
    dct:date "1952"^^xsd:gYear ;
    skos:broadMatch ex:Forest ;
    skos:definition "Woods, Woodland). Areas 1 acre or greater containing tree cover or brush that is potential tree cover. The growth must be at least 6 feet tall and dense enough to impede foot travel or give cover for troops. Logged or burnt areas are classed as \"woods\" unless new growth is not going to be established. (USGS 1952"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DI-GS 1952" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1220 a skos:Concept ;
    dct:creator "USA-FED-DI-GS" ;
    dct:date "1976"^^xsd:gYear ;
    dct:source "http://home.comcast.net/~gyde/5-agency_paper-2.doc"^^xsd:anyURI,
        "http://mapping.usgs.gov/pub/ti/LULC/lulcpp964/lulcpp964.txt"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land which has a tree-crown areal- density (crown closure percentage) of 10 percent or more, is stocked with trees capable of producing timber or other wood products, and exerts an influence on the climate or water regime. Land from which trees have been removed to less than 10 percent crown closure but which has not been developed for other uses also is included. (Anderson, et. al., 1976"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DI-GS 1976" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1221 a skos:Concept ;
    dct:creator "USA-FED-DI-GS" ;
    dct:source "http://www.pwrc.usgs.gov/brd/DefLandTerms.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land currently supporting forest or land with potential to support forest that formerly had such tree cover and that will be naturally or artificially regenerated – Note 1) forest land includes (a) transition zones, such as areas between forested and non-forested lands that are at least 10 percent stocked with forest trees, and forest areas adjacent to urban and built-up lands; note 2) the minimum area for classification of forest land is 1 acre (0.4 ha); roadside, streamside, and shelterbelt strips of trees must have a crown width of at least 120 ft. (36.6 m); unimproved roads and trails, streams, and clearings in forest areas are classified as forest if less than 120 ft wide. (cf.) Forest (1.1.2"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DI-GS" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1222 a skos:Concept ;
    dct:creator "USA-FED-DI-OSM" ;
    dct:source "http://www.osmre.gov/stateregs/wyregschap1.txt"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land used or managed for the long-term production of wood, wood fiber, or wood-derived products"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DI-OSM" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1223 a skos:Concept ;
    dct:creator "USA-FED-DI-OSM" ;
    dct:source "http://www.osmre.gov/mountaintop.htm#74"^^xsd:anyURI,
        "http://www.wvgazette.com/static/series/mining/reports/EIS/VIII.Glossary.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land with at least 25 percent tree canopy or that has been stocked with at least 10 percent forest trees of any size, including land that formerly had such tree cover and that will be naturally or artificially reforested. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DI-OSM" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1224 a skos:Concept ;
    dct:creator "USA-FED-DOE" ;
    dct:source "http://www.eren.doe.gov/biopower/glossary.html#F"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Any land that is capable of producing or has produced forest growth or, if lacking forest growth, has evidence of a former forest and is not now in other use"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DOE" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1225 a skos:Concept ;
    dct:creator "USA-FED-DOE" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land at least 16.7 percent stocked by forest trees of any size, or formerly having such tree cover, and not currently developed for nonforest use. Glossary of Terms used in Timber Harvesting and Forest Engineering. Biomass Resource Information Clearinghouse, Renewable Resource Data Center, US Dept. of Energy"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DOE" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1226 a skos:Concept ;
    dct:creator "USA-FED-DOE-EIA" ;
    dct:date "2007"^^xsd:gYear ;
    dct:source "http://www.eia.doe.gov/oiaf/1605/pdf/EIA1605_Instructions_10-23-07.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land at least 10 percent stocked by forest trees of any size, or formerly having such tree cover, and not currently developed for non-forest uses. The minimum area considered for classification is one (1) acre. U.S. Department of Energy, Energy Information Administration. Form EIA-1605 (2007"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DOE-EIA 2007" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1227 a skos:Concept ;
    dct:creator "USA-FED-EPA" ;
    dct:source "http://www.epa.gov/indicate/roe/html/roeAppDf.htm#f"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land that is at least 10 percent stocked by forest trees of any size, including land that formerly had tree cover and that will be naturally or artificially regenerated. The minimum area for classification of forest land is one acre"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-EPA" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1228 a skos:Concept ;
    dct:creator "USA-FED-GPO" ;
    dct:date "2010"^^xsd:gYear ;
    dct:source "http://ecfr.gpoaccess.gov/cgi/t/text/text-idx?c=ecfr;sid=d5c57af0e98338afc8fe525fef980c92;rgn=div5;view=text;node=40%3A23.0.1.1.20;idno=40;cc=ecfr#40:23.0.1.1.20.1.19.2"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest means any operation engaged in the outdoor production of any agricultural plant to produce wood fiber or timber products. USA WORKER PROTECTION STANDARD"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-GPO 2010" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1229 a skos:Concept ;
    dct:creator "USA-FED-NASA" ;
    dct:source "http://www.hq.nasa.gov/iwgsdi/FW_SDI_Env_Endow.html"^^xsd:anyURI,
        "http://www.hq.nasa.gov/iwgsdi/Forest_Land.html"^^xsd:anyURI,
        "http://www.hq.nasa.gov/iwgsdi/Land_Ecosystems.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Those ecosystems that have a tree crown density (crown closure percentage) of 10% or more and are stocked with trees capable of producing timber or other wood products. This includes land from which trees have been removed to less than 10%, but which have not been developed for other uses. , , and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-NASA" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_123 a skos:Concept ;
    dct:creator "EEA" ;
    dct:source "http://oaspub.epa.gov/trs/trs_proc_qry.alphabet?p_term_nm=F"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A vegetation community dominated by trees and other woody shrubs, growing close enough together that the tree tops touch or overlap, creating various degrees of shade on the forest floor. It may produce benefits such as timber, recreation, wildlife habitat, etc. European Environment Agency , European Topic Centre on Catalogue of Data Sources (ETC/CDS) : General Multilingual Environmental Thesaurus Term Detail"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "EEA" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_1280 a skos:Concept ;
    dct:creator "USA-FED-DA-NASS" ;
    dct:date "2003"^^xsd:gYear ;
    skos:broadMatch ex:Forest ;
    skos:definition "“We rely on respondent ‘self’ definition for the 5 year Census of Agriculture via mail out/mail back. Our June area survey, we rely on data collected from trained enumerators who usually represent the ‘local’ definition”. Linda Hutton. lhutton@nass.usda.gov.. 12 August 2003"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DA-NASS 2003" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "National"@en .

ex:Forest_1281 a skos:Concept ;
    dct:creator "USA-FED-DA-NRCS" ;
    dct:source "http://www.statlab.iastate.edu/soils/nssh/622.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forestland ecological sites are separated from rangeland ecological sites based on the historic climax plant community that occupied the site before the arrival of European settlers. An Ecological Site Type of \"Forestland\" is assigned and described where this historic vegetation was dominated by a 25% overstory canopy of trees, as determined by crown perimeter-vertical projection. A tree is defined as a woody-stemmed plant that can grow to 4 meters in height at maturity"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DA-NRCS" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "National"@en .

ex:Forest_1282 a skos:Concept ;
    dct:creator "USA-FED-DA-NRCS" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land on which the historic climax plant community is dominated by trees. www.plant-materials.nrcs.usda.gov/pubs/idpmctn280101.pdf"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DA-NRCS" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "National"@en .

ex:Forest_1283 a skos:Concept ;
    dct:creator "USA-FED-DI-BIA" ;
    dct:source "http://codes.lp.findlaw.com/uscode/25/33/3103"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "2) \"forest\" means an ecosystem of at least one acre in size, including timberland and woodland, which - (A) is characterized by a more or less dense and extensive tree cover, (B) contains, or once contained, at least ten percent tree crown cover, and (C) is not developed or planned for exclusive nonforest use"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DI-BIA" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "National"@en .

ex:Forest_1284 a skos:Concept ;
    dct:creator "USA-FED-DI-BLM" ;
    dct:date "1999"^^xsd:gYear ;
    dct:source "http://www.blm.gov/nstc/library/pdf/1734-7.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land on which the potential natural community is dominated by trees"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DI-BLM 1999" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "National"@en .

ex:Forest_1285 a skos:Concept ;
    dct:creator "USA-FED-DI-BLM" ;
    dct:date "1999"^^xsd:gYear ;
    dct:source "http://www.blm.gov/nstc/library/pdf/samplveg.pdf"^^xsd:anyURI,
        "http://www.blm.gov/nstc/library/pdf/utilstudies.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land on which the vegetation is dominated by trees. Lands are classified forestland if the trees now (not?) present will provide 25 percent or greater canopy cover at maturity. Lands not presently forestland that were originally or could become forested through natural succession may be classified as potential natural forestland. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DI-BLM 1999" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "National"@en .

ex:Forest_1286 a skos:Concept ;
    dct:creator "USA-FED-EPA" ;
    dct:date "2002"^^xsd:gYear ;
    dct:source "http://www.epa.gov/globalwarming/publications/outreach/general/glossary.pdf"^^xsd:anyURI,
        "http://www.gcrio.org/OnLnDoc/pdf/2002-inventory.pdf"^^xsd:anyURI,
        "http://yosemite.epa.gov/oar/globalwarming.nsf/webprintview/Glossary.html#F"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Terrestrial ecosystem (biome) with enough annual precipitation (at least 76 centimeters or 30 inches) to support growth of various species of trees and smaller forms of vegetation. , , and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-EPA 2002" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "National"@en .

ex:Forest_1287 a skos:Concept ;
    dct:creator "USA-FED-OOP" ;
    dct:source "http://www.epa.gov/trs"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Terrestrial ecosystem (biome) with enough average annual precipitation (at least 76 centimeters or 30 inches) to support growth of various species of trees and smaller forms of vegetation. Office of Policy : Inventory of U.S. Greenhouse Gas Emissions and Sinks. Annex T: Glossary Term Detail"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-OOP" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "National"@en .

ex:Forest_1340 a skos:Concept ;
    dct:creator "USA-FED-DA-FS-R8" ;
    dct:date "1997"^^xsd:gYear ;
    skos:broadMatch ex:Forest ;
    skos:definition "An area of trees with overlapping crowns (generally forming a 60 to 100 percent cover) USDA"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DA-FS-R8 1997" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_1341 a skos:Concept ;
    dct:creator "USA-FED-DA-FS-SRS" ;
    dct:source "http://www.srs.fs.fed.us/sustain/report/appendix/glossary.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "An assemblage of woody vegetation typically attaining positions in a plant community at the tallest level; attains height and diameter growth of canopy-layer trees within established averages for the species"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DA-FS-SRS" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_1342 a skos:Concept ;
    dct:creator "USA-FED-EPA-Yosemite" ;
    dct:date "2007"^^xsd:gYear ;
    dct:source "http://yosemite.epa.gov/r10/water.nsf/NPDES+Permits/Sewage+S825/$FILE/503-032007.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest is a tract of land thick with trees and underbrush"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-EPA-Yosemite 2007" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land cover"@en,
        "State"@en .

ex:Forest_1425 a skos:Concept ;
    dct:creator "USA-FED-DA-FS-INT" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land that is at least 10 percent stocked by forest trees of any size (or 5 percent crown cover where stocking cannot be determined), or land formerly having such tree cover, and is not currently developed for a nonforest use. The minimum area for classification as forest land is one acre. Roadside, stream-side, and shelterbelt strips of timber must be at least 120 feet wide to qualify as forest land. Unimproved roads and trails or natural clearings in forested areas shall be classified as forest, if less than 120 feet in width or an acre in size. Streams and other bodies of water within forest will be considered forest land if they are less than 1 acre and 30-feet wide. Grazed woodlands, reverting fields, and pastures that are not actively maintained are included if the above qualifications are satisfied. (Also see definitions of nonforest land, idle farmland and improved/maintained pasture.) Note: In some instances, area previously stocked with woodland species that have had some type of treatment (e.g., chaining or other mechanical treatment) are classified as nonforest land. Interior West FIA annual manual 5/2000 – Terms not in National Manual"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DA-FS-INT" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1426 a skos:Concept ;
    dct:creator "USA-FED-DA-FS-NC" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land not currently developed for nonforest use and having a stocking value of at least 10.0 of all live forest trees of any size or formerly having a stocking value of at least 10.0. Unimproved roads and trails, streams or other bodies of water or clearings in forest areas will be classed as forest if less than 120 feet wide. The minimum area for classification of forest land is one acre and 120 feet in width. Roadside, streamside, and shelterbelt strips of timber must be at least 120 feet wide to qualify as forest land. Also see definitions for land area, commercial forest land, noncommercial forest land, productive-reserved forest land, stocking, unproductive forest land, and water. North Central FIA manual 9/99 – terms not in National Manual"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DA-FS-NC" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1427 a skos:Concept ;
    dct:creator "USA-FED-DA-FS-R8" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land at least 10.0 percent stocked by forest trees of any size, or land formerly having such tree cover, and is not currently developed for non-forest use. The minimum area for classification of forestland is 1 acre. Roadside, streamside, and shelterbelt strips of timber must have a width of at least 120 feet wide to qualify as forestland. Unimproved roads, and trails, streams and other bodies of water, or natural clearings in forested areas shall be classified as forest, if less than 120 feet in width or an acre in size. Grazed woodlands, reverting fields, and pastures that are not actively maintained are included if the above qualifications are satisfied. (Also see definitions of non-forest land, idle farmland and improved/maintained pasture.) Southern Region FIA manual 5/2000 – Terms not in National Manual"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DA-FS-R8" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1428 a skos:Concept ;
    dct:creator "USA-FED-DA-FS" ;
    dct:date "2004"^^xsd:gYear ;
    dct:source "http://www.cbd.int/doc/world/us/us-nr-vfe-en.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land with a specified minimum tree crown cover and generally more than the specified minimum area, including land that formerly had such tree cover and that will be naturally or artificially regenerated. The trees should generally be able to reach a minimum specified tree height at maturity in situ. It may consist either of closed forest formations in which trees of various stories and undergrowth cover a high proportion of the ground, or of open forest formations with a continuous vegetation cover in which tree crown cover exceeds the minimum percent. Young natural stands and all plantations established for forestry purposes, which have yet to reach the minimum crown density or tree height, are included under forest, as are areas normally forming part of the forest area that is temporarily unstocked as a result of human intervention or natural causes, but which are expected to revert to forest"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DA-FS 2004" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1429 a skos:Concept ;
    dct:creator "USA-FED-DA–R8" ;
    dct:source "http://www.r8web.com/gwj/lrmp/plandocs/glossary.html#definitions"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "An area managed for the production of timber and other forest products, or maintained under woody vegetation for indirect benefits as protection of a watershed, recreation, or wildlife habitat"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-DA–R8" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1430 a skos:Concept ;
    dct:creator "USA-FED-EPA-R3" ;
    dct:source "http://www.epa.gov/region3/mtntop/pdf/VIII.Glossary.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land bearing a stand of trees of any stature, including seedlings, and of species attaining a minimum of 6 feet average height at maturity or land from which such a stand has been removed but on which no other use has been substituted. The term is commonly limited to land not in farms; forests on farms are commonly called woodland or farm forest"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-EPA-R3" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_1431 a skos:Concept ;
    dct:creator "USA-FED-EPA-R3" ;
    dct:source "http://www.epa.gov/region3/mtntop/pdf/VIII.Glossary.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land with at least 25 percent tree canopy or that has been stocked with at least 10 percent forest trees of any size, including land that formerly had such tree cover and that will be naturally or artificially reforested"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "USA-FED-EPA-R3" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "State"@en .

ex:Forest_219 a skos:Concept ;
    dct:creator "this is the definition now adopted by the Commonwealth Government - see NFI , pp.10-11" ;
    dct:date "1998"^^xsd:gYear ;
    dct:source "http://www.wilderness.org.au/projects/Forests/forbkgnd.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Includes woodlands and woodland-forming mallees"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "this is the definition now adopted by the Commonwealth Government - see NFI 1998, pp.10-11" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_277 a skos:Concept ;
    dct:creator "SAF" ;
    dct:date "1958"^^xsd:gYear ;
    dct:source "http://home.comcast.net/~gyde/5-agency_paper-2.doc"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land bearing forest growth or land from which the forest has been removed but which shows evidence of past forestry occupancy and which is not now in other use. To qualify as forest, an area must: (1) be at least 100 feet wide; (2) be at least I acre in area; (3) have a sufficient number of trees to provide 10 percent crown coverage, be likely to remain in forest use. (SAF 1958"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "SAF 1958" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land use"@en .

ex:Forest_278 a skos:Concept ;
    dct:creator "SAF" ;
    dct:date "1971"^^xsd:gYear ;
    dct:source "http://home.comcast.net/~gyde/5-agency_paper-2.doc"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land carrying forest growth or, if totally lacking it, bearing evidence of former forest and not now in other use. Note: Such land formally qualifies as “forest” only if not less than I acre and not less than 100 feet wide, with trees providing not less than 10 percent crown cover, or, if less, if the lands likely to remain in forest use. (FORD-ROBERTSON 1971"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "SAF 1971" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land use"@en .

ex:Forest_279 a skos:Concept ;
    dct:creator "SAF" ;
    dct:date "1998"^^xsd:gYear ;
    skos:broadMatch ex:Forest ;
    skos:definition "An ecosystem characterized by a more or less dense or extensive tree cover, often consisting of stands varying in characteristics such as species composition, structure, age class, and associated processes, and commonly including meadows streams, fish and wildlife. Note - forests include specialized kinds such as industrial forests, non-industrial private forests, plantations, public forests, production forests, and urban forests, as well as parks and wilderness (Helms 1998"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "SAF 1998" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land use"@en .

ex:Forest_369 a skos:Concept ;
    dct:creator "EU" ;
    dct:date "2000"^^xsd:gYear ;
    dct:source "http://europa.eu.int/estatref/info/sdds/en/for/for_res.htm#toc"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest land is defined as land with tree crown cover (stand density) of more than about 20% of the area. Continuous forest with trees usually growing to more than about 7 m in height and able to produce wood. This includes both closed forest formations where trees of various storeys and undergrowth cover a high proportion of the ground, and open forest formations with a continuous grass layer in which tree synusiae cover at least 10% of the ground"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "EU 2000" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_370 a skos:Concept ;
    dct:creator "EU" ;
    dct:date "2004"^^xsd:gYear ;
    dct:source "http://epp.eurostat.cec.eu.int/cache/ITY_OFFPUB/KS-CD-04-001-8/EN/KS-CD-04-001-8-EN.PDF"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land with tree crown cover (or equivalent stocking level) of more than 10 % and area of more than 0.5 ha. The trees should be able to reach a minimum height of 5 m at maturity in situ"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "EU 2004" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_371 a skos:Concept ;
    dct:creator "EU" ;
    dct:date "2010"^^xsd:gYear ;
    dct:source "http://euobserver.com/9/29410"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Continuously forested areas are defined as areas where trees have reached, or can reach, at least heights of five metres, making up a crown cover of more than 30 percent….They would normally include forest, forest plantations and other tree plantations such as palm oil. Short rotation coppice [the practice of repeatedly cutting young tree stems down] may qualify if it fulfils the height and canopy cover criteria. Phillips, Leigh. 2010. Palm oil plantations are now 'forests,' says EU. EUObserver.com"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "EU 2010" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_372 a skos:Concept ;
    dct:creator "EU" ;
    dct:date "2010"^^xsd:gYear ;
    dct:source "http://www.tropenbos.org/file.php/4/forests-dec21-final-web.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Continuously forested areas are defined as areas where trees have reached, or can reach, at least heights of 5 metres, making up a crown cover of more than 30%. They would normally include natural forest, forest plantations and other tree plantations such as oil palm. This means, for example, that a change from forest to oil palm plantation would not per se constitute a breach of the criterion (para 4.2.3, draft communication).”"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "EU 2010" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_373 a skos:Concept ;
    dct:creator "EU" ;
    dct:source "http://ec.europa.eu/agriculture/analysis/external/supply-wood/full_text_en.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Areas spanning more than 0.5 to 1.0 hectares (depending on national definitions) with trees higher than 5 meters and a canopy cover of more than 10 percent, or trees able to reach these thresholds in situ. It does not include land that is predominantly under agricultural or urban land use. Land registry systems should specify the concerned areas in terms of land use as „forest“"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "EU" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_374 a skos:Concept ;
    dct:creator "EU" ;
    dct:source "http://ec.europa.eu/agriculture/envir/report/en/lex_en/report_en.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest area is \"areas with crown cover (stand density) greater than around 20% of the area. Continuous forest with trees usually reaching a height of more than 7 metres and providing a source of wood"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "EU" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_375 a skos:Concept ;
    dct:creator "EU-JRC" ;
    dct:date "2003"^^xsd:gYear ;
    dct:source "http://www-tem.jrc.it/PDF_publis/2003/Stibig_EUR_2003_full.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forests … have a tree cover of more than 10-20% and tree heights of more than 3(-5) metres. Tree cover and forest regrowth below these thresholds were considered ‘Wood & shrubland’"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "EU-JRC 2003" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_377 a skos:Concept ;
    dct:creator "European Community -DGXIII" ;
    dct:source "http://europa.eu.int/comm/development/body/publications/forests/en/en4_6.htm"^^xsd:anyURI,
        "http://europa.eu.int/comm/dg08/forests/en/en4_6.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Ecosystems with a minimum of 10 per cent crown cover of trees and/or bamboos. They usually contain wild flora, fauna and natural soil conditions, and are not subject to agricultural practices. Forests can be divided into two categories: natural and plantation forests and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "European Community -DGXIII" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_378 a skos:Concept ;
    dct:creator "European Environment Agency" ;
    dct:source "http://www.epa.gov/trs"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A vegetation community dominated by trees and other woody shrubs, growing close enough together that the tree tops touch or overlap, creating various degrees of shade on the forest floor. It may produce benefits such as timber, recreation, wildlife habitat, etc.(Source: DUNSTE) European Environment Agency (EEA), European Topic Centre on Catalogue of Data Sources (ETC/CDS) : General Multilingual Environmental Thesaurus Term Detail"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "European Environment Agency" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_379 a skos:Concept ;
    dct:creator "European Environment Agency" ;
    dct:source "http://glossary.eea.eu.int/EEAGlossary/F/forest"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land with a tree canopy cover of more than 10 % and an area of more than 0.5 ha"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "European Environment Agency" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_392 a skos:Concept ;
    dct:creator "IPCC" ;
    dct:date "1997"^^xsd:gYear ;
    dct:source "http://www.grida.no/climate/ipcc/regional/327.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "An ecosystem in which the dominant plants are trees; woodlands are distinguished from forests by their lower density of trees"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "IPCC 1997" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_393 a skos:Concept ;
    dct:creator "IPCC" ;
    dct:date "2003"^^xsd:gYear ;
    dct:source "http://www.junkscience.com/draft_AR4/GLOSSARY_SOD_TSU_FINAL.pdf"^^xsd:anyURI,
        "http://www.unep.ch/ipcc/pub/syrgloss.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A vegetation type dominated by trees. Many definitions of the term forest are in use throughout the world, reflecting wide differences in bio-geophysical conditions, social structure, and economics. For a discussion of the term forest and related terms such as →afforestation, →reforestation, and →deforestation: see the IPCC Report on Land Use, Land-Use Change and Forestry (IPCC, 2000). See also the Report on Definitions and Methodological Options to Inventory Emissions from Direct Human-induced Degradation of Forests and Devegetation of Other Vegetation Types (IPCC, 2003) (Source: Second Order Draft Glossary IPCC WGI Fourth Assessment Report"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "IPCC 2003" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_394 a skos:Concept ;
    dct:creator "IPCC?" ;
    dct:source "http://bookshop.europa.eu/is-bin/INTERSHOP.enfinity/WFS/EU-Bookshop-Site/en_GB/-/EUR/ViewPDFFile-OpenPDFFile?FileName=LBNA24300ENC_002.pdf&SKU=LBNA24300ENC_PDF"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest land: includes all land with woody vegetation consistent with thresholds used to define forest land in the national GHG inventory, sub-divided into managed and unmanaged. It also includes systems with vegetation that currently fall below, but are expected to exceed, the threshold of the forest land category. Countries must also specify a forest definition under the Kyoto Protocol. This definition is based on area (0.05 – 1.0 ha); canopy closure (10% - 30%) and tree height (2 – 5 m"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "IPCC?" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_397 a skos:Concept ;
    dct:creator "IUCN" ;
    dct:source "http://cmsdata.iucn.org/downloads/forestcover.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "IUCN defines forests as tree dominated landscapes"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "IUCN" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_404 a skos:Concept ;
    dct:creator "TBFRA" ;
    dct:date "1990"^^xsd:gYear ;
    dct:source "http://www.metla.fi/eu/cost/e4/coste4.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "TBFRA criteria for 1990 were even stricter: crown cover had to be 20 % or more and tree height at least 7 meters"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "TBFRA 1990" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_405 a skos:Concept ;
    dct:creator "TBFRA" ;
    dct:date "2000"^^xsd:gYear ;
    dct:source "http://www.metla.fi/eu/cost/e4/coste4.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "TBFRA 2000 requires that the crown cover is greater than 10 % and tree height is greater than 5 meters"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "TBFRA 2000" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_406 a skos:Concept ;
    dct:creator "TBFRA" ;
    dct:date "2000"^^xsd:gYear ;
    dct:source "http://www.mosus.net/documents/MOSUS_Forestry%20sector.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "items are most relevant for the present study: • Forest land: Forest is defined as “land with tree crown cover of more than 10 percent and area more than 0.5 ha.” Trees on the site are considered to be higher than 5 m"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "TBFRA-2000" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_410 a skos:Concept ;
    dct:creator "UN-ECEE/FAO" ;
    dct:date "1997"^^xsd:gYear ;
    dct:source "http://figueresonline.com/csdafinal/English/publications/cdm/glossary.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land with tree crown cover (or equivalent stocking level) of more than 10 percent and area of more than 0.5 ha. The trees should be able to reach a minimum height of 5 m at maturity in situ. May consist either of closed forest formations where trees of various storeys and undergrowth cover a high portion of the ground; or of open forest formations where trees of various storeys and undergrowth cover a high portion of the ground; or of open forest formations with a continuous vegetation cover in which tree cover exceeds 10 percent. Young natural stands and all plantations established for forestry purposes which have yet to reach a crown density of 10 percent or tree height of 5 m are included under forest, as are temporarily unstocked as a result of human intervention or natural causes but which are expected to revert to forest. Includes: Forest nurseries and seed orchards that constitute an integral part of the forest; forest roads, cleared tracts, firebreaks, and other small open areas within the forest; forest in national parks, nature reserves and other protected areas such as those of special environmental, scientific, historical, cultural, or spiritual interest; wind; windbreaks and shelterbelts of trees with an area of more than 0.5 ha and a width of more than 20 m. Rubberwood plantations and cork oak stands are included. Excludes: Land predominantly used for agricultural practices"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-ECEE/FAO 1997" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_411 a skos:Concept ;
    dct:creator "UN-EP" ;
    dct:date "2013"^^xsd:gYear ;
    dct:source "http://www.unep.org/dewa/Portals/67/pdf/Nile_Basin.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Lands dominated by trees with a per cent canopy cover >60% and height exceeding 2 metres"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-EP 2013" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_412 a skos:Concept ;
    dct:creator "UN-EP" ;
    dct:source "http://www.eapap.unep.org/lc/cd/html/training/module1.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land covered by trees with the percent canopy cover greater than 10%. Trees are woody plants land cover with a single well defined stem and more than 3 meters in height. Forest with 10-40% canopy cover is classified as open forest and with 40% and above is classified as closed forest"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-EP" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_413 a skos:Concept ;
    dct:creator "UN-EP/CBD" ;
    dct:date "2001"^^xsd:gYear ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest is a land area of more than 0.5 ha, with a tree canopy cover of more than 10 percent, which is not primarily under agriculture or other specific non-forest land use. In the case of young forest or regions where tree growth is climatically suppressed, the trees should be capable of reaching a height of 5 m in situ, and of meeting the canopy cover requirement. ftp://ftp.fao.org/docrep/fao/009/j9345e/j9345e00.pdf"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-EP/CBD 2001" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_414 a skos:Concept ;
    dct:creator "UN-EP/CBD" ;
    dct:date "2002"^^xsd:gYear ;
    dct:source "http://www.environmental-auditing.org/LinkClick.aspx?fileticket=fbx%2FbAIVeFU%3D&tabid=128&mid=568"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A land area of more than 0.5 ha, with a tree canopy cover of more than 10 percent, which is not primarily under agriculture or other specific non-forest land use. In the case of young forest or regions where tree growth is climatically suppressed, the trees should be capable of reaching a height of 5 m in situ, and of meeting the canopy cover requirement"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-EP/CBD 2002" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_415 a skos:Concept ;
    dct:creator "UN-EP-EAP-AP" ;
    dct:source "http://www.rrcap.unep.org/lc/cd/html/16thacrs.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land covered by trees with the percent canopy cover greater than 10%. Trees are woody plants with a single weft defined stem and more than 3 meters in height. Forest with 10-40% canopy cover is classified as open forest and with 40% and above is classified as closed forest"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-EP-EAP-AP" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_416 a skos:Concept ;
    dct:creator "UN-EP-GRID" ;
    dct:date "2001"^^xsd:gYear ;
    dct:source "http://www.grida.no/climate/ipcc_tar/wg2/689.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A vegetation type dominated by trees. (2001"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-EP-GRID 2001" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_417 a skos:Concept ;
    dct:creator "UN-EP-GRID" ;
    dct:source "http://www.grida.no/climate/ipcc/regional/327.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "An ecosystem in which the dominant plants are trees; woodlands are distinguished from forests by their lower density of trees"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-EP-GRID" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_42 a skos:Concept ;
    dct:creator "SAF" ;
    dct:source "http://home.comcast.net/~gyde/5-agency_paper-2.doc"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "1958) (Forest) A plant association predominantly of trees and other woody vegetation. (SAF 1958"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "SAF" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_420 a skos:Concept ;
    dct:creator "UN-FAO" ;
    dct:date "1953"^^xsd:gYear ;
    dct:source "http://www.fao.org/docrep/015/an053e/an053e00.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest is defined as land bearing vegetative associations dominated by trees of any size"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO 1953" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_421 a skos:Concept ;
    dct:creator "UN-FAO" ;
    dct:date "1958"^^xsd:gYear ;
    dct:source "http://www.dse.de/zel/landinfo/pas/tk247_lup_eth/forest_inventory.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest may be defined as all lands bearing a vegetative association dominated by tree of any size, exploited or not, capable of producing wood or other products, for exerting an influence on climate or on the water regime, or providing shelter for live stock and wild life"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO 1958" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_422 a skos:Concept ;
    dct:creator "UN-FAO" ;
    dct:date "1987"^^xsd:gYear ;
    dct:source "http://www.fao.org/legal/legstud/frmdocrep/41_AK476E.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "the forest is a plant formation in which trees predominate to the extent of modifying the ecology of the terrain. In order to form a specific community of this kind, the trees must occupy a sufficiently large area of land and at a minimum level of density"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO 1987" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_423 a skos:Concept ;
    dct:creator "UN-FAO" ;
    dct:date "1990"^^xsd:gYear ;
    dct:source "http://figueresonline.com/csdafinal/English/publications/cdm/glossary.html"^^xsd:anyURI,
        "http://www.fao.org/docrep/007/t0830e/T0830E04.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Tropical countries) Ecosystems with a minimum of 10 percent crown cover of trees and/or bamboos, generally associated with wild flora, fauna and natural soil conditions, and not subject to agricultural practices. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO 1990" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_424 a skos:Concept ;
    dct:creator "UN-FAO" ;
    dct:date "1993"^^xsd:gYear ;
    dct:source "http://www.ciesin.columbia.edu/docs/002-471/002-471.html"^^xsd:anyURI,
        "http://www.fao.org/docrep/007/t0830e/T0830E00.htm#TOC"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forests are ecological systems with minimum crown coverage of land surface (here assumed as 10 percent) and generally associated with wild flora, fauna and natural soil conditions; and not subject to agronomic practices. For the present assessments, a tree is defined as a woody perennial with a single main stem (except in coppice crops where multiple stems replace a single stem), a more or less definite crown and a minimum height of more than 5 meters on maturity. Only forest areas more than 100 ha (minimum area) are considered. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO 1993" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_425 a skos:Concept ;
    dct:creator "UN-FAO" ;
    dct:date "1995"^^xsd:gYear ;
    dct:source "http://figueresonline.com/csdafinal/English/publications/cdm/glossary.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Ecosystems with a minimum of 10% cover of trees and/or bamboos, generally associated with wild flora, fauna and natural soil conditions, and not subject to agricultural practices. The term forest is further subdivided, according to its origin, into two categories: (i) Natural forests: a subset of forest composed of tree species known to be indigenous to the area; and; (ii) Plantation forests: established artificially by afforestation on lands which previously did not carry forests within living memory; establishment artificially by reforestation of land which carried forest before, and involving the replacement of the indigenous species by a new and essentially different species or genetic variety. Definition applies for developing countries"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO 1995" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_426 a skos:Concept ;
    dct:creator "UN-FAO" ;
    dct:date "1995"^^xsd:gYear ;
    dct:source "http://figueresonline.com/csdafinal/English/publications/cdm/glossary.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land with tree crown cover (stand density) of more than about 20 percent of the area. Continuous forest with trees usually growing to more than about 7 m in height and able to produce wood. This includes both closed forest formations where trees of various storeys and undergrowth cover a high proportion of the ground, and open forest formations with a continuous grass layer in which tree synusia cover at least 10 percent of the ground. Definition applies for developed countries"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO 1995" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_427 a skos:Concept ;
    dct:creator "UN-FAO" ;
    dct:date "1997"^^xsd:gYear ;
    skos:broadMatch ex:Forest ;
    skos:definition "developed countries) Land with tree crown cover (stand density) of more than about 20 per cent of the area. Continuous forest with trees usually growing to more than about 7 m in height and able to produce wood. This includes both closed forest formations where trees of various storeys and undergrowth cover a high proportion of the ground, and open forest formations with a continuous grass layer in which tree synusia cover at least 10 per cent of the ground (FAO 1997"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO 1997" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_428 a skos:Concept ;
    dct:creator "UN-FAO" ;
    dct:date "1997"^^xsd:gYear ;
    dct:source "http://faov02.fao.org:70/0gopher_root%3a[fao.fra]def_uk.txt"^^xsd:anyURI,
        "http://www.ids.ac.uk/eldis/forests/forpap.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "developing countries) Ecological systems with a minimum of 10% crown coverage of trees and/or bamboos, generally associated with wild flora, fauna and natural soil conditions, and not subject to agricultural practices. [Source: from (concepts, definitions and methodology of the FAO Forest Resources Assessment 1990) via Bernhard Schlamadinger], (FAO 1997) and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO 1997" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_429 a skos:Concept ;
    dct:creator "UN-FAO" ;
    dct:date "1999"^^xsd:gYear ;
    dct:source "http://europe.mtnforum.org/rs/econfreports/MountainPeopleForestsAndTrees.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land with tree crown cover (or equivalent stocking level) of more than 10% and area of more than 0.5 hectares (ha). The trees should be able to reach a minimum height of 5m at maturity in situ.\""@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO 1999" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_43 a skos:Concept ;
    dct:creator "SAF" ;
    dct:source "http://home.comcast.net/~gyde/5-agency_paper-2.doc"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "1971) (Forest) Generally, an ecosystem characterized by a more or less dense and extensive tree cover. More particularly, a plant community predominantly of trees and other woody vegetation, growing more or less closely together. (FORD-ROBERTSON 1971) . (Society of American Foresters, 1971"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "SAF" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_430 a skos:Concept ;
    dct:creator "UN-FAO" ;
    dct:date "2000"^^xsd:gYear ;
    dct:source "http://www.fao.org/docrep/field/385907.htm#P280_16342"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land with tree a crown cover of more than 10 percent, and a tree height of at least five meters. An important distinction is made between closed (40% crown cover) and open (10 -40 % crown cover) forest. . Note: There is another definition forest for FRA 2000 based on land use"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO 2000" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_431 a skos:Concept ;
    dct:creator "UN-FAO" ;
    dct:date "2003"^^xsd:gYear ;
    dct:source "http://www.cof.orst.edu/cof/teach/fe456/Class_Materials/State%20of%20Worlds%20Forests/SOTWF_2003.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest land is defined as having more than 10 percent crown cover and an area of more than 0.5 ha, and excludes land predominantly used for agriculture"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO 2003" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_432 a skos:Concept ;
    dct:creator "UN-FAO" ;
    dct:date "2005"^^xsd:gYear ;
    dct:source "http://www.fao.org/es/ess/census/PROGwca2010/glossary_r7.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest: land with trees of height 5 metres or more with crown cover of more than 10% (paragraph 11.35"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO 2005" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_433 a skos:Concept ;
    dct:creator "UN-FAO" ;
    dct:date "2005"^^xsd:gYear ;
    dct:source "http://www.fao.org/docrep/013/i1757e/i1757e13.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land spanning more than 0.5 hectares with trees higher than 5 meters and a canopy cover of more than 10 percent, or trees able to reach these thresholds in situ. It does not include land that is predominantly under agricultural or urban land use. FRA 2005 and 2010"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO 2005" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_434 a skos:Concept ;
    dct:creator "UN-FAO" ;
    dct:date "2007"^^xsd:gYear ;
    dct:source "http://earthobservatory.nasa.gov/Features/Deforestation/printall.php"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "any area larger than one hectare (0.01 square miles) with a minimum tree cover of 10 percent to be forested"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO 2007" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_435 a skos:Concept ;
    dct:creator "UN-FAO" ;
    dct:date "2014"^^xsd:gYear ;
    dct:source "http://www.fao.org/uploads/media/glc-share-doc.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Tree covered areas -This class includes any geographic area dominated by natural tree plants with a cover of 10% or more. Other types of plants (shrubs and/or herbs) can be present, even with a density higher than trees. Areas planted with trees for afforestation purposes and forest plantations are included in this class. This class includes areas seasonally or permanently flooded with fresh water. It excludes coastal mangroves"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO 2014" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_436 a skos:Concept ;
    dct:creator "UN-FAO" ;
    dct:source "http://ddp-ext.worldbank.org/ext/ddpreports/viewSourceNotes?DIMENSION_NAME=WDI_Series&HIERARCHY=Topic&cubeId=7"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest area is land under natural or planted stands of trees, whether productive or not"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_437 a skos:Concept ;
    dct:creator "UN-FAO" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land covered by trees with a cover of more than 40% From: Graeme Wild GraemeW@za.sappi.com"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_438 a skos:Concept ;
    dct:creator "UN-FAO" ;
    dct:source "http://glossary.eea.europa.eu"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land with a tree canopy cover of more than 10% and an area of more than 0.5 ha"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_439 a skos:Concept ;
    dct:creator "UN-FAO-RAP" ;
    dct:date "2010"^^xsd:gYear ;
    dct:source "http://www.fao.org/docrep/012/i1594e/i1594e00.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest is defined as: land spanning more than 0.5 hectares, with trees higher than 5 metres and a canopy cover of more than 10 percent or trees able to reach these thresholds in situ. It does not include land that is predominantly agricultural or under urban use"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO-RAP 2010" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_44 a skos:Concept ;
    dct:creator "SAF" ;
    dct:source "http://www.safnet.org/aboutforestry/world.cfm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "2001) A forest is considered an area with at least 10 per cent tree canopy cover"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "SAF" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_440 a skos:Concept ;
    dct:creator "UN-FCCC" ;
    dct:source "http://cdm.unfccc.int/DNA"^^xsd:anyURI,
        "http://www.snvworld.org/en/regions/asia/ourwork/Documents/SNV_UnderstandingREDD.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest land - As part of COP7 (Marrakech accords) it was decided that parties could select a single value of tree height, crown area and area to define forests, subject to certain ranges. The Designated National Authority in each country is responsible for forest definition (see and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FCCC " ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_441 a skos:Concept ;
    dct:creator "UN-FCCC" ;
    dct:date "2001"^^xsd:gYear ;
    dct:source "http://www.worldgrowth.org/assets/file/WG%20Forestry_Development_Final%20Report.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "from the Marrakesh Accords of the Kyoto Protocol): An area of land: that is at least 0.05 – 1.0 hectares in size; which has more than 10-30 per cent of tree crown cover (or equivalent stocking levels); and which has trees that have the potential to reach a minimum height at maturity in situ of 2-5 metres. It may consist either of closed forest formations or open forest. Closed forest formations involve to a high proportion of the ground being covered by trees of various storeys and undergrowth"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FCCC 2001" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_445 a skos:Concept ;
    dct:creator "WCMC" ;
    dct:source "http://www.wcmc.org.uk/forest/data/cdrom2/text2.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "While not a definition per se, the WCMC uses a 30% tree canopy cover for the development its Global Current Forest Map"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "WCMC" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_446 a skos:Concept ;
    dct:creator "World Bank" ;
    dct:date "2000"^^xsd:gYear ;
    dct:source "http://www.holz.uni-goettingen.de/ek/woodsat/pdf/worldbankforestry.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Ecosystem with a minimum of 10 percent crown cover of trees and/or bamboo, generally associated with wild flora and fauna and natural soil conditions and not subject to agricultural practices. Forests are in two categories: • Natural forests: forests composed of tree species known to be indigenous to the area. • Plantation forests: established artificially by afforestation on lands previously non-forested within living memory, or established artificially by reforestation on land that was forested, by replacement of the indigenous species with a new and essentially different species or genetic variety"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "World Bank 2000" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_447 a skos:Concept ;
    dct:creator "World Bank" ;
    dct:date "2000"^^xsd:gYear ;
    dct:source "http://www.holz.uni-goettingen.de/ek/woodsat/pdf/worldbankforestry.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest, Open: Forest in which the tree canopy layer is discontinuous but covers at least 10 percent of the area and in which the grass layer is continuous"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "World Bank 2000" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_448 a skos:Concept ;
    dct:creator "World Bank" ;
    dct:date "2000"^^xsd:gYear ;
    dct:source "http://www.holz.uni-goettingen.de/ek/woodsat/pdf/worldbankforestry.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest. Closed: Forest with a stand density greater than 20 percent of the area, and where tree crowns nearly contact one another"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "World Bank 2000" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_449 a skos:Concept ;
    dct:creator "World Bank" ;
    dct:date "2005"^^xsd:gYear ;
    dct:source "http://siteresources.worldbank.org/INTARD/Resources/devpol_final_text.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Total Forest is defined as land with tree crown cover of more than 10 percent of the ground and area of more than 0.5 hectares. Tree height at maturity should exceed 5 meters. (source: Earthtrends, WRI"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "World Bank 2005" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_450 a skos:Concept ;
    dct:creator "World Bank" ;
    dct:date "2007"^^xsd:gYear ;
    dct:source "http://www.sasi.group.shef.ac.uk/worldmapper/display.php?selected=106"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land under natural or planted stands of trees"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "World Bank 2007" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_451 a skos:Concept ;
    dct:creator "World Bank" ;
    dct:date "2008"^^xsd:gYear ;
    dct:source "http://siteresources.worldbank.org/EXTARD/Resources/336681-1215724937571/eBook.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest – Minimum are of 1 ha of land with tree-crown cover (or equivalent stocking level) of more than 30 percent with trees able to reach the potential of a minimum height of 5 m at maturity in situ. Young plantations and lands used for forestry are included even though they may not meet the cover and height thresholds"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "World Bank 2008" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_452 a skos:Concept ;
    dct:creator "World Bank" ;
    dct:date "2012"^^xsd:gYear ;
    dct:source "http://data.worldbank.org/indicator/AG.LND.FRST.ZS"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest area is land under natural or planted stands of trees of at least 5 meters in situ, whether productive or not, and excludes tree stands in agricultural production systems (for example, in fruit plantations and agroforestry systems) and trees in urban parks and gardens"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "World Bank 2012" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_453 a skos:Concept ;
    dct:creator "World Bank" ;
    dct:source "http://www.iucn.org/themes/fcp/activities/publications/worldbankdraftdefinitions.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "An area of land of not less than 1.0 hectare with tree crown cover (or equivalent stocking level) of more than 10 per cent with trees with the potential to reach a minimum height of 2 meters at maturity in situ. A forest may consist of either closed forest formations where trees of various stories and undergrowth cover a high proportion of the ground or open forest. Young natural stands and all plantations which have yet to reach a crown density of 10 per cent or tree height of 2 meters are included under forest, as are areas normally forming part of the forest area which are temporarily unstocked as a result of human intervention such as harvesting or natural causes but which are expected to revert to forest. The definition includes forests dedicated to forest production, protection, multiple- uses or conservation, whether formally recognized or not. The definition excludes areas where other land uses not dependent on tree cover predominate, such as agriculture, grazing or settlements. In low forest-cover countries, the definition may be expanded to include areas covered by trees which fall below the 10 percent threshold for canopy density, but are considered forest under local conditions"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "World Bank" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_454 a skos:Concept ;
    dct:creator "WRI" ;
    dct:date "2003"^^xsd:gYear ;
    dct:source "http://earthtrends.wri.org/pdf_library/country_profiles/for_cou_188.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "include all areas dominated by evergreen or deciduous trees with a canopy cover of greater than 60% and a height exceeding 2 meters. Both broadleaf and needleleaf trees are included"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "WRI 2003" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_455 a skos:Concept ;
    dct:creator "WRI" ;
    dct:source "http://pdf.wri.org/indoforest_glossary.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land on which trees form the dominant vegetation type"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "WRI" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_456 a skos:Concept ;
    dct:creator "WRI" ;
    dct:source "http://pdf.wri.org/page_forests.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Terrestrial ecosystems dominated by trees, where the tree canopy covers at least 10 percent of the ground area"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "WRI" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_457 a skos:Concept ;
    dct:creator "WRI" ;
    dct:source "http://earthtrends.wri.org/pdf_library/country_profiles/for_cou_188.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Total forest area includes both natural forests and plantations. Total Forest is defined as land with tree crown cover of more than 10 percent of the ground and area of more than 0.5 hectares. Tree height at maturity should exceed 5 meters. These forest statistics are based primarily on forest inventory information provided by national governments"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "WRI" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land cover"@en .

ex:Forest_459 a skos:Concept ;
    dct:creator "EU" ;
    dct:date "2013"^^xsd:gYear ;
    dct:source "http://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:32013D0529"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "‘Forest’ means an area of land defined by the minimum values for area size, tree crown cover or an equivalent stocking level, and potential tree height at maturity at the place of growth of the trees, as specified for each Member State in Annex V. It includes areas with trees, including groups of growing young natural trees, or plantations that have yet to reach the minimum values for tree crown cover or equivalent stocking level or minimum tree height as specified in Annex V, including any area that normally forms part of the forest area but on which there are temporarily no trees as a result of human intervention, such as harvesting, or as a result of natural causes, but which area can be expected to revert to forest"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "EU 2013" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land use"@en .

ex:Forest_460 a skos:Concept ;
    dct:creator "EU Copenicus" ;
    dct:source "http://land.copernicus.eu/pan-european/high-resolution-layers/forests"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "The forest type product allows to get as close as possible to the FAO forest definition. In its original (20m) resolution it consists of two products: 1) a dominant leaf type product that has a MMU of 0.5 ha, as well as a 10% tree cover density threshold applied, and 2) a support layer that maps, based on the dominant leaf type product, trees under agricultural use and in urban context (derived from CLC and imperviousness 2009 data). For the final 100m product trees under agricultural use and urban context from the support layer are removed"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "EU Copenicus" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land use"@en .

ex:Forest_461 a skos:Concept ;
    dct:creator "EUROSTAT" ;
    dct:source "http://epp.eurostat.ec.europa.eu/cache/ITY_OFFPUB/KS-74-06-823/EN/KS-74-06-823-EN.PDF"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land with tree crown cover of more than 10 percent and area of more than 0.5 ha. The trees should be able to reach a minimum height of 5m at maturity in situ. Young natural stands and all plantations established for forestry purposes which have yet to reach a crown density of 10 percent or tree height of 5m are included under forest, as are areas normally forming part of the forest area but which are temporarily unstocked as a result of human intervention or natural causes but which are expected to revert to forest. Also included are forest nurseries and seed orchards and other small open areas within the forest, forest in national parks, nature reserves and other protected areas, windbreaks and shelterbelts of trees with an area of more than 0.5 ha and a width of more than 20m"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "EUROSTAT" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land use"@en .

ex:Forest_463 a skos:Concept ;
    dct:creator "IPCC" ;
    dct:date "2006"^^xsd:gYear ;
    skos:broadMatch ex:Forest ;
    skos:definition "This category includes all land with woody vegetation consistent with thresholds used to define Forest Land in the national greenhouse gas inventory. It also includes systems with a vegetation structure that currently fall below, but in situ could potentially reach the threshold values used by a country to define the Forest Land category"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "IPCC 2006" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land use"@en .

ex:Forest_464 a skos:Concept ;
    dct:creator "IPCC -Kyoto Protocol" ;
    dct:source "http://www.v-c-s.org/docs/AFOLU%20Guidance%20Document.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A minimum area of land of 0.05 – 1.0 hectares with tree crown cover (or equivalent stocking level) of more than 10 – 30 per cent with trees with the potential to reach a minimum height of 2 – 5 metres at maturity in situ. A forest may consist either of closed forest formations where trees of various storeys and undergrowth cover a high portion of the ground or open forest. Young natural stands and all plantations which have yet to reach a crown density of 10 – 30 per cent or tree height of 2 – 5 metres are included under forest, as are areas normally forming part of the forest area which are temporarily unstocked as a result of human intervention such as harvesting or natural causes but which are expected to revert to forest"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "IPCC -Kyoto Protocol" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land use"@en .

ex:Forest_465 a skos:Concept ;
    dct:creator "ITTO" ;
    dct:date "2005"^^xsd:gYear ;
    dct:source "http://www.cde.unibe.ch/University/pdf/Feu_CP_Vol6(3)_Foener_et_al_edited_00A.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forests, Permanent. ITTO defines permanent forests as ‘certain categories of land, whether public or private, that are to be kept under permanent forest cover to secure their optimal contribution to national development’ (ITTO, 2006"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "ITTO 2005" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land use"@en .

ex:Forest_466 a skos:Concept ;
    dct:creator "IUFRO" ;
    dct:date "2002"^^xsd:gYear ;
    dct:source "http://www.efi.int/files/attachments/publications/ir_06.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A land area with a minimum 10% tree crown coverage (or equivalent stocking level), or formerly having such tree cover and that is being naturally or artificially regenerated or that is being afforested"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "IUFRO 2002" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land use"@en .

ex:Forest_467 a skos:Concept ;
    dct:creator "TBFRA-0" ;
    dct:date "2001"^^xsd:gYear ;
    dct:source "http://epp.eurostat.ec.europa.eu/cache/ITY_OFFPUB/KS-BE-02-003/EN/KS-BE-02-003-EN.PDF"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "forest is defined as land with tree crown cover (or equivalent stocking level) of more than 10 per cent and area more than 0.5 ha. The trees should be able to reach a minimum height of 5 m at maturity in situ. Included are: • young natural stands and all plantations established for forestry purposes which have yet to reach the crown density of 10 percent or tree height of 5 m. • areas normally forming part of the forest area which are temporarily unstocked as a result of human intervention or natural causes but which are expected to revert to forest. • forest roads, cleared tracts, firebreaks and other small open areas, as well as forest nurseries and seed orchards that constitute an integral part of the forest. • forest in national parks, nature reserves and other protected areas such as those of special environmental, scientific, historical, cultural or spiritual interest. • windbreaks and shelter belts of trees with an area of more than 0.5 ha and a width of more than 20 m. • rubber wood plantations and cork oak stands. Excluded is the land predominantly used for agricultural practices"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "TBFRA-20010" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land use"@en .

ex:Forest_471 a skos:Concept ;
    dct:creator "UN-EP" ;
    dct:date "2007"^^xsd:gYear ;
    dct:source "http://www.unep.org/geo/geo4/report/Glossary.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land spanning more than 0.5 hectares with trees higher than 5 metres and a canopy cover of more than 10 per cent, or trees able to reach these thresholds in situ. It does not include land that is predominantly under agricultural or urban land use"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-EP 2007" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land use"@en .

ex:Forest_472 a skos:Concept ;
    dct:creator "UN-EP-GRID" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest is defined as >30% crown cover and the tree height shall be >7 m. Seedlings under forest are also included in this class. Areas occupied by forest and woodlands with a vegetation pattern composed of native or exotic coniferous trees, and which can be used for the production of timber or other forest products. The forest trees are under normal climatic conditions higher than 5 m with a canopy closure of 30% at least. www.grida.no/baltic/related/balans_landcover_classification_methodology_ver2.pdf"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-EP-GRID" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land use"@en .

ex:Forest_473 a skos:Concept ;
    dct:creator "UN-FAO" ;
    dct:date "1948"^^xsd:gYear ;
    dct:source "http://www.fao.org/docrep/x5345e/x5345e03.htm#some%20definitions"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Lands bearing vegetative associations dominated by trees of any size, capable of producing timber or other forest products or of exerting an influence on the climate or on the water regime. Also, lands from which forests have been recently clear cut or burned, but which will be reforested in the near future"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO 1948" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land use"@en .

ex:Forest_474 a skos:Concept ;
    dct:creator "UN-FAO" ;
    dct:date "1958"^^xsd:gYear ;
    dct:source "http://www.fao.org/documents/show_cdr.asp?url_file=/docrep/007/ad906t/AD906T05.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "All lands bearing vegetative associations dominated by trees of any size, exploited or not, capable of producing wood or other forest products, of exerting an influence on the climate or on the water regime, or providing shelter for livestock and wild life. Includes: Lands from which forests have been clear-cut or burned, but which will be reforested in the foreseeable future; Public and private forest of any size; Forest of slow growth and of dwarfed or stunted forms — e.g., subalpine; Bamboo lands; All land which is not part of a recognized fallow rotation of the shifting cultivator, and which will return to forest when he abandons the land; also lands under shifting cultivation on which forest production is maintained concurrently — e.g., Acacia senegal in Sudan; Savanna types with density averaging at least 0.05; Wattle (Acacia, spp.) plantations; Tree nurseries; Forest roads. Excludes: Areas occupied by orchards of fruit or nut trees, and plantations for non-forest crops such as rubber and cinchona; Areas occupied by individual trees or lines or groups of trees — for example, along roadways, canals and streams, or in city parks, private gardens and pastures — too small to be managed as forests; Areas of windbreak and shelterbelt trees that are in small groups or narrow strips, too small to be managed as forests; Lands primarily managed for permanent agriculture; All land which is part of a recognized fallow rotation of the shifting cultivator, or which will not return to forest even though it bear a light timber crop before being cut, burned over and re-cultivated"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO 1958" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land use"@en .

ex:Forest_475 a skos:Concept ;
    dct:creator "UN-FAO" ;
    dct:date "1960"^^xsd:gYear ;
    dct:source "http://www.fao.org/3/a-ad906t.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "All lands bearing vegetative associations dominated by trees of any size, exploited or not, capable of producing wood or other forest products, of exerting an influence on the climate or on the water regime, or providing shelter for livestock and wildlife. Includes: Lands from which forests have been clear-cut or burned, but which will be reforested in the foreseeable future; Public and private forest of any size; Forest of slow growth and of dwarfed or stunted forms e.g., subalpine; Bamboo lands; (y) All land which is not part of a recognized fallow rotation of the shifting cultivator, and which will return to forest when he abandons the land; also lands under shifting cultivation on which forest production is maintained concurrently e.g., Acacia senegal in Sudan; Savanna types with density averaging at least 0.05 (5%?); Wattle (Acacia, spp.) plantations; Tree nurseries; Forest roads. Excludes: Areas occupied by orchards of fruit or nut trees, and plantations for non-forest crops such as rubber and cinchona; Areas occupied by individual trees or lines or groups of trees for example, along roadways, canals and streams, or in city parks, private gardens and pastures too small to be managed as forests; Areas of windbreak and shelterbelt trees that are in small groups or narrow strips, too small to be managed as forests; Lands primarily managed for permanent agriculture; All land which is part of a recognized fallow rotation of the shifting cultivator, or which will not return to forest even though it bear a light timber crop before being cut, burned over and re-cultivated"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO 1960" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land use"@en .

ex:Forest_476 a skos:Concept ;
    dct:creator "UN-FAO" ;
    dct:date "1963"^^xsd:gYear ;
    dct:source "http://www.fao.org/3/a-ad907t.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "All lands bearing vegetative associations dominated by trees of any size, exploited or not, capable of producing wood or other forest products, of exerting an influence on the climate or on the water regime, or providing shelter for livestock and wild life. Includes: (i) Lands from which forest has been clear-cut or burned, but which will be reforested in the foreseeable future ; Public and private forests of any size; Forest of slow growth and of dwarfed or stunted forms - e.g., subalpine; Bamboo stands; a/ All lands affected by shifting cultivation, other than those now being prepared or used for agricultural crops, which will become stocked with forest in the foreseeable future; Savanna types with density averaging, at least 0.05 (see definition of density below); Wattle plantations; (Acacia, spp.)a/ One-rotation plantations for production of timber; Nurseries of forest trees; Forest roads and other small open areas that constitute an integral part of the forest. Excludes: (i) Areas occupied by orchards of fruit or nut trees, and plantations for non-forest crops such as rubber and cinchona; Areas occupied by individual trees or lines or groups of trees - for example, along roadways, canals and streams, or in city parks, private gardens and pastures - too small to be managed as forest; Areas of windbreak and shelterbelt trees that are in small groups or narrow strips, too small to be managed as forest; Lands primarily managed for permanent agriculture; All lands under shifting cultivation being prepared or used for agricultural crops and such lands which will not return to forest in the foreseeable future . Density is estimated on the basis of how completely the tree crowns fill the space in the stand, measured as a ratio of the area of vertical projections of the crowns to the total area of the stand. Sites capable of supporting only open stands will thus never have 1.00 density even though the tree-stand may be the maximum that can be grown on the site. Includes all species, commercial and non-commercial"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO 1963" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land use"@en .

ex:Forest_477 a skos:Concept ;
    dct:creator "UN-FAO" ;
    dct:date "1987"^^xsd:gYear ;
    dct:source "http://www.fao.org/legal/legstud/frmdocrep/41_AK476E.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "forest stands by referring to them as “plant formations where the principal products consist of timber” 1/, to the exclusion of any other plants that are not otherwise agricultural products 2"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO 1987" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land use"@en .

ex:Forest_478 a skos:Concept ;
    dct:creator "UN-FAO" ;
    dct:date "1988"^^xsd:gYear ;
    dct:source "http://resweb.llu.edu/rford/docs/VGD/LUCC/background2.html"^^xsd:anyURI,
        "http://www.wcslc.edu/pers_pages/r-ford/LUCC/unit2/background2.html#Forests"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "and Woodland) Land under natural or planted stands of trees, whether productive or not, and includes land from which forests have been cleared but that will be reforested in the foreseeable future (FAO 1988a: 3). , and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO 1988" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land use"@en .

ex:Forest_479 a skos:Concept ;
    dct:creator "UN-FAO" ;
    dct:date "1992"^^xsd:gYear ;
    dct:source "http://www.mmm.fi/english/minkonf/criteria.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land under natural or planted stand of trees, whether productive or not. Included are shrub land, savannah etc., land from which forests have been cleared but that will be reforested in the foreseeable future, area occupied by forest roads, small cleared tracts and other small open areas within the forest and which constitute an integral part of the forest. [Sources: FAO yearbook Production. 1992. Vol. 46. FAO Statistics Series No. 112. 281 pp. ]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO 1992" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land use"@en .

ex:Forest_480 a skos:Concept ;
    dct:creator "UN-FAO" ;
    dct:date "1995"^^xsd:gYear ;
    dct:source "http://www.archive.org/stream/forestresourcesa034883mbp/forestresourcesa034883mbp_djvu.txt"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "land under natural or planted stands of trees, whether productive or not, including land from which forest has been cleared but that will be reforested in the foreseeable future, and including areas occupied by roads, small cleared tracts and other small open areas within the forest which constitute an integral part of the forest"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO 1995" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land use"@en .

ex:Forest_481 a skos:Concept ;
    dct:creator "UN-FAO" ;
    dct:date "1997"^^xsd:gYear ;
    dct:source "http://faostat.fao.org/site/379/DesktopDefault.aspx?PageID=379"^^xsd:anyURI,
        "http://www.fao.org/waicent/faosat/agricult/landuse-e.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "and Woodland). Land under natural or planted stands of trees, whether productive or not. This category included land from which trees have been cleared but will be reforested in the foreseeable future, but it excludes woodland or forest used only for recreation purposes. Stands of permanent crops such as rubber, fruit trees, nut trees, are classed as permanent crops under agricultural lands. [Source: FAO Production Yearbook. 10.10.97. ] and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO 1997" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land use"@en .

ex:Forest_482 a skos:Concept ;
    dct:creator "UN-FAO" ;
    dct:date "2001"^^xsd:gYear ;
    dct:source "http://www.fao.org/docrep/003/y0900e/y0900e11.htm#P1_7"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest includes natural forests and forest plantations. The term is used to refer to land with a tree canopy cover of more than 10 percent and area of more than 0.5 ha. Forests are determined both by the presence of trees and the absence of other predominant land uses. The trees should be able to reach a minimum height of 5 m. Young stands that have not yet reached, but are expected to reach, a crown density of 10 percent and tree height of 5 m are included under forest, as are temporarily unstocked areas. The term includes forests used for purposes of production, protection, multiple use or conservation (i.e. forest in national parks, nature reserves and other protected areas), as well as forest stands on agricultural lands (e.g. windbreaks and shelterbelts of trees with a width of more than 20 m) and rubberwood plantations and cork oak stands. The term specifically excludes stands of trees established primarily for agricultural production, for example fruit tree plantations. It also excludes trees planted in agroforestry systems"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO 2001" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land use"@en .

ex:Forest_483 a skos:Concept ;
    dct:creator "UN-FAO" ;
    dct:date "2001"^^xsd:gYear ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forests are lands of more than 0.5 hectares, with a tree canopy cover of more than 10 per cent, which are not primarily under agricultural or urban land use. Explanatory note: Forests are determined both by the presence of trees and the absence of other predominant land uses. The trees should be able to reach a minimum height of 5 meters in situ. Areas under reforestation which have yet to reach a crown density of 10 per cent or tree height of 5 m are included, as are temporarily unstocked areas, resulting from human intervention or natural causes, that are expected to regenerate. The term specifically includes: forest nurseries and seed orchards that constitute an integral part of the forest; forest roads, firebreaks and other small open areas; forest in national parks, nature reserves and other protected areas such as those of specific scientific, historical, cultural or spiritual interest; windbreaks and shelterbelts of trees with an area of more than 0.5 ha and width of more than 20 m; plantations primarily used for forestry purposes, including rubberwood plantations and cork oak stands. The term specifically excludes trees planted primarily for agricultural production, for example in fruit plantations and agroforestry systems. FAO Forest Resource Assessment (FAO 2000b"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO 2001" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land use"@en .

ex:Forest_484 a skos:Concept ;
    dct:creator "UN-FAO" ;
    dct:date "2004"^^xsd:gYear ;
    dct:source "http://www.fao.org/forestry/foris/webview/forestry2/index.jsp?siteId=4261&sitetreeId=13629&langId=1&geoId=0"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land spanning more than 0.5 hectares with trees higher than 5 meters and a canopy cover of more than 10 percent, or trees able to reach these thresholds in situ. It does not include land that is predominantly under agricultural or urban land use. Explanatory notes: 1. Forest is determined both by the presence of trees and the absence of other predominant land uses. The trees should be able to reach a minimum height of 5 meters in situ. Areas under reforestation that have not yet reached but are expected to reach a canopy cover of 10 percent and a tree height of 5 m are included, as are temporarily unstocked areas, resulting from human intervention or natural causes, which are expected to regenerate. 2. Includes areas with bamboo and palms provided that height and canopy cover criteria are met. 3. Includes forest roads, firebreaks and other small open areas; forest in national parks, nature reserves and other protected areas such as those of specific scientific, historical, cultural or spiritual interest. 4. Includes windbreaks, shelterbelts and corridors of trees with an area of more than 0.5 ha and width of more than 20 m. 5. Includes plantations primarily used for forestry or protection purposes, such as rubberwood plantations and cork oak stands. 6. Excludes tree stands in agricultural production systems, for example in fruit plantations and agroforestry systems. The term also excludes trees in urban parks and gardens"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO 2004" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land use"@en .

ex:Forest_485 a skos:Concept ;
    dct:creator "UN-FAO" ;
    dct:date "2005"^^xsd:gYear ;
    dct:source "http://www.fao.org/es/ess/census/PROGwca2010/chapter11_r7.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest land is land not classified as mainly “agricultural land” and is land with crown cover of more than 10 percent of trees able to reach a mature height of 5 metres or more. It includes natural and plantation forests. Areas that are temporarily not under trees but are expected to revert to forest are included. Forest tree nurseries that form an integral part of the forest should be included"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO 2005" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land use"@en .

ex:Forest_486 a skos:Concept ;
    dct:creator "UN-FAO" ;
    dct:date "2006"^^xsd:gYear ;
    dct:source "http://www.worldgrowth.org/assets/file/WG%20Forestry_Development_Final%20Report.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "from the Global Forest Resources Assessment 2005): An area of land: that is more than 0.5 hectares in size; which has trees that are more than five metres in height; and which has a canopy cover of more than 10 per cent. It includes an area of land which has trees that have the potential to meet these thresholds in situ. It also includes areas which are temporarily unstocked (due to human intervention or natural causes) which are expected to regenerate. It excludes land that is predominantly under agriculture or urban use"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO 2006" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land use"@en .

ex:Forest_487 a skos:Concept ;
    dct:creator "UN-FAO" ;
    dct:date "2006"^^xsd:gYear ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land spanning more than 0.5 hectares with trees higher than 5 metres and a canopy cover of more than 10 percent, or trees able to reach these thresholds in situ. It does not include land that is predominantly under agriculture or urban use. Explanatory note: Forest is determined both by the presence of trees and the absence of other predominant land uses. The trees should be able to reach a minimum height of 5 m in situ. Areas under reforestation that have not yet reached but are expected to reach a canopy cover of 10 percent and tree height of 5 m are included, as are temporarily unstocked areas, resulting from human intervention or natural causes, which are expected to regenerate. It includes areas with bamboo and palms provided that height and canopy cover criteria are met. It includes forest roads, firebreaks and other small open areas; forest in national parks, nature reserves and other protected areas, such as those of specific scientific, historical, cultural or spiritual interest. It includes windbreaks, shelterbelts and corridors of trees with an area of more than 0.5 ha and width of more than 20 m. It includes plantations primarily used for forestry and protection purposes, such as rubberwood plantations and cork oak. ftp://ftp.fao.org/docrep/fao/009/j9345e/j9345e00.pdf"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO 2006" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land use"@en .

ex:Forest_488 a skos:Concept ;
    dct:creator "UN-FAO" ;
    dct:date "2010"^^xsd:gYear ;
    dct:source "http://www.fao.org/docrep/014/am665e/am665e00.pdf"^^xsd:anyURI,
        "http://www.fao.org/forestry/foris/pdf/fra/2010/north-and-central-america/united-states-virgin-islands-2010-224.doc"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest Land spanning more than 0.5 hectares with trees higher than 5 meters and a canopy cover of more than 10 percent, or trees able to reach these thresholds in situ. It does not include land that is predominantly under agricultural or urban land use. Explanatory notes 1. Forest is determined both by the presence of trees and the absence of other predominant land uses. The trees should be able to reach a minimum height of 5 meters in situ 2. Includes areas with young trees that have not yet reached but which are expected to reach a canopy cover of 10 percent and tree height of 5 meters. It also includes areas that are temporarily unstocked due to clear-cutting as part of a forest management practice or natural disasters, and which are expected to be regenerated within 5 years. Local conditions may, in exceptional cases, justify that a longer time frame is used. 3. Includes forest roads, firebreaks and other small open areas; forest in national parks, nature reserves and other protected areas such as those of specific environmental, scientific, historical, cultural or spiritual interest. 4. Includes windbreaks, shelterbelts and corridors of trees with an area of more than 0.5 hectares and width of more than 20 meters. 5. Includes abandoned shifting cultivation land with a regeneration of trees that have, or is expected to reach, a canopy cover of 10 percent and tree height of 5 meters. 6. Includes areas with mangroves in tidal zones, regardless whether this area is classified as land area or not. 7. Includes rubber wood, cork oak and Christmas tree plantations. 8. Includes areas with bamboo and palms provided that land use, height and canopy cover criteria are met. 9. Excludes tree stands in agricultural production systems, such as fruit tree plantations, oil palm plantations and agroforestry systems when crops are grown under tree cover. Note: Some agroforestry systems such as the “Taungya” system where crops are grown only during the first years of the forest rotation should be classified as forest.FRA 2010"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO 2010" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land use"@en .

ex:Forest_489 a skos:Concept ;
    dct:creator "UN-FAO Kotka III" ;
    dct:date "1996"^^xsd:gYear ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land under natural or planted stands of trees with tree crown cover (or equivalent stocking level) of more than 10 percent and area of more than 0.5 ha. whose primary use is forestry. The trees should be able to reach a minimum height of 5 m at maturity in situ. Includes: closed forest formations where trees of various storeys and undergrowth cover a height portion of the ground and open forest formations with a continuous vegetation layer in with tree crown cover exceeds 10 percent; plantations primarily used for forestry purposes, including rubberwood plantations and cork oak stands; areas normally forming part of the forest land area which are temporarily unstocked as a result of human intervention or natural causes but which are expected to revert to stocked forest; young natural stands and all plantations established for forestry purposes which have yet to reach a crown density of 10 percent; forest roads, cleared tracts, such as firebreaks and other small open areas, as well as forest in national parks, nature reserves and other protected areas such as those of specific environmental, scientific, historical, cultural or spiritual interest; windbreak and shelterbelts of an area of more than 0.5 ha and width of more than 20 m. (Anon. 1996"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO Kotka III 1996" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land use"@en .

ex:Forest_490 a skos:Concept ;
    dct:creator "UN-FAO" ;
    dct:source "http://www.fao.org/DOCREP/005/Y4357E/y4357e20.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest land: land used mainly for wood production and other forest products, protection"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land use"@en .

ex:Forest_491 a skos:Concept ;
    dct:creator "UN-FAO" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land presently in forest, or showing evidence of having been recently under forest cover - e.g. recently clear-cut or burned and not being used for other purposes - which is expected/intended to revert to forest in the near future, either naturally or by artificial reforestation. This is because of its suitability and desirability, in view of its functions as a sustainable source of timber, as watershed protector or local climate regulator, as a shelter for macro-fauna and as biodiversity herder; the land is not currently being used for or subject to agricultural practices including planted perennial tree cropping or intensively managed grazing (FAO 19?? - IPCC"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land use"@en .

ex:Forest_492 a skos:Concept ;
    dct:creator "UN-FAO" ;
    dct:date "2013"^^xsd:gYear ;
    dct:source "http://www.fao.org/docrep/017/ap862e/ap862e00.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land spanning more than 0.5 hectares with trees higher than 5 meters and a canopy cover of more than 10 percent, or trees able to reach these thresholds in situ. It does not include land that is predominantly under agricultural or urban land use. (Note – there are 9 explanatory notes with the definition. See"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO-2013" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land use"@en .

ex:Forest_493 a skos:Concept ;
    dct:creator "UN-FAO-FRA" ;
    dct:date "1958"^^xsd:gYear ;
    skos:broadMatch ex:Forest ;
    skos:definition "All lands bearing vegetative associations dominated by trees of any size, exploited or not, capable of producing wood or other forest products, of exerting an influence on the climate or on the water regime, or providing shelter for livestock and wild life. Includes: (i) Lands from which forests have been clear-cut or burned, but which will be reforested in the foreseeable future; (ii) Public and private forest of any size; (iii) Forest of slow growth and of dwarfed or stunted forms - e.g., subalpine; (iv) Bamboo lands; (v) All land which is not part of a recognized fallow rotation of the shifting cultivator, and which will return to forest when he abandons the land; also lands under shifting cultivation on which forest production is maintained concurrently - e.g., Acacia senegal in Sudan; (vi) Savanna types with density averaging at least 0.05; (vii) Wattle (Acacia,spp.) plantations; (viii)Tree nurseries; (ix) Forest roads. Excludes: (i) Areas occupied by orchards of fruit or nut trees, and plantations for non-forest crops such as rubber and cinchona; (ii) Areas occupied by individual trees or lines or groups of trees - for example, along roadways, canals and streams, or in city parks, private gardens and pastures - too small to be managed as forests; (iii) Areas of windbreak and shelterbelt trees that are in small groups or narrow strips, too small to be managed as forests; (iv) Lands primarily managed for permanent agriculture; (v) All land which is part of a recognized fallow rotation of the shifting cultivator, or which will not return to forest even though it bear a light timber crop before being cut, burned over and re-cultivated. From: Alexander.Korotkov@unece.org. Date: Thu, 15 Oct 1998 17:09:40 +0200"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO-FRA 1958" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land use"@en .

ex:Forest_494 a skos:Concept ;
    dct:creator "UN-FAO-FRA" ;
    dct:date "1990"^^xsd:gYear ;
    skos:broadMatch ex:Forest ;
    skos:definition "Developed Countries) Land with tree crown cover of more than 20 % of the area. Trees should be able to grow to a height of 7 m. Included are: 1. The area with young trees or coppice able to form forest in the future. 2. The area temporarily unstocked due to regeneration or damage. Minimum area outside continuous forest: 0.5 ha. Minimum width outside continuous forest: 15 m. The forest roads and firebreaks etc. narrower than minimum width of nurseries and storage less than 0.5 ha are included in the forest area. (minimum size stand; for instance 15 m x 333 m). (Koehl and Paivinen 1996"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO-FRA 1990" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land use"@en .

ex:Forest_495 a skos:Concept ;
    dct:creator "UN-FAO-FRA  and UNSD" ;
    dct:date "2000"^^xsd:gYear ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land with tree crown cover (or equivalent stocking level) of more than 10 percent and area of more than 0.5 ha. The trees should be able to reach a minimum height of 5 m at maturity in situ. May consist either of closed forest formations where trees of various storeys and undergrowth cover a high portion of the ground; or of open forest formations with a continuous vegetation cover in which tree cover exceeds 10 percent. Young natural stands and all plantations established for forestry purposes which have yet to reach a crown density of 10 percent or tree height of 5 m are included under forest, as are temporarily unstocked as a result of human intervention or natural causes but which are expected to revert to forest. Includes: Forest nurseries and seed orchards that constitute an integral part of the forest; forest roads, cleared tracts, firebreaks, and other small open areas within the forest; forest in national parks, nature reserves and other protected areas such as those of special environmental, scientific, historical, cultural, or spiritual interest; windbreaks and shetlterbelts of trees with an area of more than 0.5 ha and a width of more than 20 m. Rubberwood plantations and cork oak stands are included. Excludes: Land predominantly used for agricultural practices (UN-ECE/FAO 1997). Also www.un.org/Depts/unsd/enviro/q2001land.pdf United Nations Statistics Division (UNSD"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO-FRA 2000 and UNSD" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land use"@en .

ex:Forest_496 a skos:Concept ;
    dct:creator "UN-FAO-FRA" ;
    dct:date "2003"^^xsd:gYear ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land under forestry or no land use, spanning more than 0.5 hectares; with trees higher than 5 meters and a canopy cover of more than 10 percent, or trees able to reach these thresholds in situ. NOTE: Forests are determined both by the presence of trees and the absence of other predominant land uses. The trees should be able to reach a minimum height of 5 meters in situ. Areas under reforestation which have yet to reach a crown density of 10 percent or tree height of 5 meters are included, as are temporarily unstocked areas, resulting from human intervention or natural causes that are expected to regenerate. The term specifically includes forest roads, firebreaks and other small open areas; forest in national parks, nature reserves and other protected areas such as those of specific scientific, historical, cultural or spiritual interest; windbreaks, shelterbelts and corridors of trees with an area of more than 0.5 hectare and width of more than 20 meters; plantations primarily used for forestry purposes, including rubberwood plantations and cork oak stands. The term specifically excludes tree stands used in agricultural production systems, for example in fruit plantations and agroforestry systems. The term also excludes trees in urban parks and gardens. (Source: Smith, W.B. 2003. Thoughts to simplify FRA Core Data Attributes and Definitions. 8 p. USDA Forest Service, Washington, DC"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO-FRA 2003" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land use"@en .

ex:Forest_497 a skos:Concept ;
    dct:creator "UN-FAO-FRA  Proposed" ;
    dct:date "2010"^^xsd:gYear ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land with tree canopy cover of more than 10 percent and area of more than 0.5 hectares. Trees should be able to reach a minimum height of 5m at maturity in situ. Source: Brad Smith, USFS. May 2002"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO-FRA 2010 Proposed" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land use"@en .

ex:Forest_498 a skos:Concept ;
    dct:creator "UN-FAO-FRA draft Tree land" ;
    skos:broadMatch ex:Forest ;
    skos:definition "All land with tree cover of more than 10 % (or equivalent stocking level), or formerly having such tree cover and that is being naturally or artificially regenerated or that is being afforested. Land used for agricultural purposes but with 10 % or more tree cover is included. It includes coniferous and non-coniferous trees, bamboos and palms. Linear formations and planting over about 20 metres wide are also included. (Kotka-II"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FAO-FRA draft Tree land" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land use"@en .

ex:Forest_499 a skos:Concept ;
    dct:creator "UN-FCCC" ;
    dct:date "2001"^^xsd:gYear ;
    dct:source "http://www.unfccc.int/resource/docs/cop6secpart/l11r01.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "“Forest” is a minimum area of land of 0.05-1.0 hectares with tree crown cover (or equivalent stocking level) of more than 10-30 per cent with trees with the potential to reach a minimum height of 2-5 metres at maturity in situ. A forest may consist either of closed forest formations where trees of various storeys and undergrowth cover a high proportion of the ground or open forest. Young natural stands and all plantations which have yet to reach a crown density of 10-30 per cent or tree height of 2-5 metres are included under forest, as are areas normally forming part of the forest area which are temporarily unstocked as a result of human intervention such as harvesting or natural causes but which are expected to revert to forest. (From Marrakesh Accords) and. ftp://ftp.fao.org/docrep/fao/009/j9345e/j9345e00.pdf"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FCCC 2001" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land use"@en .

ex:Forest_500 a skos:Concept ;
    dct:creator "UN-FCCC" ;
    dct:source "http://epress.anu.edu.au/green_carbon/pdf/imp_carbon_policy.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forests are defined under the United Nations Framework Convention on Climate Change (UNFCCC) as woody vegetation of at least 2 m in height and 10 per cent canopy cover"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FCCC" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land use"@en .

ex:Forest_503 a skos:Concept ;
    dct:creator "World Bank" ;
    dct:date "2010"^^xsd:gYear ;
    dct:source "http://www.tradingeconomics.com/greece/forest-area-percent-of-land-area-wb-data.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest area is land under natural or planted stands of trees of at least 5 meters in situ, whether productive or not, and excludes tree stands in agricultural production systems (for example, in fruit plantations and agroforestry systems) and trees in urban parks and gardens"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "World Bank 2010" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "International"@en,
        "Land use"@en .

ex:Forest_509 a skos:Concept ;
    dct:creator "WWF" ;
    dct:date "2007"^^xsd:gYear ;
    dct:source "http://www.wwf.gr/en/index.php?option=com_content&view=category&layout=blog&id=113&Itemid=131"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A forest is a community of trees and bushes, which extend on a large area and maintain a close interrelationship in ways that their canopy, fauna, soil and climatic conditions create a special ecosystem. Forested lands have similar characteristics to forests, but vegetation is more sparse. They are however very important in maintaining biological balance. Most of these areas, if protected from human activity, will often grow into forests"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "WWF 2007" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "International"@en .

ex:Forest_649 a skos:Concept ;
