ex:Forest_162 a skos:Concept ;
    dct:creator "http://home.comcast.net/~gyde/africover.html" ;
    dct:source "http://home.comcast.net/~gyde/africover.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Areas on which vegetation is dominated by woody perennial plants having 6 meters in height or greater. Examples are loblolly pine forests, black spruce swamps, live oak stands, pinyon-juniper, maple, hickory, larch, and birch. Includes areas on which vegetation is dominated by orchards or groves for fruit or nut production such as citrus, apples, peaches, pecans, filberts, trees grown primarily for Christmas trees, nurseries and arboretums"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "http://home.comcast.net/~gyde/africover.html" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_163 a skos:Concept ;
    dct:creator "about 150-200 years" ;
    skos:broadMatch ex:Forest ;
