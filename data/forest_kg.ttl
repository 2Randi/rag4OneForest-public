ex:Forest_249 a skos:Concept ;
    dct:creator "anexo III.6" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Selvas - Constituye parte de la categoria “Formacion . Vegetacion preominanatementearborea en climas calido-humedos a calido-subhumedos. Se caracterizan por tener especies dominates arboraas de afinidad tropical. Incluye dos tipos de vegetaction: Selve perennifoia y subperennifolia y Selva caducifolia y subcaducifolia. A su vez abarca a ocho comunidades: Selva alta y mediana perennifoila, Selva baja perennikfolia, Selva alta y mediana subpoerennifolia, Selva baja subperennifolia, Selva mediana caducifolia y subcaducifolia, Sel va baha caducifolia y subcaducifolia, Matrorral subtropical y sel va espinosav (UNAM 2000"@es ;
    skos:inScheme ex:ForestScheme ;
    skos:note "anexo III.6" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_25 a skos:Concept ;
    dct:source "http://www.deanverderers.org.uk/glossary.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Its traditional definition is a territory, usually unenclosed, and not necessarily woodland but often covered with woods of varying density, but also included heathland, wood pasture, arable and even villages. It was designated by perambulation and used by the sovereign for his or her assigned, hunting, and subject to his will by forest law. The protection of deer and their habitat was paramount. In early centuries, forest virtually meant the King’s hunting ground"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "General"@en .

ex:Forest_250 a skos:Concept ;
    dct:creator "UNAM" ;
    dct:date "2000"^^xsd:gYear ;
    skos:broadMatch ex:Forest ;
    skos:definition "Selvas - Vegetacion predominantemente arborea en climas calido-humedos a calido-subhumedos. Se caracterizan por tener especies arboreas de afinidad tropical"@es ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UNAM 2000" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

