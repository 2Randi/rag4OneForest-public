ex:CrownCoverOrCrownClosure_1 a skos:Concept ;
    dct:source "http://www.privateforestry.org.au/glos_a-g.htm"^^xsd:anyURI ;
    skos:definition "The percentage of a given area covered by tree crowns"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "Crown Cover or Crown Closure"@en .

ex:CrownCover_1 a skos:Concept ;
    dct:source "http://www.deq.state.or.us/wq/TMDLs/Umatilla/UmatillaTMDLAppxA-1.pdf"^^xsd:anyURI ;
    skos:definition "The degree to which the crowns of trees are nearing general contact with one another"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "Crown cover"@en .

ex:Definitions_1 a skos:Concept ;
    skos:broadMatch ex:Forest ;
    skos:definition "forest, tree, forest summary, woodland, afforestation, deforestation, reforestation, other terms"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "Definitions"@en .

ex:DeforestationArabic_1 a skos:Concept ;
    dct:spatial "Morocco" ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Deforestation (Arabic : Zawal Al Ghabah, French : Déforestation, Spanish : deforestacion) – Aggression (negative action) leading to the removal of trees and stands from the forest. This agreesion, if not stopped in time, could put in jeopardy the preservation of the forest. The cause could be anthropic (cutting), fire (burning), or livestock (overgrazing). Mohammed Ellatifi, m.ellatifi@ellatifi.8m.com"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Morocco" ;
    skos:prefLabel "Deforestation Arabic"@en .

ex:DeforestationArabic_2 a skos:Concept ;
    dct:spatial "Yemen" ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Deforestation (Arabic : Zawal Al Ghabah, French : Déforestation, Spanish : deforestacion) – Aggression (negative action) leading to the removal of trees and stands from the forest. This agreesion, if not stopped in time, could put in jeopardy the preservation of the forest. The cause could be anthropic (cutting), fire (burning), or livestock (overgrazing). Mohammed Ellatifi, m.ellatifi@ellatifi.8m.com"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Yemen" ;
    skos:prefLabel "Deforestation Arabic"@en .

ex:Deforestation_1 a skos:Concept ;
    dct:source "http://www.cgiar.org/cifor/publications/occpaper/occpaper9.html"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Definitions are grouped depending on if they are changes in land cover, land use, or both. Additional discussions of the meaning of \"deforestation\" may be found in Sunderlin, William D.; Resosudarmo, Ida Aju Pradnja. Rate and Causes of Deforestation in Indonesia: Towards a Resolution of the Ambiguities"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_10 a skos:Concept ;
    dct:creator "EC" ;
    dct:date "2008"^^xsd:gYear ;
    dct:source "http://ec.europa.eu/environment/forests/deforestation.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Deforestation is the permanent destruction of forests and woodlands"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "EC 2008" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_100 a skos:Concept ;
    dct:source "http://www.wfmz.com/weather/What-is-deforestation/180118"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The clearing Earth's forests on a massive scale, often resulting in damage to the quality of the land"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_101 a skos:Concept ;
    dct:source "http://epdweb.engr.wisc.edu/dmc/courses/hazards/BB02-apx1.html"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The clearing of a previously forested area. Though humans are the primary deforesters, natural agents, such as volcanic eruptions, erosion, and landslides may also contribute. Clear cutting, if followed by reforestation, is not an act of deforestation"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_102 a skos:Concept ;
    dct:source "http://www.cobeconet.com/resources/worldbank/glossary.html"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The clearing of forested land"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_103 a skos:Concept ;
    dct:source "http://www.ask.com/question/what-is-deforestation"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The clearing of forests mainly by human activity, which results in the damage to the quality of the land. Forests are cut down in the process"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_104 a skos:Concept ;
    dct:source "http://lifestyle.iloveindia.com/lounge/what-is-deforestation-11731.html"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The clearing of forests mainly due to human activity by the process of logging or burning"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_105 a skos:Concept ;
    dct:source "http://www.reliefweb.int/library/mcda/refman/glossary.html"^^xsd:anyURI,
        "http://www.unisdr.org/unisdr/glossaire.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The clearing or destruction of a previously forested area. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_106 a skos:Concept ;
    dct:source "http://info.live58.org/why-should-i-care-about-deforestation/"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The clearing the earth’s forest on a massive scale, resulting in damage to the quality of the land"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_107 a skos:Concept ;
    dct:source "http://www.pachamama.org/effects-of-deforestation"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The clearing, destroying, or otherwise removal of trees through deliberate, natural or accidental means"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_108 a skos:Concept ;
    dct:source "http://www.undp.org/seed/forest/pdf/InnovatForesFinanc.pdf"^^xsd:anyURI,
        "http://www.usask.ca/agriculture/caedac/dbases/glossary.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The conversion of forested to non-forested land. Deforestation can involve the cutting and burning of trees to provide land for agricultural purposes or clearing for residential and industrial uses. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_109 a skos:Concept ;
    dct:source "http://www.nap.edu/openbook.php?record_id=1985&page=663"^^xsd:anyURI,
        "http://www.theblackvault.com/documents/ota/Ota_4/DATA/1984/8426.PDF"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The conversion of forests to land uses that have a tree cover of less than 10 percent. 1984 and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_11 a skos:Concept ;
    dct:creator "EC-DGVIII" ;
    dct:source "http://europa.eu.int/comm/dg08/forests/en/en4_6.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The depletion of tree crown cover to less than 10 per cent"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "EC-DGVIII" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_110 a skos:Concept ;
    dct:creator "especially in the rain forest" ;
    dct:source "http://ellerbruch.nmu.edu/classes/cs255f03/cs255students/jedens/P12/deforestation.ppt"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The cutting down and burning of the trees in our forests"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "especially in the rain forest" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_111 a skos:Concept ;
    dct:source "http://environment.nationalgeographic.com/environment/global-warming/deforestation-overview.html"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The cutting down and clearing away forest on a very large scale"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_112 a skos:Concept ;
    dct:source "http://gradestack.com/CBSE-Class-9/What-is-Deforestation-/14919-2955-3388-study-wtw"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The cutting down and clearing of the forests"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_113 a skos:Concept ;
    dct:creator ", Nov" ;
    dct:date "2003"^^xsd:gYear ;
    dct:source "http://www.britannica.com"^^xsd:anyURI,
        "http://www.rss.chalmers.se/gem/Education/RSES-2003/final_report_group_1.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The cutting down and clearing of trees from forests, usually causing ecological harm. Encyclopædia Britannica. Encyclopædia Britannica Online. [Online]. Available: and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "2003, Nov." ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_114 a skos:Concept ;
    dct:source "http://dictionary.cambridge.org/define.asp?key=deforestation*1+0"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The cutting down of trees in a large area"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_115 a skos:Concept ;
    dct:source "http://www.spcforests.org/Library/usestatus/usestatus.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The deliberate and accidental destruction or removal of forests through the use of fire, felling for timber and fuel, overgrazing, clearance or destruction for agricultural and urban-industrial expansion, and other human activities"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_116 a skos:Concept ;
    dct:source "http://europa.eu.int/comm/development/forests/en/en4_6.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The depletion of tree crown cover to less than 10 per cent"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_117 a skos:Concept ;
    dct:source "http://www.ocdsb.edu.on.ca/WOODSweb/geomatics/English/glossary.html"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The destruction of a forest by removal of trees and plants"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_118 a skos:Concept ;
    dct:source "http://www.kgv.edu.hk/eden/glossary.php"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The destruction of forest. This normally refers to deforestation of tropical rainforests in Indonesia, Brazil and in West Africa"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_119 a skos:Concept ;
    dct:source "http://dictionary.cambridge.org/define.asp?key=deforestation*1+0"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The destruction of forests by people"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_12 a skos:Concept ;
    dct:spatial "Fiji" ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "Removal of forested areas. Malakai Sevudredre, Conservator of Forests, F.9641/2. 01/06/2000"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Fiji" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_120 a skos:Concept ;
    dct:creator "followed by soil oxidation and/or erosion" ;
    dct:source "http://www.ficus.usf.edu/docs/guide_issues/glossary/D.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The destruction of forests, usually caused by clear-cutting , poor agricultural practices, agricultural overuse, overcutting of forests, or overgrazing"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "followed by soil oxidation and/or erosion" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_121 a skos:Concept ;
    dct:source "http://www.icons.umd.edu/resource/glossary.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The destruction of the world's forests, mainly rain forests, through direct human activity such as logging or slash and burn clearing for agriculture and grazing, and the indirect effects of pollution and acid rain"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_122 a skos:Concept ;
    dct:creator "e.g., unsustainable forestry practices, agricultural and range land clearing, and the over exploitation of wood products for use as fuel" ;
    dct:source "http://www.cia.gov/cia/publications/factbook/docs/notes.html"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The destruction of vast areas of forest without planting new growth"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "e.g., unsustainable forestry practices, agricultural and range land clearing, and the over exploitation of wood products for use as fuel" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_124 a skos:Concept ;
    dct:source "http://www.uiowa.edu/~africart/teachers/glossary/GlD.html"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The large scale cutting down or clearing away of trees"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_125 a skos:Concept ;
    dct:source "http://www.internet.ve/wildlife/glosario.htm"^^xsd:anyURI,
        "http://www.nationalgeographic.com/wildworld/glossary.html"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The large-scale removal of trees from a habitat dominated by forest. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_126 a skos:Concept ;
    dct:source "http://www.lfc.edu/academics/biology/westley/adam2.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The logging or general destruction of forest"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_127 a skos:Concept ;
    dct:source "http://www.globalchange.umich.edu/globalchange2/current/lectures/deforest/deforest.html"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The long-term reduction of the tree canopy cover below a 10 percent threshold"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_128 a skos:Concept ;
    dct:source "http://www.prb.org/pubs/lessons/5billion/glossary.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The loss of trees due to overcutting of forests. Source"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_129 a skos:Concept ;
    dct:source "http://www.lehigh.edu/~kaf3/books/reporting/glossary.html"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The loss of tropical forests due to collection of fuelwood, commercial logging, shifting cultivation, grazing, road construction, ranching, mining and fire. Leads to soil erosion and flooding and endangers wildlife through habitat destruction"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_13 a skos:Concept ;
    dct:spatial "France" ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "deforestation = déforestation = déboisement = essartage (autrefois) = défrichement (mais ce terme est souvent plus vague) : destruction durable d'une forêt \"Michel Godron\" michel.godron@libertysurf.fr"@fr ;
    skos:inScheme ex:ForestScheme ;
    skos:note "France" ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_130 a skos:Concept ;
    dct:source "http://www.theforestproject.co.uk/why-take-action/deforestation"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The loss or destruction of natural forests and is an increasing global problem with far reaching environmental and economic consequences"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_131 a skos:Concept ;
    dct:source "http://environment.about.com/od/biodiversityconservation/f/deforestation-overview.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The loss or destruction of naturally occurring forests, primarily due to human activities such as logging, cutting trees for fuel, slash-and-burn agriculture, clearing land for livestock grazing, mining operations, oil extraction, dam building, and urban sprawl or other types of development and population expansion"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_132 a skos:Concept ;
    dct:source "http://www.abf90.dial.pipex.com/bco6.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The mass destruction, usually for the supply of timber, of large areas of forest"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_133 a skos:Concept ;
    dct:source "http://www.eia.doe.gov/oiaf/1605/ggrpt/glossary.html"^^xsd:anyURI,
        "http://www.theadvisorygroup.com/PDF2/publications/Carbon%20Sequestration%20Paper.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The net removal of trees from forested land. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_134 a skos:Concept ;
    dct:source "http://www.nafi.com.au/k12/ourforests/glossary.html"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The permanent clearing of forest areas, preventing regrowth e.g. clearing land for agriculture"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_135 a skos:Concept ;
    dct:source "http://ps.ucdavis.edu/classes/ire001/env/deforest.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The permanent destruction of forests and woodlands"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_136 a skos:Concept ;
    dct:source "http://abe.msstate.edu/csd-tc/p3-g2/intro.htm"^^xsd:anyURI,
        "http://www.panda.org/resources/factsheets/forests/frame.htm?31defor.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The permanent destruction of indigenous forests and woodlands. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_137 a skos:Concept ;
    dct:source "http://anmf.web1000.com/BIBLIOGRAPHY%20ON%20AFRICA%20MOUNTAINS.html"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
    skos:definition "The permanent loss of forests to other land uses such as agriculture, grazing, new settlements, infrastructure, and dam reservoirs"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "DEFORESTATION"@de .

ex:Deforestation_138 a skos:Concept ;
    dct:source "http://www.sovereignty.net/p/land/gba-gloss.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Deforestation ;
