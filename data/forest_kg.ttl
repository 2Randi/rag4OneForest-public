    skos:inScheme ex:ForestScheme ;
    skos:note "Cameroon" ;
    skos:prefLabel "Dense Forest"@no ;
    skos:scopeNote "Land cover"@en,
        "National"@en .

ex:Devegetation_1 a skos:Concept ;
    dct:creator "UN-FCCC-IPCC" ;
    dct:source "http://www.ipcc-nggip.iges.or.jp/public/gpglulucf/gpglulucf_files/Task2/Degradation.pdf"^^xsd:anyURI ;
    skos:definition "A direct human-induced long-term loss (persisting for X years or more) of at least Y% of vegetation [characterized by cover / volume / carbon stocks] since time T on vegetation types other than forest and not subject to an elected activity under Article 3.4 of the Kyoto Protocol. Vegetation types consist of a minimum area of land of Z hectares with foliar cover of W%"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "UN-FCCC-IPCC" ;
    skos:prefLabel "Devegetation"@da .

