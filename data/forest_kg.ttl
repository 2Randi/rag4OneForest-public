    skos:note "Argentina" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1046 a skos:Concept ;
    dct:date "2005"^^xsd:gYear ;
    dct:source "http://www.nature-ic.am/res/pdfs/legislation/general/Forest%20Code%20of%20RA.pdf"^^xsd:anyURI ;
    dct:spatial "Armenia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "interconnected and interacting integrity of biological diversity dominated by tree-bush vegetation and of components of natural environment on forest lands or other lands allocated for afforestation with the minimal area of 0,1 ha, minimal width of 10 m and with tree crowns covering at least 30% of the area, as well as non-forested areas of previously forested forest lands. Forest Code of Armenia"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Armenia 2005" ;
    skos:prefLabel "Forest"@no ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1047 a skos:Concept ;
    dct:creator "Old" ;
    dct:source "http://www.rfa.gov.au/nfps/gloss.html"^^xsd:anyURI ;
    dct:spatial "Australia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "An area, incorporating all living and non-living components, that is dominated by trees having usually a single stem and a mature or potentially mature stand height exceeding 5 metres, and with existing or potential projective cover of overstorey strata about equal to or greater than 30 per cent. This definition includes Australia's diverse native forests and plantations, regardless of age. It is also sufficiently broad to encompass areas of trees that are sometimes described as woodlands. The focus of this Statement excludes woodlands"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Australia -Old" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1048 a skos:Concept ;
    dct:date "1977"^^xsd:gYear ;
    dct:spatial "Austria" ;
    skos:broadMatch ex:Forest ;
    skos:definition "An area stocked by trees (a list of tree species in this context is given in an annex to the Austrian Forestry Act), if the stocking of trees represents an area of at least 1000 m2 and is of an average width of at least 10 m. Forest areas, which are unstocked due to forest management practices (for instance harvesting areas or areas used for timber storage, skidding tracks or forest roads), are still referred to as \"forest land.\" (Austrian Forestry Act (Federal Legal Gazette no. 440/1975, as amended Federal Legal Gazette 231/1977, 142/1978 and 576/1987) From: Weiss Peter weissp@ubavie.gv.at"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Austria 1977" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1049 a skos:Concept ;
    dct:creator "–" ;
    dct:date "2011"^^xsd:gYear ;
    dct:source "http://www.tradingeconomics.com/barbados/forest-area-sq-km-wb-data.html"^^xsd:anyURI ;
    dct:spatial "Barbados" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest area is land under natural or planted stands of trees of at least 5 meters in situ, whether productive or not, and excludes tree stands in agricultural production systems (for example, in fruit plantations and agroforestry systems) and trees in urban parks and gardens"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Barbados – 2011" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_105 a skos:Concept ;
    dct:creator "http://www.globalff.org/Feature_Articles/Previous_Articles/pre-defo.htm and http://www.geocities.com/atlas/word/gff_deforest.html" ;
    dct:source "http://www.geocities.com/atlas/word/gff_deforest.html"^^xsd:anyURI,
        "http://www.globalff.org/Feature_Articles/Previous_Articles/pre-defo.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A natural, self-sustaining community characterized by vertical structure created by the presence of trees. ( and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "http://www.globalff.org/Feature_Articles/Previous_Articles/pre-defo.htm and http://www.geocities.com/atlas/word/gff_deforest.html" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_1050 a skos:Concept ;
    dct:date "2000"^^xsd:gYear ;
    dct:spatial "Belarus" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest includes land covered in trees (main and other forest-forming species), non-continuous forest growth, nurseries, and plantations. Not covered in trees - openings, slashes, dead stands, cuttings, clearings. (For FRA 2000 - Source: UN/ECE 2000 p .73"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Belarus 2000" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1051 a skos:Concept ;
    dct:date "1969"^^xsd:gYear ;
    dct:source "http://extwprlegs1.fao.org/docs/pdf/bhu2744.pdf"^^xsd:anyURI ;
    dct:spatial "Bhutan" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest means any land under forest which no person has acquired a permanent heritable and transferable right of use and occupancy"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Bhutan 1969" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1052 a skos:Concept ;
    dct:creator "Bolivia" ;
    dct:date "2002"^^xsd:gYear ;
    dct:source "http://www.fao.org/docrep/005/y2328e/y2328e03.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "By principal land use: in Bolivia, forest land refers to areas covered with natural forest, cultivated, intended for various uses, and also treeless lands which may be reforested. Meadows and pasture, with scattered trees or shrubs, do not constitute forest lands"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Bolivia 2002" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1053 a skos:Concept ;
    dct:creator "Bolivia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "TERRENO FORESTAL: Es superficie cubierta de bosque nativo, cultivado, destinado para diferentes usos; también son terrenos desprovistos de árboles, que que pueden ser reforestados. Las praderas y pastizales con árboles o arbustos dispersos, no constituye un terreno forestal. Aquel que utilizado técnica y científicamente, proporciona en forma permanente mayor utilidad económica, protectora y escénica, con cultivo forestal de bajo aprovechamiento agropecuario. Source: Luis Castello faopaf@caoba.entelnet.bo Adjunto sírvase encontrar la versión no oficial y premilinar del Glosario Forestal elaborado por el Proyecto de Apoyo a la Coordinación e Implementación del Plan de Acción Forestal para Bolivia"@es ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Bolivia" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1054 a skos:Concept ;
    dct:creator "Bosnia – FbiH – RS" ;
    dct:source "http://www.fris.sk/Phare/Projects/ManagementOfForestInEurope/PDF/annex2.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest land is land on which forest is grown or land that is, because its natural characteristics, foreseen or used for this purpose. Forest land is land covered with forest or where it is more rational, due to natural characteristics, to have a forest or cultivate the land for forestry production"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Bosnia – FbiH – RS" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1055 a skos:Concept ;
    dct:creator "Bosnia" ;
    dct:date "2001"^^xsd:gYear ;
    dct:source "http://www.iufro.org/download/file/5574/4510/61300-jundola01_pdf/"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest Law, land covered by forest trees in the form of stands on an area bigger than 0.1 hectare is considered forest. Separated groups of forest trees on an area smaller than 0,1 hectare, forest nurseries, windscreen zones and parks in populated areas are not considered forests. Land where forests are grown or which are, because of their natural features and management conditions, anticipated to be favorable for growing of forests are considered as forestlands"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Bosnia 2001" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1056 a skos:Concept ;
    dct:date "2013"^^xsd:gYear ;
    dct:source "http://www.efi.int/files/attachments/publications/annex_1_to_efi_technical_report_88__2013.pdf"^^xsd:anyURI ;
    dct:spatial "Bosnia and Herzegovina" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forests (definitions) Including all areas covered with forest tree species, minimum (0.16 ha, minimum width 20 m) with minimum crown coverage 20%, whatever age, or origin of the tree. Growth more than 5 m in height. Forest including areas temporarily unstocked areas (with crown cover less than 20%) if higher coverage can be expected in the near future. Forest includes forest roads inside the forest area, less than 5 m in wide (could be covered with tree crowns) and streams. Forest does not include forest roads wider than 5 m, and streams and rivers wider than 7 m (at the highest water level"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Bosnia and Herzegovina 2013" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1057 a skos:Concept ;
    dct:date "1997"^^xsd:gYear ;
    dct:spatial "Burkina Faso" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Au sens du present Code, sont consideres comme forets les espaces occupes par des formations vegetales d'arbres et d'arbustes, a l'exclusion de celles resultant d'activites agricoles (all area but town and agricultural lands) Source: au BF d'apres le Code Forestier au Burkina Faso (ministere de l'environnement et de l'eau, 1997) Loi n[006/97/ADP du 31 janvier 1997, portant Code Forestier au Burkina FAso, Article 12. Via Daniel-Yyves Alexandre"@fr ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Burkina Faso 1997" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1058 a skos:Concept ;
    dct:date "1985"^^xsd:gYear ;
    dct:spatial "Burundi" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Aux termes du présent Code, on entend, d'une manière générale, par forêts ou boisements: 1. Les terrains recouverts d'une formation végétale à base d'arbres ou d'arbustes, que cette formation soit naturelle ou résultant de semis ou de plantations faits de main d'homme: a. capables de produite du bois ou des produits forestiers; b. ou exerçant un effet indirect sur le climat, le régime des eaux ou le sol. 2. les terrains qui étaient recouverts de forêts ou boisements récemment coupés à blanc ou incendiés, mais qui seront susceptibles de régénération naturelle ou de reboisement artificiel. LEX-FAOC002166. BURUNDI: Loi n&ordm; 1-02 portant Code forestier. Date of text: 25 March 1985"@fr ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Burundi 1985" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1059 a skos:Concept ;
    dct:date "2009"^^xsd:gYear ;
    dct:source "http://www.cedc-info.org/English/qtzcfg/8c09d4969ce4d2be/"^^xsd:anyURI ;
    dct:spatial "Cambodia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest, means a unit of natural or artificial forest ecosystem, in the form of wet, flooded or dry land, comprised of mixed vegetation, natural or planted, wildlife and other natural resources located therein, primarily utilized for timber and NTFPs production conservation and other forest services. Lands to which this law does not apply include all land designated by the State as permanent agricultural land including, chamcar, idle land to be designated for non timber agriculture production, industrial land and land for urbanization and construction. Cambodia Economic Development Council(CEDC"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Cambodia 2009" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_106 a skos:Concept ;
    dct:source "http://hassam.hubpages.com/hub/Types-Of-Forests"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A piece of land that is thickly covered with trees is the general of definition of a forest. Forest is also known as woods, weald or woodlands"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_1060 a skos:Concept ;
    dct:date "1994"^^xsd:gYear ;
    dct:source "http://files.forestsnetwork.org/Chapter4.pdf"^^xsd:anyURI ;
    dct:spatial "Cameroon" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Cameroon is based on the 1994 Forest Code, in which community forests are defined as forest areas in the ‘non-Permanent Forest Domain’ (NPFD), a land use designation that permits timber extraction, agriculture, mining, and other utilisation activities. Each community forest must not exceed 5,000 hectares, and must be managed by village communities following a simplified management plan that excludes the use of heavy machinery"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Cameroon 1994" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1061 a skos:Concept ;
    dct:creator "– n and Northern Affairs" ;
    dct:source "http://www.ainc-inac.gc.ca/pr/pub/bldg/frst/glss_e.html"^^xsd:anyURI ;
    dct:spatial "Canada" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land primarily intended for growing, or currently supporting, forest. Includes land not now forested, i.e. clear-cut lands; northern lands that are forested but not intended for any use; and plantations"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Canada – Indian and Northern Affairs" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1062 a skos:Concept ;
    dct:date "2011"^^xsd:gYear ;
    dct:source "http://nfdp.ccfm.org/terms/terms_e.php?letter=f"^^xsd:anyURI ;
    dct:spatial "Canada" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Silviculture/forest management: An area managed for the production of timber and other forest produce, or maintained under woody vegetation for such indirect benefits as the protection of watersheds, the provision of recreation areas, or the preservation of natural habitat"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Canada 2011" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1063 a skos:Concept ;
    dct:spatial "Canada" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land primarily intended for growing, or currently supporting, forest. Includes land not now forested (e.g., clearcuts), and plantations. Source: \"Forest Inventory Terms in Canada.\" From: \"Haddon, Brian\" <BHaddon@nrcan.gc.ca"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Canada" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1064 a skos:Concept ;
    dct:spatial "Chile" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Terrenos de aptitud preferentemente forestal (Lands with forestry preferably aptitude) - Todos aquellos terrenos que por las condiciones de clima y suelo no deban ararse en forma permanente, estén cubiertos o no de vegetación, excluyendo los que sin sufrir degradación puedan ser utilizados en agricultura, fruticultura o ganadería intensiva. All terrain where climate and soils conditions do not allow permanent plowing, being or not covered with vegetation, excluding those that would not be degraded and can be used in agriculture, fruit production or intensive cattle raising. From: Patricio Gonzalez <pgonzale@infor.cl"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Chile" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1065 a skos:Concept ;
    dct:date "2014"^^xsd:gYear ;
    dct:source "http://redd.unfccc.int/files/20.10.15col__frel_english_clean_numbers.pdf"^^xsd:anyURI ;
    dct:spatial "Colombia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "For the purposes of the National REDD + Strategy (ENREDD +), and in particular for the construction of this FREL, forest is defined as: Land mainly covered by trees which might contain shrubs, palms, guaduas, grass and vines, in which tree cover predominates with a minimum canopy density of 30%, a minimum canopy height (in situ) of 5 meters at the time of identification , and a minimum area of 1.0 ha. Commercial forest plantations, palm crops and planted trees for agricultural production are excluded. In this frame, the minimum mapping unit used for the FREL is 1.0 ha"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Colombia 2014" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1066 a skos:Concept ;
    dct:date "1930"^^xsd:gYear ;
    dct:spatial "Comoros" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Article premier) Par forêt, au sens de la présente loi, on entend toutes surfaces répondant aux qualifications ci-après : - les surfaces couvertes d'arbres ou de végétation ligneuse, autres que plantées à des fins exclusives de production fruitière, de production de fourrage ou d'ornementation; - les surfaces occupées par les arbres et les buissons situés sur les berges des cours d'eau et lacs et sur des terrains érodés ; - les terrains dont les fruits exclusifs ou principaux sont des produits forestiers, tels qu'ils sont définis à l'alinéa ci-dessous ; Sont qualifiés produits des forêts : tous produits naturels issus de leur exploitation et dont la liste fera l’objet d’un décret.Article 2 : Sont assimilés aux forêts : - les surfaces non boisées d'un bien fonds forestier telles que les clairières ou surfaces occupées par des routes forestières, constructions et installations nécessaires à la gestion forestière ; - les terrains non boisés à vocation forestière, notamment pour la conservation et la restauration des sols, la conservation de la biodiversité, la régulation des systèmes hydriques ou l'accroissement de la production forestière dès qu'ils auront fait l'objet d'un classement tel que défini aux articles 76 et suivants de la présente loi; - les terrains déboisés depuis moins de cinq ans et n'ayant pas fait l'objet d'une autorisation de défrichement ; - les marais, les peuplements d'aloës ; - les peuplements naturels et purs d'arbres produisant des fruits, tels que les manguiers et anacardiers ; - les mangroves, les bois sacrés, les raphières (coeur de palmiers Ravinala). Article 3 : Des surfaces minimales peuvent être fixées par voie réglementaire et adaptées au niveau régional. Article 4 : Ne sont pas considérés comme forêts : - les cultures d’arbres et boisements plantés sur un terrain non forestier ; - les jardins boisés, les allées et parcs urbains et les pépinières non situées sur des biens fonds forestiers ; - les cultures d'arbres et boisements destinés à une exploitation à court terme, plantés sur un terrain non forestier, annoncés et enregistrés comme tels auprès de l'Administration forestière lors de leur établissement. - toute surface donnant des produits agricoles, sauf s'il s'agit de surface couverte d'arbres ayant poussé naturellement, ou de reboisements ; - les pâturages, suivant la vocation des sols définie par la loi. EX-FAOC002302. MADAGASCAR; COMOROS: Décret du 25 janvier 1930 réorganisant le régime forestier à Madagascar et dépendances, compte tenu des modifications jusqu'au 1941. Date of text: 25 January 1930"@fr ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Comoros 1930" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1067 a skos:Concept ;
    dct:creator ", Democratic Republic" ;
    dct:source "http://www.nortonrose.com/files/forest-carbon-rights-in-redd-countries-a-snapshot-of-africa-pdf-994-kb-32479.pdf"^^xsd:anyURI ;
    dct:spatial "Congo" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Article 1(a) Forestry Code: “land covered with plant formation based on trees or bushes suitable for providing forest products, sheltering wild fauna and exercising a direct orindirect effect on the soil, climate or water system” and land that could benefit from reforestation under Article 1(b) Forestry Code: “land which, having previously contained a tree or shrub plant covering, has been cut bare or burnt and for which natural regeneration or reforestation actions are implemented.”"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Congo, Democratic Republic" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1068 a skos:Concept ;
    dct:date "2010"^^xsd:gYear ;
    dct:source "http://www.efi.int/files/attachments/publications/annex_1_to_efi_technical_report_88__2013.pdf"^^xsd:anyURI ;
    dct:spatial "Croatia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "National definition: Forest is defined as the land covered by forest trees formed as forest stand over an area larger than 10 ars (1 ar = 100 m2). Separate forest tree groups over an area up to 10 ars, forest nurseries, windbreaks, tree avenues, and parks in settlements are not considered forests. Faculty of forestry University of Zagreb, Ministry for regional development of forestry and water management, 2010"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Croatia 2010" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1069 a skos:Concept ;
    dct:date "1998"^^xsd:gYear ;
    dct:spatial "Cuba" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Patrimonio forestal lo integran los bosques naturales y artificiales, los terrenos destinados a esta actividad,las áreas deforestadas con condiciones para la actividad forestal, así como los árboles de especies forestales que se desarrollen en forma aislada o en grupos, cualquiera que sea su ubicación y tenencia. También forman parte del patrimonio forestal las áreas inforestales... (Artículo 3) Area inforestal: área dentro del bosque y en terrenos destinados a la actividad forestal no aptas para el crecimiento del bosque,como pastizales, ciénagas, ríos, arroyos, embalses, asomos rocosos, viales,viveros,áreas destinadas para el autoabastecimiento, criaderos de animales e instalaciones. (Artículo 2 ,Ley Forestal). Bibliografía.-Ley No 85.Ley Forestal en Gaceta Oficial de la República de Cuba,Edición Ordinaria,La Habana, Lunes 31 de Agosto de 1998.\"Nelida Puentes Alvarez\" <npuentes@eco.upr.edu.cu"@es ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Cuba 1998" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_107 a skos:Concept ;
    dct:source "http://wings.ucdavis.edu/Book/Atmosphere/beginner/deforestation-01.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A place with many trees and plants"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_1070 a skos:Concept ;
    dct:date "2002"^^xsd:gYear ;
    dct:source "http://www.efi.int/files/attachments/publications/annex_1_to_efi_technical_report_88__2013.pdf"^^xsd:anyURI ;
    dct:spatial "Cyprus" ;
    skos:broadMatch ex:Forest ;
    skos:definition "It corresponds to FRA definition except the threshold value for minimum area, which is 1 ha, with trees higher than 5 m and a crown cover of more than 10%, or trees able to reach these thresholds in situ. Land predominantly under agricultural or urban use not included. Old definition: Forest Land with tree crown cover of more that 10 % and area of more than 1 ha. Cyprus Department of forests ministry of agriculture, natural resources and environment, 2006. Kyriacou K. 2002"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Cyprus 2002" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1071 a skos:Concept ;
    dct:creator "Czech Republic" ;
    dct:date "1995"^^xsd:gYear ;
    dct:source "http://www.uhul.cz/images/ke_stazeni/legislativa_jazyky/Lesni_zakon_en.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest stands with its environment and land designated for the fulfillment of forest functions. Forest functions shall mean benefits towards the general well-being of the society conditional on the existence of forests, which consist of wood-producing and non-wood-producing functions. Forest stands shall mean trees and shrubs of forest tree species which, in their particular environment, fulfil forest functions. [Source: Act on Forests and Amendments to Some Acts (the Forest Act) dated 3 November 1995. Ministry of Agriculture of the Czech Republic. Prague, 1996. 58 pp. From: \"Maksym Polyakov\" <mpoliak@pcomp.usau.kiev.ua Date: Mon, 15 Jun 1998 11:32:47 +0300 (MSD)] and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Czech Republic 1995" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1072 a skos:Concept ;
    dct:creator "Czech Republic" ;
    dct:date "1997"^^xsd:gYear ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land destined to fulfill the forest functions, that is: (a) land with forest stands and land after clear cutting ready for reforestation, forest line and soft road of a width less than 4 m; (b) forest roads, water surfaces, land above timber line and other land serving for forest management. Minimum area is 0.01 ha with a minimum width of 20 m and with no definition on crown cover or stand density. (European Communities 1997b - p. 1225"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Czech Republic 1997" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1073 a skos:Concept ;
    dct:creator "Czech Republic" ;
    dct:date "2004"^^xsd:gYear ;
    dct:source "http://www.efi.int/files/attachments/publications/annex_1_to_efi_technical_report_88__2013.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest land: land with forest stands and land after cutting ready for reforestation, forest line and soft roads of width less than 4 m. Forest roads, water surfaces, land above timber line and other land serving for forest management. Minimum area is 0.01 ha and with a minimum width of 20 m. NIL definition: Forest - areas (subplot), which are forest land as defined in the Forest Act No. 289/95 Coll. § 3, paragraph 1, letter a) and the Ministry of Agriculture Decree No. 84/1996 (which are divided into forest land stand soil and forest-free areas). Are also included in this category sites that have the character of the forest and not defined in the above legislation (e.g. forests on agricultural land). Ustav pro Hospodarskou Upravu Lesu (UHUL), 2004"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Czech Republic 2004" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1074 a skos:Concept ;
    dct:creator "Czech Republic" ;
    dct:source "http://afoludata.jrc.it/carboinvent/cimd_eufoin_data.cfm#countrylist"^^xsd:anyURI,
        "http://www.carpathianconvention.org/NR/rdonlyres/7D98EFF7-133E-4B26-9488-EBF73ACD26B5/0/Report1_ForestResources.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "definition of forest is given by law: \"Forest land is land destined to fulfil the forest functions that is: land with forest stands and land after clear cutting ready for reforestation, forest line and soft road of a width less than 4 m; forest roads, water surfaces, land above timber line and other land serving for forest management.\" The Czech forest management instructions give 0.01 ha as a minimum area of forest, with a minimum width of 20 m. (CarboInvent JRC"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Czech Republic" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1075 a skos:Concept ;
    dct:date "1998"^^xsd:gYear ;
    dct:spatial "Denmark" ;
    skos:broadMatch ex:Forest ;
    skos:definition "More than 0.5 ha, broader than 30 m, covered by tree-species which are or is able to be more that 6 m's in height. (From: PMP@sns.dk Date: Tue, 29 Sep 1998 09:31:59 +0100). Note: at first glance this appears to be a land cover description, but subsequent definitions of afforestation and reforestation for Denmark show that \"forest\" is really a land use term"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Denmark 1998" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1076 a skos:Concept ;
    dct:date "2011"^^xsd:gYear ;
    dct:source "http://www.efi.int/files/attachments/publications/annex_1_to_efi_technical_report_88__2013.pdf"^^xsd:anyURI ;
    dct:spatial "Denmark" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land with tree crown cover (or equivalent stocking level) of more than 10% and area of more than 0.5 ha. The trees should be able to reach a minimum height of 5 m at maturity in situ. Areas with agricultural production and urban land are not included.FOREST EUROPE, UNECE AND FAO, 2011"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Denmark 2011" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1077 a skos:Concept ;
    dct:spatial "Denmark" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Areas covered with species capable of producing wood that grow to a height of more than 6 m. Forest or plantation shall be more than 0.5 ha in size. Forest area should be wider than 20 m (no hedgerows) although narrow sections are allowed as part of a larger forest. The forest area has -- or is expected to have within a short period -- a crown density of at least 50 percent. Older stands of Christmas trees on arable land are considered forest, if at the time of inventory, they were in such a condition the wood production was at least the same economic importance as the production of Christmas trees. (UN/ECE 1992 p. 140"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Denmark" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1078 a skos:Concept ;
    dct:date "2002"^^xsd:gYear ;
    dct:source "http://www-sydsvenskskogsvetenskap.slu.se/Grundutbildning/Masterk/2002/Estonia/forest.html"^^xsd:anyURI ;
    dct:spatial "Estonia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "By legal definition, \"forest\" means a site of woody vegetation with an area of at least 0,5 ha, and at least one of the following requirements: Trees with the height of at least 1,3 m and with the canopy coverage of at least 30 %. If the site is managed for obtaining timber or other forest products"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Estonia 2002" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1079 a skos:Concept ;
    dct:date "2005"^^xsd:gYear ;
    dct:source "http://www.efi.int/files/attachments/publications/annex_1_to_efi_technical_report_88__2013.pdf"^^xsd:anyURI ;
    dct:spatial "Estonia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest land (= productive forest land, National definition) Minimum area 0.1 ha and 30% crown cover, with height more than 1.3 m, with average annual productivity more than 1 m3/ha of stem wood (incl. temporarily unstocked areas). Pärt E., Adermann V., Merenäk M., 2010"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Estonia 2005" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_108 a skos:Concept ;
    dct:source "http://www.morcd.org/totorcd/Forestry%20Terms.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A plant and animal community dominated by trees"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_1080 a skos:Concept ;
    dct:date "2006"^^xsd:gYear ;
    dct:source "https://www.riigiteataja.ee/en/eli/504092017014/consolide"^^xsd:anyURI ;
    dct:spatial "Estonia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "a plot of land with an area of at least 0.1 hectares and woody plants with the height of at least 1.3 metres and with the canopy density of at least 30 per cent grow there. The land of yards, residential land, parks, cemeteries, green areas, berry gardens, orchards, forest nurseries, gardening centres, arboreta, and plantations of trees and shrubs is not deemed forest land for the purposes of this Act. [RT I, 06.07.2017, 1 – entry into force 01.09.2017]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Estonia 2006" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1081 a skos:Concept ;
    dct:date "2010"^^xsd:gYear ;
    dct:source "http://www.efi.int/files/attachments/publications/annex_1_to_efi_technical_report_88__2013.pdf"^^xsd:anyURI ;
    dct:spatial "Estonia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest land (reference definition, applied parallel with National definition since 2005) Land with tree crown cover (or equivalent stocking level) of more than 10% and area of more than 0.5 ha. The trees should be able to reach a minimum height of 5 m at maturity in situ (incl. temporarily unstocked areas). Forest land (= productive forest land, National definition) Minimum area 0.1 ha and 30% crown cover, with height more than 1.3 m, with average annual productivity more than 1 m3/ha of stem wood (incl. temporarily unstocked areas). Pärt E., Adermann V., Merenäk M., 2010"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Estonia 2010" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1082 a skos:Concept ;
    dct:creator "FIJI" ;
    dct:date "2016"^^xsd:gYear ;
    dct:source "http://www.parliament.gov.fj/wp-content/uploads/2017/03/Bill-No-13-Forest.pdf"^^xsd:anyURI ;
    dct:spatial "Fiji" ;
    skos:broadMatch ex:Forest ;
    skos:definition "“forest” includes but is not limited to— (a) land spanning more than 0.5 hectares with trees higher than 5 metres and a canopy cover of more than 10 percent, or trees able to reach these thresholds in situ; (b) areas with bamboo and forest palms provided that height and canopy cover criteria are met; forest road, fire breaks and other small open areas; (c) areas defined by both the presence of trees and the absence of other predominant land uses; and (d) excluding tree stands in agricultural production systems"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "FIJI 2016" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1083 a skos:Concept ;
    dct:date "1997"^^xsd:gYear ;
    dct:spatial "Finland" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land with the potential capacity to produce a mean annual increment of at least 1 m3/ha stemwood, over bark, given an optimum tree species mixture, growing stock volume and prescribed rotations. (European Communities 1997a - p. 186"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Finland 1997" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1084 a skos:Concept ;
    dct:date "2000"^^xsd:gYear ;
    dct:source "http://www.efi.int/files/attachments/publications/annex_1_to_efi_technical_report_88__2013.pdf"^^xsd:anyURI ;
    dct:spatial "Finland" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Finland adopts two definitions of forests: one is the FRA FAO 2000 definition: “Forest is land spanning more than 0.5 ha with trees higher than 5 m and a canopy cover of more than 10%, or trees able to reach these 5 m thresholds in situ. It does not include land that is predominantly under agricultural or urban land use.” METLA (Finnish Forest Research Institute), 2009"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Finland 2000" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1085 a skos:Concept ;
    dct:date "2009"^^xsd:gYear ;
    dct:spatial "Finland" ;
    skos:broadMatch ex:Forest ;
    skos:definition "The second definition is the national definition of forest that in Finland is the same as in the two other Nordic countries, Sweden and Norway: forest is defined as a land capable of producing an annual increment of volume growing stock of at least 1 m3/ha per year over the rotation under the most favorable tree species composition, and not used for any other purpose than forestry or forestry related purposes. METLA (Finnish Forest Research Institute"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Finland 2009" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1086 a skos:Concept ;
    dct:date "2011"^^xsd:gYear ;
    dct:source "http://www.efi.int/files/attachments/publications/annex_1_to_efi_technical_report_88__2013.pdf"^^xsd:anyURI,
        "http://www6.nancy.inra.fr/lef_eng/LEF-Data-Group/Tools/Glossary/"^^xsd:anyURI ;
    dct:spatial "France" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest: Wooden area of 50 acres with trees able to reach a height greater than five meters at maturity in situ, a of more than 10% and a width of at least 20 meters. Areas temporarily cleared or regenerating forests are classified as though they covered less than 10% during the inventory. Note: poplar (rate of free covered poplar grown on more than 75%) are included in the definition of forest. In contrast, walnut groves and chestnut groves as well as truffle cultivation and orchards are excluded (agricultural production). FN definition , new inventory method . 2009"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "France 2011" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1087 a skos:Concept ;
    dct:date "1982"^^xsd:gYear ;
    dct:spatial "Gabon" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Sont qualifiés de forêts au sens de la présente loi, les périmètres comportant ou non une couverture végétale et capables: soit de foumir du bois ou des produits végétaux autres qu'agricoles; soit d'abriter la faune sauvage; soit d'exercer un effet direct ou indirect sur le sol, le climat ou le régime des eaux. Source: Loi no. 1/82/PR, 22 Juillet 1982, d'orientation en matière des Eaux et Forêts Title II, Article 9 (Jean-Pierre Profizi"@fr ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Gabon 1982" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1088 a skos:Concept ;
    dct:date "1975"^^xsd:gYear ;
    dct:source "http://www.landconsult.de/markus/foram/home/forrev2.html"^^xsd:anyURI ;
    dct:spatial "Germany" ;
    skos:broadMatch ex:Forest ;
    skos:definition "A forest (\"Wald\") in the meaning of the Federal Forest Act (Section 2) is \"(1)... every tract of land planted with forest plants. Also to be rated as forests are clear-cut or thinned out tracts of land, forest tracks and roads, forest marking-off-safety strips, gaps in the forest cover as well as clearings, forest meadows, game feeding points, timber storing points as well as other areas connected with forests and ancillary to them. (2) Smaller lots planted with individual clusters of trees, with line-planted trees or with hedges or serving as forest nurseries and being situated on farmland or within built-up areas, are not forests within the meaning of this act. (3) The States may assign other tracks of land as forests; they may institute exemptions from the legal definition of \"forest\" for christmas-tree plantations and plantations providing ornamental sprigs as well as for parks within residential areas.\""@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Germany 1975" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1089 a skos:Concept ;
    dct:date "2001"^^xsd:gYear ;
    dct:spatial "Germany" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest within the meaning of the FFI (Federal Forest Inventory) is any area of ground covered by forest vegetation, irrespective of the information in the cadastal survey or similar records. The term forest also refers to cutover or thinned areas, forest tracks, firebreaks, openings and clearings, forest glades, feeding grounds for game, landings, rides located in the forest, further areas linked to and serving the forest including areas with recreation facilities, overgrown heaths and moreland, overgrown former pastures, alpine pastures and rough pastures, as well as areas of dwarf pines and green alders. Heaths, moorland, pastures, alpine pastures and rough pastures are considered to be overgrown if the natural forest cover has reached an average age of five years and if at least 50% of the area is covered by forest. Areas with forest cover in open pasture land or in built-up areas of under 1000 m2, coppices under 10 m wide and the cultivation of Christmas trees and ornamental brushwood as well as parkland attached to country houses are not forest within the meaning of the FFI. Watercourses up to 5 m wide do not break the continuity of a forest area. (Source: Anon. 2003. Survey instructions for Federal Forest Inventory II (2001-2002). 2nd corrected and revised reprint. May 2001. Bundesministerium für Verbaraucherschutz Ernährung und Landwirtschaft, Bonn, Germany"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Germany 2001" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_109 a skos:Concept ;
    dct:source "http://agebb.missouri.edu/mfgc/contest/glossary.htm"^^xsd:anyURI,
        "http://www.fnr.purdue.edu/inwood/glossary.html"^^xsd:anyURI,
        "http://www.inwoodlands.org"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A plant association predominantly of trees and other woody vegetation. /, , and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_1090 a skos:Concept ;
    dct:date "2002"^^xsd:gYear ;
    dct:source "http://www.efi.int/files/attachments/publications/annex_1_to_efi_technical_report_88__2013.pdf"^^xsd:anyURI ;
    dct:spatial "Germany" ;
    skos:broadMatch ex:Forest ;
    skos:definition "The National Forest Inventory definition follows the definition of forest under the Federal Forest Act: Forest within the meaning of the NFI is any area of ground covered by forest vegetation, irrespective of the information in the cadastral survey or similar records. The term forest also refers to cutover or thinned areas, forest tracks, fire breaks, openings and clearings, forest glades, feeding grounds for game, landings, rides located in the forest, further areas linked to and serving the forest including areas with recreation facilities, overgrown heather and moorland, overgrown former pastures, alpine pastures and rough pastures, as well as areas of dwarf pines and green alders. Heath, moorland, pastures, alpine pastures and in rough pastures are considered to be overgrown if the natural forest cover has reached an average age of five years and if at least 50% of the area is covered by forest. Areas with forest cover in open pasture land or in built-up areas of under 1000 m, Coppice under 10 m wide and the cultivation of Christmas trees and ornamental brushwood as well as parkland attached to country houses are not forest within the meaning of the NFI. Watercourses up to 5 m wide do not break the continuity of a forest area. Source: Survey instructions for Second Federal Forest Inventory, 2nd corrected and revised reprint, May 2001. Bundesministerium für Ernährung, Landwirtschaft und Verbraucherschutz, 2002"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Germany 2002" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1091 a skos:Concept ;
    dct:date "1997"^^xsd:gYear ;
    dct:spatial "Germany" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Any area stocked with woody plants. Forest include clear-felled areas, forest roads, forest meadows, game pastures, timber yards, pipe routes located in the forest, further recreation facilities connected with the forest, overgrown heathens and moors, overgrown former meadows, alpine areas and rough grazing as well as dwarf pine and green alder areas. Heathens, moors, meadows, alpine areas and rough grazing are considered overgrown when the natural stocking has an average age of 5 years and at least 50% of the area is stocked. (European Communities 1997a - p 306"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Germany1997" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1092 a skos:Concept ;
    dct:date "1992"^^xsd:gYear ;
    dct:source "http://bookshop.europa.eu/is-bin/INTERSHOP.enfinity/WFS/EU-Bookshop-Site/en_GB/-/EUR/ViewPDFFile-OpenPDFFile?FileName=LBNA24300ENC_002.pdf&SKU=LBNA24300ENC_PDF"^^xsd:anyURI ;
    dct:spatial "Greece" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest Land includes: (a) areas larger than 0.5 ha or strips more than 30 m wide with tree crown cover (stand density) of more than 10% of the area, or areas with 250 trees of reproductive age per hectare, able to produce wood or other products or services and are not used for any other land-use (b) areas where trees are removed to below 10% of stand density and are not given for other landuse (c) reforested areas and (d) scrublands (areas covered by broadleaved evergreens"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Greece 1992" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1093 a skos:Concept ;
    dct:date "1997"^^xsd:gYear ;
    dct:spatial "Greece" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Areas with 0.5 ha or 30cm (30 m?) strips with a tree crown closure that covers 10% of the area, or areas with 250 trees of a regeneration size not used for other purposes, and which are able to produce forest products or/and other services. Includes areas where trees have been removed with a crown closure less than 10% and they have not been used for other purposes, areas with regeneration, brush lands (areas covered by evergreen broad-leaved trees) Includes other wooded lands. (European Communities 1997a - p 371"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Greece 1997" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1094 a skos:Concept ;
    dct:date "2001"^^xsd:gYear ;
    dct:source "http://www.efi.int/files/attachments/publications/annex_1_to_efi_technical_report_88__2013.pdf"^^xsd:anyURI ;
    dct:spatial "Greece" ;
    skos:broadMatch ex:Forest ;
    skos:definition "NATIONAL DEFINITIONS. Area with 0.5 ha or 30 m strips with a tree crown closure that covers 10% of the area, or areas with 250 trees of a regeneration size, not used for other purposes or/and other services. Area where trees have been removed with a crown closure less than 10% and they have not been used for other purposes. Area with regeneration. Brush lands (area covered by evergreen broadleaved trees"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Greece 2001" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1095 a skos:Concept ;
    dct:date "2002"^^xsd:gYear ;
    dct:source "http://www.efi.int/files/attachments/publications/ir_06.pdf"^^xsd:anyURI ;
    dct:spatial "Greece" ;
    skos:broadMatch ex:Forest ;
    skos:definition "1) Areas with 0.05 ha or 30 cm (30 m?) strips with a tree crown closure that covers 10% of the area, or areas with 250 trees of regeneration size not used for other purposes or/ and other services. 2) Areas where trees have been removed with a crown closure less than 10% and that have not been used for other purposes. 3) Areas with regeneration. 4) Brush lands (areas covered by evergreen broad-leaved trees.) Schuck, Andreas et al. 2002. Compilation of forestry terms and definitions. European Forest Institute Internal Report No. 6. 48 p"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Greece 2002" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1096 a skos:Concept ;
    dct:date "2008"^^xsd:gYear ;
    dct:source "http://www.rainforestcoalition.org/TinyMceFiles/2008-presentations/Grassi_Berlin%20March%2016-18%202008.pdf"^^xsd:anyURI ;
    dct:spatial "Greece" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Includes: (a) areas larger than 0.5 ha or strips more than 30 m wide with tree crown cover (stand density) of more than 10% of the area, or areas with 250 trees of reproductive age per hectare, able to produce wood or other products or services and are not used for any other land-use (b) areas where trees are removed to below 10% of stand density and are not given for other land-use (c) reforested areas and (d) scrublands (areas covered by broadleaved evergreens). Grassi, Giacomo. 2008. Reporting emissions and removals from forests: experience from LULUCF in Europe and challenges for REDD. European Commission - Joint Research Centre, Ispra, Italy. 30 slides"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Greece 2008" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1097 a skos:Concept ;
    dct:date "2013"^^xsd:gYear ;
    dct:source "http://www.efi.int/files/attachments/publications/annex_1_to_efi_technical_report_88__2013.pdf"^^xsd:anyURI ;
    dct:spatial "Greece" ;
    skos:broadMatch ex:Forest ;
    skos:definition "NEW DEFINTION: Forest is a land with 10% crown cover with minimum height of trees of 5 m at maturity (in situ); areas of approximately 0.5 ha or strips with widths of 30 m (with tree canopy cover of 10%); areas not used for any purpose other than production of wood. Galatsidas S. 2001"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Greece 2013" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1098 a skos:Concept ;
    dct:date "1949"^^xsd:gYear ;
    dct:spatial "Grenada" ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"Timber lands\" means lands whereon trees are growing and which are not under permanent agricultural cultivation. LEX-FAOC005062. GRENADA: Forest, Soil and Water Conservation Ordinance. An ordinance to make provision for the conservation of forest, soil, water and other natural resources of the Colony. Date of original text: 01 August 1949"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Grenada 1949" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1099 a skos:Concept ;
    dct:date "1996"^^xsd:gYear ;
    dct:spatial "Hungary" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest-land shall be: a) an area of one thousand five hundred square meters or more covered with wood-including also land with spontaneous afforestation and land temporarily utilized – together with the glades and fire strips located in it; b) an area of one thousand five hundred square meters or more on which forest plantation (seed sowing, planting of saplings, propagation) was performed; c) the area of a tree plantation of one thousand five hundred square meters or more covered with tree species not indigenous in the natural geographic environment of the country for the period of a production cycle, and not exceeding thirty years, planted without applying state subsidy and after the enactment of this Act (hereinafter: tree plantation) (Act No LIV of 1996 on Forests and the Protection of Forests &sect; 8 (1)). Tree crown cover = 30% in open forest formations. For FRA 2000 - Source: UN/ECE 2000 p 79"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Hungary 1996" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_11 a skos:Concept ;
    dct:creator "Manwood. 1598. The Lawes of the Forest" ;
    dct:source "http://dspace.wbpublibnet.gov.in/dspace/bitstream/10689/10100/4/Chapter%201_1%20-%20125p.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A forest is a certain territory of woody grounds, fruitful pastures, privileged for wild beast and fowls of forest chase, and warren, to nest and abide in, in the safe protection of the King, for his princely delight and pleasure, with territory of ground, so privilege is meered and bounded with unremovable marks, meers and boundaries either know by matter of record, or else by prescription"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Manwood. 1598. The Lawes of the Forest" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "General"@en .

ex:Forest_110 a skos:Concept ;
    dct:creator "Helms" ;
    dct:date "2002"^^xsd:gYear ;
    skos:broadMatch ex:Forest ;
    skos:definition "A plant association predominatly of trees and other woody vegetation occupying an extensive area of land. SF 1944, 1958"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Helms 2002" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_1100 a skos:Concept ;
    dct:date "1997"^^xsd:gYear ;
    dct:spatial "Hungary" ;
    skos:broadMatch ex:Forest ;
    skos:definition "A biocoenosis formed of arborescent plants of the species determined in an order by the Minister of Agriculture and of associated live beings (forest biocoenosis) together with its soil, irrespective of whether the growing stock or another components of the biocoenosis is temporarily missing. (Act No. LIV of 1996 on Forests and the Protection of Forests, Ministry of Agriculture, Republic of Hungary, Budapest, 1997"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Hungary 1997" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1101 a skos:Concept ;
    dct:source "http://www.fris.sk/Phare/Projects/ManagementOfForestInEurope/PDF/annex2.pdf"^^xsd:anyURI ;
    dct:spatial "Hungary" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Biocenosis formed of arborescent plants and associated live beings (forest biocenosis) together with its soil, irrespective of whether the growing stock or other components of the biocenosis is temporarily missing, minimum size >0.15 ha for forest land"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Hungary" ;
    skos:prefLabel "Forest"@no ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1102 a skos:Concept ;
    dct:date "2010"^^xsd:gYear ;
    dct:source "http://groa.rala.is/Kortavefsja/ICELAND_NIR_2010.pdf"^^xsd:anyURI ;
    dct:spatial "Iceland" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest land: All land, not included under Settlements, presently covered with trees or woody vegetation more than 2 m high, crown cover of minimum 10% and at least 0.5 ha in continuous area and minimum width 20 m and also land which currently fall below these thresholds, but in situ expected to reach these thresholds at mature state"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Iceland 2010" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1103 a skos:Concept ;
    dct:date "2007"^^xsd:gYear ;
    dct:source "https://tribal.nic.in/FRA/data/FRARulesBook.pdf"^^xsd:anyURI ;
    dct:spatial "India" ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"Forest land\" means land of any description falling within any forest area and includes unclassified forests, undermarcated forests, existing or deemed forests, protected forests, reserved forests, Sanctuaries and National Parks"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "India 2007" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1104 a skos:Concept ;
    dct:date "1998"^^xsd:gYear ;
    dct:spatial "Indonesia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Hutan adalah hamparan lahan yang berisi atau yang dikehendaki akan berisi pepohonan, unsur-unsur hayati lainnya, dan non-hayati yang secara keseluruhan merupakan satu kesatuan ekosistem. (Rancangan Undang-Undang Nomor .... Tahun 1998 tentang Kehutanan). (Translation: A forest is a spread out area filled with or planned to be filled with trees, other living (biological) and non-living elements which as a whole form a ecosystem unit. (Law on Forestry, Number ... Year 1998))Other terms used in this law are: - Sumberdaya hutan (forest resource) - Kawasan hutan (forest area) - Kawasan hutan negara (state forest land) - Kawasan hutan adat (traditional forest land) - Kawasan hutan produksi (production forest) - Kawasan hutan lindung (conservation/protected forest). Source: Nico Smith, MSc. Lecturer at Fakultas Kehutanan Universitas Muhammadiyah Sumatra Barat"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Indonesia 1998" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1105 a skos:Concept ;
    dct:date "1998"^^xsd:gYear ;
    dct:source "http://europe.mtnforum.org/rs/econfreports/MountainPeopleForestsAndTrees.pdf"^^xsd:anyURI ;
    dct:spatial "Indonesia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "the legal definition of forest in Indonesia is: \"a spread out area filled with or planned to be filled with trees, other living (biological) and non-living elements which as a whole form an ecosystem unit\" (Law on Forestry 1998, Tr. Nico Smith 1999"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Indonesia 1998" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1106 a skos:Concept ;
    dct:date "2014"^^xsd:gYear ;
    dct:source "https://www.agriculture.gov.ie/media/migration/forestry/forestrythelaw/ForestryAct2014240517.pdf"^^xsd:anyURI ;
    dct:spatial "Ireland" ;
    skos:broadMatch ex:Forest ;
    skos:definition "“Forest” means land under trees with— (a) a minimum area of 0.1 hectare, and (b) tree crown cover of more than 20 per cent of the total area, or the potential to achieve this cover at maturity, and includes all species of trees"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Ireland 2014" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1107 a skos:Concept ;
    dct:date "1997"^^xsd:gYear ;
    dct:spatial "Italy" ;
    skos:broadMatch ex:Forest ;
    skos:definition "A territory with one or more of the following characteristics: purpose to wood or non-wood productions currently regards as forested, contain tree or bush stands with direct or indirect function of protection, contain spontaneous tree or bush stands with naturalist, scenic or recreation function. Included also are areas temporarily without a stand because cutting or exceptional occurrence. Not included city parks, gardens, nurseries, orchards, etc. (European Communities 1997a - p. 464"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Italy 1997" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1108 a skos:Concept ;
    dct:date "2007"^^xsd:gYear ;
    dct:source "http://www.efi.int/files/attachments/publications/annex_1_to_efi_technical_report_88__2013.pdf"^^xsd:anyURI ;
    dct:spatial "Italy" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land with tree crown cover (or equivalent stocking level) of more than 10% and area of more than 0.5 ha. The trees should be able to reach a minimum height of 5 m at maturity in situ. May consist either of closed forest formations where trees of various stories and undergrowth cover a high proportion of the ground; or open forest formations with a continuous vegetation cover in which tree crown cover exceeds 10%. Young natural stands and all plantations established for forestry purposes which have yet to reach a crown density of 10% or tree height of 5 m are included under forest, as are areas normally forming part of the forest area which are temporarily unstocked as a result of human intervention or natural causes but which are expected to revert to forest. Includes: forest nurseries and seed orchards that constitute an integral part of the forest; forest roads, cleared tracts, firebreaks and other small open areas; forest in national parks, nature reserves and other protected areas such as those of specific scientific, historical, cultural or spiritual interest; windbreaks and shelterbelts of trees with an area of more than 0.5 ha and width of more than 20 m; plantations primarily used for forestry purposes, including rubberwood plantations and cork oak stands. Excludes: Land predominantly used for agricultural practices"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Italy 2007" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1109 a skos:Concept ;
    dct:creator "legal definition" ;
    dct:spatial "Japan" ;
    skos:broadMatch ex:Forest ;
    skos:definition "1) Land aimed at growing a group of trees (includes a non-forested land at present) or 2) a mountainous area with tree cover registered as 'forest' on a land register. Note: House lots and shrine enclosures being not aimed at growing trees are not forests even if they are covered with trees. Yukichi Konohira Konohira@cc.tuat.ac.jp"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Japan - legal definition" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_111 a skos:Concept ;
    dct:source "http://muextension.missouri.edu/xplor/agguides/forestry/g05054.htm"^^xsd:anyURI,
        "http://www.ag.iastate.edu/departments/forestry/ext/dictionary.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A plant community dominated by trees and other wood plants. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_1110 a skos:Concept ;
    dct:spatial "Japan" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest: In this law, FOREST shall be defined as listed below. The definition, however, shall exclude lands used for agriculture, housing, or equivalent purposes and standing trees and bamboo upon those lands. (1) Lands with trees and bamboo in groups and standing tree and bamboo upon the lands. (2) Besides the lands mentioned in the paragraphs, lands that serve as habitats for trees and bamboo. Definition of Forest Law, Forest Agency. From: Masahiro Amano masahiro@ss.ffpri.affrc.go.jp"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Japan" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1111 a skos:Concept ;
    dct:date "2005"^^xsd:gYear ;
    dct:source "http://www.donorplatform.org/load/5971"^^xsd:anyURI ;
    dct:spatial "Kenya" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forests are often thought of as areas with continuous tree cover consisting either of naturally occurring (indigenous) tree species or plantations. However, this definition ignores the importance of open savannah or dry land forests in which individual trees are scattered over wide areas of grassland. It also fails to cover small groups of trees planted on farms and other cultivated land. It is these dry land forests and farm trees that provide important livelihood strategies for many of Kenya’s poor people, including wood fuel, charcoal burning for income, and use of wood products for building. Forest Act 2005"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Kenya 2005" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1112 a skos:Concept ;
    dct:date "2015"^^xsd:gYear ;
    dct:source "http://www.kenyaforestservice.org/documents/ForestConservationandManagementActNo34of2016.pdf"^^xsd:anyURI ;
    dct:spatial "Kenya" ;
    skos:broadMatch ex:Forest ;
    skos:definition "“Forestland\" means a tract of land, including its flora and fauna, that is devoted to growing trees for the production of timber, wood and other forest products"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Kenya 2015" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1113 a skos:Concept ;
    dct:spatial "Korea, Republic of" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest is defined as one of followings: 1. collectively standing and growing trees and bamboos, and the land that have them. 2. the land that temporarily lost standing trees and bamboos. 3. the land that is used for collectively growing trees and bamboos. 4. forestry roads. 5. rockland and wetland within 1, 2 and 3. Forest does not include followings 1. Orchard 2. the land that have growing trees and bamboos within buildings 3. the road with growing street trees. 4. stream banks. Korean Forestry Law. \"Matthias ChangDuck Koo\" koochangd@hotmail.com"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Korea, Republic of" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1114 a skos:Concept ;
    dct:date "2015"^^xsd:gYear ;
    dct:source "http://www.fao.org/3/a-i5444e.pdf"^^xsd:anyURI ;
    dct:spatial "Korea, Republic of" ;
    skos:broadMatch ex:Forest ;
    skos:definition "The Republic of Korea defines forest as including not only stands of timber and bamboo and the land on which they are growing, but also land that has temporarily lost its stands of timber and bamboo. Source: KFS, 2015; agricultural land area from World Bank, 2015"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Korea, Republic of- 2015" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1115 a skos:Concept ;
    dct:creator "Kyrgyz" ;
    dct:date "1999"^^xsd:gYear ;
    dct:source "http://www.libertas-institut.com/de/Mittel-Osteuropa/Forest%20Code.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest lands are lands of the Forest Fund both covered and uncovered by forest and intended for forest growing. Forest Code of the Kyrgyz Republic"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Kyrgyz 1999" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1116 a skos:Concept ;
    dct:date "1999"^^xsd:gYear ;
    dct:source "http://www.libertas-institut.com/de/Mittel-Osteuropa/Forest%20Code.pdf"^^xsd:anyURI ;
    dct:spatial "Kyrgyzstan" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest lands Lands of the Forest Fund both covered and uncovered by forest and intended for forest growing. Source: Irina Yunusova irina@lesic.elcat.kg and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Kyrgyzstan -1999" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1117 a skos:Concept ;
    dct:date "2000"^^xsd:gYear ;
    dct:source "http://www.fao.org/docrep/article/WFC/XII/0504-C3.htm"^^xsd:anyURI ;
    dct:spatial "Latvia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "According to the Forest Law of the Republic of Latvia adopted in 2000 (Item 2, Paragraph 3, Section 1) \"forestland is the land carrying the forest, the land under forest infrastructure facilities, as well as overflowing clearings, bogs and glades in the forest and in the territories contiguous to it\""@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Latvia 2000" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1118 a skos:Concept ;
    dct:source "http://www.fris.sk/Phare/Projects/ManagementOfForestInEurope/PDF/annex2.pdf"^^xsd:anyURI ;
    dct:spatial "Latvia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest land includes areas which constitute an integral part of the forest: forest roads, cleared tracts, firebreaks and other small open areas within the forest"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Latvia" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1119 a skos:Concept ;
    dct:spatial "Latvia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Rural or urban land covered by forest or land which is not covered by forest but prescribed for forest growing in compliance with the State Land Cadastre. Source: \"Maksym Polyakov\" mpoliak@pcomp.nauu.kiev.ua"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Latvia" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_112 a skos:Concept ;
    dct:source "http://ext.msstate.edu/pubs/pub1250.htm"^^xsd:anyURI,
        "http://www.idahoforests.org/dict1.htm"^^xsd:anyURI,
        "http://www.washingtonforests.com/glossary.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A plant community dominated by trees and other woody plants. Washington Forest Protection Association, the Idaho Forest, and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_1120 a skos:Concept ;
    dct:source "http://www.fris.sk/Phare/Projects/ManagementOfForestInEurope/PDF/annex2.pdf"^^xsd:anyURI ;
    dct:spatial "Latvia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "The forest definition is not included in Forest Act. State Land Service for land use inventory is applying the following definition of forest and forest land: Land with tree crown cover of more than 20% and area of more than 0.1 ha. The trees should be able to reach a minimum height of 7m at maturity in situ. Young natural stands and artificially reforested areas of more than 0.1 ha, up to 20 years old with mean height >1m and number of trees 2000-3000/ha (depends on species). Includes areas normally forming part of the forest area which are temporarily unstocked as a result of human intervention or natural causes but which are expected to revert to forest"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Latvia" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1121 a skos:Concept ;
    dct:date "2011"^^xsd:gYear ;
    dct:source "http://www.tradingeconomics.com/lebanon/forest-area-percent-of-land-area-wb-data.html"^^xsd:anyURI ;
    dct:spatial "Lebanon" ;
    skos:broadMatch ex:Forest ;
    skos:definition "land under natural or planted stands of trees of at least 5 meters in situ, whether productive or not, and excludes tree stands in agricultural production systems (for example, in fruit plantations and agroforestry systems) and trees in urban parks and gardens"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Lebanon- 2011" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1122 a skos:Concept ;
    dct:spatial "Lesotho" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Any existing area of land under section 11 and any areas of land used for forestry, or declared forestry use, under sections 12, 13, and 14 of this Act. Forestry Act 1998. Via David May ISTF CVP Lesotho"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Lesotho" ;
    skos:prefLabel "- Forest"@no ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1123 a skos:Concept ;
    dct:date "2006"^^xsd:gYear ;
    dct:source "http://www.fao.org/forestry/16151-05fd47b845599b5d3a594a9b0240dacff.pdf"^^xsd:anyURI ;
    dct:spatial "Liberia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest Land: A tract of land, including its flora and fauna, capable of producing Forest Resources, not including land in urban areas, land in permanent settlements, and land that has been in long-term use for non-shifting cultivation of crops or livestock in a manner that precludes producing Forest Resources. An Act Adopting the National Forestry Reform Law of 2006"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Liberia 2006" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1124 a skos:Concept ;
    dct:date "2001"^^xsd:gYear ;
    dct:source "http://www.seniejitrakai.lt/law-on-the-amendment"^^xsd:anyURI ;
    dct:spatial "Lithuania" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest –a land area not less than 0.1 hectare in size covered with trees, the height of which in a natural site in the maturity age is not less than 5 meters, other forest plants as well as thinned or vegetation-lost forest due to the acts of nature or human activities (cutting areas, burnt areas, clearings). Tree lines up to 10 meters of width in fields, at roadsides, water bodies, in living areas and cemeteries , single trees and bushes, parks planted and grown by man in urban and rural areas are not defined as forests. The law on the amendment of the forest law of the Republic of Lithuania"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Lithuania 2001" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1125 a skos:Concept ;
    dct:date "2010"^^xsd:gYear ;
    dct:source "http://www.efi.int/files/attachments/publications/annex_1_to_efi_technical_report_88__2013.pdf"^^xsd:anyURI ;
    dct:spatial "Lithuania" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest land NFI is: a land area not less than 0.1 ha in size covered with trees, the height of which in a natural site in the maturity age is not less than 5 m, other forest plants as well as thinned or vegetation lost forest due to the acts of nature or human activities (cutting areas, burnt areas, clearings). Forest pitches, nursery areas, forest seed orchards, raw-material bushings and plantation, forest roads, forest block, technological and fire break lines, areas covered by timber storage houses and other forest related equipment, recreation grounds, animal feed grounds, and land assigned for afforestation is ascribed to forest land as well. Tree lines up to 10 m of width in fields, at roadsides, water bodies, in living areas and cemeteries, single trees and bushes, parks planted and grown by man in urban and rural areas are not defined as forests. Department of Statistics, 2010"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Lithuania 2010" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1126 a skos:Concept ;
    dct:source "http://www.fris.sk/Phare/Projects/ManagementOfForestInEurope/PDF/annex2.pdf"^^xsd:anyURI ;
    dct:spatial "Lithuania" ;
    skos:broadMatch ex:Forest ;
    skos:definition "A tract of land not less than 0.1 ha, covered with trees or other forest vegetation or temporarily without it (cleared or burned areas). Not considered a forest: Clusters of trees situated in fields, by roadsides, water bodies, within towns or rural settlements as well as cemeteries, narrow - up to 10 metres - tree lines, hedges, single trees, shrubs as well as parks planted by man within towns and rural settlements"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Lithuania" ;
    skos:prefLabel "Forest"@no ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1127 a skos:Concept ;
    dct:spatial "Lithuania" ;
    skos:broadMatch ex:Forest ;
    skos:definition "land area, no less than 0,1 ha, covered by trees and other forest plants or temporarily has lost them (clear-cut and burnt areas). Narrow belts up to 10 m, small groups and single trees in villages and towns, also artificially established parks are not forests. In forest inventory we use such a restriction: all forests must have site index - 11 m and more. Forests with less productivity, mainly growing on peatlands are inventoried as peatlands covered by woody plants (Other wooded lands). Source: A. Kuliesis, Director of Lithuanain Forest Inventory and Management Institute Email: Sekrtetore sek@mp.is.lt"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Lithuania" ;
    skos:prefLabel "Forest"@no ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1128 a skos:Concept ;
    dct:source "http://www.fris.sk/Phare/Projects/ManagementOfForestInEurope/PDF/annex2.pdf"^^xsd:anyURI ;
    dct:spatial "Lithuania" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest land is land covered by forest stands or not covered by forest (cleared areas, perished stands, forest meadows, nurseries, seed-plots, seed orchards and raw shrubbery and plantations). Includes forest roads and drain ditches, forest compartment lines, technological and fire-prevention strips, piling places and facilities related to forest, rest spots, game feeding points, swamps, sands, as well as land for afforestation. Forest land may be forestry or conservation designated"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Lithuania" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1129 a skos:Concept ;
    dct:spatial "Luxembourg" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Terres représentant un couvert forestier (ou peuplement équivalent) de plus de 10 % et une superficie supérieure à 0,5 ha. Les arbres doivent pouvoir atteindre une hauteur abattable minimale de 5 mètres. Ces forêts peuvent comprendre soit des formations forestières denses dont les divers étages et le sous-bois couvrent une forte proportion du sol, soit des formations forestières claires avec une strate herbacée continue dans lesquelles les cimes couvrent plus de 10 % de la superficie. Sont également compris dans les forêts les jeunes peuplements naturels ou toutes plantations créées à des fins forestières, mais dont les cimes ne couvrent pas encore 10 % de la superficie ou dont les arbres sont encore inférieurs à 5 mètres, tout comme les zones qui font normalement partie de la région forestière et qui sont temporairement déboisées par le fait de l'intervention de l'homme ou de causes naturelles, mais qui sont appelées à redevenir des forêts. Ces terres comprennent : les pépinières, les vergers à graine qui font partie intégrante de la forêt ; les routes forestières , les zones coupées à blanc, les pare-feu et autres petites clairières. Source: Definitions De La Foret Utilisees Dans Le Cadre De L'inventaire Forestier National Au Luxembourg (Marc Wagner"@fr ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Luxembourg" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_113 a skos:Concept ;
    dct:source "http://msucares.com/pubs/pub1250.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A plant community dominated by trees and woody plants. From a management standpoint, a forest is a collection of stands administered as a unit"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_1130 a skos:Concept ;
    dct:creator "Macedonia" ;
    dct:date "1997"^^xsd:gYear ;
    dct:source "http://www.efi.int/files/attachments/publications/annex_1_to_efi_technical_report_88__2013.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land covered with forest tree and shrub as well as forest bare lands and forest roads, forest nurseries and other areas that are closely connected to forests. (Law on forests, 1997g., article 3). Republic Of Macedonia, Ministry Of Agriculture, Forestry And Water Economy. National Forestry Strategyfor Sustainable Development, 2002"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Macedonia 1997" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1131 a skos:Concept ;
    dct:creator "Macedonia" ;
    dct:source "http://www.fris.sk/Phare/Projects/ManagementOfForestInEurope/PDF/annex2.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land covered with forest trees and shrubs, including forest bare lands and meadows, pastures, nurseries, and area closely related to the forest, no area limit"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Macedonia" ;
    skos:prefLabel "- Forest"@no ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1132 a skos:Concept ;
    dct:creator "Macedonia" ;
    dct:source "http://www.fris.sk/Phare/Projects/ManagementOfForestInEurope/PDF/annex2.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest Land includes forest trees and shrubs, forest-bare lands and meadows, forest pastures, nurseries and other areas closely related to the forest"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Macedonia" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1133 a skos:Concept ;
    dct:spatial "Madagascar" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Article premier) Par forêt, au sens de la présente loi, on entend toutes surfaces répondant aux qualifications ci-après : - les surfaces couvertes d'arbres ou de végétation ligneuse, autres que plantées à des fins exclusives de production fruitière, de production de fourrage ou d'ornementation; - les surfaces occupées par les arbres et les buissons situés sur les berges des cours d'eau et lacs et sur des terrains érodés ; - les terrains dont les fruits exclusifs ou principaux sont des produits forestiers, tels qu'ils sont définis à l'alinéa ci-dessous ; Sont qualifiés produits des forêts : tous produits naturels issus de leur exploitation et dont la liste fera l’objet d’un décret.Article 2 : Sont assimilés aux forêts : - les surfaces non boisées d'un bien fonds forestier telles que les clairières ou surfaces occupées par des routes forestières, constructions et installations nécessaires à la gestion forestière ; - les terrains non boisés à vocation forestière, notamment pour la conservation et la restauration des sols, la conservation de la biodiversité, la régulation des systèmes hydriques ou l'accroissement de la production forestière dès qu'ils auront fait l'objet d'un classement tel que défini aux articles 76 et suivants de la présente loi; - les terrains déboisés depuis moins de cinq ans et n'ayant pas fait l'objet d'une autorisation de défrichement ; - les marais, les peuplements d'aloës ; - les peuplements naturels et purs d'arbres produisant des fruits, tels que les manguiers et anacardiers ; - les mangroves, les bois sacrés, les raphières (coeur de palmiers Ravinala). Article 3 : Des surfaces minimales peuvent être fixées par voie réglementaire et adaptées au niveau régional. Article 4 : Ne sont pas considérés comme forêts : - les cultures d’arbres et boisements plantés sur un terrain non forestier ; - les jardins boisés, les allées et parcs urbains et les pépinières non situées sur des biens fonds forestiers ; - les cultures d'arbres et boisements destinés à une exploitation à court terme, plantés sur un terrain non forestier, annoncés et enregistrés comme tels auprès de l'Administration forestière lors de leur établissement. - toute surface donnant des produits agricoles, sauf s'il s'agit de surface couverte d'arbres ayant poussé naturellement, ou de reboisements ; - les pâturages, suivant la vocation des sols définie par la loi. Madagascar TITRE I. DEFINITION DE LA FORET"@fr ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Madagascar" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1134 a skos:Concept ;
    dct:date "2003"^^xsd:gYear ;
    dct:source "http://www.efi.int/files/attachments/publications/annex_1_to_efi_technical_report_88__2013.pdf"^^xsd:anyURI ;
    dct:spatial "Malta" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest area is land under natural or planted stands of trees of at least 5 m in situ, whether productive or not, and excludes tree stands in agricultural production systems (for example, in fruit plantations and agroforestry systems) and trees in urban parks and gardens. EarthTrends, 2003"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Malta 2003" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1135 a skos:Concept ;
    dct:spatial "Mexico" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forestal).- Todo aquello que se relaciona con los bosques. Esta definición es adecuada desde el punto de vista económico y social, ya que da idea de la relación entre las áreas arboladas y la población. Sin embargo es más ambigua por la desigualdad en cada país en la distribución de la población urbana y rural Source: Glosario de Términos de la Memoria del Inventario Nacional Forestal Periódico y del Reglamento de la Ley Forestal from Unidad del Inventario <varelah@servidor.unam.mx"@es ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Mexico" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1136 a skos:Concept ;
    dct:date "2014"^^xsd:gYear ;
    dct:source "http://redd.unfccc.int/files/frel_mexico_modified.pdf"^^xsd:anyURI ;
    dct:spatial "Mexico" ;
    skos:broadMatch ex:Forest ;
    skos:definition "In the LGDFS, the definition of “forest land” comprises all lands covered by “forest vegetation”, and “forest vegetation” is defined as \"the set of plants and fungi that grow and develop naturally, forming temperate forests, tropical forests, arid and semi-arid areas, and other ecosystems.\" According to the definition above, forest is defined as all \"Forest Lands” with a canopy cover of more than 10 percent, with trees of more than 4 meters in height −or trees able to reach this height in situ−and a minimum mapping unit of at least 50 hectares . It does not include lands subject to a land use that is predominantly agricultural or urban.\" This definition is exactly the same one used in the development of the INEGEI, which is included in the BUR to be presented at UNFCCC. The definition of forest is consistent with the progress in the national REDD+ Readiness Process, and responds to commentaries and suggestions made by the various actors involved in this process(CTC, GT-ENAREDD+ CONAF, among others), who recommended using the broadest definition of forests to accomplish the objective of implementing REDD+ in an inclusive manner in Mexico (ENAREDD+, 2014"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Mexico 2014" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1137 a skos:Concept ;
    dct:date "2002"^^xsd:gYear ;
    dct:source "http://www.bioone.org/doi/pdf/10.1659/0276-4741(2002)022"^^xsd:anyURI ;
    dct:spatial "Nepal" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Area where trees with well-defined stems are growing and crown coverage is more than 10 per cent. Area must not be used primarily for uses other than forestry (widely understood) and must be at least 100 m wide. Area can include treeless patches not wider than 25 m and not exceeding 1 hectare. per cent5B0085:IONSFR per cent5D2.0.CO per cent3B2"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Nepal 2002" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1138 a skos:Concept ;
    dct:source "http://www.fao.org/forestry/fo/country/index.jsp?lang_id=1&geo_id=35"^^xsd:anyURI ;
    dct:spatial "Nepal" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest is defined as all land with a forest cover, i.e. with trees whose crowns cover more than 10% of the area, and not used primarily for purposes other than forestry. Temporarily clear-cut area that will be planted is also forest area"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Nepal" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1139 a skos:Concept ;
    dct:date "2006"^^xsd:gYear ;
    dct:source "http://unfccc.int/files/national_reports/application/pdf/new_zealands_initial_report_under_the_kyoto_protocol.pdf"^^xsd:anyURI,
        "http://www.cbd.int/doc/world/us/us-nr-vfe-en.pdf"^^xsd:anyURI ;
    dct:spatial "New Zealand" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Use Min. Area (ha) = 5 Min. Crown Cover (%) = 20 Min. Tree Height (m) = 6 Min. Strip Width (m) = ns \"Tree\" includes not only timber trees- but also all other kinds of trees- shrubs- and bushes- seedlings- saplings- cuttings- suckers- and shoots of every description. lists the minimum area of 0.5 ha. (2003) and USFS 2004. “Forests planted in exotic tree species predominately grown for wood or wood fibre greater than 1 ha in extent. All forest in this class will exceed 30 percent canopy cover and 5 metres in height before 10 years of age.” “Indigenous forest is defined as forest dominated by tall indigenous forest canopy species greater than 1 hectare in size. All forests mapped into this class exceed 30 percent canopy cover and 5 metres in height"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "New Zealand 2006" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_114 a skos:Concept ;
    dct:source "http://research.yale.edu/gisf/assets/pdf/tfd/IFIR_report.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A plant community of predominantly trees and other woody vegetation growing together, its land, flora and fauna, their interrelationships, and other resources and values attributed to it"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_1140 a skos:Concept ;
    dct:date "2011"^^xsd:gYear ;
    dct:source "http://www.maf.govt.nz/portals/0/documents/forestry/forestry-ets/2011-ETS-look-up-tables-guide.pdf"^^xsd:anyURI ;
    dct:spatial "New Zealand" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest land: (a) means an area of land of at least 1 hectare that has, or is likely to have, tree crown cover from forest species of more than 30 percent in each hectare; and (b) includes an area of land that temporarily does not meet the requirements specified in paragraph (a) because of human intervention or natural causes but that is likely to revert to land that meets the requirements specified in paragraph (a); (c) does not include: – a shelter belt of forest species, where the tree crown cover at maturity has, or is likely to have, a naverage width of less than 30 metres; or – an area of land where the forest species have, or are likely to have, a tree crown cover at maturity of an average width of less than 30 metres, unless the area is contiguous with land that meets the requirements specified in paragraph (a) or (b). If an area of land temporarily does not meet the forest species and crown cover requirements because of human action or natural events (it may have just been harvested, or trees may have been blown over by strong winds), but is likely to meet these requirements again in the future, it is still considered to be forest land as per paragraph (b) above. Such areas are termed “temporarily unstocked”"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "New Zealand 2011" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1141 a skos:Concept ;
    dct:date "1974"^^xsd:gYear ;
    dct:spatial "Niger" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Sont qualifiés forêts, les terrains dont les fruits exclusifs ou principaux sont les bois d'ébénisterie, les bois de service ou d'industrie, les bois de chauffage et à charbon, ou des produits accessoires tels que : les écorces et fruits à tanin, les écorces textiles et tinctoriales, le kapok, la glu, les gommes, les palmiers spontanés et tous autres végétaux ne constituant pas un produit agricole. Article 2: LEX-FAOC002294. NIGER: Loi n&ordm; 74-7 du 4 mars 1974 fixant le régime forestier. Date of text: 04 March 1974"@fr ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Niger 1974" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1142 a skos:Concept ;
    dct:date "1992"^^xsd:gYear ;
    dct:source "http://www.efi.int/files/attachments/publications/annex_1_to_efi_technical_report_88__2013.pdf"^^xsd:anyURI ;
    dct:spatial "Norway" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest is Land spanning more than 0.5 ha with trees higher than 5 m and a canopy cover of more than 10%, or trees able to reach these thresholds in situ. It does not include land that is predominantly under agricultural or urban land use. Productive forest area: Forest area that under favourable stand conditions has an annual yield capacity per hectare of at least 1 cubic metre of wood including bark. Noregs Offisielle Statistikk, 1992"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Norway 1992" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1143 a skos:Concept ;
    dct:date "1993"^^xsd:gYear ;
    dct:source "http://www.nijos.no/panorama/!skog.htm"^^xsd:anyURI ;
    dct:spatial "Norway" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land which produces forest or which on an overall farming- and forestry assessment is considered to be most suitable for forest production and is not being used for any other purpose. [Source: The Norwegian Forest and Forest Protection Act of May 21, 1965 with amendments, latest by the Act no. 96 of June 11, 1993. From: \"Maksym Polyakov\" <mpoliak@pcomp.usau.kiev.ua Date: Mon, 15 Jun 1998 19:27:19 +0300 (MSD)]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Norway 1993" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1144 a skos:Concept ;
    dct:source "http://odin.dep.no/ld/engelsk/dep/020001-200002/index-dok000-b-n-a.html"^^xsd:anyURI ;
    dct:spatial "Norway" ;
    skos:broadMatch ex:Forest ;
    skos:definition "For the purpose of this Act, «forest land» means land which produces forest 2) or which on an overall farming- and forestry assessment is considered to be most suitable for forest production and is not being used for any other purpose"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Norway" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1145 a skos:Concept ;
    dct:date "1953"^^xsd:gYear ;
    dct:spatial "Pakistan" ;
    skos:broadMatch ex:Forest ;
    skos:definition "An area set aside for the production of timber and other forest produce, or maintained under woody vegetation for certain indirect benefits which it provides e.g. climatic or protective. Definition adopted from the British Commonwealth Forest Terminology Part-I, 1953. Source: Mumtaz Ahmad, Section Forest Officer, Pakistan Min. of Environment, Local Government, and Rural Development"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Pakistan 1953" ;
    skos:prefLabel "Forest"@no ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1146 a skos:Concept ;
    dct:source "http://www.mef.gob.pe/DGCP/Documentacion/fondos/PERU_USA/convenio_dinat.pdf"^^xsd:anyURI ;
    dct:spatial "Peru" ;
    skos:broadMatch ex:Forest ;
    skos:definition "“Forest Land” means (i) that portion of SINANPE described in Exhibit A, which will be conserved, maintained and restored with funds provided pursuant to the Forest Conservation Agreement, and (ii) any other forest land in Perú approved for conservation, maintenance and restoration by a majority vote of the Oversight Committee in accordance with the terms of the Forest Conservation Agreement"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Peru" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1147 a skos:Concept ;
    dct:source "http://sunsite.nus.edu.sg/apcel/dbase/filipino/primary/phdfor.html"^^xsd:anyURI,
        "http://www.chanrobles.com/pd705.htm"^^xsd:anyURI ;
    dct:spatial "Philippines" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest lands include the public forest, the permanent forest or forest reserves, and forest reservations. Public forest is the mass of lands of the public domain which has not been the subject of the present system of classification for the determination of which lands are needed for forest purposes and which are not. b. Permanent forest or forest reserves refers to those lands of the public domain which have been the subject of the present system of classification and declared as not needed for forest purposes. g. Forest reservations refer to forest lands which have been reserved by the President of the Philippines for any specific purpose or purposes. Source: REVISED FORESTRY CODE [REVISING PRESIDENTIAL DECREE NO. 389, OTHERWISE KNOWN AS THE FORESTRY REFORM CODE OF THE PHILIPPINES] and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Philippines" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1148 a skos:Concept ;
    dct:date "1904"^^xsd:gYear ;
    dct:source "https://www.biodiversitylibrary.org/item/119973"^^xsd:anyURI ;
    dct:spatial "Philippines" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Public forests and torest reserves shall include all unreserved public lands covered with trees of whatever age"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Philippines1904" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1149 a skos:Concept ;
    dct:date "1997"^^xsd:gYear ;
    dct:spatial "Poland" ;
    skos:broadMatch ex:Forest ;
    skos:definition "A ground covered with a forest vegetation, of area above 0.1 ha; it includes forest grounds, temporarily deprived of forest vegetation, and grounds related to forestry (forest roads, nurseries, etc.). (European Communities 1997b - p. 1251). Forest roads, nurseries, etc. excluded. For FRA 2000 - Source: UN/ECE 2000 p 83"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Poland 1997" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_115 a skos:Concept ;
    dct:creator "Helms" ;
    dct:date "2002"^^xsd:gYear ;
    dct:source "http://www.cnr.vt.edu/for3364/ecolterms.htm#F"^^xsd:anyURI,
        "http://www.cofi.org/factbook98/seven/7-4.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A plant community predominately of trees and other woody vegetation growing more closely together. , and SAF 1971"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Helms 2002" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_1150 a skos:Concept ;
    dct:date "2010"^^xsd:gYear ;
    dct:source "http://www.efi.int/files/attachments/publications/annex_1_to_efi_technical_report_88__2013.pdf"^^xsd:anyURI ;
    dct:spatial "Poland" ;
    skos:broadMatch ex:Forest ;
    skos:definition "1) Land covered with forest vegetation, of area above 0.1 ha; it includes forest grounds temporarily deprived of forest vegetation, and (2) Lands related to forestry (forest roads, nurseries etc.) (FAO 2010"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Poland 2010" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1151 a skos:Concept ;
    dct:date "2012"^^xsd:gYear ;
    dct:source "http://www.stat.gov.pl/gus/definicje_ENG_HTML.htm?id=ANG-3369.htm"^^xsd:anyURI ;
    dct:spatial "Poland" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land covered with forest plants or lacking such plants for a temporary period of time as well as land associate with forestry management. Land covered with forest crops, young woodland and older trees as well as plantations of poplar and other fast growing trees being maintained both on forest land as well as outside of forests is included in forest land surface area. Land that has been temporarily deprived of trees and which includes logged over forest, blanks, irregularly stocked open stand as well as pine plantations being maintained on forest land and outside of forest land as well as forest land deprived of trees as a result of industrial emissions or mining (flood lands, depressed land). Land connected with silviculture includes land used for purposes of forest management: buildings and structures, spatial division lines in forests, forest roads, forest nurseries, wood stockpiling areas, land reclamation equipment, land under power lines, forest parking lots and tourist equipment"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Poland 2012" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1152 a skos:Concept ;
    dct:creator "?" ;
    dct:source "http://icaci.org/documents/ICC_proceedings/ICC2011/Oral%20Presentations%20PDF/A3-Data%20integration/CO-028.pdf"^^xsd:anyURI ;
    dct:spatial "Poland" ;
    skos:broadMatch ex:Forest ;
    skos:definition "In SLMN forest is defined as an area of land use categories Ls wooded, with trees older than 20 years"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Poland? " ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1153 a skos:Concept ;
    dct:date "1997"^^xsd:gYear ;
    dct:spatial "Portugal" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Every portion of land with a greater than 2000 m2 and 15 m wide, is considered forest area. Forest area includes exploitable forests, recently harvested or burned areas, recent seedlings and plantations, and green zones (reserves, protection forests and recreation forests). (European Communities 1997b - p. 879"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Portugal 1997" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1154 a skos:Concept ;
    dct:creator "European Part" ;
    dct:source "http://www.efi.int/files/attachments/publications/annex_1_to_efi_technical_report_88__2013.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Russia 2003) - Forest Land (FL) = covered by forest + uncovered by forest, comprises land which is suitable and designated for forest growth. FL is divided into following categories: Forested Areas; Non-Stocked Planted Forests; Forest Plantations and Nurseries; Natural Sparse Forests; and Unforested Areas. .Forested Areas include: (1) lands, covered by young stands with the relative stocking 0.4 and more, and stands of other age groups with the relative stocking 0.3 and more; (2) cutovers, burns and other territories of naturally reforesting FL, on which amount and quality of natural regeneration, or young trees, protected under harvest, are corresponding to requirements, developed for conversion of these categories into FA; (3) areas covered by shrubs in regions where tree species cannot grow due to severe natural and geographical conditions, or where special shrub management is provided. IIASA 2003"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "European Part" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1155 a skos:Concept ;
    dct:date "2000"^^xsd:gYear ;
    dct:spatial "Russian Federation" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest includes land -wooded land (main and other forest-forming tree species), non-continuous forest growth, nurseries and plantations, and unwooded land-openings, slashes, dead stands, cuttings, clearings. For FRA 2000 - Source: UN/ECE 2000 p 85"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Russian Federation 2000" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1156 a skos:Concept ;
    dct:date "1995"^^xsd:gYear ;
    dct:source "http://www.fire.uni-freiburg.de/iffn/iffn_24/iffn24.pdf"^^xsd:anyURI ;
    dct:spatial "Russian Federation" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest lands include lands covered by forest vegetation or those not covered by it but intended for its restoration (cutovers, slashes, perished forest stands, open stands [comment: better-sparse forests], wastelands, glades [comment: better-grassy glades and barrens], areas occupied by nurseries, free-growing forest cultures [comment; i.e., forest plantations], and others"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Russian Federation1995" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1157 a skos:Concept ;
    dct:date "2013"^^xsd:gYear ;
    dct:source "http://www-wds.worldbank.org/external/default/WDSContentServer/WDSP/IB/2014/08/14/000470435_20140814100003/Rendered/INDEX/PAD10410PAD0GE040Box385296B00OUO090.txt"^^xsd:anyURI ;
    dct:spatial "Rwanda" ;
    skos:broadMatch ex:Forest ;
    skos:definition "land covered with trees, shrubs and other plants or land which was covered with trees and is in the process of regeneration or under replantation or land that has not been covered with trees but is intended for forestry purposes or other activities related to forests"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Rwanda 2013" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1158 a skos:Concept ;
    dct:date "2014"^^xsd:gYear ;
    dct:source "http://knoema.com/WBWDIGDF2015Feb/world-development-indicators-wdi-february-2015"^^xsd:anyURI ;
    dct:spatial "Rwanda" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land under natural or planted stands of trees of at least 5 meters in situ, whether productive or not, and excludes tree stands in agricultural production systems (for example, in fruit plantations and agroforestry systems) and trees in urban parks and gardens"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Rwanda 2014" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1159 a skos:Concept ;
    dct:creator "&" ;
    dct:source "http://www.unece.org/trade/timber/docs/dp/dp-40.pdf"^^xsd:anyURI ;
    dct:spatial "Montenegro" ;
    skos:broadMatch ex:Forest ;
    skos:definition "A forest is a forest area exceeding 0.5 ha. Hedgerows, municipal parks, forest nurseries and groups of trees on areas smaller then 0.5 ha are not considered forests. Plantations are forests raised from selected plant sources with intensive high yield measures (short rotation). Unstocked forest land includes land which yields the best results if forests are growing on it"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Serbia & Montenegro" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_116 a skos:Concept ;
    dct:source "http://www.chesco.com/~treeman/words/words-f.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A system, where trees and their associates are so highly ordered in their connections that they all survive at a high quality state"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_1160 a skos:Concept ;
    dct:date "2010"^^xsd:gYear ;
    dct:source "http://www.efi.int/files/attachments/publications/annex_1_to_efi_technical_report_88__2013.pdf"^^xsd:anyURI ;
    dct:spatial "Serbia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "The inventory uses the definition of FRA FAO. A national definition is given in the FRA 2010 country report: A forest is every area over 5 are covered with forest trees in the form of stands having a protective function but is used for production of forest assortments or has a special purpose. Tree line paths, parks in inhabited places, forest tree nurseries, and groups of forest trees on an area under 5 are not considered a forest. [1are=0.01 ha]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Serbia 2010" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1161 a skos:Concept ;
    dct:date "2011"^^xsd:gYear ;
    dct:source "http://www.tradingeconomics.com/seychelles/forest-area-sq-km-wb-data.html"^^xsd:anyURI ;
    dct:spatial "Seychelles" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land under natural or planted stands of trees of at least 5 meters in situ, whether productive or not, and excludes tree stands in agricultural production systems (for example, in fruit plantations and agroforestry systems) and trees in urban parks and gardens"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Seychelles 2011" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1162 a skos:Concept ;
    dct:spatial "Slovakia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land determined to permanently fulfil the functions of forests (forest stands, forest nurseries, seed plantations, plots to be afforested, cleared boundary lines, skidding roads, infertile forest land, alpine land with specific functions) (M. Jasenská, Faculty of Wood Technology, Technical University Zvolen, Slovak Republic"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Slovakia" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1163 a skos:Concept ;
    dct:source "http://www.fris.sk/Phare/Projects/ManagementOfForestInEurope/PDF/annex2.pdf"^^xsd:anyURI ;
    dct:spatial "Slovakia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest land includes the area of forest stands, nurseries, plantations, temporary clearings where forest is under regeneration, forest roads, meadows and other areas"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Slovakia" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1164 a skos:Concept ;
    dct:source "http://bookshop.europa.eu/is-bin/INTERSHOP.enfinity/WFS/EU-Bookshop-Site/en_GB/-/EUR/ViewPDFFile-OpenPDFFile?FileName=LBNA24300ENC_002.pdf&SKU=LBNA24300ENC_PDF"^^xsd:anyURI ;
    dct:spatial "Slovakia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest Land includes: land with minimum tree crown cover of 20 % for trees capable to reach minimum height of 5 m in situ. The minimum area for forest is 0.3 ha. Temporarily unstocked areas are included (forest regeneration areas). For linear formations, a minimum width of 20 m is applied"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Slovakia" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1165 a skos:Concept ;
    dct:date "1993"^^xsd:gYear ;
    dct:source "http://www.efi.int/files/attachments/publications/annex_1_to_efi_technical_report_88__2013.pdf"^^xsd:anyURI ;
    dct:spatial "Slovenia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "The term “forest” is defined also by the Law on Forests of Slovenia (Official Journal of the Republic of Slovenia, nr. 30/1993). Article two states: .... “A forest is an area of land, covered with forest trees in the form of stands or other forest growths which provide any of the functions of a forest. Forest, according to this law also includes overgrown plots of land which are defined as forest in the spatial part of the forest management plan. The forest infrastructure which is apportioned to individual plots is an integral part of the forest. The following are not forest within the meaning of this law: individual forest trees; groups of forest trees up to an area of 0.05 ha; non-autochthonous riverine and windbelt trees; avenues; pastures overgrown with forest trees if they are used for pasturing, irrespective of how they are described in the land register. Zavod za Gozdove Slovenije, (Institution for Forest of Slovenia), 2011"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Slovenia 1993" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1166 a skos:Concept ;
    dct:date "2011"^^xsd:gYear ;
    dct:source "http://www.efi.int/files/attachments/publications/annex_1_to_efi_technical_report_88__2013.pdf"^^xsd:anyURI ;
    dct:spatial "Slovenia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "The national forest inventory defines forest as: (a) A plot of land overgrown with forest trees in the form of stands, which can reach a height of at least 5 m and sized to at least 0.25 ha (b) A plot of agricultural land in transition to forest land sized to at least 0.25 ha that has not been used for agriculture for the last 20 years and is overgrown with forest trees which can reach a height of at least 5 m and their crown cover should be at least 75% (c) Riverside forest corridors and windbreaks sized to at least 0.25 ha, if their widths are at least one tree-height. Kusar et al. in Tomppo et al. 2009. p. 439-440"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Slovenia 2011" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1167 a skos:Concept ;
    dct:source "http://www.metla.fi/eu/cost/e43/minutes/wg1-min-florence.pdf"^^xsd:anyURI ;
    dct:spatial "Slovenia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "National definition is use, probably close to FAO but a specific problem may be when to regard abandoned agriculture land as forest"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Slovenia" ;
    skos:prefLabel "Forest"@no ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1168 a skos:Concept ;
    dct:source "http://www.fris.sk/Phare/Projects/ManagementOfForestInEurope/PDF/annex2.pdf"^^xsd:anyURI ;
    dct:spatial "Slovenia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest land is a forest or forest plot matching with the definition of forest, and non-forest plots of land ecologically or functionally linked to forest, together guaranteeing the performance of the function of forest"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Slovenia" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1169 a skos:Concept ;
    dct:date "2004"^^xsd:gYear ;
    dct:source "http://www.parliament.gov.sb/files/legislation/Bills/2004/The%20Forests%20Bill%202004.pdf"^^xsd:anyURI ;
    dct:spatial "Solomon Islands" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forested land means an area of land predominately covered by trees other than trees planted for agricultural purposes"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Solomon Islands 2004" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_117 a skos:Concept ;
    dct:source "http://www.yourdictionary.com/forest"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A thick growth of trees and underbrush covering an extensive tract of land; large woods: often used figuratively"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_1170 a skos:Concept ;
    dct:source "http://www.nda.agric.za/doaDev/sideMenu/ForestryWeb/webapp/ResourceCentre/Documents/Policy,_Legislation,_Legal_Proceducers_&_Act/Third_draft_KIP_on_forestry_and_poverty_1Feb.pdf"^^xsd:anyURI ;
    dct:spatial "South Africa" ;
    skos:broadMatch ex:Forest ;
    skos:definition "In terms of the National Forests Act, 1998, forests include all natural forests, woodlands and plantations as well as the forest produce produced in it. In keeping with this definition, reference in this paper to forestry development and forest activities includes the use of these three categories of forest resources, as well as the primary processing of all timber, nontimber and non-wood forest products derived from these sources"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "South Africa" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1171 a skos:Concept ;
    dct:spatial "South Africa" ;
    skos:broadMatch ex:Forest ;
    skos:definition "“Forest land”means any land covered by trees or which is designated in any legislation, or national or sub-national forestry plan, or land-use plan as forest land or as land for afforestation or reforestation; www.dwaf.gov.za/Forestry/Forestry%20Policy/October%202001%20draft%20Protocol.doc"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "South Africa" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1172 a skos:Concept ;
    dct:creator "South" ;
    dct:source "http://country-facts.findthedata.com/l/241/South-Sudan"^^xsd:anyURI ;
    dct:spatial "Sudan" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest area is land under natural or planted stands of trees of at least 5 meters in situ, whether productive or not, and excludes tree stands in agricultural production systems (for example, in fruit plantations and agroforestry systems) and trees in urban parks and gardens"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "South Sudan" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1173 a skos:Concept ;
    dct:date "1998"^^xsd:gYear ;
    dct:spatial "Spain" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest-tree lands. All lands with a forest-tree cover, at maturity, \"in situ, of more than 5% of the area, which is able to reach a minimum height of 7 m and to produce wood. Minimum area is 0.25 ha. Excludes wood lots and isolated tree groups with areas under 0.25 ha. Forest lands are divided into forest 20 % cc, open forests 5-20% cc, unstocked areas and complementary areas - roads, buildings, etc. related to forestry activities. Source: Establecimiento de una tipología de usos agroselvícolas de los suelos. Spain Min. de Agricultura, Pesca y Almentacion. 1998. 173 p"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Spain 1998" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1174 a skos:Concept ;
    dct:date "1992"^^xsd:gYear ;
    dct:spatial "Sweden" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land suitable for wood production and not primarily used for other purposes. Potential yield under ideal management conditions at least 1 m3sk per hectare per year. Includes abandoned agricultural land and land user for grazing not yet covered by forest. Includes forest land with density of tree crowns = 0%. (UN/ECE 1992 p. 249"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Sweden 1992" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1175 a skos:Concept ;
    dct:date "1997"^^xsd:gYear ;
    dct:spatial "Sweden" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land suitable for forest production, not used for other purposes, and with an average production higher than (or equal to) 1 m3 per hectare and year during a period of 100 years. The minimum area is 0.25 ha. (European Communities 1997b - p. 983"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Sweden 1997" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1176 a skos:Concept ;
    dct:date "2009"^^xsd:gYear ;
    dct:source "http://www-markinfo.slu.se/eng/soildes/ago/agodef.html"^^xsd:anyURI,
        "http://www.efi.int/files/attachments/publications/annex_1_to_efi_technical_report_88__2013.pdf"^^xsd:anyURI ;
    dct:spatial "Sweden" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Types of land under the Forestry Act Determined for the traditional types of land in productive forest, bog, mountain pine forests and other land. Forest land: Land bearing forest or without measures to increase production has the potential to bear forest with a height of 5 m and with a crown cover of at least 10%. Sveriges Lantbruksuniversitet (SLU), 2009. (Sweden) Land that is suitable for timber production and that is not used for other purposes to any significant degree. Soil is deemed suitable if it can produce on average a total forest cubic metre of 1 m3 per ha and year for a 100 year growth period (min. site quality class VIII according to Jonson or H100 higher than approx. 10 m). The class ’forest land‘ includes extensively grazed permanent pasture and land within wildlife reserves that is not agricultural land. Also classified as forest land are abandoned farmland and other land suitable for forest production but not used for that purpose, unless forest is a clearly inappropriate land use (e.g. monument areas). Farmland that has not been used within the previous three years is considered abandoned and re-classified as forest land. However so-called transition land is classified as farmland until its land use is altered. Plant nurseries, seed plantations, ornamental plant cultivations, clear cases of Christmas tree plantations and energy forest plantations are classified as built-up land. Swedish forest taxation system"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Sweden 2009" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1177 a skos:Concept ;
    dct:source "http://www.svo.se/eng/englaw.htm"^^xsd:anyURI ;
    dct:spatial "Sweden" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land which is suitable for wood production, and not used to a significant extent for other purposes; and land where tree cover is desirable in order to protect against sand or soil erosion, or to prevent a lowering of the tree line. [Source: Swedish Forest Act - ]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Sweden" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1178 a skos:Concept ;
    dct:date "1991"^^xsd:gYear ;
    dct:source "https://www.admin.ch/opc/en/classified-compilation/19910255/index.html"^^xsd:anyURI ;
    dct:spatial "Switzerland" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest is defined as any area that is covered with forest trees or forest shrubs and can fulfil forest functions. Origin, type of use and land registry designation are not decisive. Also defined as forest are: a. grazing forests, wooded pastures and chestnut and walnut groves; b. unstocked or unproductive areas of a forest plot, such as clearings, forest roads and other forest structures and installations; c. plots subject to compulsory afforestation. Isolated groups of trees and shrubs, hedges, avenues, gardens, planted areas and parks, tree plantations established on open ground for short-term use and trees and bushes on check dams and in the immediate foreground of such installations are not defined as forest"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Switzerland 1991" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1179 a skos:Concept ;
    dct:creator "Tanzania" ;
    dct:date "2002"^^xsd:gYear ;
    dct:source "http://www.parliament.go.tz/Polis/PAMS/Docs/14-2002.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "''forest'' means an area of land with at leas 10% tree crown cover, naturally grown or planted and or 50% or more shrub and tree regeneration cover and includes all forest reserves of whatever kind declared or gazetted under this Act and all plantations"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Tanzania 2002" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_118 a skos:Concept ;
    dct:source "http://pittsford.monroe.edu/jefferson/calfieri/maps&globes/Glossary.html"^^xsd:anyURI,
        "http://www.mcwdn.org/MAPS&GLOBES/Glossary.html"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A thick growth of trees in an area and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_1180 a skos:Concept ;
    dct:creator "Tanzania" ;
    dct:date "2016"^^xsd:gYear ;
    dct:source "http://www.environment.go.ke/wp-content/uploads/2016/07/Kenya-NFP-draft-doc-2016-07-12-small-v2-1.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest in this NFP means a land area of more than 0.5 ha, crown cover of 10%, trees of at least 2.5 m height, which is not primarily under agricultural or other specific non-forest land use. In line with the Constitution, the NFP also operates with “tree cover”, e.g. trees on farms"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Tanzania 2016" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1181 a skos:Concept ;
    dct:date "1941"^^xsd:gYear ;
    dct:spatial "Thailand" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land which has not been taken up or acquired by any other means under the Land Law. Forest Act, 1941, Royal Forestry Department, Ministry of Agriculture and Cooperatives. \"Wilailak Pangtawaong\" <wpangtaw@deqp.go.th"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Thailand 1941" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1182 a skos:Concept ;
    dct:date "1964"^^xsd:gYear ;
    dct:source "http://thailawonline.com/en/thai-laws/laws-of-thailand/211-national-reserved-forest-act-be-2507-1964"^^xsd:anyURI ;
    dct:spatial "Thailand" ;
    skos:broadMatch ex:Forest ;
    skos:definition "“Forest” means land including mountain, rivulet, marsh, canal, swamp, waterway, lagoon, island, and sea shore in which nobody acquired by law; “National Reserved Forest” means forest determined to be national reserved forest under the provisions of this Act; “"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Thailand. 1964" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1183 a skos:Concept ;
    dct:date "1938"^^xsd:gYear ;
    dct:spatial "Togo" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Sont qualifiés forêts, les terrains dont les fruits exclusifs ou principaux sont les bois d'ébénisterie, d'industrie, ou de service, les bois de chauffage et à charbon ou des produits accessoires tels que: les écorces et fruits à tanin, les écorces textiles et tinctoriales, le kapok, le caoutchouc, la glu, les résines, les gommes, les bambous, les palmiers spontanés et tous autres végétaux ne constituant pas un produit agricole. 1. Décret du 5 février 1938 portant organisation du régime forestier du territoire du Togo LA PRESIDENT DE LA REPUBLIQUE FRANCAISE, LEX-FAOC018437. TOGO: Décret du 5 février 1938 portant organisation du régime forestier du territoire du Togo.Article 2. Date of text: 05 February 1938"@fr ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Togo 1938" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1184 a skos:Concept ;
    dct:creator "Turkey" ;
    dct:date "1956"^^xsd:gYear ;
    skos:broadMatch ex:Forest ;
    skos:definition "According to the Turkey's Forest Law in force, the community of trees, and shrubs grown naturally or artificially, together with the area they occupy, are considered as forest. According to Paragraph 20 of the Regulations still in force: a) The trees are the plants of at least 8 m., or more height, have crowns and the wooden stems, at any age or diameter. b) Shrubs are the wood plants showing generally horizontal growth and when mature reaches less than 8 m. in height. c) Community is a group of trees and shrubs occupying an area with a density of 0.1 or more. In the areas which can give the benefits expected from a forest which receives care continuously or periodically, density limit is not applicable. Also the areas exposed to the risk of erosion, and the areas important for the climate and water regime can be considered as forest even if the density is under 10 %. d) Areas are defined as places covered by the trees and shrubs or deforested as a result of human activity or natural events. For the private forests there is a size limit. Areas smaller than 3 ha. are left outside the forest regime. According to Paragraph 2, Section 1 of the Turkey’s Forest Law in force the following areas are not forests: a) marshy places, b) areas covered with step plants, c) thorn bushes, d) parks, e) places covered with trees and shrubs in the ancient graveyards in towns and villages, and city parks, f) places covered with trees and shrubs in groups within agricultural lands or private property which are in or near forests, g) places covered with trees and shrubs, not larger than 3 ha. Far from the forests and privately owned, h) areas containing fruit trees already mature or those to be grown in future including Pinus pinaster and Quercus aegilops trees within owned lands, i) privately owned areas covered with olive trees wild or domesticated by grafting; wild olive groves separated from state forests by special laws, and fulfilled the conditions to private ownership, and groves of Pistachio, Carob and Mastic trees, wild or improved by grafting as specified by the Law No. 6777 (9 July 1956). j) Areas of maquies or heather not subject to soil erosion are not considered as forest. Source: Turkey's Forest Law No.6831 - \"Ersin Yýlmaz\" yilmazersin@hotmail.com"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Turkey 1956" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1185 a skos:Concept ;
    dct:date "2006"^^xsd:gYear ;
    dct:source "http://www.efi.int/files/attachments/publications/annex_1_to_efi_technical_report_88__2013.pdf"^^xsd:anyURI ;
    dct:spatial "Ukraine" ;
    skos:broadMatch ex:Forest ;
    skos:definition "In Ukraine's forest are forest areas, including those protective plantings linear type, area of not less than 0.1 ha. In Ukraine the forest area does not include: green spaces within settlements (parks, gardens, squares, boulevards, etc.) that are not included in the prescribed manner to the forest; individual trees and groups of trees, shrubs on agricultural land, homestead, cottage and garden areas. Supreme Council of Ukraine, 2006"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Ukraine 2006" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1186 a skos:Concept ;
    dct:date "2010"^^xsd:gYear ;
    dct:source "http://uk-air.defra.gov.uk/reports/cat07/1010151419_ukghgi-90-08_main_chapters_Issue3_r.pdf"^^xsd:anyURI ;
    dct:spatial "United Kingdom" ;
    skos:broadMatch ex:Forest ;
    skos:definition "The definition of woodland in United Kingdom forestry statistics and in National Inventory is land under stands of trees with a canopy cover of at least 20% (or having the potential to achieve this), including integral open space, and including felled areas that are awaiting restocking. There is no minimum size for a woodland"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "United Kingdom 2010" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1187 a skos:Concept ;
    dct:date "1997"^^xsd:gYear ;
    dct:spatial "United Kingdom" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Woodlands minimum mappable area of 1 ha. In general the width for a woodland is 50 m. Areas of scattered trees with distinct crowns constitute woodland if the canopy covers more than 20 percent of the ground. Areas of young trees which have to potential to achieve a canopy cover more than 20% are also interpreted as woodland. Woodland also includes areas that may be temporarily without tree cover following forest operations such as felling. Orchards are excluded. (European Communities 1997b - p. 1127-1128"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "United Kingdom 1997" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1188 a skos:Concept ;
    dct:date "2009"^^xsd:gYear ;
    dct:source "http://uk-air.defra.gov.uk/reports/cat07/1010151419_ukghgi-90-08_main_chapters_Issue3_r.pdf"^^xsd:anyURI ;
    dct:spatial "United Kingdom" ;
    skos:broadMatch ex:Forest ;
    skos:definition "The UK has chosen the following definition of forest and single minimum values (also in table NIR.1). A definition of „forest‟ as agreed with the Forestry Commission comprising: a minimum area of 0.1 hectares; a minimum width of 20 metres; tree crown cover of at least 20 per cent, or the potential to achieve it; a minimum height of 2 metres, or the potential to achieve it. This definition includes felled areas awaiting restocking and integral open space (open areas up to 1 hectare) (Forestry Statistics 2009, section 11.1"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "United Kingdom 2009" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_119 a skos:Concept ;
    dct:source "http://www.wordsmyth.net/cgi-bin/simplesearch.cgi?matchent=forestland&matchtype=exact&matchid=-1&retall=1"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A tract of land covered by a forest"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_12 a skos:Concept ;
    dct:creator "Eng. Law" ;
    skos:broadMatch ex:Forest ;
    skos:definition "A large extent or precinct of country, generally waste and woody, belonging to the sovereign, set apart for the keeping of game for his use, not inclosed, but distinguished by certain limits, and protected by certain laws, courts, and officers of its own. --Burrill. Source: Webster's Revised Unabridged Dictionary, © 1996, 1998 MICRA, Inc"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Eng. Law" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Declared"@en,
        "General"@en .

ex:Forest_120 a skos:Concept ;
    dct:source "http://www.planning.org/guidebookhtm/chapter_three.htm"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A tract or tracts of contiguous trees or tree stands"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_121 a skos:Concept ;
    dct:source "http://targetstudy.com/nature/habitats/forests/"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "A type of habitat or biome which has a high density of trees"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_122 a skos:Concept ;
    dct:creator "Hamilton" ;
    dct:date "1991"^^xsd:gYear ;
    skos:broadMatch ex:Forest ;
    skos:definition "A type of vegetation dominated by trees and without narrow-leaved grasses in the herbaceous layer"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Hamilton 1991" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_1230 a skos:Concept ;
    dct:creator "Vanatu  Proposed Definition" ;
    dct:date "2011"^^xsd:gYear ;
    dct:source "http://cn.china.cn/2011images/vanuatu/NFP_Comprehensive_June_2011.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Land spanning more than 0.5 hectares with trees higher than 5 meters and a canopy cover of more than 10 percent, or trees able to reach these thresholds in situ. It does not include land that is predominantly under agriculture or urban use. Forest is determined both by the presence of trees and the absence of other predominant land uses. Areas under reforestation that have not yet reached but are expected to reach a canopy cover of 10 percent and a tree height of 5 meter are included, as are temporarily unstocked areas, resulting from human intervention or natural causes, which are expected to regenerate"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Vanatu 2011 Proposed Definition" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1231 a skos:Concept ;
    dct:creator "Venezuela" ;
    dct:date "1969"^^xsd:gYear ;
    skos:broadMatch ex:Forest ;
    skos:definition "Terrenos forestales: a) los que deban permanecer cubiertos por vegetación forestal; b) el que carece de vegetación alguna, pero que por su declive y estructura necesita una cobertura vegetal permanente que asegure su conservación; el que por sus condiciones climáticas, topográficas y agrológicas sea impropio para las actividades agropecuarias productivas y permanentes. LEX-FAOC003046. VENEZUELA: Decreto N&ordm; 1.333 por el cual se edita el Reglamento de la Ley Forestal, de Suelos y de Aguas. Date of text: 11 February 1969"@es ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Venezuela 1969" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1232 a skos:Concept ;
    dct:date "1991"^^xsd:gYear ;
    dct:spatial "Viet Nam" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Natural and man-made forests established on forest land with all their resources such as vegetation, wildlife and other natural assets found therein. Forest land comprises: 1) Forested land and 2) Non forested land for which plans have been made for forest plantation , below referred to as forest plantation land . Source: Article 1. The National assembly of the Socialist Republic of Vietnam, legislature VIII session IX , held from July 27th to August 12th 1991"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Viet Nam 1991" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1233 a skos:Concept ;
    dct:date "1991"^^xsd:gYear ;
    dct:source "http://coombs.anu.edu.au/~vern/luat/english/Law-forest-protect.txt"^^xsd:anyURI ;
    dct:spatial "Viet Nam" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forestry land includes: 1. Land of forest cover, 2. Land of no forest cover is planned for afforestation, hereinafter called afforestation land. ORDER NO. 58-LCT/HDNN8 DATED 19-8-1991"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Viet Nam 1991" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1234 a skos:Concept ;
    dct:date "1993"^^xsd:gYear ;
    dct:source "http://coombs.anu.edu.au/~vern/luat/english/Law-land-law.txt"^^xsd:anyURI ;
    dct:spatial "Viet Nam" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forestry Land = DDa^'t la^m nghie^.p - Land designated primarily for use in silviculture production, including land with natural forest, land under afforestation, and land used for forestry purposes such as afforestation, forest nursery, protection for natural rehabilitation, forest enrichment and experimental research on silviculture. LAND LAW OF VIETNAM Article 43 1993"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Viet Nam 1993" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1235 a skos:Concept ;
    dct:date "2016"^^xsd:gYear ;
    dct:source "http://redd.unfccc.int/files/2016_submission_frel_viet_nam.pdf"^^xsd:anyURI ;
    dct:spatial "Viet Nam" ;
    skos:broadMatch ex:Forest ;
    skos:definition "The definition of forests used for the construction of FREL/FRL for Vietnam, applies the definitions provided under Circular No. 34/2009/TT-BNNPTNT on criteria for forest identification and classification, defining forests as: minimum 10% tree cover, at a minimum height of 5 meters, over a minimum area of 0.5 ha or forest tree strips of at least 20 meters in width and of at least 3 tree lines. Agricultural and aqua-cultural ecosystems with scattered perennial trees, bamboos or palms etc. will not be regarded as forests"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Viet Nam 2016" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1236 a skos:Concept ;
    dct:date "2015"^^xsd:gYear ;
    dct:source "http://redd.unfccc.int/files/2016_submission_frel_zambia.pdf"^^xsd:anyURI,
        "http://www.parliament.gov.zm/sites/default/files/documents/acts/The%20Forest%20Act%202015.pdf"^^xsd:anyURI ;
    dct:spatial "Zambia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "The Forest Act (Commencement) Order, 2015 provides a definition of forest as below: “forest” means any land with a tree canopy cover of more than ten percent and area of more than zero point five hectares and includes young stands that have not yet reached, but are expected to reach, a crown density of ten percent and tree height of five metres that are temporarily under stocked areas; In practice, the bolded part of the forest definition is used in measurement of forest cover and forest cover loss based on the minimum canopy cover, area and height thresholds provided in the Forest Act. This practice is consistent with the way in which estimates were generated for Zambia’s most recent GHG inventory report, the Second National Communications (SNC), submitted December 2014, as well as to report forest and forest area changes to the FAO’s Forest Resources Assessment (FRA). In practice, the unbolded part of the forest definition is used in accounting for forests managed under cadastral maps for protected forest areas and planted stands for the purpose of conservation, protection and enhancement of the growing biomass and carbon stocks. and"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Zambia 2015" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1237 a skos:Concept ;
    dct:date "2015"^^xsd:gYear ;
    dct:source "http://www.parliament.gov.zm/sites/default/files/documents/acts/The%20Forest%20Act%202015.pdf"^^xsd:anyURI ;
    dct:spatial "Zambia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "“Forest area” means a National Forest, Local Forest, botanical reserve, plantation, private forest, community forest, joint forest management area and open areas"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Zambia 2015" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Land use"@en,
        "National"@en .

ex:Forest_1238 a skos:Concept ;
    dct:creator "Republic" ;
    dct:source "http://www.enpi-fleg.org/fileadmin/ufs/04.%20Program%20Information/4.02%20Program%20Components/4.02.01%20General/4.02.01.Azerbaijan/4.02.01.Forest_Code_ENG.pdf"^^xsd:anyURI ;
    dct:spatial "Azerbaijan" ;
    skos:broadMatch ex:Forest ;
    skos:definition "from the biological point of view the unity of interconnected and mutually influencing at development, lands, waters, trees, bushes and grasses, animals, microorganisms and other components of environment; The Forest Code of Azerbaijan Republic"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Azerbaijan Republic" ;
    skos:prefLabel "- Forest"@no ;
    skos:scopeNote "Ecological"@en,
        "National"@en .

ex:Forest_1239 a skos:Concept ;
    dct:source "http://www.enpi-fleg.az/index/leg/Forest%20Code%20in%20English.pdf"^^xsd:anyURI ;
    dct:spatial "Azerbaijan" ;
    skos:broadMatch ex:Forest ;
    skos:definition "from the biological point of view the unity of interconnected and mutually influencing at development, lands, waters, trees, bushes and grasses, animals, microorganisms and other components of environment; Forest Code of Azerbaijan"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Azerbaijan" ;
    skos:prefLabel "Forest"@no ;
    skos:scopeNote "Ecological"@en,
        "National"@en .

ex:Forest_124 a skos:Concept ;
    dct:source "http://sedac.ciesin.org/guides/lu/glossary.jsp"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "All lands with a tree canopy density of more than 10%, though they may not be statutorily notified as forest"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_1240 a skos:Concept ;
    dct:date "2000"^^xsd:gYear ;
    dct:spatial "Cambodia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "\"Forest\" means natural ecosystems, land, water, plants, and micro-organisms etc. which are dominated by woody plants or bamboo of more than ten (10%) percent and has a size of 0.5 hectare or more, including dryland and wetland forest formations and any non-treed wetlands covering most part of land or open land within a forest that form ten (10%) of that ecosystem. All stages of natural forest succession and planted trees for forestry purposes with a leaf density smaller than ten (10%) percent or former forest land that were degraded by human action or natural acts but is expected to be repaired/improved shall be deemed forest. www.mlmupc.gov.kh/mlm/docout.php?ID=396"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Cambodia 2000" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "National"@en .

ex:Forest_1241 a skos:Concept ;
    dct:source "http://www.wisc.edu/ltc/news82a1.html"^^xsd:anyURI ;
    dct:spatial "Cambodia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "A forest is anywhere there have ever been trees"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Cambodia" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "National"@en .

ex:Forest_1242 a skos:Concept ;
    dct:source "http://befac.net/pdf/t127.pdf"^^xsd:anyURI ;
    dct:spatial "Cameroon" ;
    skos:broadMatch ex:Forest ;
    skos:definition "A forest is an ecosystem or a combination of ecosystems"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Cameroon" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "National"@en .

ex:Forest_1243 a skos:Concept ;
    dct:date "1931"^^xsd:gYear ;
    dct:source "http://derechoambiental.udp.cl/wp-content/uploads/2009/08/chile-case-cdm-ar-projects-as-published-by-iucn.pdf"^^xsd:anyURI ;
    dct:spatial "Chile" ;
    skos:broadMatch ex:Forest ;
    skos:definition "“lands preferentially suitable for forestry”. These are defined as “all those grounds that due to climate and soil conditions should not be plowed permanently, independently of whether they are covered by vegetation or not, excluding those grounds that might be used for intensive agriculture, fruit growing, or cattle ranching without suffering degradation”"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Chile 1931" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "National"@en .

ex:Forest_1244 a skos:Concept ;
    dct:creator "Czech Republic" ;
    dct:date "1995"^^xsd:gYear ;
    dct:source "http://www.natura2000.gov.si/uploads/tx_library/Diaci_Virgin_forests_and_forest_reserves__Cost_E4_.pdf"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "The new Forest Act No. 289/1995 Coll., in force since 1 January 1996, defines forests as national heritage which constitutes an irreplaceable part of the environment"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Czech Republic 1995" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
        "National"@en .

ex:Forest_1245 a skos:Concept ;
    dct:source "http://www.metla.fi/eu/cost/e43/minutes/wg1-min-florence.pdf"^^xsd:anyURI ;
    dct:spatial "Estonia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "National definition in use, related to productivity, do not have data for swamps"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Estonia" ;
    skos:prefLabel "Forest"@no ;
    skos:scopeNote "Ecological"@en,
        "National"@en .

ex:Forest_1246 a skos:Concept ;
    dct:date "2006"^^xsd:gYear ;
    dct:source "https://www.riigiteataja.ee/en/eli/504092017014/consolide"^^xsd:anyURI ;
    dct:spatial "Estonia" ;
    skos:broadMatch ex:Forest ;
    skos:definition "Forest and forest land (1) Forest is an ecosystem consisting of forest land and the flora and fauna thereof"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "Estonia 2006" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "Ecological"@en,
