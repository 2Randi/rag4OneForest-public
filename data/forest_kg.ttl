ex:LandCover a skos:Concept ;
    skos:definition "The observed physical and biological cover of the Earth’s land surface including natural features such as vegetation, soils and waterbodies, as well as human-made features such as buildings and roads. Land cover is distinct from land use, which refers to the activities people undertake on a particular land cover type."@en ;
    skos:exactMatch agv:c_37897 ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "LandCover"@en ;
    skos:related ex:Forest,
        ex:LandUse ;
    skos:topConceptOf ex:ForestScheme .

ex:LandUse a skos:Concept ;
    skos:definition "The activities, arrangements and inputs that people undertake on a particular land cover type to produce, change or maintain it. Land use encompasses a wide range of human activities, from farming and forestry to urban development and infrastructure, and is a key aspect of land management and sustainable development."@en ;
    skos:exactMatch agv:c_4182 ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "LandUse"@en ;
    skos:related ex:Forest,
        ex:LandCover ;
    skos:topConceptOf ex:ForestScheme .

ex:Afforestation a skos:Concept ;
    skos:definition "Establishment of forest through planting and/or deliberate seeding on land that, until then, was under a different land use, implies a transformation of land use form non-forest to forest."@en ;
    skos:exactMatch agv:c_162 ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "Afforestation"@en ;
    skos:related ex:Forest,
        ex:Plantation,
        ex:Reforestation,
        ex:Regeneration ;
    skos:topConceptOf ex:ForestScheme .

ex:Reforestation a skos:Concept ;
    skos:definition "Re-establishment of forest through planting and/or deliberate seeding on land classified as forest."@en ;
    skos:exactMatch agv:c_13802 ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "Reforestation"@en ;
    skos:related ex:Afforestation,
        ex:Deforestation,
        ex:Forest,
        ex:Regeneration ;
    skos:topConceptOf ex:ForestScheme .

ex:Woodland a skos:Concept ;
    skos:definition "Wood that is harvested from trees, specifically those that are suitable for use in construction, carpentry, and other applications."@en ;
    skos:exactMatch agv:c_8421 ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "Woodland"@en ;
    skos:related ex:Forest,
        ex:Tree ;
    skos:topConceptOf ex:ForestScheme .

ex:Tree a skos:Concept ;
    skos:definition "A woody perennial with a single main stem, or in the case of coppice with several stems, having a more or less definite crown."@en ;
    skos:exactMatch agv:c_7887 ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "Tree"@en ;
    skos:related ex:Forest,
        ex:Woodland ;
    skos:topConceptOf ex:ForestScheme .

ex:Deforestation a skos:Concept ;
    skos:definition "The environment is the totality of all the external conditions affecting the life, development and survival of an organism."@en ;
    skos:exactMatch agv:c_2593 ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "Deforestation"@en ;
    skos:related ex:Degradation,
        ex:Forest,
        ex:NonForest,
        ex:Reforestation ;
    skos:topConceptOf ex:ForestScheme .

ex:Forest a skos:Concept ;
    skos:definition "Land spanning more than 0.5 hectares with trees higher than 5 meters and a canopy cover of more than 10 percent, or trees able to reach these thresholds in situ. It does not include land that is predominantly under agricultural or urban land use."@en ;
    skos:exactMatch agv:c_3062 ;
    skos:inScheme ex:ForestScheme ;
    skos:prefLabel "Forest"@en ;
    skos:related ex:Afforestation,
        ex:Deforestation,
        ex:Degradation,
        ex:LandCover,
        ex:LandUse,
        ex:NativeForest,
        ex:NaturalForest,
        ex:NonForest,
        ex:Plantation,
        ex:Reforestation,
        ex:Regeneration,
        ex:SemiNaturalForest,
        ex:Tree,
        ex:Woodland ;
    skos:topConceptOf ex:ForestScheme .

ex:ForestScheme a skos:ConceptScheme ;
    dct:description "SKOS vocabulary of forest, deforestation, afforestation and reforestation definitions compiled from Lund (2018) — used in the RAG4OneForest system within the RAG4OneForest project."@en ;
    dct:hasVersion "3.0" ;
    dct:source "Lund, H.G. (2018). Definitions of Forest, Deforestation, Afforestation and Reforestation. Forest Information Services." ;
    dct:title "RAG4OneForest Knowledge Graph"@en ;
    skos:hasTopConcept ex:Afforestation,
        ex:Deforestation,
        ex:Degradation,
        ex:Forest,
        ex:LandCover,
        ex:LandUse,
        ex:NativeForest,
        ex:NaturalForest,
        ex:NonForest,
        ex:Plantation,
        ex:Reforestation,
        ex:Regeneration,
        ex:SemiNaturalForest,
        ex:Tree,
        ex:Woodland ;
    skos:prefLabel "Forest Definitions Vocabulary"@en .

