ex:GHAUnfccc_1 a skos:Concept ;
    ex:minAreaHa 0.1 ;
    ex:minCrownCoverPct 15.0 ;
    ex:minTreeHeightM 2.0 ;
    dct:creator "KP" ;
    dct:date "2006"^^xsd:gYear,
        "2009"^^xsd:gYear ;
    dct:source "http://cdm.unfccc.int/DNA/index.html"^^xsd:anyURI,
