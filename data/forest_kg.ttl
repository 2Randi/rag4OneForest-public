ex:Forest_266 a skos:Concept ;
    dct:creator "IGBP" ;
    dct:source "http://onlinelibrary.wiley.com/doi/10.1002/2014GL062777/full"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Consistent with the United Nations Framework Convention on Climate Change [UNFCCC, 2002], United Nations Food and Agriculture Organization [UNFAO, 2002], and the International Geosphere-Biosphere Programme [Belward, 1996], we defined forest cover (as opposed to forest use [Belward, 1996; Hansen et al., 2010]) as parcels >1 ha in area and comprising pixels with >30% tree cover. Our definition corresponds with the definitions of IGBP classes for forest (>60% tree cover) and woody savannas (>30% tree cover) combined. Table 1 shows the differences in forest definition for each set of estimates compared in this study. It is notable that among the sources, only the FAO definition relies on dominant land use [Stibig et al., 2014]"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "IGBP" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

ex:Forest_267 a skos:Concept ;
    dct:creator "regardless of its quality" ;
    dct:source "http://eyesontheforest.or.id/index.php?option=com_docman&task=doc_download&gid=5"^^xsd:anyURI ;
    skos:broadMatch ex:Forest ;
    skos:definition "Unless otherwise indicated all references to “forest” in the report assume natural forest . Plantation forest areas are specified as such.(2005"@en ;
    skos:inScheme ex:ForestScheme ;
    skos:note "regardless of its quality" ;
    skos:prefLabel "FOREST/FOREST LAND"@de ;
    skos:scopeNote "General"@en,
        "Land cover"@en .

