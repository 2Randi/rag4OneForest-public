# ── LLM Providers — chaîne de fallback automatique ──────────────────────────
# Priorité : Gemini → DeepSeek → Claude → GPT → Groq
# Un seul suffit. Configurez-en plusieurs pour la résilience (quota).

# Google Gemini (gratuit + très rapide)
# GEMINI_API_KEY=AIza...
# GEMINI_API_KEY_2=AIza...   # backup si quota dépassé
# GEMINI_MODEL=gemini-2.0-flash

# DeepSeek (API OpenAI-compatible, très bon rapport qualité/prix)
# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_MODEL=deepseek-chat

# Anthropic Claude
# ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-sonnet-4-6

# OpenAI GPT
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Groq (Llama 3.3 — rapide et gratuit)
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile

# ── Vector Store ─────────────────────────────────────────────────────────────
CHROMA_PATH=./chroma_db
CHROMA_COLLECTION=forest_definitions
EMBED_MODEL=all-MiniLM-L6-v2

# ── Graphe RDF ───────────────────────────────────────────────────────────────
TTL_PATH=../data/forest_kg.ttl

# ── Retrieval ────────────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=8

# ── API ──────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=info
